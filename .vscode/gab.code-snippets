  "GAB MsgBox": {
    "scope": "vb",
    "prefix": "gabmsgbox",
    "body": [
      "V.Local.${1:iResult}.Declare(Long)",
      "Function.Intrinsic.UI.Msgbox(\"${2:Message text}\", ${3:36}, \"${4:Title}\", V.Local.${1:iResult})",
      "Function.Intrinsic.Control.If(V.Local.${1:iResult}, =, 6)",
      "  $0",
      "Function.Intrinsic.Control.EndIf"
    ],
    "description": "GAB MsgBox with Yes/No result handling (36=YesNo+Question, 6=Yes)"
  },

  "GAB Centralized Error Handler": {
    "scope": "vb",
    "prefix": "gaberror",
    "body": [
      "Program.Sub.ErrorMessage.Start",
      "Function.Intrinsic.Control.Try",
      "",
      "Function.Intrinsic.Control.If(V.Global.bError)",
      "  Function.Intrinsic.Control.ExitSub",
      "Function.Intrinsic.Control.EndIf",
      "V.Global.bError.Set(True)",
      "",
      "V.Local.sError.Declare(String,\"\")",
      "Function.Intrinsic.String.Build(\"Project: ${1:filename}.g2u{0}{0}Subroutine: {1}{0}Error: {2} - {3}\", V.Ambient.NewLine, V.Ambient.SubroutineCalledFrom, V.Ambient.ErrorNumber, V.Ambient.ErrorDescription, V.Local.sError)",
      "Function.Intrinsic.UI.Msgbox(V.Local.sError)",
      "",
      "V.Global.bError.Set(False)",
      "",
      "Function.Intrinsic.Control.Catch",
      "Function.Intrinsic.Control.EndTry",
      "Program.Sub.ErrorMessage.End"
    ],
    "description": "GAB centralized error handler with recursion guard"
  },

