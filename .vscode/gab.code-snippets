      "Function.Intrinsic.Data.DataColumnAdd(V.Local.${1:dtData}, \"${2:Column1}\", \"String\")",
      "Function.Intrinsic.Data.DataColumnAdd(V.Local.${1:dtData}, \"${3:Column2}\", \"String\")",
      "Function.Intrinsic.Data.DataColumnAdd(V.Local.${1:dtData}, \"${4:Column3}\", \"Decimal\")",
      "",
      "'-- Bind to grid",
      "Gui.${5:Form}.${6:gsgcMain}.DataSource(V.Local.${1:dtData})",
      "Gui.${5:Form}.${6:gsgcMain}.ColumnHeaderText(\"${2:Column1}\", \"${7:Display Name 1}\")",
      "Gui.${5:Form}.${6:gsgcMain}.ColumnHeaderText(\"${3:Column2}\", \"${8:Display Name 2}\")",
      "Gui.${5:Form}.${6:gsgcMain}.ColumnHeaderText(\"${4:Column3}\", \"${9:Display Name 3}\")",
      "Gui.${5:Form}.${6:gsgcMain}.AutoSizeColumns()",
      "$0"
    ],
