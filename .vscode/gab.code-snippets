{
  "GAB Form Script Skeleton": {
    "scope": "vb",
    "prefix": "gabform",
    "body": [
      "Program.Sub.ScreenSU.Start",
      "Gui.${1:Form}..Create(BaseForm)",
      "Gui.${1:Form}..Caption(\"${2:Form Title}\")",
      "Gui.${1:Form}..Size(${3:800},${4:600})",
      "Gui.${1:Form}..MinX(${3:800})",
      "Gui.${1:Form}..MinY(${4:600})",
      "Gui.${1:Form}..Position(0,0)",
      "Gui.${1:Form}..AlwaysOnTop(False)",
      "Gui.${1:Form}..FontName(\"Tahoma\")",
      "Gui.${1:Form}..FontSize(8.25)",
      "Gui.${1:Form}..ControlBox(True)",
      "Gui.${1:Form}..MaxButton(True)",
      "Gui.${1:Form}..MinButton(True)",
      "Gui.${1:Form}..Moveable(True)",
      "Gui.${1:Form}..Sizeable(True)",
      "Gui.${1:Form}..ShowInTaskBar(True)",
      "Gui.${1:Form}..TitleBar(True)",
      "Gui.${1:Form}..Event(UnLoad,${1:Form}_UnLoad)",
      "Program.Sub.ScreenSU.End",
      "",
      "Program.Sub.Preflight.Start",
      "Program.Sub.Preflight.End",
      "",
      "Program.Sub.Main.Start",
      "Function.Intrinsic.UI.UsePixels",
      "Function.Intrinsic.Control.SetErrorHandler(Main_Err)",
      "",
      "$0",
      "",
      "Gui.${1:Form}..Show(1)",
      "Function.Intrinsic.Control.End",
      "Program.Sub.Main.End",
      "",
      "Program.Sub.Main_Err.Start",
      "Function.Intrinsic.Control.SetErrorHandler()",
      "V.Local.sErr.Declare(String)",
      "Function.Intrinsic.String.Build(\"Error in Main: {0} - {1}\", V.Ambient.ErrorNumber, V.Ambient.ErrorDescription, V.Local.sErr)",
      "Function.Intrinsic.UI.Msgbox(V.Local.sErr, 16, \"Error\")",
      "Program.Sub.Main_Err.End",
      "",
      "Program.Sub.${1:Form}_UnLoad.Start",
      "Program.Sub.${1:Form}_UnLoad.End",
      "",
      "Program.Sub.Comments.Start",
      "Program.Sub.Comments.End"
    ],
    "description": "Complete GAB form script with ScreenSU, Main, error handler, and UnLoad"
  },

