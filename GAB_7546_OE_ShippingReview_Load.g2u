v.Local.sQuery.Declare(String)
v.Local.iCnt.Declare

'filter for selected rows
Function.Intrinsic.Control.BlockEvents
Function.Data.DataTable.AcceptChanges("dtLoad")
'verify that we have a checked value in SELECT and load is not 0. 
F.Data.Datatable.Select("dtLoad","SELECT = 1 and [LOAD NUMBER] <> 0 and [PICKED] = 1",v.Local.sSel)

Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")	
		F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
		F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
			'update gridview with gridview with ready to pick flag
			F.Data.Datatable.SetValue("dtLoad",v.Local.sSel(v.Local.i),"SELECT",0,"PICKED",0)
			F.Intrinsic.String.Build("Update Load_Plan Set PICKED = 0 Where ORDER_NO = '{1}' And ORDER_SUFFIX = '{2}' ANd ORDER_LINE = '{3}' and CUSTOMER = '{4}' and Load_No = '{0}'",v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).LOAD NUMBER!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_NO!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_SUFFIX!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_LINE!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).CUSTOMER!FieldVal,v.Local.sSQL)
			f.ODBC.Connection!con.Execute(v.Local.sSQL)
		F.Intrinsic.Control.Next(v.Local.i)	
		gui.frmShip.lblRunMRP.Visible(True)
f.Intrinsic.Control.Else
	F.Intrinsic.UI.Msgbox("Please select rows where load # is not 0 or not currently not flagged as picked.  Click OK to Exit.","No rows selected to remove picked flag.")
Function.Intrinsic.Control.EndIf
Function.Intrinsic.Control.UnBlockEvents
f.Intrinsic.Control.ExitSub
Function.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.CallSub(frmShip_UnLoad)	
Function.Intrinsic.Control.EndTry
Program.Sub.Load_OverridePickedFlag_remove.End

