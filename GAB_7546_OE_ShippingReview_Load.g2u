Program.Sub.txtORD_KeyPressEnter.Start
	F.Intrinsic.Control.Try 
	V.Local.sError.Declare 
	
	V.Local.sOrderNo.Declare 
	V.Local.sOrderLine.Declare 
	V.Local.sFilter.Declare 
	
	V.Local.sOrderNo.Set(V.Screen.frmShip!txtORD.Text)
	F.Intrinsic.String.LPad(v.Local.sOrderNo,"0",7,v.Local.sOrderNo)
	F.Intrinsic.String.Build("ORDER_NO = '{0}'",V.Local.sOrderNo,V.Local.sFilter) 
	F.Data.DataTable.Compute("dtAllShip","Min(RECORD_NO)",V.Local.sFilter,V.Local.sOrderLine) 
	F.Intrinsic.String.Build("{0}0",V.Local.sOrderLine,V.Local.sOrderLine) 
	
	F.Intrinsic.Control.If(V.Screen.frmShip!optShip.Value,=,True) 
		F.Global.Callwrapper.New("ShipEnter","Sales.NewShipments") 
		F.Global.Callwrapper.SetProperty("ShipEnter","OrderNumber",V.Local.sOrderNo) 
		F.Global.Callwrapper.SetProperty("ShipEnter","OrderLine",V.Local.sOrderLine) 
		F.Global.CallWrapper.Run("ShipEnter") 
		Gui.frmShip.txtORD.Text("") 
	F.Intrinsic.Control.EndIf
	
	F.Intrinsic.Control.Catch 
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version:{5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError) 
		F.Intrinsic.UI.Msgbox(V.Local.sError) 
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry 
Program.Sub.txtORD_KeyPressEnter.End

'7546 UDF 03/25/2026: Shared dictionary optimization — load lookup dictionaries once for both LoadOpenOrders and LoadLoad instead of duplicating each SQL query.
Program.Sub.LoadSharedDictionaries.Start
F.Intrinsic.Control.Try
V.Local.sError.Declare

'7546 UDF 03/25/2026: Customer order notes (may fail if view does not exist)
V.Global.bCustOrderNotesFailedToLoad.Set(False)
F.Intrinsic.Control.Try
	F.Data.Dictionary.CreateFromSQL("dCustOrderNotes","con","SELECT RTrim(CUSTOMER) AS CUSTOMER, TEXT AS CUST_ORDER_NOTES FROM V_CUST_ORDER_NOTES")
	F.Data.Dictionary.SetDefaultReturn("dCustOrderNotes","")
F.Intrinsic.Control.Catch
	V.Global.bCustOrderNotesFailedToLoad.Set(True)
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",V.Ambient.ScriptPath,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.Debug.SetLA(V.Local.sError)
F.Intrinsic.Control.EndTry

'7546 UDF 03/25/2026: Customer SO notes
F.Data.Dictionary.CreateFromSQL("dNotes","con","Select Cast(Concat(SO,SOLINE) as CHAR(10)),RTrim(Notes) as Notes From GAB_4167_SO_NOTES;")
F.Data.Dictionary.SetDefaultReturn("dNotes","")

'7546 UDF 03/25/2026: Order line text (type 9999)
F.Data.Dictionary.CreateFromSQL("dText","con","Select Cast(Concat(ORDER_NUM,ORDER_LINE) as CHAR(10)),RTrim(Text) as Line_Text From ORDER_LN_TEXT WHERE ORDER_TYPE = 9999;")
F.Data.Dictionary.SetDefaultReturn("dText","")

'7546 UDF 03/25/2026: Carrier descriptions
F.Data.DataTable.CreateFromSQL("dtCarrDesc","con","Select Carrier_CD+Cast(Srvc_Type As Char(3)) As CSRV,RTrim(Short_Desc) As Short_Desc,RTrim(Long_Desc) As Long_Desc From OE_Carrier;")
F.Data.Dictionary.CreateFromDataTable("dShortDesc","dtCarrDesc","CSRV","Short_Desc")
F.Data.Dictionary.CreateFromDataTable("dLongDesc","dtCarrDesc","CSRV","Long_Desc")
F.Data.Dictionary.SetDefaultReturn("dShortDesc","")
F.Data.Dictionary.SetDefaultReturn("dLongDesc","")
F.Data.DataTable.Close("dtCarrDesc")

'7546 UDF 03/25/2026: Location 90 / on-water inventory
F.Intrinsic.Control.If(V.Screen.frmShip!ddlCalculateMRPOnHand.ItemData,=,4)
	F.Data.Dictionary.CreateFromSQL("d90","con","SELECT part+location as partloc, COALESCE(SUM(QUANTITY),0) AS QTY_ONWATER FROM ITEM_MASTER WHERE BIN LIKE 'O%' GROUP BY PART,LOCATION;")
	F.Data.Dictionary.SetDefaultReturn("d90","0")
F.Intrinsic.Control.Else
	F.Data.Dictionary.CreateFromSQL("d90","con","Select RTRIM(PART) AS PART,QTY_ONHAND from V_INVENTORY_MSTR where LOCATION='90';")
	F.Data.Dictionary.SetDefaultReturn("d90","0")
F.Intrinsic.Control.EndIf

'7546 UDF 07/01/2026: First bin with qty on hand > 0 per part/location
F.Data.Dictionary.CreateFromSQL("dFirstBin","con","SELECT PART+LOCATION AS PARTLOC, RTRIM(MIN(BIN)) AS FIRST_BIN FROM ITEM_MASTER WHERE QUANTITY > 0 GROUP BY PART, LOCATION;")
F.Data.Dictionary.SetDefaultReturn("dFirstBin","")

'7546 UDF 04/06/2026: SO Document Control status (shared, session-lived for split form access)
V.Local.bDccExists.Declare(Boolean,False)
F.Data.Dictionary.Exists("dDCC",V.Local.bDccExists)
F.Intrinsic.Control.If(V.Local.bDccExists)
	F.Data.Dictionary.Close("dDCC")
F.Intrinsic.Control.EndIf
F.Data.Dictionary.CreateFromSQL("dDCC","con","Select rtrim(ID) As SO,'DCS-ON' As DCC From Link_Data Where Type = '00045'")
F.Data.Dictionary.SetDefaultReturn("dDCC","DCS-OFF")

F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",V.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.End
F.Intrinsic.Control.EndTry
Program.Sub.LoadSharedDictionaries.End

'7546 UDF 03/25/2026: Shared dictionary optimization — close all shared lookup dictionaries after both LoadOpenOrders and LoadLoad have consumed them.
Program.Sub.CloseSharedDictionaries.Start
F.Intrinsic.Control.Try
V.Local.sError.Declare
F.Intrinsic.Control.If(V.Global.bCustOrderNotesFailedToLoad,=,False)
	F.Data.Dictionary.Close("dCustOrderNotes")
F.Intrinsic.Control.EndIf
F.Data.Dictionary.Close("dNotes")
F.Data.Dictionary.Close("dText")
F.Data.Dictionary.Close("dShortDesc")
F.Data.Dictionary.Close("dLongDesc")
F.Data.Dictionary.Close("d90")
F.Data.Dictionary.Close("dFirstBin")
F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",V.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
F.Intrinsic.Control.EndTry
Program.Sub.CloseSharedDictionaries.End

Program.Sub.LoadOpenOrders.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare	
	V.Local.sFilter.Declare
	v.Local.sQuery.Declare(string)
	
	Gui.frmShip.lblStatus.Visible(True)
	Gui.frmShip.lblStatus.ForeColor(V.Color.Black)
	Gui.frmShip.lblStatus.Caption("Loading Shipments....")

	F.Intrinsic.Control.If(V.DataTable.dtAllShip.Exists)
		F.Data.DataTable.Close("dtAllShip")
	F.Intrinsic.Control.EndIf
	
	F.Intrinsic.Control.If(V.DataTable.dtAllShip0.Exists)
		F.Data.DataTable.Close("dtAllShip0")
	F.Intrinsic.Control.EndIf
	
	V.Global.bLoadData.Set(True)
	
	f.Intrinsic.StringBuilder.Create("Query")
	f.Intrinsic.StringBuilder.Append("Query","Select Case When A.Pick_List_Printed = 'Y' Then 'RePrint' Else 'Print' End As PICKLIST, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(A.CUSTOMER) AS CUSTOMER, C.NAME_CUSTOMER, F.CUSTOMER_PO, A.ORDER_NO, LEFT(A.Record_NO,3) AS RECORD_NO, ")
	f.Intrinsic.StringBuilder.Append("Query","A.Record_NO As Order_Line, RTRIM(LTRIM(COALESCE(A.PART,''))) AS PART, '' As DISPLAY_PART, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(LTRIM(A.LOCATION)) AS LOCATION, A.PRODUCT_LINE, A.DESCRIPTION, A.WEIGHT, ")
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN A.FLAG_USE_MQD != 'Y' THEN A.QTY_BO WHEN FLAG_USE_MQD = 'Y' AND B.FLAG_CLOSED <> 'Y' ")
	f.Intrinsic.StringBuilder.Append("Query","THEN B.QTY_OPEN WHEN FLAG_USE_MQD = 'Y' AND B.FLAG_CLOSED = 'Y' THEN 0 END AS QTY_BO, ")
	f.Intrinsic.StringBuilder.Append("Query","COALESCE(D.QTY_ONHAND,0) AS QTY_ONHAND, COALESCE(D.QTY_REQUIRED,0) AS QTY_REQUIRED, F.ORDER_SUFFIX, ")
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN A.DATE_ORDER = '1900-01-01' THEN CONVERT(NULL, SQL_DATE) ELSE A.DATE_ORDER END AS DATE_ORDER, ")
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN A.FLAG_USE_MQD != 'Y' THEN IF(A.MUST_DLVR_BY_DATE = '1900-01-01', CONVERT(NULL, SQL_DATE), ")
	f.Intrinsic.StringBuilder.Append("Query","A.MUST_DLVR_BY_DATE) WHEN FLAG_USE_MQD = 'Y' THEN IF(B.CUST_DUE_DATE = '1900-01-01', CONVERT(NULL, SQL_DATE), B.CUST_DUE_DATE) END AS MUST_DLVR_BY_DATE, ")
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN A.FLAG_USE_MQD != 'Y' THEN IF(A.DATE_ITEM_PROM = '1900-01-01', CONVERT(NULL, SQL_DATE), A.DATE_ITEM_PROM) ")
	f.Intrinsic.StringBuilder.Append("Query","WHEN FLAG_USE_MQD = 'Y' THEN IF(B.DATE_DUE = '1900-01-01', CONVERT(NULL, SQL_DATE), B.DATE_DUE) END AS DATE_ITEM_PROM, ")
	f.Intrinsic.StringBuilder.Append("Query","A.SHIP_ID, E.CITY_SHIP, RTRIM(E.STATE_SHIP) AS STATE_SHIP, E.SHIP_VIA_SHIP, E.CARRIER_CD, '' AS CARR_SHORT_DESC, ")
	f.Intrinsic.StringBuilder.Append("Query","'' AS CARR_LONG_DESC, CONVERT(A.STAGED,SQL_BIT) AS STAGED, CASE WHEN FLAG_USE_MQD = 'Y' THEN 'Ship Schd' ELSE '-' END AS FLAG_USE_MQD, ")

	'CHANGE: Fix NULL comparison (Zen/SQL correctness). "= NULL" is never true; must use "IS NULL".
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN F.SHP_HLD_FLAG = 02 OR F.SHP_HLD_FLAG = 04 THEN CONVERT(1,SQL_BIT) WHEN F.SHP_HLD_FLAG IS NULL THEN CONVERT(0,SQL_BIT) ELSE CONVERT(0,SQL_BIT) END AS SHP_HLD_FLAG, ")

	f.Intrinsic.StringBuilder.Append("Query","A.QTY_SHIPPED, '' AS NOTES, '' AS LINE_TEXT,RTRIM(A.USER_1) AS USER_1, RTRIM(A.USER_2) AS USER_2, RTRIM(A.USER_3) AS USER_3, RTRIM(A.USER_4) AS USER_4, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(A.USER_5) AS USER_5, RTRIM(A.INFO_1) AS INFO_1, RTRIM(A.INFO_2) AS INFO_2, Cast(Concat(A.Order_No,A.Record_No) as CHAR(10)) As ORDLN, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(F.USER_1) AS H_USER_1, RTRIM(F.USER_2) AS H_USER_2, RTRIM(F.USER_3) AS H_USER_3, RTRIM(F.USER_4) AS H_USER_4, RTRIM(F.USER_5) AS H_USER_5, ")
	f.Intrinsic.StringBuilder.Append("Query","E.CARRIER_CD+Cast(E.SHIP_SRVC_TYPE As Char(3)) As CSRV, A.CUSTOMER_PART, rtrim(D.CODE_SOURCE) as CODE_SOURCE, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(F.CODE_SORT) AS CODE_SORT, RTRIM(F.ORDER_SORT_2) AS ORDER_SORT_2, RTRIM(D.CODE_SORT) AS INV_CODE_SORT, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(F.CODE_FOB) AS CODE_FOB, F.SALESPERSON, RTRIM(CASE WHEN F.ORDER_TYPE = 'B' THEN 'BLANKET' WHEN F.ORDER_TYPE = 'X' THEN 'INVOICE ONLY' ")
	f.Intrinsic.StringBuilder.Append("Query","WHEN F.ORDER_TYPE = '' AND F.FLAG_TIME_MATL = 'Y' THEN 'TIME MATERIAL' ELSE F.ORDER_TYPE END) AS ORDER_TYPE, ")
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN LINE_TYPE = 'S' AND FLAG_COGS = 'Y' THEN 'COGS' WHEN LINE_TYPE = 'S' THEN 'STANDARD' WHEN LINE_TYPE = 'F' THEN 'FREIGHT' WHEN LINE_TYPE = 'D' THEN 'DROP SHIP' ELSE LINE_TYPE END AS LINE_TYPE, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(F.BLANKET_NO) AS BLANKET_NO, CAST(CASE WHEN F.FLAG_NO_BACKORDER = 'Y' ")
	f.Intrinsic.StringBuilder.Append("Query","THEN 1 ELSE 0 END AS BIT) AS FLAG_NO_BACKORDER ")
	f.Intrinsic.StringBuilder.Append("Query",", A.PHASE, F.PROJECT ")
	f.Intrinsic.StringBuilder.Append("Query",", E.Address_1_Ship, E.Address_2_Ship, E.Address_3_Ship, E.Address_4_Ship, E.Address_5_Ship,E.Freight_Zone_Ship, E.Name_Customer_Ship ")
	f.Intrinsic.StringBuilder.Append("Query",", D.Description_2, D.Description_3 ")	

	'estimated packing container code.. Assume max container standard packing unit by part
	f.Intrinsic.StringBuilder.Append("Query",", CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN X.CNTNR_CODE WHEN D.PCS_PER_CNTNR <> 0 THEN Z.CNTNR_CODE WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN X.CNTNR_CODE END AS 'Container Name',CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN X.CNTNR_DESC WHEN D.PCS_PER_CNTNR <> 0 THEN Z.CNTNR_DESC WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN X.CNTNR_DESC END AS 'Container Description', CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN X.WEIGHT WHEN D.PCS_PER_CNTNR <> 0 THEN Z.WEIGHT WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN X.WEIGHT END  AS 'Ind Container Weight', CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN X.LENGTH WHEN D.PCS_PER_CNTNR <> 0 THEN Z.LENGTH WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN X.LENGTH END AS 'Ind Container Length (In)', CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN X.WIDTH WHEN D.PCS_PER_CNTNR <> 0 THEN Z.WIDTH WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN X.WIDTH END AS 'Ind Container Width (In)', CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN X.HEIGHT WHEN D.PCS_PER_CNTNR <> 0 THEN Z.HEIGHT WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN X.HEIGHT END AS 'Ind Container Height (In)' ")

	'estimated container qty. Assume max container standard packing unit by part
	'NOTE: left as A.QTY_BO to preserve your original logic exactly (even when MQD uses B.QTY_OPEN).
	f.Intrinsic.StringBuilder.Append("Query",", CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN CEILING(A.QTY_BO/(D.PCS_PER_CNTNR*D.CNTNRS_PER_PALLET)) WHEN D.PCS_PER_CNTNR <> 0 THEN CEILING(A.QTY_BO/D.PCS_PER_CNTNR) WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN CEILING(A.QTY_BO/D.CNTNRS_PER_PALLET) END AS 'Est Container Qty' ")

	'estimated container weight. Assume max container standard packing unit by part
	'NOTE: left as A.QTY_BO to preserve your original logic exactly (even when MQD uses B.QTY_OPEN).
	f.Intrinsic.StringBuilder.Append("Query",", CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN CEILING(CEILING(A.QTY_BO/(D.PCS_PER_CNTNR*D.CNTNRS_PER_PALLET))*X.WEIGHT+(CEILING(A.QTY_BO/(D.PCS_PER_CNTNR*D.CNTNRS_PER_PALLET))*Z.WEIGHT*D.CNTNRS_PER_PALLET)+A.QTY_BO*D.LBS) WHEN D.PCS_PER_CNTNR <> 0 THEN CEILING(CEILING(A.QTY_BO/D.PCS_PER_CNTNR)*Z.WEIGHT+A.QTY_BO*D.LBS) WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN CEILING(CEILING(A.QTY_BO/D.CNTNRS_PER_PALLET)*X.WEIGHT+A.QTY_BO*D.LBS) ELSE CEILING(A.QTY_BO*D.LBS) END AS 'Est Packaged Weight' ")

	'estimated container dimensions. Assume max container standard packing unit by part
	'NOTE: left as A.QTY_BO to preserve your original logic exactly (even when MQD uses B.QTY_OPEN).
	f.Intrinsic.StringBuilder.Append("Query",", CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN CEILING((CEILING(A.QTY_BO/(D.PCS_PER_CNTNR*D.CNTNRS_PER_PALLET))*X.LENGTH*X.WIDTH)/144) WHEN D.PCS_PER_CNTNR <> 0 THEN CEILING((CEILING(A.QTY_BO/D.PCS_PER_CNTNR)*Z.LENGTH*Z.WIDTH)/144) WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN CEILING((CEILING(A.QTY_BO/D.CNTNRS_PER_PALLET)*X.LENGTH*X.WIDTH)/144) ELSE 0 END AS 'Est Area' ")

	f.Intrinsic.StringBuilder.Append("Query",", W.CONTACT, W.CONTACT_PHONE, W.CONTACT_EMAIL ")
	f.Intrinsic.StringBuilder.Append("Query",", A.EXTENSION AS EXT_AMT ")
	f.Intrinsic.StringBuilder.Append("Query",", A.PART+A.LOCATION AS PARTLOC ")

	f.Intrinsic.StringBuilder.Append("Query","FROM V_ORDER_LINES A ")
	f.Intrinsic.StringBuilder.Append("Query","LEFT JOIN V_OE_SHIP_SCHED B ON B.ORDER_NO = A.ORDER_NO AND B.ORDER_LINE = A.RECORD_NO LEFT JOIN V_CUSTOMER_MASTER C ON A.CUSTOMER = C.CUSTOMER ")
	f.Intrinsic.StringBuilder.Append("Query","LEFT JOIN V_INVENTORY_ALL D ON A.PART = D.PART AND A.LOCATION = D.LOCATION LEFT JOIN V_ORDER_SHIP_TO E ON E.ORDER_NO = A.ORDER_NO and E.SHIP_ID = A.SHIP_ID ")
	f.Intrinsic.StringBuilder.Append("Query","LEFT JOIN V_ORDER_HEADER F ON A.ORDER_NO = F.ORDER_NO ")
	f.Intrinsic.StringBuilder.Append("Query","LEFT JOIN V_ORDER_BILL_TO W ON A.ORDER_NO = W.ORDER_NO ")
	f.Intrinsic.StringBuilder.Append("Query","LEFT JOIN BOL_CONTAINERS Z ON D.DFLT_CARTON_CD = Z.CNTNR_CODE ")
	f.Intrinsic.StringBuilder.Append("Query","LEFT JOIN BOL_CONTAINERS X ON D.DFLT_PALLET_CD = X.CNTNR_CODE ")

	'CHANGE: Push row reduction into WHERE (faster in Zen). Also avoid filtering on the SELECT alias QTY_BO.
	'Original: WHERE F.RECORD_NO = '  A' AND QTY_BO <> 0 AND LINE_TYPE <> 'P'
	'New:
	'  1) Keep header filter
	'  2) Early row reduction: LINE_TYPE <> 'P' AND (A.QTY_BO <> 0 OR A.FLAG_USE_MQD = 'Y')
	'  3) Replace alias filter (QTY_BO <> 0) with equivalent base logic that matches your CASE for QTY_BO
	f.Intrinsic.StringBuilder.Append("Query","WHERE F.RECORD_NO = '  A' ")
	f.Intrinsic.StringBuilder.Append("Query","  AND A.LINE_TYPE <> 'P' ")
	f.Intrinsic.StringBuilder.Append("Query","  AND (A.QTY_BO <> 0 OR A.FLAG_USE_MQD = 'Y') ")
	f.Intrinsic.StringBuilder.Append("Query","  AND ( (A.FLAG_USE_MQD <> 'Y' AND A.QTY_BO <> 0) ")
	f.Intrinsic.StringBuilder.Append("Query","        OR (A.FLAG_USE_MQD = 'Y' AND B.FLAG_CLOSED <> 'Y' AND B.QTY_OPEN <> 0) ")
	f.Intrinsic.StringBuilder.Append("Query","      ) ")

	f.Intrinsic.StringBuilder.Append("Query","ORDER BY DATE_ITEM_PROM, A.ORDER_NO, A.RECORD_NO;")

	f.Intrinsic.StringBuilder.ToString("Query",v.Local.sQuery)
	f.Intrinsic.StringBuilder.Dispose("Query")

	f.Data.DataTable.CreateFromSQL("dtAllShip0","con",v.Local.sQuery,True)

			
	'LONG PART NUMBER
	f.Intrinsic.Control.If(v.Global.bLongPart)
		F.Data.DataTable.AddDisplayPartColumn("dtAllShip0",0,"PART","DISPLAY_PART")
	f.Intrinsic.Control.Else
		f.Data.DataTable.CopyColumn("dtAllShip0","PART","DISPLAY_PART")
	f.Intrinsic.Control.EndIf
							
	F.Data.DataTable.AddColumn("dtAllShip0","CUST_ORDER_NOTES",String,"")
	
	'7546 UDF 03/25/2026: Shared dictionary optimization — fill from pre-loaded shared dictionaries (loaded in LoadSharedDictionaries)
	F.Intrinsic.Control.If(V.Global.bCustOrderNotesFailedToLoad,=,False)
		F.Data.DataTable.FillFromDictionary("dtAllShip0","dCustOrderNotes","CUSTOMER","CUST_ORDER_NOTES")
	F.Intrinsic.Control.EndIf
	
	F.Data.DataTable.FillFromDictionary("dtAllShip0","dNotes","ORDLN","NOTES")
	F.Data.DataTable.FillFromDictionary("dtAllShip0","dText","ORDLN","LINE_TEXT")
	F.Data.DataTable.FillFromDictionary("dtAllShip0","dShortDesc","CSRV","CARR_SHORT_DESC")
	F.Data.DataTable.FillFromDictionary("dtAllShip0","dLongDesc","CSRV","CARR_LONG_DESC")
	
	'STATUS Column
	F.Data.DataTable.AddColumn("dtAllShip0","STATUS",String,"")
	
    'Add AllocationFlag Column for our mrp allocation drop down things code behind only. not displayed to user.
	F.Data.Datatable.AddColumn("dtAllShip0","AllocationFlag",Boolean,False)
	
	F.Data.Datatable.AddColumn("dtAllShip0","QTY_90","LONG",0)
	F.Intrinsic.Control.If(V.Screen.frmShip!ddlCalculateMRPOnHand.ItemData,=,4)
		F.Data.DataTable.FillFromDictionary("dtAllShip0","d90","PARTLOC","QTY_90")
	F.Intrinsic.Control.Else
		F.Data.DataTable.FillFromDictionary("dtAllShip0","d90","PART","QTY_90")
	F.Intrinsic.Control.EndIf
	
	'Assign Picker Column
	F.Data.Datatable.AddColumn("dtAllShip0","ASSIGNPICKER","Boolean",False)
	'load Order Picker Information
	F.Intrinsic.Control.CallSub(LoadPicker)
	'v.Local.sFilter.Set(v.DataTable.dtAllShip0.FieldNames)
	'linq join orderpicker and dtallship0	
	'HERE
	Function.Intrinsic.Control.If(v.DataTable.dtOrderPicker.Exists) 	
		F.Data.Linq.Join("LeftJoin","datatable","dtAllShip0*!*A","datatable","dtOrderPicker*!*B","A.ORDER_NO = B.ORDER_NO And A.ORDER_SUFFIX = B.ORDER_SUFFIX AND A.ORDER_LINE = B.ORDER_LINE","A.PICKLIST*!*A.CUSTOMER*!*A.NAME_CUSTOMER*!*A.CUSTOMER_PO*!*A.ORDER_NO*!*A.RECORD_NO*!*A.ORDER_LINE*!*A.ORDER_SUFFIX*!*A.PART*!*A.DISPLAY_PART*!*A.LOCATION*!*A.PRODUCT_LINE*!*A.DESCRIPTION*!*A.Description_2*!*A.Description_3*!*A.WEIGHT*!*A.Container Name*!*A.Container Description*!*A.Ind Container Height (In)*!*A.Ind Container Width (In)*!*A.Ind Container Length (In)*!*A.Ind Container Weight*!*A.Est Container Qty*!*A.Est Packaged Weight*!*A.Est Area*!*A.QTY_BO*!*A.QTY_ONHAND*!*A.QTY_90*!*A.EXT_AMT*!*A.QTY_REQUIRED*!*A.DATE_ORDER*!*A.MUST_DLVR_BY_DATE*!*A.DATE_ITEM_PROM*!*A.SHIP_ID*!*A.CITY_SHIP*!*A.STATE_SHIP*!*A.Address_1_Ship*!*A.Address_2_Ship*!*A.Address_3_Ship*!*A.Address_4_Ship*!*A.Address_5_Ship*!*A.Name_Customer_Ship*!*A.Freight_Zone_Ship*!*A.SHIP_VIA_SHIP*!*A.CARRIER_CD*!*A.CARR_SHORT_DESC*!*A.CARR_LONG_DESC*!*A.STAGED*!*A.FLAG_USE_MQD*!*A.SHP_HLD_FLAG*!*A.QTY_SHIPPED*!*A.NOTES*!*A.LINE_TEXT*!*A.USER_1*!*A.USER_2*!*A.USER_3*!*A.USER_4*!*A.USER_5*!*A.INFO_1*!*A.INFO_2*!*A.H_USER_1*!*A.H_USER_2*!*A.H_USER_3*!*A.H_USER_4*!*A.H_USER_5*!*A.ORDLN*!*A.CSRV*!*A.CUSTOMER_PART*!*A.CODE_SOURCE*!*A.CODE_SORT*!*A.ORDER_SORT_2*!*A.INV_CODE_SORT*!*A.CODE_FOB*!*A.SALESPERSON*!*A.ORDER_TYPE*!*A.LINE_TYPE*!*A.BLANKET_NO*!*A.FLAG_NO_BACKORDER*!*A.STATUS*!*A.ASSIGNPICKER*!*A.CUST_ORDER_NOTES*!*B.Assigned_To*!*A.AllocationFlag*!*A.PROJECT*!*A.PHASE*!*A.CONTACT*!*A.CONTACT_PHONE*!*A.CONTACT_EMAIL*!*A.PARTLOC","","","","dtAllShip1",True)
	Function.Intrinsic.Control.Else
		f.Data.Datatable.Clone("dtAllShip0","dtAllShip1",True)
	Function.Intrinsic.Control.EndIf
	
	'Create DataView and filter out locations
	F.Intrinsic.Control.If(V.Global.bUseShippingLocations)
		F.Intrinsic.Control.If(V.Global.bShippingOverride)
			V.Local.sFilter.Set("")
		F.Intrinsic.Control.Else
			F.Intrinsic.String.Build("LOCATION = '{0}'",V.Global.sShippingLocation,V.Local.sFilter)
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.Else
		V.Local.sFilter.Set("")
	F.Intrinsic.Control.EndIf
	
	F.Data.DataView.Create("dtAllShip1","dvAllShip",22,V.Local.sFilter,"")
	
	'Convert DV to DT
	F.Data.DataView.ToDataTable("dtAllShip1","dvAllShip","dtAllShip",True)
	F.Data.DataTable.Close("dtAllShip1")

	F.Intrinsic.Control.If(V.Screen.frmShip!ddlCalculateMRPOnHand.Text,<>,"No")
		F.Intrinsic.Control.CallSub(CalculateMaterial)
	F.Intrinsic.Control.EndIf
	
	'Remove Columns	
	F.Data.DataTable.RemoveColumn("dtAllShip","ORDLN")
	F.Data.DataTable.RemoveColumn("dtAllShip","CSRV")
	F.Data.DataTable.RemoveColumn("dtAllShip","PARTLOC")
	
	F.Intrinsic.Control.CallSub(LoadOpenOrdersGV,"DT","dtAllShip","GV","gvAllShip","GSGC","GsGCAllShip")
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.LoadOpenOrders.End

Program.Sub.LoadDueOrders.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sFilter.Declare
			
	F.Intrinsic.Control.If(V.DataTable.dtDueShip.Exists)
		F.Data.DataTable.Close("dtDueShip")
	F.Intrinsic.Control.EndIf
			
	f.Intrinsic.Control.If(v.Global.bUseShippingLocations,=,False,or,V.Global.bShippingOverride,=,True)
		F.Intrinsic.String.Build("DATE_ITEM_PROM <= #{0}#",V.Ambient.Date.FormatMM/DD/YYYY,V.Local.sFilter)	
	F.Intrinsic.Control.Else
		F.Intrinsic.String.Build("DATE_ITEM_PROM <= #{0}# AND LOCATION = '{1}'",V.Ambient.Date.FormatMM/DD/YYYY,,V.Global.sShippingLocation,V.Local.sFilter)
	F.Intrinsic.Control.EndIf
	
	F.Data.DataView.Create("dtAllShip","dvDueShip",22,V.Local.sFilter,"")
	F.Data.DataView.ToDataTable("dtAllShip","dvDueShip","dtDueShip",True)

	F.Intrinsic.Control.CallSub(LoadOpenOrdersGV,"DT","dtDueShip","GV","gvDue","GSGC","GsGCDue")
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.LoadDueOrders.End

Program.Sub.LoadLoad.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sFilter.Declare
	v.Local.sQuery.Declare(string)
	Gui.frmShip.lblStatus.Caption("Loading Load tab....")

	F.Intrinsic.Control.If(V.DataTable.dtLoad.Exists)
		F.Data.DataTable.Close("dtLoad")
	F.Intrinsic.Control.EndIf
	
	F.Intrinsic.Control.If(V.DataTable.dtLoad0.Exists)
		F.Data.DataTable.Close("dtLoad0")
	F.Intrinsic.Control.EndIf
	
	'Clean Truck_Type value in LOAD_PLAN table
	f.Intrinsic.Control.CallSub("Clean_Load_Plan_TruckType")
	
	V.Global.bLoadData.Set(True)
	f.Intrinsic.StringBuilder.Create("Query")
	'LOAD
	'-------------------
	
	f.Intrinsic.StringBuilder.Append("Query","Select G.LOAD_NO as 'Load Number', H.PCK_NO as 'Packing List', L.SHP_DATE as 'PL Ship Date', I.QTY_SHIPPED AS 'Staged Qty', ")
	f.Intrinsic.StringBuilder.Append("Query","G.LOAD_SEQ AS 'Drop Seq', rtrim(G.CARRIER) AS 'Carrier Number', rtrim(G.CARRIER_LOAD_NUM) AS 'Carrier Load Number', rtrim(G.CARRIER_TRAILER) AS 'Carrier Trailer', ")
	
	'--- CHANGED: simplified TRUCK_TYPE CASE (same logic)
	' OLD:
	' f.Intrinsic.StringBuilder.Append("Query","CASE WHEN G.TRUCK_TYPE = '-1' THEN '' WHEN G.TRUCK_TYPE = '00000J' THEN '' WHEN G.TRUCK_TYPE != '-1' THEN G.TRUCK_TYPE END AS 'Truck Type ID', J.DESCRIPTION AS 'Truck Description',J.MAX_WEIGHT_LBS AS 'Truck Max Weight(lbs)',(J.LENGTH*J.WIDTH)*(PERCENT_CAPACITY/100) AS 'Truck SF Capacity', ")
	' NEW:
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN G.TRUCK_TYPE IN ('-1','00000J') THEN '' ELSE G.TRUCK_TYPE END AS 'Truck Type ID', J.DESCRIPTION AS 'Truck Description',J.MAX_WEIGHT_LBS AS 'Truck Max Weight(lbs)',(J.LENGTH*J.WIDTH)*(PERCENT_CAPACITY/100) AS 'Truck SF Capacity', ")
	
	'f.Intrinsic.StringBuilder.Append("Query","J.DESCRIPTION AS 'Truck Description', ")
	f.Intrinsic.StringBuilder.Append("Query","G.STAGING_BIN AS 'Staging Bin', CASE WHEN G.DOCK_NO IS NULL OR RTRIM(G.DOCK_NO)='' THEN '' ELSE G.DOCK_NO END AS 'Dock ID', G.PICK_BY_DATE AS 'Pick By Date', G.SHIP_DATE AS 'Ship Date', G.NOTES AS 'Load Notes', G.PCKLST_DISP_FLAG AS 'Ready to Pick', G.PICKED,  ")
	f.Intrinsic.StringBuilder.Append("Query","Case When A.Pick_List_Printed = 'Y' Then 'RePrint' Else 'Print' End As PICKLIST, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(A.CUSTOMER) AS CUSTOMER, C.NAME_CUSTOMER, F.CUSTOMER_PO, A.ORDER_NO, LEFT(A.Record_NO,3) AS RECORD_NO, ")
	f.Intrinsic.StringBuilder.Append("Query","A.Record_NO As Order_Line, RTRIM(LTRIM(COALESCE(A.PART,''))) AS PART, '' As DISPLAY_PART, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(LTRIM(A.LOCATION)) AS LOCATION, A.PRODUCT_LINE, A.DESCRIPTION, A.WEIGHT, ")
	
	'--- CHANGED: qualify FLAG_USE_MQD with A. to avoid ambiguity
	' OLD:
	' f.Intrinsic.StringBuilder.Append("Query","CASE WHEN A.FLAG_USE_MQD != 'Y' THEN A.QTY_BO WHEN FLAG_USE_MQD = 'Y' AND B.FLAG_CLOSED <> 'Y' ")
	' f.Intrinsic.StringBuilder.Append("Query","THEN B.QTY_OPEN WHEN FLAG_USE_MQD = 'Y' AND B.FLAG_CLOSED = 'Y' THEN 0 END AS QTY_BO, ")
	' NEW:
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN A.FLAG_USE_MQD != 'Y' THEN A.QTY_BO WHEN A.FLAG_USE_MQD = 'Y' AND B.FLAG_CLOSED <> 'Y' ")
	f.Intrinsic.StringBuilder.Append("Query","THEN B.QTY_OPEN WHEN A.FLAG_USE_MQD = 'Y' AND B.FLAG_CLOSED = 'Y' THEN 0 END AS QTY_BO, ")
	
	f.Intrinsic.StringBuilder.Append("Query","COALESCE(D.QTY_ONHAND,0) AS QTY_ONHAND, COALESCE(D.QTY_REQUIRED,0) AS QTY_REQUIRED, F.ORDER_SUFFIX as CURRENT_ORDER_SUFFIX, G.ORDER_SUFFIX, ")
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN A.DATE_ORDER = '1900-01-01' THEN CONVERT(NULL, SQL_DATE) ELSE A.DATE_ORDER END AS DATE_ORDER, ")
	
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN A.FLAG_USE_MQD != 'Y' THEN IF(A.MUST_DLVR_BY_DATE = '1900-01-01', CONVERT(NULL, SQL_DATE), ")
	'--- CHANGED: qualify FLAG_USE_MQD in date logic
	' OLD:
	' f.Intrinsic.StringBuilder.Append("Query","A.MUST_DLVR_BY_DATE) WHEN FLAG_USE_MQD = 'Y' THEN IF(B.CUST_DUE_DATE = '1900-01-01', CONVERT(NULL, SQL_DATE), B.CUST_DUE_DATE) END AS MUST_DLVR_BY_DATE, ")
	' NEW:
	f.Intrinsic.StringBuilder.Append("Query","A.MUST_DLVR_BY_DATE) WHEN A.FLAG_USE_MQD = 'Y' THEN IF(B.CUST_DUE_DATE = '1900-01-01', CONVERT(NULL, SQL_DATE), B.CUST_DUE_DATE) END AS MUST_DLVR_BY_DATE, ")
	
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN A.FLAG_USE_MQD != 'Y' THEN IF(A.DATE_ITEM_PROM = '1900-01-01', CONVERT(NULL, SQL_DATE), A.DATE_ITEM_PROM) ")
	'--- CHANGED: qualify FLAG_USE_MQD in date logic
	' OLD:
	' f.Intrinsic.StringBuilder.Append("Query","WHEN FLAG_USE_MQD = 'Y' THEN IF(B.DATE_DUE = '1900-01-01', CONVERT(NULL, SQL_DATE), B.DATE_DUE) END AS DATE_ITEM_PROM, ")
	' NEW:
	f.Intrinsic.StringBuilder.Append("Query","WHEN A.FLAG_USE_MQD = 'Y' THEN IF(B.DATE_DUE = '1900-01-01', CONVERT(NULL, SQL_DATE), B.DATE_DUE) END AS DATE_ITEM_PROM, ")
	
	f.Intrinsic.StringBuilder.Append("Query","A.SHIP_ID, E.CITY_SHIP, RTRIM(E.STATE_SHIP) AS STATE_SHIP, E.SHIP_VIA_SHIP, E.CARRIER_CD, '' AS CARR_SHORT_DESC, ")
	
	'--- CHANGED: qualify FLAG_USE_MQD again
	' OLD:
	' f.Intrinsic.StringBuilder.Append("Query","'' AS CARR_LONG_DESC, CONVERT(A.STAGED,SQL_BIT) AS STAGED, CASE WHEN FLAG_USE_MQD = 'Y' THEN 'Ship Schd' ELSE '-' END AS FLAG_USE_MQD, ")
	' NEW:
	f.Intrinsic.StringBuilder.Append("Query","'' AS CARR_LONG_DESC, CONVERT(A.STAGED,SQL_BIT) AS STAGED, CASE WHEN A.FLAG_USE_MQD = 'Y' THEN 'Ship Schd' ELSE '-' END AS FLAG_USE_MQD, ")
	
	'--- CHANGED: fix NULL compare + simplify IN()
	' OLD:
	' f.Intrinsic.StringBuilder.Append("Query","CASE WHEN F.SHP_HLD_FLAG = 02 OR F.SHP_HLD_FLAG = 04 THEN CONVERT(1,SQL_BIT) WHEN F.SHP_HLD_FLAG = NULL THEN CONVERT(0,SQL_BIT) ELSE CONVERT(0,SQL_BIT) END AS SHP_HLD_FLAG, ")
	' NEW:
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN F.SHP_HLD_FLAG IN (2,4) THEN CONVERT(1,SQL_BIT) WHEN F.SHP_HLD_FLAG IS NULL THEN CONVERT(0,SQL_BIT) ELSE CONVERT(0,SQL_BIT) END AS SHP_HLD_FLAG, ")
	
	f.Intrinsic.StringBuilder.Append("Query","A.QTY_SHIPPED, '' AS NOTES, '' AS LINE_TEXT,RTRIM(A.USER_1) AS USER_1, RTRIM(A.USER_2) AS USER_2, RTRIM(A.USER_3) AS USER_3, RTRIM(A.USER_4) AS USER_4, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(A.USER_5) AS USER_5, RTRIM(A.INFO_1) AS INFO_1, RTRIM(A.INFO_2) AS INFO_2, Cast(Concat(A.Order_No,A.Record_No) as CHAR(10)) As ORDLN,")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(F.USER_1) AS H_USER_1, RTRIM(F.USER_2) AS H_USER_2, RTRIM(F.USER_3) AS H_USER_3, RTRIM(F.USER_4) AS H_USER_4, RTRIM(F.USER_5) AS H_USER_5, ")
	f.Intrinsic.StringBuilder.Append("Query","E.CARRIER_CD+Cast(E.SHIP_SRVC_TYPE As Char(3)) As CSRV, A.CUSTOMER_PART, rtrim(D.CODE_SOURCE) as CODE_SOURCE, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(F.CODE_SORT) AS CODE_SORT, RTRIM(F.ORDER_SORT_2) AS ORDER_SORT_2, RTRIM(D.CODE_SORT) AS INV_CODE_SORT, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(F.CODE_FOB) AS CODE_FOB, F.SALESPERSON, RTRIM(CASE WHEN F.ORDER_TYPE = 'B' THEN 'BLANKET' WHEN F.ORDER_TYPE = 'X' THEN 'INVOICE ONLY' ")
	f.Intrinsic.StringBuilder.Append("Query","WHEN F.ORDER_TYPE = '' AND F.FLAG_TIME_MATL = 'Y' THEN 'TIME MATERIAL' ELSE F.ORDER_TYPE END) AS ORDER_TYPE, ")
	f.Intrinsic.StringBuilder.Append("Query","CASE WHEN A.LINE_TYPE = 'S' AND A.FLAG_COGS = 'Y' THEN 'COGS' WHEN A.LINE_TYPE = 'S' THEN 'STANDARD' WHEN A.LINE_TYPE = 'F' THEN 'FREIGHT' WHEN A.LINE_TYPE = 'D' THEN 'DROP SHIP' ELSE A.LINE_TYPE END AS LINE_TYPE, ")
	f.Intrinsic.StringBuilder.Append("Query","RTRIM(F.BLANKET_NO) AS BLANKET_NO, CAST(CASE WHEN F.FLAG_NO_BACKORDER = 'Y' ")
	f.Intrinsic.StringBuilder.Append("Query","THEN 1 ELSE 0 END AS BIT) AS FLAG_NO_BACKORDER ")
	f.Intrinsic.StringBuilder.Append("Query",", A.PHASE, F.PROJECT ")
	f.Intrinsic.StringBuilder.Append("Query",", E.Address_1_Ship, E.Address_2_Ship, E.Address_3_Ship, E.Address_4_Ship, E.Address_5_Ship, E.Name_Customer_Ship,E.Freight_Zone_Ship, RTRIM(M.TRACKING_NO) AS TRACKING_NO, RTRIM(M.PRO_NO) AS PRO_NO, RTRIM(M.WAY_BILL) AS WAY_BILL, N.FROM_NAME AS BOL_SHIP_FROM ")
	f.Intrinsic.StringBuilder.Append("Query",", D.Description_2, D.Description_3 ")
	f.Intrinsic.StringBuilder.Append("Query",", RTRIM(BPI.NMFC_NO) AS NMFC_NO, RTRIM(BPI.FRT_CLASS) AS FRT_CLASS, RTRIM(BPI.COMM_DESC_1) AS COMM_DESC_1 ")
	f.Intrinsic.StringBuilder.Append("Query",", COALESCE(M.WEIGHT, 0) AS 'Staged PL Weight', COALESCE(M.CARTONS, 0) AS 'Staged PL Cartons', COALESCE(M.PALLETS, 0) AS 'Staged PL Pallets' ")
	
	'estimated packing container code.. Assume max container standard packing unit by part
	f.Intrinsic.StringBuilder.Append("Query",", CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN X.CNTNR_CODE WHEN D.PCS_PER_CNTNR <> 0 THEN Z.CNTNR_CODE WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN X.CNTNR_CODE END AS 'Container Name',CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN X.CNTNR_DESC WHEN D.PCS_PER_CNTNR <> 0 THEN Z.CNTNR_DESC WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN X.CNTNR_DESC END AS 'Container Description', CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN X.WEIGHT WHEN D.PCS_PER_CNTNR <> 0 THEN Z.WEIGHT WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN X.WEIGHT END  AS 'Ind Container Weight', CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN X.LENGTH WHEN D.PCS_PER_CNTNR <> 0 THEN Z.LENGTH WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN X.LENGTH END AS 'Ind Container Length (In)', CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN X.WIDTH WHEN D.PCS_PER_CNTNR <> 0 THEN Z.WIDTH WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN X.WIDTH END AS 'Ind Container Width (In)', CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN X.HEIGHT WHEN D.PCS_PER_CNTNR <> 0 THEN Z.HEIGHT WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN X.HEIGHT END AS 'Ind Container Height (In)' ")
	f.Intrinsic.StringBuilder.Append("Query",", CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN CEILING(A.QTY_BO/(D.PCS_PER_CNTNR*D.CNTNRS_PER_PALLET)) WHEN D.PCS_PER_CNTNR <> 0 THEN CEILING(A.QTY_BO/D.PCS_PER_CNTNR) WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN CEILING(A.QTY_BO/D.CNTNRS_PER_PALLET) END AS 'Est Container Qty' ")
	
	'--- CHANGED: "++" -> "+" (typo fix)
	' OLD:
	' f.Intrinsic.StringBuilder.Append("Query",", CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN CEILING(CEILING(A.QTY_BO/(D.PCS_PER_CNTNR*D.CNTNRS_PER_PALLET))*X.WEIGHT++(CEILING(A.QTY_BO/(D.PCS_PER_CNTNR*D.CNTNRS_PER_PALLET))*Z.WEIGHT*D.CNTNRS_PER_PALLET)+A.QTY_BO*D.LBS) WHEN D.PCS_PER_CNTNR <> 0 THEN CEILING(CEILING(A.QTY_BO/D.PCS_PER_CNTNR)*Z.WEIGHT+A.QTY_BO*D.LBS) WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN CEILING(CEILING(A.QTY_BO/D.CNTNRS_PER_PALLET)*X.WEIGHT+A.QTY_BO*D.LBS) ELSE CEILING(A.QTY_BO*D.LBS) END AS 'Est Packaged Weight' ")
	' NEW:
	f.Intrinsic.StringBuilder.Append("Query",", CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN CEILING(CEILING(A.QTY_BO/(D.PCS_PER_CNTNR*D.CNTNRS_PER_PALLET))*X.WEIGHT+(CEILING(A.QTY_BO/(D.PCS_PER_CNTNR*D.CNTNRS_PER_PALLET))*Z.WEIGHT*D.CNTNRS_PER_PALLET)+A.QTY_BO*D.LBS) WHEN D.PCS_PER_CNTNR <> 0 THEN CEILING(CEILING(A.QTY_BO/D.PCS_PER_CNTNR)*Z.WEIGHT+A.QTY_BO*D.LBS) WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN CEILING(CEILING(A.QTY_BO/D.CNTNRS_PER_PALLET)*X.WEIGHT+A.QTY_BO*D.LBS) ELSE CEILING(A.QTY_BO*D.LBS) END AS 'Est Packaged Weight' ")
	
	f.Intrinsic.StringBuilder.Append("Query",", CASE WHEN D.PCS_PER_CNTNR <> 0 AND D.PALLET_FLAG = 'Y' THEN CEILING((CEILING(A.QTY_BO/(D.PCS_PER_CNTNR*D.CNTNRS_PER_PALLET))*X.LENGTH*X.WIDTH)/144) WHEN D.PCS_PER_CNTNR <> 0 THEN CEILING((CEILING(A.QTY_BO/D.PCS_PER_CNTNR)*Z.LENGTH*Z.WIDTH)/144) WHEN D.PCS_PER_CNTNR = 0 AND D.PALLET_FLAG = 'Y' THEN CEILING((CEILING(A.QTY_BO/D.CNTNRS_PER_PALLET)*X.LENGTH*X.WIDTH)/144) ELSE 0 END AS 'Est Area' ")
	
	f.Intrinsic.StringBuilder.Append("Query",", W.CONTACT, W.CONTACT_PHONE, W.CONTACT_EMAIL ")
	f.Intrinsic.StringBuilder.Append("Query",", (H.PCK_NO+G.ORDER_NO+G.ORDER_LINE) AS POL ")
	f.Intrinsic.StringBuilder.Append("Query",", CASE WHEN RTRIM(G.DOCK_NO) = '' THEN (RTRIM(CAST(G.LOAD_NO AS VARCHAR(4)))+'') ELSE (RTRIM(CAST(G.LOAD_NO AS VARCHAR(4)))+RTRIM(G.DOCK_NO)) END AS LD ")
	f.Intrinsic.StringBuilder.Append("Query",", A.EXTENSION AS EXT_AMT ")
	f.Intrinsic.StringBuilder.Append("Query",", A.PART+A.LOCATION AS PARTLOC ")
	
	'--------------------------
	' FROM / JOINs (OPTIMIZED)
	'--------------------------
	
	' OLD (commented):
	' f.Intrinsic.StringBuilder.Append("Query","FROM LOAD_PLAN G LEFT JOIN V_ORDER_LINES A ON A.ORDER_NO=G.ORDER_NO AND A.RECORD_NO=G.ORDER_LINE LEFT JOIN V_OE_SHIP_SCHED B ON B.ORDER_NO = A.ORDER_NO AND B.ORDER_LINE = A.RECORD_NO ")
	' f.Intrinsic.StringBuilder.Append("Query","LEFT JOIN V_ORDER_HEADER F ON A.ORDER_NO = F.ORDER_NO ")
	' f.Intrinsic.StringBuilder.Append("Query","WHERE F.RECORD_NO = '  A' AND A.QTY_BO <> 0 AND A.LINE_TYPE <> 'P' AND G.SHIPPED <> 1 ")
	' f.Intrinsic.StringBuilder.Append("Query","AND G.LOAD_NO > -1 ")
	
	' NEW: match your confirmed-working SQL, and keep the join optimizations
	f.Intrinsic.StringBuilder.Append("Query"," FROM (SELECT * FROM LOAD_PLAN WHERE SHIPPED <> 1 AND LOAD_NO > -1) G ")
	f.Intrinsic.StringBuilder.Append("Query"," INNER JOIN V_ORDER_LINES A ON A.ORDER_NO = G.ORDER_NO AND A.RECORD_NO = G.ORDER_LINE AND A.QTY_BO <> 0 AND A.LINE_TYPE <> 'P' ")
	f.Intrinsic.StringBuilder.Append("Query"," INNER JOIN V_ORDER_HEADER F ON F.ORDER_NO = A.ORDER_NO AND F.RECORD_NO = '  A' ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN V_OE_SHIP_SCHED B ON B.ORDER_NO = A.ORDER_NO AND B.ORDER_LINE = A.RECORD_NO ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN V_CUSTOMER_MASTER C ON A.CUSTOMER = C.CUSTOMER ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN V_INVENTORY_ALL D ON A.PART = D.PART AND A.LOCATION = D.LOCATION ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN V_ORDER_SHIP_TO E ON E.ORDER_NO = A.ORDER_NO and E.SHIP_ID = A.SHIP_ID ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN V_ORDER_BILL_TO W ON A.ORDER_NO = W.ORDER_NO ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN STAGING_QUANTITY H ON G.ORDER_NO = H.ORDER_NO AND G.ORDER_LINE = H.LINE ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN V_SHIPMENT_LINES I ON A.ORDER_NO = I.ORDER_NO AND A.RECORD_NO = I.ORDER_REC AND I.ORDER_SUFFIX = H.SEQ ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN TRUCK_TYPE J ON G.TRUCK_TYPE = J.TYPE_ID ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN DOCK_TYPE K ON G.DOCK_NO = K.DOCK_NO ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN BOL_CONTAINERS Z ON D.DFLT_CARTON_CD = Z.CNTNR_CODE ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN BOL_CONTAINERS X ON D.DFLT_PALLET_CD = X.CNTNR_CODE ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN V_STAGING_HEADER L ON H.PCK_NO=L.PCK_NO ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN V_SHIPMENT_HEADER M ON L.PCK_NO=M.PCK_NO AND M.ORDER_NO=H.ORDER_NO ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN (SELECT WAYBILL_NO, RTRIM(FROM_NAME) AS FROM_NAME FROM BOL_HEADER GROUP BY WAYBILL_NO, FROM_NAME) N ON M.WAY_BILL = N.WAYBILL_NO ")
	f.Intrinsic.StringBuilder.Append("Query"," LEFT JOIN BOL_PART_INFO BPI ON BPI.PCK_NO = H.PCK_NO AND BPI.ORDER_NO = A.ORDER_NO AND BPI.LINE = A.RECORD_NO ")
	
	' No WHERE needed; filters are in derived table and JOINs above
	'f.Intrinsic.StringBuilder.Append("Query"," WHERE (F.ORDER_SUFFIX = G.ORDER_SUFFIX OR H.PCK_NO IS NOT NULL) ")
	f.Intrinsic.StringBuilder.Append("Query"," ORDER BY G.LOAD_NO, A.DATE_ITEM_PROM, A.ORDER_NO, A.RECORD_NO; ")
	
	'--------------------------
	f.Intrinsic.StringBuilder.ToString("Query",v.Local.sQuery)
	f.Intrinsic.StringBuilder.Dispose("Query")
	f.Data.DataTable.CreateFromSQL("dtLoad0","con",v.Local.sQuery,True)

	
	'added 08/06/25 for outside PO
	F.Data.DataTable.AddColumn("dtLoad0","OPOL",String,"")
	
	'ADDED 07/14/25 BY BS FOR OUTSIDE POs	
	'F.Intrinsic.Control.CallSub(Validate_7551)
	f.Intrinsic.Control.If(v.Global.b7551)
		f.Intrinsic.Control.CallSub(Loadload_7551_outsidePO)
	f.Intrinsic.Control.EndIf	
	
	'ADDED 08/27/25 BY BS FOR LOAD VALIDATION STATUS VISIBILITY TO LOAD TAB
	F.Intrinsic.Control.CallSub(Validate_5235)
	
	'LONG PART NUMBER
	f.Intrinsic.Control.If(v.Global.bLongPart)
		F.Data.DataTable.AddDisplayPartColumn("dtLoad0",0,"PART","DISPLAY_PART")
	f.Intrinsic.Control.Else
		f.Data.DataTable.CopyColumn("dtLoad0","PART","DISPLAY_PART")
	f.Intrinsic.Control.EndIf
							
	F.Data.DataTable.AddColumn("dtLoad0","CUST_ORDER_NOTES",String,"")
	F.Data.Datatable.AddColumn("dtLoad0","Select","boolean",False)
	
	'7546 UDF 03/25/2026: Shared dictionary optimization — fill from pre-loaded shared dictionaries (loaded in LoadSharedDictionaries)
	F.Intrinsic.Control.If(V.Global.bCustOrderNotesFailedToLoad,=,False)
		F.Data.DataTable.FillFromDictionary("dtLoad0","dCustOrderNotes","CUSTOMER","CUST_ORDER_NOTES")
	F.Intrinsic.Control.EndIf
	
	F.Data.DataTable.FillFromDictionary("dtLoad0","dNotes","ORDLN","NOTES")
	F.Data.DataTable.FillFromDictionary("dtLoad0","dText","ORDLN","LINE_TEXT")
	F.Data.DataTable.FillFromDictionary("dtLoad0","dShortDesc","CSRV","CARR_SHORT_DESC")
	F.Data.DataTable.FillFromDictionary("dtLoad0","dLongDesc","CSRV","CARR_LONG_DESC")
	
	F.Data.Datatable.AddColumn("dtLoad0","QTY_90","LONG",0)
	F.Intrinsic.Control.If(V.Screen.frmShip!ddlCalculateMRPOnHand.ItemData,=,4)
		F.Data.DataTable.FillFromDictionary("dtLoad0","d90","PARTLOC","QTY_90")
	F.Intrinsic.Control.Else
		F.Data.DataTable.FillFromDictionary("dtLoad0","d90","PART","QTY_90")
	F.Intrinsic.Control.EndIf
	
	'7546 UDF 07/01/2026: First bin with qty on hand > 0
	F.Data.Datatable.AddColumn("dtLoad0","FIRST_BIN","String","")
	F.Data.DataTable.FillFromDictionary("dtLoad0","dFirstBin","PARTLOC","FIRST_BIN")
	
	'ADD COLUMN FOR LOAD VALIDATION 3/28/25
	Gui.frmShip.lblStatus.Caption("Loading Load tab Validation....")
'	F.Data.Dictionary.CreateFromSQL("dValidation","con","select (PCK_NO+ORDER_NO+ORDER_LINE)as POL,min(SHIP_VALIDATE) as VALIDATED from BOL_PACK_DTL group by pck_no,ORDER_NO,ORDER_LINE,SHIP_VALIDATE ORDER BY PCK_NO,ORDER_NO,ORDER_LINE,SHIP_VALIDATE;")
'	F.Data.Dictionary.CreateFromSQL("dValidation","con","SELECT B.PCK_NO + B.ORDER_NO + B.ORDER_LINE AS POL, MIN(B.SHIP_VALIDATE) AS VALIDATED FROM STAGING_HEADER S, BOL_PACK_DTL B WHERE B.PCK_NO = S.PCK_NO GROUP BY B.PCK_NO, B.ORDER_NO, B.ORDER_LINE;")
'	F.Data.Dictionary.CreateFromSQL("dValidation","con","SELECT B.PCK_NO + '-' + B.ORDER_NO + '-' + B.ORDER_LINE AS POL, MIN(B.SHIP_VALIDATE) AS VALIDATED FROM STAGING_HEADER S JOIN BOL_PACK_DTL B ON B.PCK_NO = S.PCK_NO GROUP BY B.PCK_NO,B.ORDER_NO, B.ORDER_LINE;")
'	BS 5/19/26 - Removed dash separators from POL key. Dashes caused key mismatch with dtLoad0.POL (line 1810) so FillFromDictionary never matched, leaving Validated=False on all Load tab rows.
	F.Data.Dictionary.CreateFromSQL("dValidation","con","SELECT B.PCK_NO + B.ORDER_NO + B.ORDER_LINE AS POL, MIN(B.SHIP_VALIDATE) AS VALIDATED FROM STAGING_HEADER S JOIN BOL_PACK_DTL B ON B.PCK_NO = S.PCK_NO GROUP BY B.PCK_NO, B.ORDER_NO, B.ORDER_LINE;")

'	F.Data.Dictionary.SetDefaultReturn("dValidation","False")
	F.Data.Datatable.AddColumn("dtLoad0","Validated","Boolean",False)
	F.Data.DataTable.FillFromDictionary("dtLoad0","dValidation","POL","Validated")
	F.Data.Dictionary.Close("dValidation")
	
	'Added to display outside PO validation status 08/06/25
	F.Data.Dictionary.CreateFromSQL("dValidation","con","select (RTRIM(USER_1)+RTRIM(PURCHASE_ORDER)+RTRIM(RECORD_NO)) as OPOL,CAST(CASE WHEN USER_4 in ('True','TRUE','true') then 1 else 0 end as bit) as VALIDATED from PO_LINES where PO_TYPE = 'O';")
'	F.Data.Dictionary.SetDefaultReturn("dValidation","False")
	F.Data.DataTable.FillFromDictionary("dtLoad0","dValidation","OPOL","Validated")
	F.Data.Dictionary.Close("dValidation")	
	
	'ADD COLUMN FOR LOADING STATUS 8/27/25
	Gui.frmShip.lblStatus.Caption("Loading Load tab Loading Status....")
	F.Data.Datatable.AddColumn("dtLoad0","Loading_Status","Boolean",False)
	F.Intrinsic.Control.If(V.Global.b5235)	
		F.Data.Dictionary.CreateFromSQL("dLoadingStatus","con","select (RTRIM(CAST(LOAD AS VARCHAR(4)))+RTRIM(dock)) as LD,ACTIVE FROM GCG_5235_RFID_LOAD;")
'		F.Data.Datatable.AddColumn("dtLoad0","Loading_Status","Boolean",False)
		F.Data.DataTable.FillFromDictionary("dtLoad0","dLoadingStatus","LD","Loading_Status")
		F.Data.Dictionary.Close("dLoadingStatus")
	F.Intrinsic.Control.EndIf
	
	'STATUS Column
	F.Data.DataTable.AddColumn("dtLoad0","STATUS",String,"")
	
    'Add AllocationFlag Column for our mrp allocation drop down things code behind only. not displayed to user.
	F.Data.Datatable.AddColumn("dtLoad0","AllocationFlag",Boolean,False)
	
	'Assign Picker Column
	F.Data.Datatable.AddColumn("dtLoad0","ASSIGNPICKER","Boolean",False)
	'load Order Picker Information
	F.Intrinsic.Control.CallSub(LoadPicker)

	'-- Dedup staged PL columns: zero out duplicates so footer SUM is correct for mixed-packing
	F.Data.DataTable.AddColumn("dtLoad0","Staged PL Mixed",String,"")
	V.Local.sSeenPL.Declare(String)
	V.Local.sPLKey.Declare(String)
	V.Local.iPos.Declare(Long)
	V.Local.iRow.Declare(Long)
	V.Local.iLastRow.Declare(Long)
	V.Local.sSeenPL.Set("")
	F.Intrinsic.Math.Sub(V.DataTable.dtLoad0.RowCount,1,V.Local.iLastRow)
	F.Intrinsic.Control.For(V.Local.iRow,0,V.Local.iLastRow)
		V.Local.sPLKey.Set(V.DataTable.dtLoad0(V.Local.iRow).Packing List!FieldValTrim)
		F.Intrinsic.Control.If(V.Local.sPLKey,<>,"")
			F.Intrinsic.String.Build("[{0}]",V.Local.sPLKey,V.Local.sPLKey)
			F.Intrinsic.String.InStr(V.Local.sSeenPL,V.Local.sPLKey,V.Local.iPos)
			F.Intrinsic.Control.If(V.Local.iPos,>,0)
				F.Data.Datatable.SetValue("dtLoad0",V.Local.iRow,"Staged PL Weight",0,"Staged PL Cartons",0,"Staged PL Pallets",0,"Staged PL Mixed","M")
			F.Intrinsic.Control.Else
				F.Intrinsic.String.Concat(V.Local.sSeenPL,V.Local.sPLKey,V.Local.sSeenPL)
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.Next(V.Local.iRow)

	'v.Local.sFilter.Set(v.DataTable.dtLoad0.FieldNames)
	'linq join orderpicker and dtLoad0
	Function.Intrinsic.Control.If(v.DataTable.dtOrderPicker.Exists) 
		F.Data.Linq.Join("LeftJoin","datatable","dtLoad0*!*A","datatable","dtOrderPicker*!*B","A.ORDER_NO = B.ORDER_NO And A.ORDER_SUFFIX = B.ORDER_SUFFIX AND A.ORDER_LINE = B.ORDER_LINE","A.Select*!*A.Load Number*!*A.Packing List*!*A.PL Ship Date*!*A.PICKLIST*!*A.TRACKING_NO*!*A.PRO_NO*!*A.WAY_BILL*!*A.BOL_SHIP_FROM*!*A.Staged Qty*!*A.Drop Seq*!*A.Carrier Number*!*A.Carrier Load Number*!*A.Carrier Trailer*!*A.Truck Type ID*!*A.Truck Description*!*A.Truck Max Weight(lbs)*!*A.Truck SF Capacity*!*A.Staging Bin*!*A.Dock ID*!*A.Pick By Date*!*A.Ship Date*!*A.Load Notes*!*A.Line_Text*!*A.Ready to Pick*!*A.PICKED*!*A.Container Name*!*A.Container Description*!*A.Ind Container Height (In)*!*A.Ind Container Width (In)*!*A.Ind Container Length (In)*!*A.Ind Container Weight*!*A.Est Container Qty*!*A.Est Packaged Weight*!*A.Est Area*!*A.CUSTOMER*!*A.NAME_CUSTOMER*!*A.CUSTOMER_PO*!*A.ORDER_NO*!*A.RECORD_NO*!*A.ORDER_LINE*!*A.ORDER_SUFFIX*!*A.CURRENT_ORDER_SUFFIX*!*A.PART*!*A.DISPLAY_PART*!*A.LOCATION*!*A.PRODUCT_LINE*!*A.DESCRIPTION*!*A.Description_2*!*A.Description_3*!*A.WEIGHT*!*A.QTY_BO*!*A.QTY_ONHAND*!*A.QTY_90*!*A.FIRST_BIN*!*A.EXT_AMT*!*A.QTY_REQUIRED*!*A.DATE_ORDER*!*A.MUST_DLVR_BY_DATE*!*A.DATE_ITEM_PROM*!*A.SHIP_ID*!*A.CITY_SHIP*!*A.STATE_SHIP*!*A.Address_1_Ship*!*A.Address_2_Ship*!*A.Address_3_Ship*!*A.Address_4_Ship*!*A.Address_5_Ship*!*A.Name_Customer_Ship*!*A.Freight_Zone_Ship*!*A.SHIP_VIA_SHIP*!*A.CARRIER_CD*!*A.CARR_SHORT_DESC*!*A.CARR_LONG_DESC*!*A.STAGED*!*A.FLAG_USE_MQD*!*A.SHP_HLD_FLAG*!*A.QTY_SHIPPED*!*A.NOTES*!*A.USER_1*!*A.USER_2*!*A.USER_3*!*A.USER_4*!*A.USER_5*!*A.INFO_1*!*A.INFO_2*!*A.H_USER_1*!*A.H_USER_2*!*A.H_USER_3*!*A.H_USER_4*!*A.H_USER_5*!*A.ORDLN*!*A.CSRV*!*A.CUSTOMER_PART*!*A.CODE_SOURCE*!*A.CODE_SORT*!*A.ORDER_SORT_2*!*A.INV_CODE_SORT*!*A.CODE_FOB*!*A.SALESPERSON*!*A.ORDER_TYPE*!*A.LINE_TYPE*!*A.BLANKET_NO*!*A.FLAG_NO_BACKORDER*!*A.STATUS*!*A.CUST_ORDER_NOTES*!*B.Assigned_To*!*A.AllocationFlag*!*A.PROJECT*!*A.PHASE*!*A.CONTACT*!*A.CONTACT_PHONE*!*A.CONTACT_EMAIL*!*A.VALIDATED*!*A.POL*!*A.OPOL*!*A.LD*!*A.LOADING_STATUS*!*A.NMFC_NO*!*A.FRT_CLASS*!*A.COMM_DESC_1*!*A.Staged PL Weight*!*A.Staged PL Cartons*!*A.Staged PL Pallets*!*A.Staged PL Mixed*!*A.PARTLOC","","","","dtLoad1",True)
	Function.Intrinsic.Control.Else
		f.Data.Datatable.Clone("dtLoad0","dtLoad1",True)
	Function.Intrinsic.Control.EndIf
	
	'Create DataView and filter out locations
	F.Intrinsic.Control.If(V.Global.bUseShippingLocations)
		F.Intrinsic.Control.If(V.Global.bShippingOverride)
			V.Local.sFilter.Set("")
		F.Intrinsic.Control.Else
			F.Intrinsic.String.Build("LOCATION = '{0}'",V.Global.sShippingLocation,V.Local.sFilter)
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.Else
		V.Local.sFilter.Set("")
	F.Intrinsic.Control.EndIf
	
	F.Data.DataView.Create("dtLoad1","dvLoad",22,V.Local.sFilter,"")
	
	'Convert DV to DT
	F.Data.DataView.ToDataTable("dtLoad1","dvLoad","dtLoad",True)
	F.Data.DataTable.Close("dtLoad1")

'	F.Intrinsic.Control.If(V.Screen.frmShip!ddlCalculateMRPOnHand.Text,<>,"No")
'		F.Intrinsic.Control.CallSub(CalculateMaterial)
'	F.Intrinsic.Control.EndIf
	
	'Remove Columns	
	F.Data.DataTable.RemoveColumn("dtLoad","ORDLN")
	F.Data.DataTable.RemoveColumn("dtLoad","CSRV")	
	F.Data.DataTable.RemoveColumn("dtLoad","POL")
	'F.Data.DataTable.RemoveColumn("dtLoad","OPOL")
	F.Data.DataTable.RemoveColumn("dtLoad","LD")
	F.Data.DataTable.RemoveColumn("dtLoad","PARTLOC")
	
	F.Intrinsic.Control.CallSub(LoadOpenOrdersGV,"DT","dtLoad","GV","gvLoad","GSGC","GsGCLoad")
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.LoadLoad.End

Program.Sub.LoadOpenOrdersGV.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.iRet.Declare
	V.Local.iCnt.Declare
	V.Local.sColumns.Declare
	V.Local.bHold.Declare
	v.Local.sRet.Declare(String)
	
	Gui.frmShip.[V.Args.GSGC].AddGridViewFromDataTable(V.Args.GV,V.Args.DT)
	Gui.frmShip.[V.Args.GSGC].SuspendLayout()
	Gui.frmShip.[V.Args.GSGC].SetGridViewProperty(V.Args.GV,"MultiSelect",True)
	Gui.frmShip.[V.Args.GSGC].SetGridViewProperty(V.Args.GV,"OptionBehaviorEditable",True)
	Gui.frmShip.[V.Args.GSGC].SetGridViewProperty(V.Args.GV,"AllowSort",True)
	Gui.frmShip.[V.Args.GSGC].SetGridViewProperty(V.Args.GV,"AllowFilter",True)
	Gui.frmShip.[V.Args.GSGC].SetGridViewProperty(V.Args.GV,"OptionsDetailShowDetailTabs",False)
	Gui.frmShip.[V.Args.GSGC].SetGridViewProperty(V.Args.GV,"OptionsViewShowGroupPanel",True)
	Gui.frmShip.[V.Args.GSGC].SetGridViewProperty(V.Args.GV,"OptionsViewColumnAutoWidth",False)
	Gui.frmShip.[V.Args.GSGC].SetGridviewProperty(V.Args.GV,"showconditionalformattingitem",True)
	Gui.frmShip.[V.Args.GSGC].SetGridviewProperty(V.Args.GV,"OptionsViewShowAutoFilterRow",True)
	Gui.frmShip.[V.Args.GSGC].SetGridviewProperty(V.Args.GV,"ShowGroupPanel",True)
	Gui.frmShip.[V.Args.GSGC].SetGridviewProperty(V.Args.GV,"ShowTotalSummaryMenu",True)
	Gui.frmShip.[V.Args.GSGC].SetGridviewProperty(V.Args.GV,"ShowAddNewSummaryItem",True)
	Gui.frmShip.[V.Args.GSGC].SetGridviewProperty(V.Args.GV,"ShowGroupSortSummaryItems",True)
	Gui.frmShip.[V.Args.GSGC].SetGridviewProperty(V.Args.GV,"ShowGroupSummaryMenu",True)
	Gui.frmShip.[V.Args.GSGC].SetGridviewProperty(V.Args.GV,"ShowSummaryItemMode",True)
	
	'Loop through columns names by using the V.DataTable.dtName.FieldNames
	F.Intrinsic.String.Split(V.DataTable.[V.Args.DT].FieldNames,"*!*",V.Local.sColumns)
	F.Intrinsic.Control.For(V.Local.iCnt,0,V.Local.sColumns.UBound,1)
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,V.Local.sColumns(V.Local.iCnt),"HeaderFontBold",True)
	F.Intrinsic.Control.Next(V.Local.iCnt)
	
	'VisibleIndex
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PICKLIST","VisibleIndex","0")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"NAME_CUSTOMER","VisibleIndex","1")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CUSTOMER_PO","VisibleIndex","2")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"ORDER_NO","VisibleIndex","3")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"RECORD_NO","VisibleIndex","4")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"DISPLAY_PART","VisibleIndex","5")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"LOCATION","VisibleIndex","6")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PRODUCT_LINE","VisibleIndex","7")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"DESCRIPTION","VisibleIndex","8")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"WEIGHT","VisibleIndex","9")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"QTY_BO","VisibleIndex","10")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"QTY_ONHAND","VisibleIndex","11")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"QTY_REQUIRED","VisibleIndex","12")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"DATE_ORDER","VisibleIndex","13")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"DATE_ITEM_PROM","VisibleIndex","14")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"MUST_DLVR_BY_DATE","VisibleIndex","15")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"SHIP_ID","VisibleIndex","16")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CITY_SHIP","VisibleIndex","17")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"STATE_SHIP","VisibleIndex","18")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"ADDRESS_1_SHIP","VisibleIndex","19")	
