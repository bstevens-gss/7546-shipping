	F.Intrinsic.Control.SelectCase(V.Args.MenuName)
	F.Intrinsic.Control.Case("CTXOPEN")
		Gui.frmShip.GsGCAllShip.SetColumnProperty("gvAllShip","PICKLIST","CellBackColor","LightGray")
		
		'Shipping
		F.Intrinsic.Control.If(v.Global.bViewSO,=,True,or,v.Global.bShipOEPermission,=,True,v.Global.bShipSHIPPermission,=,True)
			Gui.frmShip.GsGCAllShip.SetColumnProperty("gvAllShip","ORDER_NO","CellForeColor",V.Enum.ThemeColors!AccentColor.Minus(15))
			Gui.frmShip.GsGCAllShip.SetColumnProperty("gvAllShip","ORDER_NO","IsHyperlink",True)
		F.Intrinsic.Control.EndIf
		'Supply and Demand
		F.Intrinsic.Control.If(v.Global.bSupDemView,=,True,OR,v.Global.bSupDemEdit,=,True,v.Global.bSupDemNODollars,=,True,V.Global.bSupDemNew, =, True)
			Gui.frmShip.GsGCAllShip.SetColumnProperty("gvAllShip","DISPLAY_PART","CellForeColor",V.Enum.ThemeColors!AccentColor.Minus(15))
			Gui.frmShip.GsGCAllShip.SetColumnProperty("gvAllShip","DISPLAY_PART","IsHyperlink",True)
