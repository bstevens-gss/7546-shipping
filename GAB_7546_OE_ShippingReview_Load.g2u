gui.frmShip.tabShip.Enabled(False)
Gui.frmSplitLine..Show
Gui.frmSplitLine..WaitForDismiss
gui.frmShip.tabShip.Enabled(True)

F.Intrinsic.Control.If(V.Global.bSplitSaved)
	F.Intrinsic.Control.CallSub(cmdRefresh_Click)
F.Intrinsic.Control.EndIf

F.Intrinsic.Control.If(V.DataTable.dtSplitLines.Exists)
	F.Data.DataTable.Close("dtSplitLines")
F.Intrinsic.Control.EndIf

