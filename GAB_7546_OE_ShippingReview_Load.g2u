		F.Intrinsic.Control.CaseAny("Carrier Load Number","CARRIER LOAD NUMBER")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrder)
