			F.Data.Datatable.SetValue("dtLoad",v.Local.sSel(v.Local.i),"SELECT",1,"VALIDATED",0)
			F.Intrinsic.String.Build("UPDATE PO_LINES Set USER_4 = '' Where USER_1 = '{2}' AND PURCHASE_ORDER = '{0}' AND RECORD_NO = '{1}'",v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_NO!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_LINE!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).Carrier Load Number!FieldVal,v.Local.sSQL)
			f.ODBC.Connection!con.Execute(v.Local.sSQL)			
