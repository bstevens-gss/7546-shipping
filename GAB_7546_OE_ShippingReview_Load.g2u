		Gui.frmShip.GsGCAllShip.SetColumnProperty("gvAllShip","USER_5","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCAllShip.SetColumnProperty("gvAllShip","NOTES","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)

		
	F.Intrinsic.Control.Case("CTXDUE")
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","PICKLIST","CellBackColor","LightGray")
		
		'Shipping
		F.Intrinsic.Control.If(v.Global.bViewSO,=,True,or,v.Global.bShipOEPermission,=,True,v.Global.bShipSHIPPermission,=,True)
			Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","ORDER_NO","CellForeColor",V.Enum.ThemeColors!AccentColor.Minus(15))
			Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","ORDER_NO","IsHyperlink",True)
		F.Intrinsic.Control.EndIf
		'Supply and Demand
		F.Intrinsic.Control.If(v.Global.bSupDemView,=,True,OR,v.Global.bSupDemEdit,=,True,v.Global.bSupDemNODollars,=,True,V.Global.bSupDemNew, =, True)
			Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","DISPLAY_PART","CellForeColor",V.Enum.ThemeColors!AccentColor.Minus(15))
			Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","DISPLAY_PART","IsHyperlink",True)
		F.Intrinsic.Control.EndIf
		
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","QTY_ONHAND","CellForeColor",V.Enum.ThemeColors!AccentColor.Minus(15))	
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","QTY_ONHAND","IsHyperlink",True)
		
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","FLAG_USE_MQD","CellBackColor","LightGray")
		
		'Set On Hold (Pink) and Ready (Green) colors
		F.Intrinsic.Control.For(V.Local.iCnt,0,V.DataTable.dtDueShip.RowCount--,1)
			F.Intrinsic.Control.If(V.DataTable.dtDueShip(v.Local.iCnt).QTY_ONHAND!fieldValFloat,>=,V.DataTable.dtDueShip(v.Local.iCnt).QTY_BO!FieldValFloat)
				Gui.frmShip.GsGCDue.SetRowAppearance("gvDue",v.Local.iCnt,"BackColor",V.Enum.ThemeColors!ColorGreen.Highlight)
				F.Data.DataTable.SetValue("dtDueShip",V.Local.iCnt,"STATUS","Ready To Ship")
			F.Intrinsic.Control.EndIf
	
			Gui.frmShip.GsGCDue.GetCellValueByColumnName("gvDue","SHP_HLD_FLAG",v.Local.iCnt,V.Local.bHold)
			F.Intrinsic.Control.If(V.Local.bHold)
				Gui.frmShip.GsGCDue.SetRowAppearance("gvDue",V.Local.iCnt,"BackColor",V.Enum.ThemeColors!ColorRed.Highlight)
				F.Data.DataTable.SetValue("dtDueShip",V.Local.iCnt,"STATUS","On Hold")
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.Next(V.Local.iCnt)
		
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","PICKLIST","CellForeColor","Black")
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","FLAG_USE_MQD","CellForeColor","Black")
		
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","NOTES","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","USER_1","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","USER_2","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","USER_3","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","USER_4","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","USER_5","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","NOTES","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","USER_1","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","USER_2","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","USER_3","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","USER_4","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCDue.SetColumnProperty("gvDue","USER_5","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		
	F.Intrinsic.Control.Case("CTXLOAD")
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","PICKLIST","CellBackColor","LightGray")
		
		'Shipping
		F.Intrinsic.Control.If(v.Global.bViewSO,=,True,or,v.Global.bShipOEPermission,=,True,v.Global.bShipSHIPPermission,=,True)
			Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","ORDER_NO","CellForeColor",V.Enum.ThemeColors!AccentColor.Minus(15))
			Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","ORDER_NO","IsHyperlink",True)
		F.Intrinsic.Control.EndIf
		'Supply and Demand
		F.Intrinsic.Control.If(v.Global.bSupDemView,=,True,OR,v.Global.bSupDemEdit,=,True,v.Global.bSupDemNODollars,=,True,V.Global.bSupDemNew, =, True)
			Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","DISPLAY_PART","CellForeColor",V.Enum.ThemeColors!AccentColor.Minus(15))
			Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","DISPLAY_PART","IsHyperlink",True)
		F.Intrinsic.Control.EndIf
		
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","QTY_ONHAND","CellForeColor",V.Enum.ThemeColors!AccentColor.Minus(15))	
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","QTY_ONHAND","IsHyperlink",True)
		
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","FLAG_USE_MQD","CellBackColor","LightGray")
		
		'Set On Hold (Pink)
		F.Intrinsic.Control.For(V.Local.iCnt,0,V.DataTable.dtLoad.RowCount--,1)	
			Gui.frmShip.GsGCLoad.GetCellValueByColumnName("gvLoad","SHP_HLD_FLAG",v.Local.iCnt,V.Local.bHold)
			F.Intrinsic.Control.If(V.Local.bHold)
				Gui.frmShip.GsGCLoad.SetRowAppearance("gvLoad",V.Local.iCnt,"BackColor",V.Enum.ThemeColors!ColorRed.Highlight)
				F.Data.DataTable.SetValue("dtLoad",V.Local.iCnt,"STATUS","On Hold")
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.Next(V.Local.iCnt)
		
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","PICKLIST","CellForeColor","Black")
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","FLAG_USE_MQD","CellForeColor","Black")
		
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","NOTES","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","USER_1","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","USER_2","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","USER_3","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","USER_4","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","USER_5","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","NOTES","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","USER_1","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","USER_2","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","USER_3","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","USER_4","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","USER_5","CellForeColor",V.Enum.ThemeColors!ColorBlack)
		
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","LOAD NUMBER","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","PACKING LIST","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","STAGED QTY","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Drop Seq","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Carrier Number","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Carrier Load Number","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Carrier Trailer","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)		
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Truck Type ID","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)		
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Truck Description","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)		
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Staging Bin","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Dock ID","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Pick By Date","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Ship Date","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)		
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Load Notes","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Ready To Pick","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Picked","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Truck Max Weight(lbs)","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Truck SF Capacity","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","TRACKING_NO","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","PRO_NO","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","PL SHIP DATE","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","WAY_BILL","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)	
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","BOL_SHIP_FROM","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","VALIDATED","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
		Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","LOADING_STATUS","CellBackColor",V.Enum.ThemeColors!ColorBlue.Highlight)
	F.Intrinsic.Control.Case("CTXSTAGING")
		Gui.frmShip.GsGCStaging.SetColumnProperty("gvStaging","PCK_NO","CellForeColor",V.Enum.ThemeColors!AccentColor)
		Gui.frmShip.GsGCStaging.SetColumnProperty("gvStaging","PCK_NO","IsHyperlink",True)
		
		F.Intrinsic.Control.For(V.Local.iCnt,0,V.DataTable.dtStaging.RowCount--,1)
			
			'Set Row Color Depending on Percent Complete
			Gui.frmShip.GsGCStaging.GetCellValueByColumnName("gvStaging","PCT_COMPLETE",V.Local.iCnt,V.Local.sPercentReturn)
			f.Intrinsic.String.TrimChar(v.Local.sPercentReturn,"%",v.Local.fPercentReturn)
			F.Intrinsic.Control.If(V.Local.fPercentReturn,<=,25)
				Gui.frmShip.GsGCStaging.SetRowAppearance("gvSTAGING",V.Local.iCnt,"BackColor",V.Enum.ThemeColors!ColorOrange.Highlight)
			
			f.Intrinsic.Control.ElseIf(V.Local.fPercentReturn,>,25,"AND",v.Local.fPercentReturn,<=,75)
				Gui.frmShip.GsGCStaging.SetRowAppearance("gvSTAGING",V.Local.iCnt,"BackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
			f.Intrinsic.Control.Else
				Gui.frmShip.GsGCStaging.SetRowAppearance("gvSTAGING",V.Local.iCnt,"BackColor",V.Enum.ThemeColors!ColorGreen.Highlight)
			
			F.Intrinsic.Control.EndIf
			'Set Row Color to Red for if the shipment is On Hold
			Gui.frmShip.GsGCStaging.GetCellValueByColumnName("gvStaging","SHP_HLD_FLAG",V.Local.iCnt,V.Local.bHold)
			F.Intrinsic.Control.If(V.Local.bHold)
				Gui.frmShip.GsGCStaging.SetRowAppearance("gvSTAGING",V.Local.iCnt,"BackColor",V.Enum.ThemeColors!ColorRed.Highlight)
			F.Intrinsic.Control.EndIf
			
		F.Intrinsic.Control.Next(V.Local.iCnt)
		
	F.Intrinsic.Control.Case("CTXSHIPPED")
		F.Data.DataTable.Select("dtShipped","LN_SHP_STAT = 2",V.Local.sSelect)
		F.Intrinsic.Control.If(V.Local.sSelect.IsNotNoReturn)
			F.Intrinsic.String.Split(V.Local.sSelect,"*!*",V.Local.sSelect)
			F.Intrinsic.Control.For(V.Local.iCnt,0,V.Local.sSelect.UBound,1)
				Gui.frmShip.GsGCShipped.SetRowAppearance("gvShipped",V.Local.sSelect(V.Local.iCnt),"BackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
			F.Intrinsic.Control.Next(V.Local.iCnt)
		F.Intrinsic.Control.EndIf
	
		F.Data.DataTable.Select("dtShipped","LN_SHP_STAT = 3",V.Local.sSelect)
		F.Intrinsic.Control.If(V.Local.sSelect.IsNotNoReturn)
			F.Intrinsic.String.Split(V.Local.sSelect,"*!*",V.Local.sSelect)
			F.Intrinsic.Control.For(V.Local.iCnt,0,V.Local.sSelect.UBound,1)
				Gui.frmShip.GsGCShipped.SetRowAppearance("gvShipped",V.Local.sSelect(V.Local.iCnt),"BackColor",V.Enum.ThemeColors!ColorGreen.Highlight)
			F.Intrinsic.Control.Next(V.Local.iCnt)
		F.Intrinsic.Control.EndIf
		
		Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LN_USER_1","CellBackColor", V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LN_USER_2","CellBackColor", V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LN_USER_3","CellBackColor", V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LN_USER_4","CellBackColor", V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LN_USER_5","CellBackColor", V.Enum.ThemeColors!ColorYellow.Highlight)
		Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LN_USER_1","CellForeColor", V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LN_USER_2","CellForeColor", V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LN_USER_3","CellForeColor", V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LN_USER_4","CellForeColor", V.Enum.ThemeColors!ColorBlack)
		Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LN_USER_5","CellForeColor", V.Enum.ThemeColors!ColorBlack)
		
F.Intrinsic.Control.EndSelect
	
F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.End 
F.Intrinsic.Control.EndTry

Program.Sub.ResetGridColors.End

Program.Sub.optShip_Click.Start
