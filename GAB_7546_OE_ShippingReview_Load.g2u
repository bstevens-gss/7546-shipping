	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PROJECT","MinWidth","70")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PROJECT","AllowEdit",False)
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PROJECT","ReadOnly",True)
