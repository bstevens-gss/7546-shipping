Program.Sub.GridViewFilterToDataViewFilter.Start
f.Intrinsic.Control.Try
	'this sub is for converting the active filter string of a gridview into a dataview friendly version
	'FILTER	-	The Active Filter String
	'will return FILTER
	'valid operators: =, >, <, >=, <=, <>, in, is null, not, like
	V.Local.sFilter.Declare(String)
	V.Local.sRet.Declare(String)
	V.Local.iCounter.Declare(Long)
	V.Local.sFields.Declare(String)
	V.Local.sTemp.Declare(String)
	V.Local.sTemp2.Declare(String)
	V.Local.sFindString.Declare(String)
	V.Local.sReplaceString.Declare(String)
	V.Local.sValues.Declare(String)
	V.Local.sValueReturn.Declare(String)
	V.Local.sFieldReturn.Declare(String)
	V.Local.sValueRegEx.Declare(String, "\'[^']*\'")
	V.Local.sFieldRegEx.Declare(String, "\[[A-Za-z0-9_-]+\]")
	V.Local.sNumberRegEx.Declare(String, "-?[0-9]+(\.[0-9]+)?")
	V.Local.sRegEx.Declare(String)
	V.Local.sMatch.Declare(String)
	V.Local.ilength.Declare(Long)
	V.Local.sValueReturn2.Declare(String)
	V.Local.sError.Declare(String)
	V.Local.sFilter.Set(V.Args.Filter)
	
	'fix all IsNullOrEmpty
	F.Intrinsic.String.Build("IsNullOrEmpty\({0}\)", V.Local.sFieldRegEx, V.Local.sRegEx)
	F.Intrinsic.String.RegExMatch(V.Local.sFilter, V.Local.sRegEx, True, V.Local.sRet)
	F.Intrinsic.Control.If(V.Local.sRet.Trim, !=, "")
		F.Intrinsic.String.Split(V.Local.sRet, "@!@", V.Local.sRet)
		F.Intrinsic.Control.For(V.Local.iCounter, 0, V.Local.sRet.UBound, 1)
			'get match
			F.Intrinsic.String.Split(V.Local.sRet(V.Local.iCounter), "*!*", V.Local.sTemp)
			V.Local.sMatch.Set(V.Local.sTemp(1))
			'get the field, only one
			F.Intrinsic.String.RegExMatch(V.Local.sMatch, V.Local.sFieldRegEx, True, V.Local.sTemp)
			F.Intrinsic.String.Split(V.Local.sTemp, "*!*", V.Local.sTemp)
			V.Local.sFieldReturn.Set(V.Local.sTemp(1))
			'Replace
			F.Intrinsic.String.Build("({0} is Null or {0} = '')", V.Local.sFieldReturn, V.Local.sReplaceString)
			F.Intrinsic.String.Replace(V.Local.sFilter, V.Local.sMatch, V.Local.sReplaceString, V.Local.sFilter)
		F.Intrinsic.Control.Next(V.Local.iCounter)
	F.Intrinsic.Control.EndIf
	'fix all StartsWith
	F.Intrinsic.String.Build("StartsWith\({0},\s*{1}\)", V.Local.sFieldRegEx, V.Local.sValueRegEx, V.Local.sRegEx)
	F.Intrinsic.String.RegExMatch(V.Local.sFilter, V.Local.sRegEx, True, V.Local.sRet)
	F.Intrinsic.Control.If(V.Local.sRet.Trim, !=, "")
		F.Intrinsic.String.Split(V.Local.sRet, "@!@", V.Local.sRet)
		F.Intrinsic.Control.For(V.Local.iCounter, 0, V.Local.sRet.UBound, 1)
			'get match
			F.Intrinsic.String.Split(V.Local.sRet(V.Local.iCounter), "*!*", V.Local.sTemp)
			V.Local.sMatch.Set(V.Local.sTemp(1))
			'get the field, only one
			F.Intrinsic.String.RegExMatch(V.Local.sMatch, V.Local.sFieldRegEx, True, V.Local.sTemp)
			F.Intrinsic.String.Split(V.Local.sTemp, "*!*", V.Local.sTemp)
			V.Local.sFieldReturn.Set(V.Local.sTemp(1))
			'get the value, only one
			F.Intrinsic.String.RegExMatch(V.Local.sMatch, V.Local.sValueRegEx, True, V.Local.sTemp)
			F.Intrinsic.String.Split(V.Local.sTemp, "*!*", V.Local.sTemp)
			V.Local.sValueReturn.Set(V.Local.sTemp(1))
			F.Intrinsic.String.TrimChar(V.Local.sValueReturn, "'", V.Local.sValueReturn)
			'Replace
			F.Intrinsic.String.Build("{0} like '{1}%'", V.Local.sFieldReturn, V.Local.sValueReturn, V.Local.sReplaceString)
			F.Intrinsic.String.Replace(V.Local.sFilter, V.Local.sMatch, V.Local.sReplaceString, V.Local.sFilter)
		F.Intrinsic.Control.Next(V.Local.iCounter)
	F.Intrinsic.Control.EndIf
	'fix all EndsWith
	F.Intrinsic.String.Build("EndsWith\({0},\s*{1}\)", V.Local.sFieldRegEx, V.Local.sValueRegEx, V.Local.sRegEx)
	F.Intrinsic.String.RegExMatch(V.Local.sFilter, V.Local.sRegEx, True, V.Local.sRet)
	F.Intrinsic.Control.If(V.Local.sRet.Trim, !=, "")
		F.Intrinsic.String.Split(V.Local.sRet, "@!@", V.Local.sRet)
		F.Intrinsic.Control.For(V.Local.iCounter, 0, V.Local.sRet.UBound, 1)
			'get match
			F.Intrinsic.String.Split(V.Local.sRet(V.Local.iCounter), "*!*", V.Local.sTemp)
			V.Local.sMatch.Set(V.Local.sTemp(1))
			'get the field, only one
			F.Intrinsic.String.RegExMatch(V.Local.sMatch, V.Local.sFieldRegEx, True, V.Local.sTemp)
			F.Intrinsic.String.Split(V.Local.sTemp, "*!*", V.Local.sTemp)
			V.Local.sFieldReturn.Set(V.Local.sTemp(1))
			'get the value, only one
			F.Intrinsic.String.RegExMatch(V.Local.sMatch, V.Local.sValueRegEx, True, V.Local.sTemp)
			F.Intrinsic.String.Split(V.Local.sTemp, "*!*", V.Local.sTemp)
			V.Local.sValueReturn.Set(V.Local.sTemp(1))
			F.Intrinsic.String.TrimChar(V.Local.sValueReturn, "'", V.Local.sValueReturn)
			'Replace
			F.Intrinsic.String.Build("{0} like '%{1}'", V.Local.sFieldReturn, V.Local.sValueReturn, V.Local.sReplaceString)
			F.Intrinsic.String.Replace(V.Local.sFilter, V.Local.sMatch, V.Local.sReplaceString, V.Local.sFilter)
		F.Intrinsic.Control.Next(V.Local.iCounter)
	F.Intrinsic.Control.EndIf
	'fix all Contains
	F.Intrinsic.String.Build("Contains\({0},\s*{1}\)", V.Local.sFieldRegEx, V.Local.sValueRegEx, V.Local.sRegEx)
	F.Intrinsic.String.RegExMatch(V.Local.sFilter, V.Local.sRegEx, True, V.Local.sRet)
	F.Intrinsic.Control.If(V.Local.sRet.Trim, !=, "")
		F.Intrinsic.String.Split(V.Local.sRet, "@!@", V.Local.sRet)
		F.Intrinsic.Control.For(V.Local.iCounter, 0, V.Local.sRet.UBound, 1)
			'get match
			F.Intrinsic.String.Split(V.Local.sRet(V.Local.iCounter), "*!*", V.Local.sTemp)
			V.Local.sMatch.Set(V.Local.sTemp(1))
			'get the field, only one
			F.Intrinsic.String.RegExMatch(V.Local.sMatch, V.Local.sFieldRegEx, True, V.Local.sTemp)
			F.Intrinsic.String.Split(V.Local.sTemp, "*!*", V.Local.sTemp)
			V.Local.sFieldReturn.Set(V.Local.sTemp(1))
			'get the value, only one
			F.Intrinsic.String.RegExMatch(V.Local.sMatch, V.Local.sValueRegEx, True, V.Local.sTemp)
			F.Intrinsic.String.Split(V.Local.sTemp, "*!*", V.Local.sTemp)
			V.Local.sValueReturn.Set(V.Local.sTemp(1))
			F.Intrinsic.String.TrimChar(V.Local.sValueReturn, "'", V.Local.sValueReturn)
			'Replace
			F.Intrinsic.String.Build("{0} like '%{1}%'", V.Local.sFieldReturn, V.Local.sValueReturn, V.Local.sReplaceString)
			F.Intrinsic.String.Replace(V.Local.sFilter, V.Local.sMatch, V.Local.sReplaceString, V.Local.sFilter)
		F.Intrinsic.Control.Next(V.Local.iCounter)
	F.Intrinsic.Control.EndIf
	'fix between
	F.Intrinsic.String.Build("{0} Between\({1}m?, {1}m?\)", V.Local.sFieldRegEx, V.Local.sNumberRegEx, V.Local.sRegEx)
	F.Intrinsic.String.RegExMatch(V.Local.sFilter, V.Local.sRegEx, True, V.Local.sRet)
	F.Intrinsic.Control.If(V.Local.sRet.Trim, !=, "")
		F.Intrinsic.String.Split(V.Local.sRet, "@!@", V.Local.sRet)
		F.Intrinsic.Control.For(V.Local.iCounter, 0, V.Local.sRet.UBound, 1)
			'get match
			F.Intrinsic.String.Split(V.Local.sRet(V.Local.iCounter), "*!*", V.Local.sTemp)
			V.Local.sMatch.Set(V.Local.sTemp(1))
			'get the field, only one
			F.Intrinsic.String.RegExMatch(V.Local.sMatch, V.Local.sFieldRegEx, True, V.Local.sTemp)
			F.Intrinsic.String.Split(V.Local.sTemp, "*!*", V.Local.sTemp)
			V.Local.sFieldReturn.Set(V.Local.sTemp(1))
			'get the values, two
			F.Intrinsic.String.RegExMatch(V.Local.sMatch, V.Local.sNumberRegEx, True, V.Local.sTemp)
			F.Intrinsic.String.Split(V.Local.sTemp, "@!@", V.Local.sTemp)
			F.Intrinsic.String.Split(V.Local.sTemp(0), "*!*", V.Local.sTemp2)
			V.Local.sValueReturn.Set(V.Local.sTemp2(1))
			F.Intrinsic.String.Split(V.Local.sTemp(1), "*!*", V.Local.sTemp2)
			V.Local.sValueReturn2.Set(V.Local.sTemp2(1))
			'Replace
			F.Intrinsic.String.Build("({0} >= {1} and {0} <= {2})", V.Local.sFieldReturn, V.Local.sValueReturn, V.Local.sValueReturn2, V.Local.sReplaceString)
			F.Intrinsic.String.Replace(V.Local.sFilter, V.Local.sMatch, V.Local.sReplaceString, V.Local.sFilter)
		F.Intrinsic.Control.Next(V.Local.iCounter)
	F.Intrinsic.Control.EndIf
	F.Intrinsic.Variable.AddRV("FILTER", V.Local.sFilter)
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.CallSub(frmShip_UnLoad)
F.Intrinsic.Control.EndTry	
Program.Sub.GridViewFilterToDataViewFilter.End

Program.Sub.Clean_Load_Plan_TruckType.Start
Function.Intrinsic.Control.Try
v.Local.dPickDate.Declare(Date)
v.Local.sSQL.Declare(String)

	F.Intrinsic.String.Build("Update Load_Plan Set Truck_Type = '-1' Where Truck_Type = '{0}';","00000J",v.Local.sSQL)
	f.ODBC.Connection!con.Execute(v.Local.sSQL)
		
Function.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.CallSub(frmShip_UnLoad)	
Function.Intrinsic.Control.EndTry
Program.Sub.Clean_Load_Plan_TruckType.End

Program.Sub.ValidateLoad_ShipHold.Start
'6/1/26 BS - POR020: Check if any selected Load rows are on shipping hold
'Sets V.Global.bLoadHoldBlock = True if hold rows found, False otherwise
F.Intrinsic.Control.Try
V.Local.sFilterString.Declare
V.Local.sSel.Declare
V.Local.sError.Declare

V.Global.bLoadHoldBlock.Set(False)

F.Intrinsic.Control.If(V.Global.bIsPOR020,=,False)
	F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.EndIf

V.Local.sFilterString.Set("[SELECT] = 1 AND [SHP_HLD_FLAG] = True")
F.Data.DataView.Create("dtLoad","dvloadhold",22,V.Local.sFilterString,"")
F.Data.DataView.ToDataTable("dtLoad","dvloadhold","dtloadhold",True)
F.Data.DataTable.Select("dtloadhold","",V.Local.sSel)

F.Intrinsic.Control.If(V.Local.sSel,<>,"***NORETURN***")
	V.Global.bLoadHoldBlock.Set(True)
	F.Intrinsic.UI.Msgbox("Selected rows contain sales orders on shipping hold. Packing lists cannot be printed until the hold is removed.","Warning")
F.Intrinsic.Control.EndIf

F.Data.DataView.Close("dtLoad","dvloadhold")
F.Data.DataTable.Close("dtloadhold")

F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("ValidateLoad_ShipHold Error {0}: {1}",V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError,"ValidateLoad_ShipHold Error")
	V.Global.bLoadHoldBlock.Set(False)
F.Intrinsic.Control.EndTry
Program.Sub.ValidateLoad_ShipHold.End

Program.Sub.Click_Launch_PrintStagedForms.Start
v.Local.iRet.Declare(boolean)
'6/1/26 BS - POR020: Block if any selected rows are on shipping hold
F.Intrinsic.Control.CallSub(ValidateLoad_ShipHold)
F.Intrinsic.Control.If(V.Global.bLoadHoldBlock,=,True)
	F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.EndIf
F.Global.General.LaunchMenuTask(887,4,V.Local.iRet)
Program.Sub.Click_Launch_PrintStagedForms.End

Program.Sub.Click_Launch_StagedShip.Start
v.Local.iRet.Declare(boolean)	
F.Global.General.LaunchMenuTask(887,5,V.Local.iRet)
Program.Sub.Click_Launch_StagedShip.End

Program.Sub.Click_Print_PL.Start
Function.Intrinsic.Control.Try
v.Local.sFilterString.Declare
V.Local.sActiveFilter.Declare
v.Local.sError.Declare(String)
v.Local.sSel.Declare(String)
v.Local.sRet.Declare(String)
v.Local.i.Declare(Long)
v.Local.dPickDate.Declare(Date)
v.Local.sSQL.Declare(String)
v.Local.sQuery.Declare(String)
v.Local.iCnt.Declare
v.Local.sParam.Declare

'6/1/26 BS - POR020: Block if any selected rows are on shipping hold
F.Intrinsic.Control.CallSub(ValidateLoad_ShipHold)
F.Intrinsic.Control.If(V.Global.bLoadHoldBlock,=,True)
	F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.EndIf

'filter for selected rows
Function.Intrinsic.Control.BlockEvents
Function.Data.DataTable.AcceptChanges("dtLoad")
'verify that we have a checked value in SELECT and load is not 0. 
v.Local.sFilterString.Set("[SELECT] = 1 and [PACKING LIST] <> ''")
f.Data.DataView.Create("dtLoad","dvloadPL",22,v.Local.sFilterString,"")
f.Data.DataView.ToDataTableDistinct("dtload","dvloadPL","dtloadPL","PACKING LIST",)
F.Data.Datatable.Select("dtLoadPL","[PACKING LIST] <> ''",v.Local.sSel)

Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")	
		F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
		F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
			'Print packing list		
'			f.Intrinsic.String.Build("{1}!*!{1}!*!{1}!*!{1}!*!{1}!*!{1}!*!Y!*!{0}!*!{1}!*!{1};",v.DataTable.dtLoadPL(v.Local.sSel(v.Local.i)).PACKING LIST!FieldVal,"*!*ZDR*!*",V.Local.sParam)
'			f.Global.General.CallWrapperSync(910070,v.Local.sParam)
'12/30/24 -BS changed to used .NET callwrapper to print packing lists
			F.Global.Callwrapper.New("PL","Sales.Shipping.PrintPackingList")
			F.Global.Callwrapper.SetProperty("PL","CompanyCode",v.Caller.CompanyCode)
			F.Global.Callwrapper.SetProperty("PL","CallingProgram","CW")
			F.Global.Callwrapper.SetProperty("PL","PackingListNumber",v.DataTable.dtLoadPL(v.Local.sSel(v.Local.i)).PACKING LIST!FieldVal)
			F.Global.Callwrapper.SetProperty("PL","Staged",True)
			F.Global.CallWrapper.Run("PL")
		F.Intrinsic.Control.Next(v.Local.i)	
f.Intrinsic.Control.Else
	F.Intrinsic.UI.Msgbox("Please select rows from load with packing lists.  Click OK to Exit.","Warning")
Function.Intrinsic.Control.EndIf
f.Data.Datatable.Close("dtloadPL")
f.Data.DataView.Close("dtLoad","dvloadPL")
Function.Intrinsic.Control.UnBlockEvents
f.Intrinsic.Control.ExitSub
Function.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.CallSub(frmShip_UnLoad)	
Function.Intrinsic.Control.EndTry	
Program.Sub.Click_Print_PL.End

Program.Sub.Click_Print_PL_Certs.Start
Function.Intrinsic.Control.Try
v.Local.sFilterString.Declare(String,"")
v.Local.sError.Declare(String,"")
v.Local.sSel.Declare(String,"")
v.Local.i.Declare(Long,0)
v.Local.sSQL.Declare(String,"")
v.Local.sParam.Declare(String,"")
V.Local.sDefault.Declare(String,"")
V.Local.sValues.Declare(String,"")
V.Local.sRptID.Declare(String,"")
V.Local.iBol.Declare(Long,0)
V.Local.sPrinter.Declare(String,"")
V.Local.sExt.Declare(String,"")
V.Local.sCopyFile.Declare(String,"")
V.Local.sFile.Declare(String,"")
V.Local.sGrpID.Declare(String,"")
V.Local.sLinkID.Declare(String,"")
V.Local.iLinkID.Declare(Long,0)
V.Local.iHist.Declare(Long,0)
V.Local.iDoc.Declare(Long,0)
V.Local.sPart.Declare(String,"")
V.Local.sLoc.Declare(String,"")
V.Local.sLot.Declare(String,"")
V.Local.sHeat.Declare(String,"")
V.Local.sBin.Declare(String,"")
V.Local.sSerial.Declare(String,"")
V.Local.sJob.Declare(String,"")
V.Local.sSuff.Declare(String,"")

V.Local.iBIRunID.Declare
V.Local.iLogID.Declare
V.Local.iRet.Declare

'6/1/26 BS - POR020: Block if any selected rows are on shipping hold
F.Intrinsic.Control.CallSub(ValidateLoad_ShipHold)
F.Intrinsic.Control.If(V.Global.bLoadHoldBlock,=,True)
	F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.EndIf
				
V.Local.sDefault.Set(V.Printer.DefaultPrinter)

'ROGER
'filter for selected rows
Function.Intrinsic.Control.BlockEvents
Function.Data.DataTable.AcceptChanges("dtLoad")
'verify that we have a checked value in SELECT and load is not 0. 
v.Local.sFilterString.Set("[SELECT] = 1 and [PACKING LIST] <> ''")
f.Data.DataView.Create("dtLoad","dvloadPL",22,v.Local.sFilterString,"")
f.Data.DataView.ToDataTableDistinct("dtload","dvloadPL","dtloadPL","PACKING LIST",)
F.Data.Datatable.Select("dtLoadPL","[PACKING LIST] <> ''",v.Local.sSel)

Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")	
	F.Data.Datatable.Create("dtLotBin",True)
	F.Data.Datatable.AddColumn("dtLotBin","Part",String)
	F.Data.Datatable.AddColumn("dtLotBin","Locn",String)
	F.Data.Datatable.AddColumn("dtLotBin","Lot",String)
	F.Data.Datatable.AddColumn("dtLotBin","Bin",String)
	F.Data.Datatable.AddColumn("dtLotBin","Heat",String)
	F.Data.Datatable.AddColumn("dtLotBin","Serial",String)
	
	F.Data.Datatable.Create("dtDoc",True)
	F.Data.Datatable.AddColumn("dtDoc","Document",String)
	
	F.Intrinsic.Printer.SelectPrinterDialog
	f.Intrinsic.Control.If(v.Ambient.PRINTERDIALOGSELECTION,<>,"***CANCEL***")
		V.Local.sPrinter.Set(v.Ambient.PRINTERDIALOGSELECTION)
		F.Intrinsic.Printer.SetDefaultPrinter(V.Local.sPrinter)
		F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
		
		F.ODBC.Connection!ConP.OpenCompanyConnection
		
		F.ODBC.Connection!ConP.ExecuteAndReturn("Select GRP_ID From ATG_DOC_GRP Where rtrim(ucase(GRP_NAME)) = 'CERTS'",V.Local.sGrpID)
		
		F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound,1)
			F.Intrinsic.String.Build("Delete From BI_PACKING_LIST Where Terminal = '{0}'",V.Caller.Terminal,V.Local.sSQL)
			F.ODBC.Connection!ConP.Execute(V.Local.sSQL)

			'Print packing list		
			F.Intrinsic.String.Concat("","!*!","","!*!!*!N!*!Y!*!N!*!Y!*!",v.DataTable.dtLoadPL(v.Local.sSel(v.Local.i)).PACKING LIST!FieldVal,"!*!!*!!*!|~|CRYSTAL-OVERRIDE|~|",V.Local.sParam)
			F.Global.General.CallWrapperSyncBIO(910070,V.Local.sParam)
			
			F.Intrinsic.String.Build("select Top 1 Rptid from BI_PACKING_LIST Where Pck_no = '{0}' and Terminal = '{1}'",v.DataTable.dtLoadPL(v.Local.sSel(v.Local.i)).PACKING LIST!FieldVal,V.Caller.Terminal,V.Local.sSQL)
			
			F.ODBC.Connection!ConP.ExecuteAndReturn(V.Local.sSQL,V.Local.sRptID)
			
			V.Local.sParam.Set("Terminal*!*REPORTID*!*PCKNO")
			F.Intrinsic.String.Build("{0}*!*{1}*!*{2}",V.Caller.Terminal,V.Local.sRptID,"Y",V.Local.sValues)

			F.Intrinsic.Control.If(V.Local.sGrpID.Trim,<>,"")
				F.Intrinsic.String.Build("Select Pck_No,Order_No, Order_Line, Order_Seq, Part, Locn, Lot, Bin, Heat, Serial From BOL_Pack_DTL Where Pck_No = '{0}' Group by Pck_No,Order_No, Order_Line, Order_Seq, Part, Locn, Lot, Bin, Heat, Serial",v.DataTable.dtLoadPL(v.Local.sSel(v.Local.i)).PACKING LIST!FieldVal,V.Local.sSQL)
				F.Data.Datatable.CreateFromSQL("PackLotBin",ConP,V.Local.sSQL,True)
				
				F.Intrinsic.Control.For(V.Local.iBol,0,V.DataTable.PackLotBin.RowCount--,1)
					V.Local.sJob.Set("")
					V.Local.sSuff.Set("")
					F.Intrinsic.String.RPad(V.DataTable.PackLotBin(V.Local.iBol).Part!FieldValTrim," ",20,V.Local.sPart)
					F.Intrinsic.String.RPad(V.DataTable.PackLotBin(V.Local.iBol).Locn!FieldValTrim," ",2,V.Local.sLoc)
					F.Intrinsic.String.RPad(V.DataTable.PackLotBin(V.Local.iBol).Lot!FieldValTrim," ",15,V.Local.sLot)
					F.Intrinsic.String.RPad(V.DataTable.PackLotBin(V.Local.iBol).Bin!FieldValTrim," ",6,V.Local.sBin)
					F.Intrinsic.String.RPad(V.DataTable.PackLotBin(V.Local.iBol).Heat!FieldValTrim," ",15,V.Local.sHeat)
					F.Intrinsic.String.RPad(V.DataTable.PackLotBin(V.Local.iBol).Serial!FieldValTrim," ",30,V.Local.sSerial)
					F.Data.Datatable.AddRow("dtLotBin","Part",v.Local.sPart,"Locn",v.Local.sLoc,"Lot",V.Local.sLot,"Bin",V.Local.sBin,"Heat",V.Local.sHeat,"Serial",V.Local.sSerial)
					
					F.Intrinsic.Control.If(V.Local.sLot.Trim,<>,"")
						F.Intrinsic.String.Build("SELECT DISTINCT CODE_TRANSACTION,JOB,SUFFIX,SEQUENCE, PART,LOCATION,LOT,BIN,HEAT,SERIAL_NUMBER FROM V_ITEM_HISTORY WHERE LOT = '{0}' AND CODE_TRANSACTION IN ('J52','J55','S52','C52','R10','R11') and Reversed <> 'R';",V.Local.sLot,V.Local.sSQL)
						F.Data.Datatable.CreateFromSQL("ItemHist",ConP,V.Local.sSQL,True)
						F.Intrinsic.Control.For(V.Local.iHist,0,V.DataTable.ItemHist.RowCount--,1)
							F.Intrinsic.String.RPad(V.DataTable.ItemHist(V.Local.iHist).Part!FieldValTrim," ",20,V.Local.sPart)
							F.Intrinsic.String.RPad(V.DataTable.ItemHist(V.Local.iHist).Location!FieldValTrim," ",2,V.Local.sLoc)
							F.Intrinsic.String.RPad(V.DataTable.ItemHist(V.Local.iHist).Lot!FieldValTrim," ",15,V.Local.sLot)
							F.Intrinsic.String.RPad(V.DataTable.ItemHist(V.Local.iHist).Bin!FieldValTrim," ",6,V.Local.sBin)
							F.Intrinsic.String.RPad(V.DataTable.ItemHist(V.Local.iHist).Heat!FieldValTrim," ",15,V.Local.sHeat)
							F.Intrinsic.String.RPad(V.DataTable.ItemHist(V.Local.iHist).Serial_Number!FieldValTrim," ",30,V.Local.sSerial)
							F.Data.Datatable.AddRow("dtLotBin","Part",v.Local.sPart,"Locn",v.Local.sLoc,"Lot",V.Local.sLot,"Bin",V.Local.sBin,"Heat",V.Local.sHeat,"Serial",V.Local.sSerial)
							
							F.Intrinsic.Control.If(V.DataTable.ItemHist(V.Local.iHist).SEQUENCE!FieldVal,>=,990000)
								F.Intrinsic.Control.SelectCase(V.DataTable.ItemHist(V.Local.iHist).CODE_TRANSACTION!FieldVal)
									F.Intrinsic.Control.CaseAny("J52","S52","C52")
										V.Local.sJob.Set(V.DataTable.ItemHist(V.Local.iHist).Job!FieldValTrim)
										V.Local.sSuff.Set(V.DataTable.ItemHist(V.Local.iHist).Suffix!FieldValTrim)
								F.Intrinsic.Control.EndSelect
							F.Intrinsic.Control.EndIf
						F.Intrinsic.Control.Next(V.Local.iHist)
						F.Data.Datatable.Close("ItemHist")
						
						F.Intrinsic.Control.If(V.Local.sJob.Trim,<>,"")
							'Check if Job Suffix is a Bom
							F.Intrinsic.String.Build("Select Parent_WO, Parent_Suffix_Parent From Job_Header Where Job = '{0}'",V.Local.sJob,V.Local.sSQL)
							F.Data.Datatable.CreateFromSQL("JobSuf",ConP,V.Local.sSQL,True)
							F.Intrinsic.Control.For(V.Local.iDoc,0,V.DataTable.JobSuf.RowCount--,1)
								F.Intrinsic.String.Build("SELECT DISTINCT CODE_TRANSACTION,JOB,SUFFIX,SEQUENCE, PART,LOCATION,LOT,BIN,HEAT,SERIAL_NUMBER FROM V_ITEM_HISTORY WHERE JOB = '{0}' AND SUFFIX = '{1}' AND SEQUENCE < '990000' AND CODE_TRANSACTION IN ('J52','J55','S52','C52','R10','R11') and Reversed <> 'R';",V.Local.sJob.Trim,V.Local.sSuff.Trim,V.Local.sSQL)
								F.Data.Datatable.CreateFromSQL("ItemHist",ConP,V.Local.sSQL,True)
								F.Intrinsic.Control.For(V.Local.iHist,0,V.DataTable.ItemHist.RowCount--,1)
									F.Intrinsic.String.RPad(V.DataTable.ItemHist(V.Local.iHist).Part!FieldValTrim," ",20,V.Local.sPart)
									F.Intrinsic.String.RPad(V.DataTable.ItemHist(V.Local.iHist).Location!FieldValTrim," ",2,V.Local.sLoc)
									F.Intrinsic.String.RPad(V.DataTable.ItemHist(V.Local.iHist).Lot!FieldValTrim," ",15,V.Local.sLot)
									F.Intrinsic.String.RPad(V.DataTable.ItemHist(V.Local.iHist).Bin!FieldValTrim," ",6,V.Local.sBin)
									F.Intrinsic.String.RPad(V.DataTable.ItemHist(V.Local.iHist).Heat!FieldValTrim," ",15,V.Local.sHeat)
									F.Intrinsic.String.RPad(V.DataTable.ItemHist(V.Local.iHist).Serial_Number!FieldValTrim," ",30,V.Local.sSerial)
									F.Data.Datatable.AddRow("dtLotBin","Part",v.Local.sPart,"Locn",v.Local.sLoc,"Lot",V.Local.sLot,"Bin",V.Local.sBin,"Heat",V.Local.sHeat,"Serial",V.Local.sSerial)
								F.Intrinsic.Control.Next(V.Local.iHist)
								F.Data.Datatable.Close("ItemHist")
							F.Intrinsic.Control.Next(V.Local.iDoc)
							F.Data.Datatable.Close("JobSuf")
						F.Intrinsic.Control.EndIf
					F.Intrinsic.Control.EndIf
				F.Intrinsic.Control.Next(V.Local.iBol)
				
				F.Data.Datatable.Close("PackLotBin")
				
				F.Data.DataView.Create("dtLotBin","Temp",22,"","")
				F.Data.DataView.ToDataTableDistinct("dtLotBin","Temp","dtLBHS","Part*!*Locn*!*Lot*!*Bin*!*Heat*!*Serial",True)
				F.Data.DataView.Close("dtLotBin","Temp")
				F.Data.Datatable.DeleteRow("dtLotBin")
				F.Data.Datatable.AcceptChanges("dtLotBin")
				
				F.Intrinsic.Control.For(V.Local.iDoc,0,V.DataTable.dtLBHS.RowCount--,1)
					F.Intrinsic.String.Build("{0}{1}{2}{3}{4}{5}",V.DataTable.dtLBHS(V.Local.iDoc).Part!FieldVal,V.DataTable.dtLBHS(V.Local.iDoc).Locn!FieldVal,V.DataTable.dtLBHS(V.Local.iDoc).Lot!FieldVal,V.DataTable.dtLBHS(V.Local.iDoc).Bin!FieldVal,V.DataTable.dtLBHS(V.Local.iDoc).Heat!FieldVal,V.DataTable.dtLBHS(V.Local.iDoc).Serial!FieldVal,V.Local.sLinkID)
					F.Global.DocumentControl.GetLinkID(V.Local.sLinkID,31,V.Local.iLinkID)
					F.Intrinsic.String.Build("select rtrim(Path)+rtrim(File) as Document from ATG_DOC_ASSOC Where Link_ID = {0} and Grp_ID = {1};",V.Local.iLinkID,V.Local.sGrpID.Long,V.Local.sSQL)
					F.Data.Datatable.CreateFromSQL("TempDoc",ConP,V.Local.sSQL)
					F.Intrinsic.Control.If(V.DataTable.TempDoc.RowCount--,<>,-1)
						F.Data.Datatable.Merge("TempDoc","dtDoc",False,2)
					F.Intrinsic.Control.EndIf
					F.Data.Datatable.Close("TempDoc")
				F.Intrinsic.Control.Next(V.Local.iDoc)
				
				F.Data.Datatable.Close("dtLBHS")
				
				F.Intrinsic.Control.If(V.Local.sRptID.Trim,=,"")
					V.Local.sRptID.Set("000051")
				F.Intrinsic.Control.ElseIf(V.Local.sRptID.Trim,=,"000110")
					F.Intrinsic.String.Build("{0}*!*SHIPLABEL",V.Local.sParam,V.Local.sParam)
					F.Intrinsic.String.Build("{0}*!*Shipping No.",V.Local.sValues,V.Local.sValues)
				F.Intrinsic.Control.EndIf
				
				F.Intrinsic.String.Split(V.Local.sParam,"*!*",V.Local.sParam)
				F.Intrinsic.String.Split(V.Local.sValues,"*!*",V.Local.sValues)

				F.Global.BI.PrintReport(V.Local.sRptID.Long,3,V.Local.sParam,V.Local.sValues,V.Local.sPrinter,True)
				
				F.Intrinsic.Control.For(V.Local.iDoc,0,V.DataTable.dtDoc.RowCount--,1)
					F.Intrinsic.File.GetExtensionComponent(V.DataTable.dtDoc(V.Local.iDoc).Document!FieldValTrim,V.Local.sExt)
					F.Intrinsic.Control.If(V.Local.sPrinter.UCase,=,"MICROSOFT PRINT TO PDF","AND",V.Local.sExt.UCase,=,"PDF")
						'Copying file to Temp and open file since and error will occur trying to take a pdf to a pdf
						F.Intrinsic.File.GetFileNameFromFQN(V.DataTable.dtDoc(V.Local.iDoc).Document!FieldValTrim,V.Local.sFile)
						F.Intrinsic.String.Build("{0}\{1}",V.Caller.LocalGSSTempDir,V.Local.sFile,V.Local.sCopyFile)
						F.Intrinsic.File.CopyFile(V.DataTable.dtDoc(V.Local.iDoc).Document!FieldValTrim,V.Local.sCopyFile)
						F.Intrinsic.task.ShellExec(V.Caller.Handle,"OPEN",V.Local.sCopyFile,"","",5)
					F.Intrinsic.Control.Else
						'printing to the default printer setup
						F.Intrinsic.task.ShellExec(V.Caller.Handle,"PRINT",V.DataTable.dtDoc(V.Local.iDoc).Document!FieldValTrim,"","",5)
					F.Intrinsic.Control.EndIf
				F.Intrinsic.Control.Next(V.Local.iDoc)
				
				F.Data.Datatable.DeleteRow("dtDoc")
				F.Data.Datatable.AcceptChanges("dtDoc")
			F.Intrinsic.Control.EndIf
			
		F.Intrinsic.Control.Next(v.Local.i)
		
		F.ODBC.Connection!ConP.Close
		
		'5/20/26 BS - Auto-chain PO Pack Report for outside PO lines (lot/bin suppressed, direct print)
		F.Intrinsic.Control.If(v.Global.b7551)
			V.Global.sPOPackPrinter.Set(V.Local.sPrinter)
			V.Global.bSuppressPOPackLotBin.Set(True)
			F.Intrinsic.Control.CallSub(PrintPOPackForLoad)
			V.Global.bSuppressPOPackLotBin.Set(False)
			V.Global.sPOPackPrinter.Set("")
		F.Intrinsic.Control.EndIf
		
	F.Intrinsic.Control.Else
		F.Intrinsic.UI.Msgbox("No Printer Selected and Print is Canceled.  Click OK to Exit.","Warning")
	f.Intrinsic.Control.EndIf
	
	F.Data.Datatable.Close("dtDoc")
	F.Data.Datatable.Close("dtLotBin")
f.Intrinsic.Control.Else
	F.Intrinsic.UI.Msgbox("Please select rows from load with packing lists.  Click OK to Exit.","Warning")
Function.Intrinsic.Control.EndIf

F.Intrinsic.Printer.SetDefaultPrinter(V.Local.sDefault)

f.Data.Datatable.Close("dtloadPL")
f.Data.DataView.Close("dtLoad","dvloadPL")
Function.Intrinsic.Control.UnBlockEvents

Function.Intrinsic.Control.Catch
