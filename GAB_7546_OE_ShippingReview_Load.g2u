Gui.frmSplitLine.GsGCSplit.SetGridViewProperty("gvSplit","AllowFilter",False)
Gui.frmSplitLine.GsGCSplit.SetGridViewProperty("gvSplit","OptionsViewColumnAutoWidth",False)
Gui.frmSplitLine.GsGCSplit.SetGridViewProperty("gvSplit","OptionsDetailShowDetailTabs",False)
Gui.frmSplitLine.GsGCSplit.SetGridViewProperty("gvSplit","OptionsViewShowGroupPanel",False)

