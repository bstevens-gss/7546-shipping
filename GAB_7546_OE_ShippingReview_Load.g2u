	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.CallSub(frmShip_UnLoad)	
Function.Intrinsic.Control.EndTry
Program.Sub.Load_0_remove.End

Program.Sub.Load_Override_Validate.Start
Function.Intrinsic.Control.Try
v.Local.sFilterString.Declare
V.Local.sActiveFilter.Declare
v.Local.sError.Declare(String)
v.Local.sSel.Declare(String)
v.Local.sRet.Declare(String)
v.Local.i.Declare(Long)
v.Local.dPickDate.Declare(Date)
v.Local.sSQL.Declare(String)
v.Local.sQuery.Declare(String)
v.Local.iCnt.Declare
v.Local.btest.Declare

'filter for selected rows
Function.Intrinsic.Control.BlockEvents
Function.Data.DataTable.AcceptChanges("dtLoad")
'verify that we have a checked value in SELECT and load is not 0. 
F.Data.Datatable.Select("dtLoad","SELECT = 1 and [LOAD NUMBER] <> 0 and [LOAD NUMBER] <> 9999 and [VALIDATED] = 0 and [PACKING LIST]<>''",v.Local.sSel)

Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")	
		F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
		F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
			'update gridview with ready to pick flag
			F.Data.Datatable.SetValue("dtLoad",v.Local.sSel(v.Local.i),"SELECT",1,"VALIDATED",1)
			F.Intrinsic.String.Build("UPDATE BOL_PACK_DTL Set SHIP_VALIDATE = 1 Where PCK_NO = '{2}' AND ORDER_NO = '{0}' AND ORDER_LINE = '{1}'",v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_NO!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_LINE!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).Packing List!FieldVal,v.Local.sSQL)
			f.ODBC.Connection!con.Execute(v.Local.sSQL)			
		F.Intrinsic.Control.Next(v.Local.i)
		v.Local.btest.Set(True)
f.Intrinsic.Control.Else
	v.Local.btest.Set(False)
F.Intrinsic.Control.EndIf		
'update outside PO lines as VALIDATED to user_4

F.Data.Datatable.Select("dtLoad","SELECT = 1 and [LOAD NUMBER] <> 0 and [LOAD NUMBER] <> 9999 and [VALIDATED] = 0 and [Carrier Load Number]<>'' AND [OPOL] <> ''",v.Local.sSel)

Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")	
		F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
		F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
			'update gridview with gridview with ready to pick flag
			F.Data.Datatable.SetValue("dtLoad",v.Local.sSel(v.Local.i),"SELECT",1,"VALIDATED",1)
			F.Intrinsic.String.Build("UPDATE PO_LINES Set USER_4 = 'TRUE' Where USER_1 = '{2}' AND PURCHASE_ORDER = '{0}' AND RECORD_NO = '{1}'",v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_NO!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_LINE!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).Carrier Load Number!FieldVal,v.Local.sSQL)
			f.ODBC.Connection!con.Execute(v.Local.sSQL)			
		F.Intrinsic.Control.Next(v.Local.i)
		v.Local.btest.Set(True)
f.Intrinsic.Control.Else
	'v.Local.btest.Set(False)
f.Intrinsic.Control.EndIf

f.Intrinsic.Control.If(v.Local.btest,=,False)
	F.Intrinsic.UI.Msgbox("Please select rows where load # is not 0 OR 9999 and not currently flagged as validated and have a staged packing list.  Click OK to Exit.","No rows selected to flag as validated.")
Function.Intrinsic.Control.EndIf
Function.Intrinsic.Control.UnBlockEvents
f.Intrinsic.Control.ExitSub
Function.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.CallSub(frmShip_UnLoad)	
Function.Intrinsic.Control.EndTry
Program.Sub.Load_Override_Validate.End

