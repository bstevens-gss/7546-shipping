Program.Sub.Click_Load_Ship.Start
Function.Intrinsic.Control.Try
v.Local.sFilterString.Declare
V.Local.sActiveFilter.Declare
v.Local.sError.Declare(String)
v.Local.sSel.Declare(String)
v.Local.sRet.Declare(String)
v.Local.i.Declare(Long)
v.Local.dPickDate.Declare(Date)
v.Local.sSQL.Declare(String)
v.Local.sQuery.Declare(String)
v.Local.iCnt.Declare
v.Local.sParam.Declare
V.Local.sTransIDNew.Declare
V.Local.sUserID.Declare

v.Local.sUserID.Set(v.Caller.user)

'validate if any rows selected are validated but missing packing list
v.Local.sFilterString.Set("[SELECT] = 1  AND [LOAD NUMBER] <> 0 AND [LOAD NUMBER] <> 9999 AND [PACKING LIST]='' AND [ORDER_SUFFIX] <> 'P'")
f.Data.DataView.Create("dtLoad","dvloadshipy",22,v.Local.sFilterString,"")
	f.Data.DataView.ToDataTable("dtload","dvloadshipy","dtloadshipy",True)
	F.Data.Datatable.Select("dtloadshipy","",v.Local.sSel)	
	Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")
		F.Intrinsic.UI.Msgbox("Rows exist in load(s) that have no packing list staged.  Click OK to Exit.","Warning")
		f.Data.DataView.Close("dtLoad","dvloadshipy")
		f.Data.Datatable.Close("dtloadshipy")
		v.Local.sSel.Set("")
		f.Intrinsic.Control.ExitSub
	Function.Intrinsic.Control.EndIf
	f.Data.DataView.Close("dtLoad","dvloadshipy")
	f.Data.Datatable.Close("dtloadshipy")	

'validate if any rows selected are not validated
v.Local.sFilterString.Set("[SELECT] = 1 AND [VALIDATED]=0")
f.Data.DataView.Create("dtLoad","dvloadshipx",22,v.Local.sFilterString,"")
	f.Data.DataView.ToDataTable("dtload","dvloadshipx","dtloadshipx",True)
	F.Data.Datatable.Select("dtloadshipx","[VALIDATED]=0",v.Local.sSel)	
	Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")	
		F.Intrinsic.UI.Msgbox("Rows exist in load(s) that are not yet flagged as validated.  Click OK to Exit.","Warning")
		f.Data.DataView.Close("dtLoad","dvloadshipx")
		f.Data.Datatable.Close("dtloadshipx")
		v.Local.sSel.Set("")
		f.Intrinsic.Control.ExitSub
	Function.Intrinsic.Control.EndIf
	f.Data.DataView.Close("dtLoad","dvloadshipx")
	f.Data.Datatable.Close("dtloadshipx")
	
'validate if any rows selected do not have load ship date set and not 1/1/1900
v.Local.sFilterString.Set("[SELECT] = 1 AND [SHIP DATE] = #1/1/1900#")
f.Data.DataView.Create("dtLoad","dvloadshipdate",22,v.Local.sFilterString,"")
	f.Data.DataView.ToDataTable("dtload","dvloadshipdate","dtloadshipdate",True)
	F.Data.Datatable.Select("dtloadshipdate","[SHIP DATE]=#1/1/1900#",v.Local.sSel)	
	Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")	
		F.Intrinsic.UI.Msgbox("Rows exist in load(s) without load ship date first being set.  Click OK to Exit.","Warning")
		f.Data.DataView.Close("dtLoad","dvloadshipdate")
		f.Data.Datatable.Close("dtloadshipdate")
		v.Local.sSel.Set("")
		f.Intrinsic.Control.ExitSub
	Function.Intrinsic.Control.EndIf
	f.Data.DataView.Close("dtLoad","dvloadshipdate")
	f.Data.Datatable.Close("dtloadshipdate")	
	
'filter for selected rows to process
Function.Intrinsic.Control.BlockEvents
Function.Data.DataTable.AcceptChanges("dtLoad")
'verify that we have a checked value in SELECT and load is not 0 or 9999 AND only sales orders. 
v.Local.sFilterString.Set("[SELECT] = 1 AND [LOAD NUMBER] <> 0 AND [LOAD NUMBER] <> 9999 AND [PACKING LIST] <> '' AND [ORDER_SUFFIX] <> 'P' AND [VALIDATED]=1")
f.Data.DataView.Create("dtLoad","dvloadship",22,v.Local.sFilterString,"")

'02/05/26 validate if any rows are staged with qty but no matching allocated qty
f.Data.DataView.ToDataTableDistinct("dtload","dvloadship","dtloadShipv","PACKING LIST",True)
F.Data.Datatable.Select("dtLoadShipv","[PACKING LIST] <> ''",v.Local.sSel)
Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")	
		F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
	F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)	
		f.Intrinsic.Control.SelectCase(v.Global.sAllocType)	
			f.Intrinsic.Control.Case("HEAT")	
				F.Intrinsic.String.Build("SELECT s.ordersuffixline,s.qty_shipped,COALESCE(im.qty_alloc,0) AS qty_alloc FROM (SELECT a.order_no+'-'+RIGHT(RTRIM(a.order_suffix),3)+'-'+LEFT(a.order_rec,3) AS ordersuffixline,SUM(a.qty_shipped) AS qty_shipped FROM v_SHIPMENT_lines a WHERE a.flag_bom<>'Y' AND a.flag_cogs<>'Y' AND a.line_type<>'D' AND a.pck_no='{0}' AND a.ln_shp_stat=0 GROUP BY a.order_no+'-'+RIGHT(RTRIM(a.order_suffix),3)+'-'+LEFT(a.order_rec,3)) s LEFT JOIN (SELECT RTRIM(b.heat) AS heat,SUM(COALESCE(CAST(b.quantity AS DECIMAL(18,4)),0)) AS qty_alloc FROM item_master b GROUP BY RTRIM(b.heat)) im ON s.ordersuffixline=im.heat WHERE s.qty_shipped<>COALESCE(im.qty_alloc,0); ",v.DataTable.dtLoadShipv(v.Local.sSel(v.Local.i)).PACKING LIST!FieldVal,V.Local.sSQL)
			f.Intrinsic.Control.Case("SERIAL_NUMBER")	
				F.Intrinsic.String.Build("SELECT s.ordersuffixline,s.qty_shipped,COALESCE(im.qty_alloc,0) AS qty_alloc FROM (SELECT a.order_no+'-'+RIGHT(RTRIM(a.order_suffix),3)+'-'+LEFT(a.order_rec,3) AS ordersuffixline,SUM(a.qty_shipped) AS qty_shipped FROM v_SHIPMENT_lines a WHERE a.flag_bom<>'Y' AND a.flag_cogs<>'Y' AND a.line_type<>'D' AND a.pck_no='{0}' AND a.ln_shp_stat=0 GROUP BY a.order_no+'-'+RIGHT(RTRIM(a.order_suffix),3)+'-'+LEFT(a.order_rec,3)) s LEFT JOIN (SELECT RTRIM(b.serial_number) AS serial_number,SUM(COALESCE(CAST(b.quantity AS DECIMAL(18,4)),0)) AS qty_alloc FROM item_master b GROUP BY RTRIM(b.serial_number)) im ON s.ordersuffixline=im.serial_number WHERE s.qty_shipped<>COALESCE(im.qty_alloc,0); ",v.DataTable.dtLoadShipv(v.Local.sSel(v.Local.i)).PACKING LIST!FieldVal,V.Local.sSQL)
			f.Intrinsic.Control.Case("LOT")	
				F.Intrinsic.String.Build("SELECT s.ordersuffixline,s.qty_shipped,COALESCE(im.qty_alloc,0) AS qty_alloc FROM (SELECT a.order_no+'-'+RIGHT(RTRIM(a.order_suffix),3)+'-'+LEFT(a.order_rec,3) AS ordersuffixline,SUM(a.qty_shipped) AS qty_shipped FROM v_SHIPMENT_lines a WHERE a.flag_bom<>'Y' AND a.flag_cogs<>'Y' AND a.line_type<>'D' AND a.pck_no='{0}' AND a.ln_shp_stat=0 GROUP BY a.order_no+'-'+RIGHT(RTRIM(a.order_suffix),3)+'-'+LEFT(a.order_rec,3)) s LEFT JOIN (SELECT RTRIM(b.lot) AS lot,SUM(COALESCE(CAST(b.quantity AS DECIMAL(18,4)),0)) AS qty_alloc FROM item_master b GROUP BY RTRIM(b.lot)) im ON s.ordersuffixline=im.lot WHERE s.qty_shipped<>COALESCE(im.qty_alloc,0); ",v.DataTable.dtLoadShipv(v.Local.sSel(v.Local.i)).PACKING LIST!FieldVal,V.Local.sSQL)
			f.Intrinsic.Control.Case("NONE")
				V.Local.sSQL.Set("")
		f.Intrinsic.Control.EndSelect
		F.Intrinsic.Control.If(V.Local.sSQL,<>,"")
			F.Data.DataTable.CreateFromSQL("dtvalidateallocated","con",V.Local.sSQL)
			F.Intrinsic.Control.If(V.DataTable.dtvalidateallocated.RowCount,=,0)
			 'continue to next pl
			 f.Data.Datatable.Close("dtvalidateallocated")
			f.Intrinsic.Control.else
				F.Intrinsic.UI.Msgbox("selected packing lists in load need to be reviewed as there are staged qty not fully allocated.  Click OK to Exit.","Warning")
				f.Data.Datatable.Close("dtvalidateallocated")
				f.Data.Datatable.Close("dtloadShipv")
				f.Data.DataView.Close("dtLoad","dvloadShip")
				Function.Intrinsic.Control.UnBlockEvents
				F.Intrinsic.Control.If(V.Screen.frmShip!chkdisablerefresh.Value,=,0)
					F.Intrinsic.Control.CallSub(cmdrefresh_click)					
				F.Intrinsic.Control.EndIf
				f.Intrinsic.Control.ExitSub
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.Next(v.Local.i)	
f.Intrinsic.Control.endif
f.Data.Datatable.Close("dtloadShipv")

f.Data.DataView.ToDataTable("dtload","dvloadship","dtloadship0",True)
v.local.iCnt.Set(0)	
F.Intrinsic.Control.For(V.Local.iCnt,0,v.DataTable.dtloadship0.RowCount--,1)
	'Flag load plan record as shipped/picked
	F.Intrinsic.String.Build("update load_plan set shipped = 1,picked = 1 where order_no = '{0}' and order_line = '{1}' ",V.DataTable.dtloadship0(V.Local.iCnt).ORDER_NO!FieldVal,V.DataTable.dtloadship0(V.Local.iCnt).ORDER_LINE!FieldVal,V.Local.sSQL)
	F.ODBC.Connection!Con.Execute(V.Local.sSQL)	
	'02/23/26
	'update order_suffix to current_order_suffix + 1 for all unshipped/pending order lines that match sales order shipped
	F.Intrinsic.String.Build("UPDATE load_plan SET order_suffix = CASE WHEN (CAST('{1}' AS INTEGER) + 1) < 10 THEN '000' + CAST((CAST('{1}' AS INTEGER) + 1) AS VARCHAR(1)) WHEN (CAST('{1}' AS INTEGER) + 1) < 100 THEN '00' + CAST((CAST('{1}' AS INTEGER) + 1) AS VARCHAR(2)) WHEN (CAST('{1}' AS INTEGER) + 1) < 1000 THEN '0' + CAST((CAST('{1}' AS INTEGER) + 1) AS VARCHAR(3)) ELSE CAST((CAST('{1}' AS INTEGER) + 1) AS VARCHAR(4)) END WHERE shipped = 0 AND order_no = '{0}' ",V.DataTable.dtloadship0(V.Local.iCnt).ORDER_NO!FieldVal,V.DataTable.dtloadship0(V.Local.iCnt).CURRENT_ORDER_SUFFIX!FieldVal,V.Local.sSQL)
	F.ODBC.Connection!Con.Execute(V.Local.sSQL)	
F.Intrinsic.Control.Next(V.Local.iCnt)	

'verify that we have a checked value in SELECT and load is not 0 or 9999 AND ORDER_SUFFIX = 'P'. 
v.Local.sFilterString.Set("[SELECT] = 1 AND [LOAD NUMBER] <> 0 AND [LOAD NUMBER] <> 9999 AND [ORDER_SUFFIX] = 'P' AND [VALIDATED]=1")
f.Data.DataView.Create("dtLoad","dvloadshipOSP",22,v.Local.sFilterString,"")

f.Data.DataView.ToDataTable("dtload","dvloadshipOSP","dtloadshipOSP",True)
v.local.iCnt.Set(0)	
F.Intrinsic.Control.For(V.Local.iCnt,0,v.DataTable.dtloadshipOSP.RowCount--,1)
	'Flag load plan record as shipped/picked
	F.Intrinsic.String.Build("update load_plan set shipped = 1,picked = 1 where order_no = '{0}' and order_line = '{1}' and load_no = {2} ",V.DataTable.dtloadshipOSP(V.Local.iCnt).ORDER_NO!FieldVal,V.DataTable.dtloadshipOSP(V.Local.iCnt).ORDER_LINE!FieldVal,V.DataTable.dtloadshipOSP(V.Local.iCnt).LOAD NUMBER!FieldVal,V.Local.sSQL)
	F.ODBC.Connection!Con.Execute(V.Local.sSQL)
	'update PO_LINES.USER_5 with load# | Shipped Date
	F.Intrinsic.String.Build("update po_lines set USER_5 = '{2}'+' | '+'{3}' where purchase_order = '{0}' and record_no = '{1}' and po_type = 'O'",V.DataTable.dtloadshipOSP(V.Local.iCnt).ORDER_NO!FieldVal,V.DataTable.dtloadshipOSP(V.Local.iCnt).ORDER_LINE!FieldVal,V.DataTable.dtloadshipOSP(V.Local.iCnt).LOAD NUMBER!FieldVal,V.DataTable.dtloadshipOSP(V.Local.iCnt).Ship Date!FieldVal,V.Local.sSQL)
	F.ODBC.Connection!Con.Execute(V.Local.sSQL)	
F.Intrinsic.Control.Next(V.Local.iCnt)
f.Data.DataView.Close("dtLoad","dvloadShipOSP")
f.Data.Datatable.Close("dtloadshipOSP")

f.Data.DataView.ToDataTableDistinct("dtload","dvloadship","dtloadShip","PACKING LIST",)
F.Data.Datatable.Select("dtLoadShip","[PACKING LIST] <> ''",v.Local.sSel)

Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")	
		F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)			
		F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
			'Ship staged packing lists				
			'WRITE S40 for packing list			
			'Get Next Transaction ID
			F.ODBC.Connection!Con.ExecuteAndReturn("select TOP 1 RIGHT(CONCAT('000000000',CAST(TRANS_ID AS INT)+1),9) AS TRANS_ID from WIRELESS_HDR ORDER BY TRANS_ID DESC",V.Local.sTransIDNew)
			F.Intrinsic.String.LPad(V.Local.sTransIDNew,"0",9,V.Local.sTransIDNew)
			
			'WRITE S40 for packing list TO WIRELESS TABLES			
			'WRITE TO WIRELESS_HDR
			F.Intrinsic.String.Build("insert into WIRELESS_HDR (TRANS_ID,TRANS_TYPE,ATTEMPTED_DATE,ATTEMPTED_TIME,USER_ID,BATCH,ATTEMPTED_FLAG) values ('{0}','S40','00000000','00000000','{1}',0,'Y')",V.Local.stransIDnew,V.Local.sUserID,V.Local.sSQL)
			F.ODBC.Connection!Con.Execute(V.Local.sSQL)
			
			'WRITE TO WIRELESS_LINE			
			'sTransIDNew,'0000','S40',sPL			
			F.Intrinsic.String.Build("insert into WIRELESS_LINE (TRANS_ID,SEQ,TRANS_TYPE,FIELD_1,ERROR_ID) values ('{0}','0000','S40','{1}',0)",V.Local.sTransIDNew,v.DataTable.dtLoadShip(v.Local.sSel(v.Local.i)).PACKING LIST!FieldVal,V.Local.sSQL)
			F.ODBC.Connection!Con.Execute(V.Local.sSQL)
					
			'REMOVE ATTEMPTED_FLAG FOR WIREPOLL TO PROCESS
			F.Intrinsic.String.Build("update WIRELESS_HDR set ATTEMPTED_FLAG='' where TRANS_ID='{0}'",V.Local.sTransIDNew,V.Local.sSQL)
			F.ODBC.Connection!Con.Execute(V.Local.sSQL)				
		F.Intrinsic.Control.Next(v.Local.i)	
		F.Intrinsic.UI.Msgbox("Staged packing lists for load(s) are in process of shipping...  Click OK to Exit and Refresh.","Shipping load")
f.Intrinsic.Control.Else
	F.Intrinsic.UI.Msgbox("Please select rows from load with packing lists that have been validated and not load 0 or 9999.  Click OK to Exit.","Warning")
Function.Intrinsic.Control.EndIf
f.Data.Datatable.Close("dtloadShip")
f.Data.DataView.Close("dtLoad","dvloadShip")
f.Data.Datatable.Close("dtloadship0")
Function.Intrinsic.Control.UnBlockEvents
F.Intrinsic.Control.If(V.Screen.frmShip!chkdisablerefresh.Value,=,0)
	F.Intrinsic.Control.CallSub(cmdrefresh_click)					
F.Intrinsic.Control.EndIf
f.Intrinsic.Control.ExitSub
Function.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.CallSub(frmShip_UnLoad)	
Function.Intrinsic.Control.EndTry

Program.Sub.Click_Load_Ship.End

