v.Local.dPickDate.Declare(Date)
v.Local.sSQL.Declare(String)
v.Local.sQuery.Declare(String)
v.Local.iCnt.Declare

'filter for selected rows
Function.Intrinsic.Control.BlockEvents
Function.Data.DataTable.AcceptChanges("dtLoad")
'verify that we have a checked value in SELECT and load is 0. 
F.Data.Datatable.Select("dtLoad","[SELECT] = 1 and [LOAD NUMBER] = 0 and [PACKING LIST] is null",v.Local.sSel)

Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")	
		F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
		F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
			'Delete rows from load_plan
			F.Intrinsic.String.Build("delete from Load_Plan Where ORDER_NO = '{1}' And ORDER_SUFFIX = '{2}' ANd ORDER_LINE = '{3}' and CUSTOMER = '{4}' and Load_No = '{0}'",v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).LOAD NUMBER!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_NO!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_SUFFIX!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_LINE!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).CUSTOMER!FieldVal,v.Local.sSQL)
			f.ODBC.Connection!con.Execute(v.Local.sSQL)
			f.Data.Datatable.DeleteRow("dtLoad",v.Local.sSel(v.Local.i))
		F.Intrinsic.Control.Next(v.Local.i)	
		gui.frmShip.lblRunMRP.Visible(True)
f.Intrinsic.Control.Else
