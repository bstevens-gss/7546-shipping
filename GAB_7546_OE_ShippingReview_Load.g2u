Program.Sub.Preflight.Start
	V.Global.bRefresh.Declare
	V.Global.bSecs.Declare
	V.Global.iTimerMili.Declare
	V.Global.iTimerMili2.Declare
	V.Global.iTimerDiff.Declare
	V.Global.iCnt.Declare
	V.Global.iSecs.Declare
	V.Global.bShip.Declare
	V.Global.bLoadData.Declare
	V.Global.bLongPart.Declare
	V.Global.bUseShippingLocations.Declare
	V.Global.bShippingOverride.Declare
	V.Global.sShippingLocation.Declare
	v.Global.bViewSO.Declare
	v.Global.bShipOEPermission.Declare
	v.Global.bShipSHIPPermission.Declare
	v.Global.bSupDemView.Declare
	v.Global.bSupDemEdit.Declare
	v.Global.bSupDemNODollars.Declare
	v.Global.bSupDemNew.Declare
	V.Global.bNotClick.Declare(Boolean, True)
	Variable.Global.bUseLoadPlanning.Declare(Boolean,False)
	variable.Global.bUseGSMobilePicklist.Declare(Boolean,False)	
	v.Global.bCustOrderNotesFailedToLoad.Declare(boolean,False)
	Variable.Global.bUseMobilePickListMRP.Declare(Boolean,False)
	v.Global.sLoadNo.Declare
	v.Global.iLoadNo.Declare
	v.Global.b7551.Declare
	'5/20/26 BS - PO Pack List direct print support
	V.Global.bSuppressPOPackLotBin.Declare(Boolean,False)
	V.Global.sPOPackPrinter.Declare(String,"")
	v.Global.b5235.Declare
	v.Global.sAllocType.Declare
	'7546 Hultec 03/23/2026: Tracks whether a split save completed successfully for grid refresh on form close.
	V.Global.bSplitSaved.Declare(Boolean,False)
	'6/1/26 BS - POR020: Block PL print when SO on shipping hold
	V.Global.bIsPOR020.Declare(Boolean,False)
	V.Global.bLoadHoldBlock.Declare(Boolean,False)
	'Program.External.Include.Library("PPT_Canny.lib")
	'7/14/26 BS - Freight Class child grid context
	V.Global.sFrtClassPckNo.Declare
	V.Global.sFrtClassOrderNo.Declare
	V.Global.sFrtClassOrderLine.Declare
	V.Global.sFrtClassWaybill.Declare
	V.Global.iFrtClassRowIdx.Declare(Long)
	V.Global.sFrtClassNMFC.Declare
	V.Global.sFrtClassWarned.Declare
	V.Global.sFrtClassWtPallets.Declare
Program.Sub.Preflight.End
Program.Sub.Main.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
		
	V.Local.sArt.Declare
	V.Local.bShipGrp.Declare
	V.Local.iProject.Declare(Long)

	'Set Application Icon
'	F.Intrinsic.String.Build("{0}\GSS2.ico",V.Caller.ArtDir,v.Local.sArt)
'	Gui.frmShip..Icon(V.Local.sArt)
'	Gui.frmItem..Icon(V.Local.sArt)
'	Gui.frmShipSch..Icon(V.Local.sArt)
			
	'Set Gss Logo
	F.Intrinsic.String.Build("{0}\GAB_GSS_Logo_Green_Dash.png",V.Caller.ArtDir,V.Local.sArt)
	Gui.frmShip.picGSSLogo.Picture(V.Local.sArt)
	
	'Set back color for upper right corner legend
	Gui.frmShip.txtOnHold.BackColor(V.Enum.ThemeColors!ColorRed.Highlight)
	Gui.frmShip.txtReady.BackColor(V.Enum.ThemeColors!ColorGreen.Highlight)
	Gui.frmShip.txtSelected.BackColor(V.Enum.ThemeColors!ColorYellow.Highlight)
	Gui.frmShip.txtBatch.BackColor(V.Enum.ThemeColors!ColorGreen.Highlight)
	
	'Canny
	'F.Intrinsic.Control.CallSub(CannyCheckUser,"Form","frmShip")

	Gui.frmShip.optView.Value(True)
	Gui.frmShip.optShip.Value(False)
	Gui.frmShip.txtORD.BackColor(-2147483633)

	F.Intrinsic.Control.BlockEvents
	
	gui.frmShip.tabShip.SetTab(0)
	
	'Open DB Connection
	F.ODBC.Connection!con.OpenCompanyConnection(500)

	'6/1/26 BS - POR020: Read SW customer code to scope shipping hold PL block
	V.Local.sSWCust.Declare
	F.Global.General.ReadOptionCommon(3280,0,0,1,"",V.Local.sSWCust)
	F.Intrinsic.Control.If(V.Local.sSWCust.UCase,=,"POR020")
		V.Global.bIsPOR020.Set(True)
	F.Intrinsic.Control.EndIf

	F.Intrinsic.Control.CallSub(SetAnchors)
	
	F.Intrinsic.Control.CallSub(CheckMRP)
	F.Intrinsic.Control.CallSub(CheckPickList)
	F.Intrinsic.Control.CallSub(CheckLongPart)
	F.Intrinsic.Control.CallSub(CheckShippingLocations)
	Function.Intrinsic.Control.CallSub(CheckGSMobileOption)
	Function.Intrinsic.Control.CallSub(CheckLoadPlanningOption)
	Function.Intrinsic.Control.CallSub(CheckMobilePickListMRPOption)	
	F.Intrinsic.Control.CallSub(CheckPermissions)
	f.Intrinsic.Control.CallSub(GetUserFields)
	f.Intrinsic.Control.CallSub(CheckAllocationType)

	Gui.frmShip..Show	
	gui.frmShip.tabShip.Enabled(False)
	F.Intrinsic.Control.CallSub(SetContextMenus)
	'7546 UDF 03/25/2026: Load shared dictionaries once for initial startup
	Gui.frmShip.lblStatus.Caption("Loading Shared Lookups....")
	F.Intrinsic.Control.CallSub(LoadSharedDictionaries)
	Gui.frmShip.lblStatus.Caption("Loading Open Orders....")
	F.Intrinsic.Control.CallSub(LoadOpenOrders)
	Gui.frmShip.lblStatus.Caption("Loading Past Due Orders....")
	F.Intrinsic.Control.CallSub(LoadDueOrders)
	Gui.frmShip.lblStatus.Caption("Loading Staged Packing Lists....")
	F.Intrinsic.Control.CallSub(LoadStaging)
	Gui.frmShip.lblStatus.Caption("Loading Shipped Packing Lists....")
	F.Intrinsic.Control.CallSub(LoadShipped)
	Gui.frmShip.lblStatus.Caption("Loading Loads....")
	F.Intrinsic.Control.CallSub(LoadLoad)
	F.Intrinsic.Control.CallSub(CloseSharedDictionaries)
	F.Intrinsic.Control.CallSub(Deserialize)
	
	'-- Deserialized layout may carry stale USER field captions; re-apply from dtUserFields
	F.Intrinsic.Control.CallSub(RefreshUserFieldCaptions)

	'-- Deserialized layout may carry old read-only state; force editable after restore
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","TRACKING_NO","AllowEdit",True)
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","TRACKING_NO","ReadOnly",False)
	
	'-- Ensure FIRST_BIN and BOL_SHIP_FROM are available in Column Chooser after Deserialize
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","FIRST_BIN","Caption","First Bin")
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","FIRST_BIN","ShowInColumnChooser",True)
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","BOL_SHIP_FROM","Caption","BOL Ship From")
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","BOL_SHIP_FROM","ShowInColumnChooser",True)
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Staged PL Weight","ShowInColumnChooser",True)
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Staged PL Cartons","ShowInColumnChooser",True)
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Staged PL Pallets","ShowInColumnChooser",True)
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Staged PL Mixed","ShowInColumnChooser",True)
	
	F.Intrinsic.Control.UnBlockEvents
	
	Gui.frmShip.lblStatus.Visible(False)
	gui.frmShip.tabShip.Enabled(True)

	Function.Intrinsic.Control.If(v.Global.bUseGSMobilePicklist) 
		'launch picker status program
		Function.Intrinsic.Control.CallSub(LaunchPickerStatus)
	Function.Intrinsic.Control.Else
		'hide the columns because serialization messed it up. 
		Gui.frmShip.GsGCAllShip.SetColumnProperty(gvallship,"Assigned_To","Visible",False)
		Gui.frmShip.GsGCAllShip.SetColumnProperty(gvallship,"Assigned_To","ShowInColumnChooser",False)

		Gui.frmShip.GsGCAllShip.SetColumnProperty(gvallship,"ASSIGNPICKER","Visible",False)
		Gui.frmShip.GsGCAllShip.SetColumnProperty(gvallship,"ASSIGNPICKER","ShowInColumnChooser",False)
		
		Gui.frmShip.GsGCDue.SetColumnProperty(gvDue,"Assigned_To","Visible",False)
		Gui.frmShip.GsGCDue.SetColumnProperty(gvDue,"Assigned_To","ShowInColumnChooser",False)

		Gui.frmShip.GsGCDue.SetColumnProperty(gvDue,"ASSIGNPICKER","Visible",False)
		Gui.frmShip.GsGCDue.SetColumnProperty(gvDue,"ASSIGNPICKER","ShowInColumnChooser",False)
		
	Function.Intrinsic.Control.EndIf
		
	Function.Intrinsic.Control.If(v.Global.bUseLoadPlanning.not)
		Gui.frmShip.GsGCStaging.SetColumnProperty("gvStaging","LOAD_NO","Visible",False)
		Gui.frmShip.GsGCStaging.SetColumnProperty("gvStaging","LOAD_NO","ShowInColumnChooser",False)
	Function.Intrinsic.Control.EndIf

	'Remove the Allocation Flag for our program 
	Gui.frmShip.GsGCAllShip.SetColumnProperty(gvallship,"AllocationFlag","Visible",False)	
	Gui.frmShip.GsGCAllShip.SetColumnProperty(gvallship,"AllocationFlag","ShowInColumnChooser",False)
	Gui.frmShip.GsGCDue.SetColumnProperty(gvDue,"AllocationFlag","Visible",False)
	Gui.frmShip.GsGCDue.SetColumnProperty(gvDue,"AllocationFlag","ShowInColumnChooser",False)
	Gui.frmShip.GsGCLoad.SetColumnProperty(gvLoad,"AllocationFlag","Visible",False)
	Gui.frmShip.GsGCLoad.SetColumnProperty(gvLoad,"AllocationFlag","ShowInColumnChooser",False)
	
	'Set the Phase column based on the Project column in the Parent Grid	
	Gui.frmShip.GsGCStaging.GetColumnProperty("gvStaging","PROJECT","VisibleIndex",V.Local.iProject)
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","OptionBehaviorEditable",True)
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","AllowColumnMoving",True)
	
	F.Intrinsic.Control.If(V.Local.iProject,=,-1)
			Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PHASE","Visible",False)			
		F.Intrinsic.Control.Else
			Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PHASE","Visible",True)
		F.Intrinsic.Control.EndIf
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","OptionBehaviorEditable",False)
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","AllowColumnMoving",False)
		
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.Main.End

Program.Sub.frmShip_UnLoad.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	F.Intrinsic.Control.If(V.Global.bLoadData)
		F.Intrinsic.Control.CallSub(Serialize)
	F.Intrinsic.Control.EndIf
	
	'7546 UDF 04/06/2026: Close session-lived dDCC dictionary
	V.Local.bDccExists.Declare(Boolean,False)
	F.Data.Dictionary.Exists("dDCC",V.Local.bDccExists)
	F.Intrinsic.Control.If(V.Local.bDccExists)
		F.Data.Dictionary.Close("dDCC")
	F.Intrinsic.Control.EndIf
	
	F.ODBC.Connection!con.Close
	F.Intrinsic.Control.End

	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.frmShip_UnLoad.End

Program.Sub.SetAnchors.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	'0 - None
	'1 - Top
	'2 - Bottom
	'4 - Left
	'8 - Right

	Gui.frmShip.picGSSLogo.Anchor(1)
	Gui.frmShip.framePermissions.Anchor(9)
	gui.frmShip.tabShip.Anchor(15)
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.SetAnchors.End

Program.Sub.CheckMRP.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sRet.Declare
	
	Gui.frmShip.ddlCalculateMRPOnHand.AddItem("No",0)
	Gui.frmShip.ddlCalculateMRPOnHand.AddItem("Running Total",1)
	Gui.frmShip.ddlCalculateMRPOnHand.AddItem("Allocations, No Running Total",2)
	Gui.frmShip.ddlCalculateMRPOnHand.AddItem("Allocations, Running Total",3)
	Gui.frmShip.ddlCalculateMRPOnHand.AddItem("UDF Running Total",4)

	F.Global.Registry.ReadValue(v.caller.User,V.Caller.CompanyCode,"7546",7546,2000,5,"",V.Local.sRet)
	
	F.Intrinsic.Control.If(V.Local.sRet,=,"")
		Gui.frmShip.ddlCalculateMRPOnHand.Text("No")
	F.Intrinsic.Control.Else
		Gui.frmShip.ddlCalculateMRPOnHand.Text(V.Local.sRet)
	F.Intrinsic.Control.EndIf
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",V.Ambient.ScriptPath,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.CheckMRP.End

Program.Sub.CheckPickList.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sRet.Declare
	
	Gui.frmShip.ddlPicklistRpt.AddItem("Shipment Pick List (Rpt 71)",0)
	Gui.frmShip.ddlPicklistRpt.AddItem("Shipment Pick List (Rpt 71) Quick Print",1)
	Gui.frmShip.ddlPicklistRpt.AddItem("Shipping Dashboard Pick List (Rpt 95)",2)

	F.Global.Registry.ReadValue(v.Caller.User,V.Caller.CompanyCode,"7546",7546,3000,5,"Shipment Pick List (Rpt 71)",V.Local.sRet)
	Gui.frmShip.ddlPicklistRpt.Text(V.Local.sRet)
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.CheckPickList.End

Program.Sub.CheckLongPart.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	F.Global.General.ReadOption("400861",0,False,"0000",V.Global.bLongPart)
	
	F.Intrinsic.Control.If(V.Global.bLongPart,=,False)
		F.Global.General.ReadOption("400861",0,False,"0004",V.Global.bLongPart)
	F.Intrinsic.Control.EndIf
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.CheckLongPart.End

Program.Sub.CheckShippingLocations.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	F.ODBC.Connection!con.ExecuteAndReturn("Select Cast(Case When F_BOOLEAN = 1 Then 1 Else 0 End As Bit) As UseShippingLocations From OP_HEADER Where ID = 401561 And Sequence = 0000;",V.Global.bUseShippingLocations)
	F.Intrinsic.Control.If(V.Global.bUseShippingLocations)
		F.Intrinsic.Control.CallSub(GetUserOptions)
	F.Intrinsic.Control.EndIf
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.CheckShippingLocations.End

Program.Sub.CheckGSMobileOption.Start
Function.Intrinsic.Control.Try

V.Local.sError.Declare
f.Global.General.ReadOption("402673",0,False,v.Global.bUseGSMobilePicklist)

Function.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.CallSub(frmShip_UnLoad)	
Function.Intrinsic.Control.EndTry
Program.Sub.CheckGSMobileOption.End

Program.Sub.CheckLoadPlanningOption.Start
Function.Intrinsic.Control.Try
V.Local.sError.Declare
f.Global.General.ReadOption("402674",0,False,v.Global.bUseLoadPlanning)

Function.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.CallSub(frmShip_UnLoad)	
Function.Intrinsic.Control.EndTry
Program.Sub.CheckLoadPlanningOption.End

Program.Sub.CheckMobilePickListMRPOption.Start
Function.Intrinsic.Control.Try
V.Local.sError.Declare(String)
F.Global.General.ReadOption("402676",0,False,v.Global.bUseMobilePickListMRP)

Function.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.CallSub(frmShip_UnLoad)	
Function.Intrinsic.Control.EndTry

Program.Sub.CheckMobilePickListMRPOption.End

Program.Sub.GetUserOptions.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sSQL.Declare
	
	F.Intrinsic.String.Build("Select Cast(Case When ASCII_FLAG = 'Y' Then 1 Else 0 End As Bit) As Override,RTrim(Text) As Location From User_Options Where ID = '{0}' And OPTION_ID = '000016';",V.Caller.User,V.Local.sSQL)
	F.Data.DataTable.CreateFromSQL("dtUserOptions","con",V.Local.sSQL)
	F.Intrinsic.Control.If(V.DataTable.dtUserOptions.RowCount,=,0)
		F.Intrinsic.UI.Msgbox("Your company is flagged to utilize Shipping Locations and your user does not have a location setup. Please contact your GS Administrator to resolve this issue.","User Options")
		F.Intrinsic.Control.CallSub(frmShip_UnLoad)
	F.Intrinsic.Control.Else
		V.Global.bShippingOverride.Set(V.DataTable.dtUserOptions(0).Override!FieldVal)
		V.Global.sShippingLocation.Set(V.DataTable.dtUserOptions(0).Location!FieldVal)
	F.Intrinsic.Control.EndIf
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.GetUserOptions.End

Program.Sub.CheckPermissions.Start
F.Intrinsic.Control.Try
V.Local.sError.Declare
v.Local.bChecked.Declare(boolean,false)
	
'User Permissions
	'Order Entry > View > Sales Orders
	F.Global.Security.CheckUserAccessIPM(131,0,V.Global.bViewSO)
	
	'Order Entry > Transactions > Shipments > New
	F.Global.Security.CheckUserAccessIPM(136,2,v.Global.bShipOEPermission)
	
	'Shipping & Receiving > Transactions > Shipments > New
	F.Global.Security.CheckUserAccessIPM(661,2,v.Global.bShipSHIPPermission)
	
	'Inventory > View > Supply and Demand
	F.Global.Security.CheckUserAccessIPM(321,0,V.Global.bSupDemView)
	
	'Inventory > View > Supply and Demand with Edit
	F.Global.Security.CheckUserAccessIPM(371,0,V.Global.bSupDemEdit)
	
	'Inventory > View > Supply and Demand (No Dollars)
	F.Global.Security.CheckUserAccessIPM(398,0,V.Global.bSupDemNODollars)
	
	'Inventory > View > Supply and Demand - NEW
	F.Global.Security.CheckUserAccessIPM(1074,0,V.Global.bSupDemNew)
	
	'View Radio Button	
	f.Intrinsic.Control.If(V.Global.bViewSO,=,True,OR,V.Global.bSupDemView,=,True,V.Global.bSupDemNODollars,=,True,V.Global.bSupDemNew, =, True)
		Gui.frmShip.optView.Enabled(1)
		f.Intrinsic.Control.If(v.Local.bChecked,=,False)
			Gui.frmShip.optView.Value(True)
			v.Local.bChecked.Set(True)
		f.Intrinsic.Control.EndIf		
	f.Intrinsic.Control.Else
		Gui.frmShip.optView.Enabled(0)
		Gui.frmShip.optView.Value(False)
		v.Local.bChecked.Set(False)
	f.Intrinsic.Control.EndIf
		
	'Ship Radio button
	F.Intrinsic.Control.If(V.Global.bShipOEPermission,=,True,OR,v.Global.bShipSHIPPermission,=,True)
		Gui.frmShip.optShip.Enabled(1)
		V.Global.bShip.Set(True)
		f.Intrinsic.Control.If(v.Local.bChecked,=,False)
			Gui.frmShip.optShip.Value(True)
			v.Local.bChecked.Set(True)
		f.Intrinsic.Control.EndIf
	F.Intrinsic.Control.Else
		Gui.frmShip.optShip.Enabled(0)
		V.Global.bShip.Set(False)
		Gui.frmShip.optShip.Value(False)
		v.Local.bChecked.Set(False)
	F.Intrinsic.Control.EndIf

F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.End 
F.Intrinsic.Control.EndTry
Program.Sub.CheckPermissions.End

Program.Sub.SetContextMenus.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.iCnt.Declare
	V.Local.sControl.Declare
	V.Local.sControlName.Declare
	V.Local.sContextMenu.Declare
	V.Local.sContextMenuName.Declare
	v.Local.bExists.Declare
	V.local.sPath.Declare
	
	
	V.Local.sControl.Set("GsGCAllShip*!*GsGCDue*!*GsGCStaging*!*GsGCLoad*!*GsGCShipped")
	V.Local.sContextMenu.Set("CTXOPEN*!*CTXDUE*!*CTXSTAGING*!*CTXLOAD*!*CTXSHIPPED")
	
	F.Intrinsic.String.Split(V.Local.sControl,"*!*",V.Local.sControl)
	F.Intrinsic.String.Split(V.Local.sContextMenu,"*!*",V.Local.sContextMenu)
	
	F.Intrinsic.Control.For(V.Local.iCnt,0,V.Local.sControl.UBound,1)
	
		V.Local.sControlName.Set(V.Local.sControl(V.Local.iCnt))
		V.Local.sContextMenuName.Set(V.Local.sContextMenu(V.Local.iCnt))
		Gui.frmShip..ContextMenuCreate(V.Local.sContextMenuName)
		Gui.frmShip.[V.Local.sControlName].ContextMenuAttach(V.Local.sContextMenuName)
		Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"Refresh",0,"Refresh")
		Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"Export",0,"Export")
		Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"ResetColumns",0,"Reset Grid Serialization")
		Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"ResetColors",0,"Reset Colors Only")
		Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"Refresh","cmdRefresh_Click")
		Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"Export","ExportGrids")
		Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"ResetColumns","ResetGridColumns")
		Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"ResetColors","ResetGridColors")
		
		Function.Intrinsic.Control.If(v.Local.sControl(v.Local.icnt),=,"GsGCAllShip","OR",v.Local.sControl(v.Local.iCnt),=,"GsGCDue")					
			Function.Intrinsic.Control.If(v.Global.bUseGSMobilePicklist)				
				Function.Intrinsic.Control.If(v.Global.bUseLoadPlanning)
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlan",0,"Launch Load Planning")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlan","Launch_LoadPlan")
				Function.Intrinsic.Control.EndIf					
				Function.Intrinsic.Control.If(v.Local.sControl(v.Local.icnt),=,"GsGCDue")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"AssignPicker_Due",0,"Assign Picker(s)")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"AssignPicker_Due","Assign_Picker_Due")
					Function.Intrinsic.Control.If(v.Global.bUseLoadPlanning)
						Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"AssignPicker_Due_9999",0,"Assign Picker(s) to Pre-Pick Load 9999")
						Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"AssignPicker_Due_9999","Assign_Picker_Due_9999")
						'5/20/26 BS - TC-01: Pick List Printing by Line context menu
						Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"AssignPicker_Due_9999_Print",0,"Assign to Pre-Pick Load && Print Pick Lists")
						Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"AssignPicker_Due_9999_Print","Assign_Picker_Due_9999_Print")
					f.Intrinsic.Control.EndIf
				Function.Intrinsic.Control.else
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"AssignPicker",0,"Assign Picker(s)")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"AssignPicker","Assign_Picker")
					Function.Intrinsic.Control.If(v.Global.bUseLoadPlanning)
						Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"AssignPicker_9999",0,"Assign Picker(s) to Pre-Pick Load 9999")
						Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"AssignPicker_9999","Assign_Picker_9999")
						'5/20/26 BS - TC-01: Pick List Printing by Line context menu
						Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"AssignPicker_9999_Print",0,"Assign to Pre-Pick Load && Print Pick Lists")
						Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"AssignPicker_9999_Print","Assign_Picker_9999_Print")
					f.Intrinsic.Control.EndIf
				f.Intrinsic.Control.EndIf
				Function.Intrinsic.Control.If(v.Local.sControl(v.Local.icnt),=,"GsGCDue")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"RemovePicker_Due",0,"Remove Picker(s)")	
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"RemovePicker_Due","Remove_Picker_Due")
				Function.Intrinsic.Control.else
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"RemovePicker",0,"Remove Picker(s)")	
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"RemovePicker","Remove_Picker")				
				f.Intrinsic.Control.EndIf							
				Function.Intrinsic.Control.If(v.Global.bUseMobilePickListMRP)
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"RunMRP",0,"Run Pick List MRP")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"RunMRP","Run_MRP")	
				Function.Intrinsic.Control.EndIf
				Function.Intrinsic.Control.If(v.Local.sControl(v.Local.icnt),=,"GsGCAllShip")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"SelectAll",0,"Select All")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"SelectAll","GsGCAllShip_SelectAll")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"UnSelectAll",0,"UnSelect All")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"UnSelectAll","GsGCAllShip_UnSelectAll")
				f.Intrinsic.Control.EndIf
				Function.Intrinsic.Control.If(v.Local.sControl(v.Local.icnt),=,"GsGCDue")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"SelectAll",0,"Select All")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"SelectAll","GsGCAllDue_SelectAll")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"UnSelectAll",0,"UnSelect All")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"UnSelectAll","GsGCAllDue_UnSelectAll")
				f.Intrinsic.Control.EndIf
			Function.Intrinsic.Control.EndIf
		'7546 Hultec 03/23/2026: Add "Split SO Line" right-click option for Open Orders and Past Due grids.
		Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"break_split",0,"--------------------------------")
		Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"SplitSOLine",0,"Split SO Line")
		Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"SplitSOLine","SplitSOLine_Click")
		'7546 Hultec 03/23/2026: Add "Edit Sales Order" right-click option for Open Orders and Past Due grids.
		Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"EditSalesOrder",0,"Edit Sales Order")
		Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"EditSalesOrder","EditSalesOrder_Click")
		Function.Intrinsic.Control.EndIf
		
	Function.Intrinsic.Control.If(v.Local.sControl(v.Local.icnt),=,"GsGCLoad")
		Function.Intrinsic.Control.If(v.Global.bUseGSMobilePicklist)
				Function.Intrinsic.Control.If(v.Global.bUseLoadPlanning)
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"break",0,"--------------------------------")	
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlan",0,"Launch Load Planning")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlan","Launch_LoadPlan")					
					'Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"RemovePicker",0,"Remove Picker(s)")
					'load management					
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanNew",0,"  [Create New Load]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanNew","load_CreateNewLoad")					
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanAdd",0,"  [Assign To Existing Load]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanAdd","load_AssignToLoad")	
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlan0",0,"  [Move To Load 0]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlan0","load_MoveToLoad0")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlan9999",0,"  [Move To Pre-pick Load 9999]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlan9999","load_AssignToLoad9999")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlan9999toNewLoad",0,"  [Create New Load from Pre-Pick 9999]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlan9999toNewLoad","load_AssignLoad9999ToNewLoad")					
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanPick",0,"  [Ready to Pick]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanPick","load_ReadyToPick")	
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanPick_Not",0,"  [Ready to Pick (Remove)]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanPick_Not","load_ReadyToPick_Not")	
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanOverridepicked",0,"  [Override-Flag as Picked]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanOverridepicked","load_OverridePickedFlag")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanOverridepickedremove",0,"  [Override-Remove Flag as Picked]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanOverridepickedremove","load_OverridePickedFlag_remove")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanRemove0",0,"  [Remove Load 0]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanRemove0","load_0_remove")					
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"break",0,"--------------------------------")					
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanLaunchForms",0,"Print Staged Forms")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanLaunchForms","Click_Launch_PrintStagedForms")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanPrintPL",0,"  [Print Packing Lists]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanPrintPL","Click_Print_PL")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanPrintPLCerts",0,"  [Print Packing Lists w/Certs]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanPrintPLCerts","Click_Print_PL_Certs")	
					'added 07/15/25 by BS					
					F.Intrinsic.Control.CallSub(Validate_7551)					
					f.Intrinsic.Control.If(v.Global.b7551)					
						Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"PACKREPORT",0,"  [Print PO Pack Report]")
						Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"PACKREPORT","Click_Print_POPackList")
					f.Intrinsic.Control.EndIf
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanPrintBOL",0,"  [Print BOL]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanPrintBOL","Click_Print_BOL")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanPrintLoadManifest",0,"  [Print Load Manifest]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanPrintLoadManifest","Click_Print_LoadManifest")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"break",0,"--------------------------------")	
					'F.Intrinsic.String.Build("{0}\GCG_5235_DockDashboard.g2p", V.Ambient.ScriptPath, V.local.sPath)
					'f.Intrinsic.File.Exists(v.Local.sPath,v.Local.bExists)
					'f.Intrinsic.Control.If(v.Local.bExists)	
					f.Intrinsic.Control.If(v.Global.b5235)
						Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanLaunchLoadValidation",0,"Launch Load Validation Dashboard")
						Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanLaunchLoadValidation","Click_Launch_LoadValidation")	
					f.Intrinsic.Control.Else
						'f.Intrinsic.UI.Msgbox("ARC 5235 is required for this menu item.")
					f.Intrinsic.Control.EndIf
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanOverrideValidated",0,"  [Override-Flag Validated]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanOverrideValidated","Load_Override_Validate")	
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanOverrideValidatedremove",0,"  [Override-Unflag Validated]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanOverrideValidatedremove","Load_Override_Validate_Remove")	
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanLaunchShip",0,"Ship Staged Shipments Menu")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanLaunchShip","Click_Launch_StagedShip")
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanShip",0,"  [Ship Load]")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanShip","Click_Load_Ship")					
				Function.Intrinsic.Control.EndIf	
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"break",0,"--------------------------------")
				Function.Intrinsic.Control.If(v.Global.bUseMobilePickListMRP)
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"RunMRP",0,"Run Pick List MRP")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"RunMRP","Run_MRP")
				Function.Intrinsic.Control.EndIf	
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanSelectAll",0,"Select All")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanSelectAll","load_SelectAll")					
					Gui.frmShip..ContextMenuAddItem(V.Local.sContextMenuName,"LoadPlanUnSelectAll",0,"UnSelect All")
					Gui.frmShip..ContextMenuSetItemEventHandler(V.Local.sContextMenuName,"LoadPlanUnSelectAll","load_UnSelectAll")	
			Function.Intrinsic.Control.EndIf
	Function.Intrinsic.Control.EndIf
		
	F.Intrinsic.Control.Next(V.Local.iCnt)
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.SetContextMenus.End

Program.Sub.cmdRefresh_Click.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	F.Intrinsic.Control.If(V.Global.bLoadData)
		F.Intrinsic.Control.CallSub(Serialize)
	F.Intrinsic.Control.EndIf
	
	F.Intrinsic.Control.BlockEvents
	'7546 UDF 03/25/2026: Load shared dictionaries once, then consume in both LoadOpenOrders and LoadLoad
	F.Intrinsic.Control.CallSub(LoadSharedDictionaries)
	F.Intrinsic.Control.CallSub(LoadOpenOrders)
	F.Intrinsic.Control.CallSub(LoadDueOrders)
	F.Intrinsic.Control.CallSub(LoadStaging)
	F.Intrinsic.Control.CallSub(LoadLoad)
	F.Intrinsic.Control.CallSub(LoadShipped)
	F.Intrinsic.Control.CallSub(CloseSharedDictionaries)
	F.Intrinsic.Control.UnBlockEvents
	F.Intrinsic.Control.CallSub(txtAutoRef_LostFocus)
	F.Intrinsic.Control.CallSub(Deserialize)
	
	'-- Deserialized layout may carry stale USER field captions; re-apply from dtUserFields
	F.Intrinsic.Control.CallSub(RefreshUserFieldCaptions)

	'-- Deserialized layout may carry old read-only state; force editable after restore
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","TRACKING_NO","AllowEdit",True)
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","TRACKING_NO","ReadOnly",False)
	
	'-- Ensure FIRST_BIN and BOL_SHIP_FROM are available in Column Chooser after Deserialize
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","FIRST_BIN","Caption","First Bin")
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","FIRST_BIN","ShowInColumnChooser",True)
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","BOL_SHIP_FROM","Caption","BOL Ship From")
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","BOL_SHIP_FROM","ShowInColumnChooser",True)
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Staged PL Weight","ShowInColumnChooser",True)
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Staged PL Cartons","ShowInColumnChooser",True)
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Staged PL Pallets","ShowInColumnChooser",True)
	Gui.frmShip.GsGCLoad.SetColumnProperty("gvLoad","Staged PL Mixed","ShowInColumnChooser",True)
	
	'Remove the Allocation Flag for our program 
	Gui.frmShip.GsGCAllShip.SetColumnProperty(gvallship,"AllocationFlag","Visible",False)	
	Gui.frmShip.GsGCAllShip.SetColumnProperty(gvallship,"AllocationFlag","ShowInColumnChooser",False)
	Gui.frmShip.GsGCDue.SetColumnProperty(gvDue,"AllocationFlag","Visible",False)
	Gui.frmShip.GsGCDue.SetColumnProperty(gvDue,"AllocationFlag","ShowInColumnChooser",False)
	Gui.frmShip.GsGCLoad.SetColumnProperty(gvLoad,"AllocationFlag","Visible",False)
	Gui.frmShip.GsGCLoad.SetColumnProperty(gvLoad,"AllocationFlag","ShowInColumnChooser",False)
	
	Gui.frmShip.lblStatus.Visible(False)

	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.cmdRefresh_Click.End

Program.Sub.ExportGrids.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.bExcel.Declare
	V.Local.sExt.Declare
	V.Local.sControl.Declare
	V.Local.sFileExport.Declare
	V.Local.bFileLocked.Declare
	V.Local.sMsg.Declare
	
	F.Intrinsic.Control.SelectCase(V.Args.MenuName)
		F.Intrinsic.Control.Case("CTXOPEN")
			V.Local.sControl.Set("GsGCAllShip")
			
		F.Intrinsic.Control.Case("CTXDUE")
			V.Local.sControl.Set("GsGCDue")
			
		F.Intrinsic.Control.Case("CTXSTAGING")
			V.Local.sControl.Set("GsGCStaging")
			
		F.Intrinsic.Control.Case("CTXSHIPPED")
			V.Local.sControl.Set("GsGCShipped")
			
		F.Intrinsic.Control.Case("CTXLOAD")
			V.Local.sControl.Set("GsGCLoad")
	F.Intrinsic.Control.EndSelect
	
	F.Automation.MSExcel.CheckPresence(V.Local.bExcel)
	F.Intrinsic.Control.If(V.Local.bExcel)
		V.Local.sExt.Set("xlsx")
	F.Intrinsic.Control.Else
		V.Local.sExt.Set("csv")
	F.Intrinsic.Control.EndIf
	
	F.Intrinsic.String.Build("{0}\GAB_7546_{1}_Export.{2}",V.Caller.LocalGssTempDir,V.Local.sControl,V.Local.sExt,V.Local.sFileExport)
	F.Intrinsic.File.IsFileLocked(V.Local.sFileExport,V.Local.bFileLocked)
	F.Intrinsic.Control.If(V.Local.bFileLocked)
		F.Intrinsic.String.Build("File is already open. Please close and export again.{0}File: {1}",V.Ambient.NewLine,V.Local.sFileExport,V.Local.sMsg)
		F.Intrinsic.UI.Msgbox(V.Local.sMsg,"File In Use")
	F.Intrinsic.Control.Else
		Gui.frmShip.[V.Local.sControl].Export(V.Local.sFileExport,V.Local.sExt)
		F.Intrinsic.Task.ShellExec(0,"",V.Local.sFileExport,"","",1)
	F.Intrinsic.Control.EndIf
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.ExportGrids.End

Program.Sub.ResetGridColumns.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	F.Intrinsic.Control.SelectCase(V.Args.MenuName)
		F.Intrinsic.Control.Case("CTXOPEN")
			F.Global.Registry.AddValue(V.Caller.User,V.Caller.CompanyCode,"GVALLSHIP",7546,1000,False,"Serialize",False,0,-999.0,1/1/1980,12:00:00 AM,"")
			
		F.Intrinsic.Control.Case("CTXDUE")
			F.Global.Registry.AddValue(V.Caller.User,V.Caller.CompanyCode,"GVDUESHIP",7546,1000,False,"Serialize",False,0,-999.0,1/1/1980,12:00:00 AM,"")
			
		F.Intrinsic.Control.Case("CTXSTAGING")
			F.Global.Registry.AddValue(V.Caller.User,V.Caller.CompanyCode,"GVSTAGING",7546,1000,False,"Serialize",False,0,-999.0,1/1/1980,12:00:00 AM,"")
			
		F.Intrinsic.Control.Case("CTXSHIPPED")
			F.Global.Registry.AddValue(V.Caller.User,V.Caller.CompanyCode,"GVSHIPPED",7546,1000,False,"Serialize",False,0,-999.0,1/1/1980,12:00:00 AM,"")
		F.Intrinsic.Control.Case("CTXLOAD")
			F.Global.Registry.AddValue(V.Caller.User,V.Caller.CompanyCode,"GVLOAD",7546,1000,False,"Serialize",False,0,-999.0,1/1/1980,12:00:00 AM,"")
	F.Intrinsic.Control.EndSelect
	
	V.Global.bLoadData.Set(False)
	F.Intrinsic.Control.CallSub(cmdRefresh_Click)
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.ResetGridColumns.End

Program.Sub.ResetGridColors.Start
F.Intrinsic.Control.Try
	V.Local.sError.Declare
	V.Local.iCnt.Declare
	V.Local.bHold.Declare
	V.Local.sSelect.Declare
	V.Local.sPercentReturn.Declare
