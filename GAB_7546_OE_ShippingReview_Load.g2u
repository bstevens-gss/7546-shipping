Program.Sub.LoadItemMaster.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sSql.Declare
	V.Local.fQtyOnHand.Declare
	V.Local.iCnt.Declare
	V.Local.sColumns.Declare

	F.Intrinsic.Control.If(V.DataTable.dtItem.Exists,=,True)
			F.Data.DataTable.Close("dtItem")
	F.Intrinsic.Control.EndIf

	F.Intrinsic.String.Build("Select RTRIM(LOT) AS LOT, RTRIM(BIN) AS BIN, RTRIM(HEAT) AS HEAT, RTRIM(SERIAL_NUMBER) AS SERIAL_NUMBER, QUANTITY, QTY_AVAILABLE_SHIP, ALLOCATED, Case ALLOC_TYPE When 'U' Then 'User' When 'W' Then 'Work Order' When 'G' Then 'Consigned' When 'S' Then 'Sales Order' When 'C' Then 'Customer' When 'T' Then 'Staged' When 'P' Then 'Purchased' End As ALLOC_TYPE From V_ITEM_MASTER WHERE PART = '{0}' AND LOCATION = '{1}' ORDER BY LOT, BIN, HEAT, SERIAL_NUMBER;",V.Args.Part.TRIM,V.Args.Loc.TRIM,V.Local.sSql)
	F.Data.DataTable.CreateFromSQL("dtItem","con",v.Local.sSql,True)

	Gui.frmItem.GsGCItem.AddGridViewFromDataTable("gvItem","dtItem")
	Gui.frmItem.GsGCItem.SuspendLayout()
	Gui.frmItem.GsGCItem.SetGridViewProperty("gvItem","MultiSelect",True)
	Gui.frmItem.GsGCItem.SetGridViewProperty("gvItem","OptionBehaviorEditable",False)
	Gui.frmItem.GsGCItem.SetGridViewProperty("gvItem","ReadOnly",True)
	Gui.frmItem.GsGCItem.SetGridViewProperty("gvItem","AllowSort",True)
	Gui.frmItem.GsGCItem.SetGridViewProperty("gvItem","AllowFilter",True)
	Gui.frmItem.GsGCItem.SetGridViewProperty("gvItem","OptionsDetailShowDetailTabs",False)
	Gui.frmItem.GsGCItem.SetGridViewProperty("gvItem","OptionsViewShowGroupPanel",True)
	Gui.frmItem.GsGCItem.SetGridViewProperty("gvItem","AllowColumnMoving",False)
	
	'Loop through columns names by using the V.DataTable.dtName.FieldNames
	F.Intrinsic.String.Split(V.DataTable.dtItem.FieldNames,"*!*",V.Local.sColumns)
	F.Intrinsic.Control.For(V.Local.iCnt,0,V.Local.sColumns.UBound,1)
		Gui.frmItem.GsGCItem.SetColumnProperty("gvItem",V.Local.sColumns(V.Local.iCnt),"HeaderFontBold",True)
	F.Intrinsic.Control.Next(V.Local.iCnt)

	'LOT
	Gui.frmItem.GsGCItem.SetColumnProperty("gvItem","LOT","Caption","Lot")
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","LOT","MinWidth","50")
	
	'BIN
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","BIN","Caption","Bin")
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","BIN","MinWidth","50")
	
	'HEAT
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","HEAT","Caption","Heat")
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","HEAT","MinWidth","50")
	
	'SERIAL_NUMBER
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","SERIAL_NUMBER","Caption","Serial Number")
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","SERIAL_NUMBER","MinWidth","50")
	
	'QUANTITY
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","QUANTITY","Caption","Quantity")
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","QUANTITY","MinWidth","50")
	
	'QTY_AVAILABLE_SHIP
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","QTY_AVAILABLE_SHIP","Caption","Available")
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","QTY_AVAILABLE_SHIP","MinWidth","50")
	
	'ALLOCATED
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","ALLOCATED","Caption","Allocated")
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","ALLOCATED","MinWidth","50")
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","ALLOCATED","HeaderHAlignment","Center")
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","ALLOCATED","CellHAlignment","Center")
	
	'ALLOC_TYPE
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","ALLOC_TYPE","Caption","Type")
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","ALLOC_TYPE","MinWidth","50")
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","ALLOC_TYPE","HeaderHAlignment","Center")
	Gui.frmItem.GSGCItem.setColumnProperty("gvItem","ALLOC_TYPE","CellHAlignment","Center")
	
	Gui.frmItem.GSGCItem.ResumeLayout()
	Gui.frmItem.GSGCItem.MainView("gvItem")
	
	'Set Screen Values
	Gui.frmItem.txtItemPart.Text(V.Args.Part)
	Gui.frmItem.txtItemLoc.Text(V.Args.Loc)	
	Gui.frmItem.txtItemDesc.Text(v.Args.Desc)
	'Qty On Hand
	F.Data.DataTable.Compute("dtItem","SUM(QUANTITY)","",V.Local.fQtyOnHand)
	Gui.frmItem.txtInvOnHand.Text(V.Local.fQtyOnHand)
	'Qty Avail
	F.Data.DataTable.Compute("dtItem","SUM(QUANTITY)","Allocated <> 'Y'",V.Local.fQtyOnHand)
	Gui.frmItem.txtQtyAvail.Text(V.Local.fQtyOnHand)

	Gui.frmItem..Show
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.LoadItemMaster.End

Program.Sub.LoadItemMaster90.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sSql.Declare
	V.Local.fQtyOnHand.Declare
	V.Local.iCnt.Declare
	V.Local.sColumns.Declare
	v.Local.sRet.Declare

	F.Intrinsic.Control.If(V.DataTable.dtItem90.Exists,=,True)
			F.Data.DataTable.Close("dtItem90")
	F.Intrinsic.Control.EndIf

	'F.Intrinsic.String.Build("Select RTRIM(LOT) AS LOT, RTRIM(BIN) AS BIN, RTRIM(HEAT) AS HEAT, RTRIM(SERIAL_NUMBER) AS SERIAL_NUMBER, QUANTITY, QTY_AVAILABLE_SHIP, ALLOCATED, Case ALLOC_TYPE When 'U' Then 'User' When 'W' Then 'Work Order' When 'G' Then 'Consigned' When 'S' Then 'Sales Order' When 'C' Then 'Customer' When 'T' Then 'Staged' When 'P' Then 'Purchased' End As ALLOC_TYPE From V_ITEM_MASTER WHERE PART = '{0}' AND LOCATION = '{1}' ORDER BY LOT, BIN, HEAT, SERIAL_NUMBER;",V.Args.Part.TRIM,V.Args.Loc.TRIM,V.Local.sSql)
	F.Intrinsic.String.Build("Select RTRIM(A.PART) as PART,CASE WHEN RTRIM(A.USER_FIELD_6)='' THEN '1/1/1900' ELSE  RTRIM(A.USER_FIELD_6) END as SHIP_DATE,RTRIM(A.USER_FIELD_7) as CONTAINER,A.QUANTITY,RTRIM(A.USER_FIELD_8) as CARRIER,RTRIM(A.USER_FIELD_9) as DESTINATION from ITEM_MASTER A inner join INVENTORY_MSTR B on B.PART = A.PART and B.LOCATION = A.LOCATION where A.PART = '{0}' and A.LOCATION = '90' and A.QUANTITY <> 0 ORDER BY A.USER_FIELD_6;",V.Args.Part.TRIM,V.Args.Loc.TRIM,V.Local.sSql)
	F.Data.DataTable.CreateFromSQL("dtItem90","con",v.Local.sSql,True)
'Function.Intrinsic.Debug.InvokeDebugger
Function.Intrinsic.Debug.Stop

	F.Data.DataTable.AddColumn("dtItem90","DATE_EXPECTED","Date")
	F.Data.DataTable.AddColumn("dtItem90","LEAD","String",7)
	
	F.Global.Registry.ReadValue(999,V.Caller.CompanyCode,"GCG_7754",7754,3333,6,"",V.Local.sRet)
	F.Intrinsic.Control.If(V.Local.sRet.Trim,<>,"")
    	F.Data.DataTable.CreateFromString("dtTemp",V.Local.sRet,"CARRIER*!*LEAD_TIME","String*!*String","*!*","#$#",False)
    	F.Data.Dictionary.CreateFromDataTable("dictLead","dtTemp","CARRIER","LEAD_TIME")
    	F.Data.DataTable.FillFromDictionary("dtItem90","dictLead","CARRIER","LEAD")
    	F.Data.DataTable.Close("dtTemp")
    	F.Data.Dictionary.Close("dictLead")
	F.Intrinsic.Control.EndIf
	
	F.Data.DataTable.DateAdd("dtItem90","SHIP_DATE","d","LEAD","DATE_EXPECTED",62)

	'Gui.frmItem90.GSGCItem90.AddGridViewFromDataTable("gvItem90","dtItem90")
	F.Data.DataView.Create("dtItem90","dvItem90",22,"","DATE_EXPECTED DESC")
	Gui.frmItem90.GSGCItem90.AddGridviewFromDataview("gvItem90","dtItem90","dvItem90")
	Gui.frmItem90.GSGCItem90.SuspendLayout()
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","MultiSelect",True)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","OptionBehaviorEditable",False)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","ReadOnly",True)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","AllowSort",True)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","AllowFilter",True)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","OptionsDetailShowDetailTabs",False)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","OptionsViewShowGroupPanel",True)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","AllowColumnMoving",False)
	
	'Loop through columns names by using the V.DataTable.dtName.FieldNames
	F.Intrinsic.String.Split(V.DataTable.dtItem90.FieldNames,"*!*",V.Local.sColumns)
	F.Intrinsic.Control.For(V.Local.iCnt,0,V.Local.sColumns.UBound,1)
		Gui.frmItem90.GSGCItem90.SetColumnProperty("gvItem90",V.Local.sColumns(V.Local.iCnt),"HeaderFontBold",True)
	F.Intrinsic.Control.Next(V.Local.iCnt)

	'PART
	Gui.frmItem90.GSGCItem90.SetColumnProperty("gvItem90","PART","Caption","Part")
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","PART","MinWidth","80")
	
	'SHIP DATE
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","SHIP_DATE","Caption","Ship Date")
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","SHIP_DATE","MinWidth","50")
	
	'CONTAINER
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","CONTAINER","Caption","Container#")
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","CONTAINER","MinWidth","100")
	
	'Quantity
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","QUANTITY","Caption","Quantity")
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","QUANTITY","MinWidth","50")
	Gui.frmItem90.GSGCItem90.SetColumnProperty(gvItem90,"QUANTITY","DisplayCustomNumeric","n4")
	
	
	'CARRIER
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","CARRIER","Caption","Carrier")
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","CARRIER","MinWidth","50")
	
	'DESTINATION
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","DESTINATION","Caption","Destination")
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","DESTINATION","MinWidth","50")
	
	'DATE EXPECTED
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","DATE_EXPECTED","Caption","Date Expected")
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","DATE_EXPECTED","MinWidth","100")
	Gui.frmItem90.GSGCItem90.SetColumnProperty(gvItem90,"DATE_EXPECTED","DisplayCustomDatetime","d")
	

	'LEAD
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","LEAD","Caption","Lead")
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","LEAD","MinWidth","50")
	
	Gui.frmItem90.GSGCItem90.ResumeLayout()
	Gui.frmItem90.GSGCItem90.MainView("gvItem90")
	
	'Set Screen Values
	Gui.frmItem90.txtItemPart.Text(V.Args.Part)
	Gui.frmItem90.txtItemLoc.Text("90")	
	Gui.frmItem90.txtItemDesc.Text(v.Args.Desc)
	'Qty On Hand
	F.Data.DataTable.Compute("dtItem90","SUM(QUANTITY)","",V.Local.fQtyOnHand)
	Gui.frmItem90.txtInvOnHand.Text(V.Local.fQtyOnHand)
	'Qty Avail
	Gui.frmItem90.txtQtyAvail.Text(V.Local.fQtyOnHand)

	Gui.frmItem90..Show
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.LoadItemMaster90.End

Program.Sub.LoadItemMaster90_UDF.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sSql.Declare
	V.Local.fQtyOnHand.Declare
	V.Local.iCnt.Declare
	V.Local.sColumns.Declare
	v.Local.sRet.Declare

	F.Intrinsic.Control.If(V.DataTable.dtItem90.Exists,=,True)
			F.Data.DataTable.Close("dtItem90")
	F.Intrinsic.Control.EndIf

	F.Intrinsic.String.Build("Select RTRIM(A.PART) as PART,A.BIN,C.BIN_DESCRIPTION,QUANTITY from ITEM_MASTER A inner join INVENTORY_MSTR B on B.PART = A.PART and B.LOCATION = A.LOCATION left outer join BIN_MASTER C ON A.BIN=C.BIN AND A.LOCATION=C.LOCATION where A.PART = '{0}' AND A.LOCATION = '{1}' AND A.BIN LIKE 'O%' and A.QUANTITY <> 0 ORDER BY A.BIN;",V.Args.Part.TRIM,V.Args.Loc.TRIM,V.Local.sSql)

	F.Data.DataTable.CreateFromSQL("dtItem90","con",v.Local.sSql,True)
'Function.Intrinsic.Debug.InvokeDebugger
Function.Intrinsic.Debug.Stop

	F.Data.DataView.Create("dtItem90","dvItem90",22,"","BIN ASC")
	Gui.frmItem90.GSGCItem90.AddGridviewFromDataview("gvItem90","dtItem90","dvItem90")
	Gui.frmItem90.GSGCItem90.SuspendLayout()
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","MultiSelect",True)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","OptionBehaviorEditable",False)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","ReadOnly",True)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","AllowSort",True)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","AllowFilter",True)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","OptionsDetailShowDetailTabs",False)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","OptionsViewShowGroupPanel",True)
	Gui.frmItem90.GSGCItem90.SetGridViewProperty("gvItem90","AllowColumnMoving",False)
	
	'Loop through columns names by using the V.DataTable.dtName.FieldNames
	F.Intrinsic.String.Split(V.DataTable.dtItem90.FieldNames,"*!*",V.Local.sColumns)
	F.Intrinsic.Control.For(V.Local.iCnt,0,V.Local.sColumns.UBound,1)
		Gui.frmItem90.GSGCItem90.SetColumnProperty("gvItem90",V.Local.sColumns(V.Local.iCnt),"HeaderFontBold",True)
	F.Intrinsic.Control.Next(V.Local.iCnt)

	'PART
	Gui.frmItem90.GSGCItem90.SetColumnProperty("gvItem90","PART","Caption","Part")
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","PART","MinWidth","80")
	
	'BIN
	Gui.frmItem90.GSGCItem90.SetColumnProperty("gvItem90","BIN","Caption","Bin")
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","BIN","MinWidth","80")
	
	'CONTAINER
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","BIN_DESCRIPTION","Caption","Container#")
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","BIN_DESCRIPTION","MinWidth","100")
	
	'Quantity
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","QUANTITY","Caption","Quantity")
	Gui.frmItem90.GSGCItem90.setColumnProperty("gvItem90","QUANTITY","MinWidth","50")
	Gui.frmItem90.GSGCItem90.SetColumnProperty(gvItem90,"QUANTITY","DisplayCustomNumeric","n4")
	
	Gui.frmItem90.GSGCItem90.ResumeLayout()
	Gui.frmItem90.GSGCItem90.MainView("gvItem90")
	
	'Set Screen Values
	Gui.frmItem90.txtItemPart.Text(V.Args.Part)
	Gui.frmItem90.txtItemLoc.Text("")	
	Gui.frmItem90.txtItemDesc.Text(v.Args.Desc)
	'Qty On Hand
	F.Data.DataTable.Compute("dtItem90","SUM(QUANTITY)","",V.Local.fQtyOnHand)
	Gui.frmItem90.txtInvOnHand.Text(V.Local.fQtyOnHand)
	'Qty Avail
	Gui.frmItem90.txtQtyAvail.Text(V.Local.fQtyOnHand)

	Gui.frmItem90..Show
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.LoadItemMaster90_UDF.End

Program.Sub.LoadStaging.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	F.Intrinsic.Control.If(V.DataTable.dtStaging.Exists)
		F.Data.DataTable.Close("dtStaging")
	F.Intrinsic.Control.EndIf
	
	F.Data.DataTable.CreateFromSQL("dtStaging","con","SELECT Distinct VCM.NAME_CUSTOMER,CAST(VSO.PCK_NO AS NUMERIC(7,0)) AS PCK_NO,VSO.ORDER_NO,VOH.CUSTOMER_PO,VSH.SHP_DATE,CASE WHEN VOH.SHP_HLD_FLAG = 02 OR VOH.SHP_HLD_FLAG = 04 THEN CONVERT(1,SQL_BIT) ELSE CONVERT(0,SQL_BIT) END AS SHP_HLD_FLAG FROM V_STAGING_ORDERS VSO LEFT JOIN V_STAGING_HEADER VSH ON VSO.PCK_NO = CAST(VSH.PCK_NO AS NUMERIC(7, 0)) LEFT JOIN v_ORDER_HEADER VOH ON VSO.ORDER_NO = VOH.ORDER_NO LEFT JOIN V_CUSTOMER_MASTER VCM ON VOH.CUSTOMER = VCM.CUSTOMER  GROUP BY VCM.NAME_CUSTOMER,PCK_NO,VSO.ORDER_NO,VOH.CUSTOMER_PO,VSH.SHP_DATE,SHP_HLD_FLAG ORDER BY VSO.PCK_NO;",True)	
	
	F.Data.DataTable.AddColumn("dtStaging", "LOAD_NO", "Integer")
	F.Data.Dictionary.CreateFromSQL("dLoadNO", "con", "Select ORDER_NO,MAX(LOAD_NO) As LOAD_NO From LOAD_PLAN Group By ORDER_NO Order by ORDER_NO;")
	F.Data.Dictionary.SetDefaultReturn("dLoadNO", 0)
	F.Data.DataTable.FillFromDictionary("dtStaging", "dLoadNO", "ORDER_NO", "LOAD_NO")
	F.Data.Dictionary.Close("dLoadNO")

	F.Intrinsic.Control.CallSub(LoadStagingDetails)	
	F.Intrinsic.Control.CallSub(LoadStagingGV)
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.LoadStaging.End

