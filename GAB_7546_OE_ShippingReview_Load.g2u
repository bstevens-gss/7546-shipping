		F.Intrinsic.Control.CaseAny("Tracking Number","TRACKING_NO")
			'-- Tracking number saves to SHIPMENT_HEADER (staged rows only)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"Packing List",V.Args.RowIndex,V.Local.sPackinglist)
			F.Intrinsic.Control.If(V.Local.sPackinglist.Trim,=,"")
				F.Intrinsic.UI.Msgbox("Cannot edit tracking number - no shipment exists for this line.")
				F.Data.Datatable.SetValue("dtLoad",V.Args.RowIndex,"TRACKING_NO","")
				F.Intrinsic.Control.ExitSub
			F.Intrinsic.Control.EndIf
			'-- Trim leading/trailing spaces from input
			V.Local.sRet.Set(V.Args.Value.Trim)
			F.Data.Datatable.SetValue("dtLoad",V.Args.RowIndex,"TRACKING_NO",V.Local.sRet)
			'-- Propagate to all rows with the same packing list
			F.Intrinsic.String.Build("[Packing List] = '{0}'",V.Local.sPackinglist,V.Local.sFilter)
			F.Data.Datatable.Select("dtLoad",V.Local.sFilter,V.Local.sSel)
			F.Intrinsic.Control.If(V.Local.sSel.Trim,<>,"***NORETURN***")
				F.Intrinsic.String.Split(V.Local.sSel,"*!*",V.Local.sSel)
				F.Intrinsic.Control.For(V.Local.i,0,V.Local.sSel.UBound)
					F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"TRACKING_NO",V.Local.sRet)
				F.Intrinsic.Control.Next(V.Local.i)
			F.Intrinsic.Control.EndIf
			F.Intrinsic.String.Build("UPDATE SHIPMENT_HEADER SET TRACKING_NO = '{0}' WHERE PCK_NO = '{1}';",V.Local.sRet,V.Local.sPackinglist,V.Local.sSQL.PSQLFriendly)
			F.ODBC.Connection!con.Execute(V.Local.sSQL)
			'-- Also update BOL_HEADER if a waybill exists
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"WAY_BILL",V.Args.RowIndex,V.Local.sWaybill)
			F.Intrinsic.Control.If(V.Local.sWaybill.Trim,<>,"")
				F.Intrinsic.String.Build("UPDATE BOL_HEADER SET TRACKING_NO = '{0}' WHERE WAYBILL_NO = '{1}';",V.Local.sRet,V.Local.sWaybill.Trim,V.Local.sSQL)
