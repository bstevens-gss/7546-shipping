Program.Sub.LoadStagingDetails.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sSQL.Declare
	V.Local.sFilter.Declare

'Removing loop here took the time to run from 25 seconds to 1 second

	F.Data.DataTable.CreateFromSQL("dtStagingDetails","con","Select CAST(VSQ.PCK_NO AS NUMERIC(7,0)) AS PCK_NO,VSQ.ORDER_NO,VSQ.LINE,VSQ.PART,VSQ.LOC,VSL.Order_Desc as Description,VSL.QTY_ORDERED,VSL.QTY_SHIPPED,VSL.QTY_BO,VIM.QTY_ONHAND,VOL.CUSTOMER_PART,VOL.PHASE AS PHASE FROM V_STAGING_QUANTITY VSQ LEFT JOIN V_ORDER_LINES VOL ON VSQ.ORDER_NO = VOL.ORDER_NO AND VSQ.LINE = VOL.RECORD_NO LEFT JOIN V_SHIPMENT_LINES VSL ON VOL.ORDER_NO = VSL.ORDER_NO AND VOL.RECORD_NO = VSL.ORDER_REC  AND VSQ.PCK_NO = VSL.PCK_NO LEFT JOIN V_INVENTORY_MSTR VIM ON VOL.PART = VIM.PART AND VOL.LOCATION = VIM.LOCATION ORDER BY VSQ.ORDER_NO, VSQ.LINE;",True)
		
	F.Data.DataTable.CreateFromSQL("dtLTemp","con","Select ORDER_NO, RECORD_NO As Line, OL.Part,OL.Location As LOC, OL.Description, Qty_Ordered, QTY_Shipped,qty_BO,Customer_Part,  IM.Qty_ONHAND  From V_ORDER_LINES OL Left Join Inventory_MSTR IM On OL.Part=IM.Part and OL.Location = IM.Location Where ORDER_NO In(Select ORDER_NO from STAGING_QUANTITY)  AND Order_No+'-'+RECORD_NO NOT In(Select Order_No+'-'+Line from STAGING_QUANTITY) ;")
	F.Data.DataTable.AddColumn("dtLTemp", "PCK_NO", "Long")
	F.Data.Dictionary.CreateFromSQL("dDict", "con", "Select distinct order_no, CAST(PCK_NO AS NUMERIC(7,0)) AS PCK_NO from STAGING_QUANTITY;")
	F.Data.Dictionary.SetDefaultReturn("dDict", 0)
	F.Data.DataTable.FillFromDictionary("dtLTemp", "dDict", "ORDER_NO", "PCK_NO")
	F.Data.Dictionary.Close("dDict")
	
	F.Data.DataTable.Merge("dtLTemp", "dtStagingDetails", True, 2)	
	
	F.Intrinsic.Control.CallSub(AddQTYColumns)
	
	'We'll be filtering the data in the child table to ensure everything in there has a corresponding parent for the relation
	F.Data.DataView.Create("dtStaging", "dvStagingDeets", 22, "", "")
	F.Data.DataView.ToDataTableDistinct("dtStaging", "dvStagingDeets", "dtForDictionary", "PCK_NO*!*ORDER_NO", True)
	F.Data.DataTable.AddExpressionColumn("dtForDictionary", "PCKORDKEY", "String", "[PCK_NO] + '-' + [ORDER_NO]")
	F.Data.DataTable.AddExpressionColumn("dtStagingDetails", "PCKORDKEY", "String", "[PCK_NO] + '-' + [ORDER_NO]")
	F.Data.Dictionary.CreateFromDataTable("dicChild", "dtForDictionary", "PCKORDKEY", "PCKORDKEY")
	F.Data.Dictionary.SetDefaultReturn("dicChild", "-1")
	
	F.Data.DataTable.AddColumn("dtStagingDetails", "VERIFICATION", "String")
	F.Data.DataTable.FillFromDictionary("dtStagingDetails", "dicChild", "PCKORDKEY", "VERIFICATION")
	
	V.Local.sFilter.Set("VERIFICATION <> '-1'")
	
	'Create DataView and filter out locations
	F.Intrinsic.Control.If(V.Global.bUseShippingLocations)
		F.Intrinsic.Control.If(V.Global.bShippingOverride.Not)
			F.Intrinsic.String.Build("{0} and LOC = '{1}'", V.Local.sFilter, V.Global.sShippingLocation, V.Local.sFilter)
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf
	
	F.Data.DataView.Create("dtStagingDetails","dvStagingDetails",22,V.Local.sFilter,"")
	
	'Clean up before moving on
	F.Data.DataTable.RemoveColumn("dtStagingDetails", "VERIFICATION")
	F.Data.DataTable.RemoveColumn("dtStagingDetails", "PCKORDKEY")
	
	F.Data.DataView.Close("dtStaging", "dvStagingDeets")
	F.Data.DataTable.Close("dtForDictionary")
	F.Data.Dictionary.Close("dicChild")
	
	'Convert DV to DT
	F.Data.DataView.ToDataTable("dtStagingDetails","dvStagingDetails","dtStaging$dtStagExpand",True)
	F.Data.DataTable.Close("dtStagingDetails")
	
	'update Staged Flag on Open Orders tab. 
	Function.Intrinsic.Control.CallSub("Update_StagedFlag")

	F.Data.Datatable.AddRelation("dtStaging","PCK_NO*!*ORDER_NO","dtStaging$dtStagExpand","PCK_NO*!*ORDER_NO")
	F.Data.DataTable.AddExpressionColumn("dtStaging", "TOTAL_QTY", "Float", "sum(Child.QTY_ORDERED)")
	F.Data.DataTable.AddExpressionColumn("dtStaging", "QTY_PICKED", "Float", "sum(Child.QTY_SHIPPED)")	
	F.Data.DataTable.AddExpressionColumn("dtStaging", "PCT_COMPLETE", "String", "(Convert(IIF(TOTAL_QTY = 0, 0, ((QTY_PICKED/TOTAL_QTY)*100)), 'System.Int32')) + '%'")
			
	F.Intrinsic.Control.CallSub(LoadStagingDetailsGV)
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.LoadStagingDetails.End

Program.Sub.LoadStagingDetailsGV.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.iCnt.Declare
	V.Local.sColumns.Declare
	
	'Create DataView
	F.Data.DataView.Create("dtStaging$dtStagExpand","dvStagExpand")
	Gui.frmShip.GsGCStaging.AddGridViewFromDataView("gvStagExpand","dtStaging","dvStagExpand")
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","MultiSelect",True)
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","OptionBehaviorEditable",False)
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","ReadOnly",True)
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","AllowSort",True)
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","AllowFilter",True)
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","OptionsDetailShowDetailTabs",False)
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","OptionsViewShowGroupPanel",True)
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","AllowColumnMoving",False)
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","EnableAppearanceOddRow",True)
	Gui.frmShip.GsGCStaging.SetGridViewProperty("gvStagExpand","OptionsViewColumnAutoWidth",False)
	
	'Loop through columns names by using the V.DataTable.dtName.FieldNames
	F.Intrinsic.String.Split(V.DataTable.dtStaging$dtStagExpand.FieldNames,"*!*",V.Local.sColumns)
	F.Intrinsic.Control.For(V.Local.iCnt,0,V.Local.sColumns.UBound,1)
		Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand",V.Local.sColumns(V.Local.iCnt),"HeaderFontBold",True)
	F.Intrinsic.Control.Next(V.Local.iCnt)

	'PCK_NO
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PCK_NO","Visible",False)
	
	'ORDER_NO
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","ORDER_NO","Visible",False)

	'LINE
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","LINE","Caption","Line ")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","LINE","MinWidth","35")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","LINE","HeaderFontBold",True)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","LINE","AllowShowHide",False)
	
	'PART
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PART","Caption","Part ")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PART","MinWidth","150")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PART","HeaderFontBold",True)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PART","AllowShowHide",False)
	
	'LOC
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","LOC","Caption","Location")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","LOC","MinWidth","137")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","LOC","HeaderFontBold",True)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","LOC","AllowShowHide",False)
	
	'DESCRIPTION
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","DESCRIPTION","Caption","Descr")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","DESCRIPTION","MinWidth","137")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","DESCRIPTION","HeaderFontBold",True)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","DESCRIPTION","AllowShowHide",False)
	
	'QTY_ORDERED
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_ORDERED","Caption","Order Qty")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_ORDERED","MinWidth","88")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_ORDERED","HeaderFontBold",True)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_ORDERED","AllowShowHide",False)
	
	'QTY_SHIPPED
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_SHIPPED","Caption","Staged Qty")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_SHIPPED","MinWidth","88")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_SHIPPED","HeaderFontBold",True)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_SHIPPED","AllowShowHide",False)
	
	'QTY_BO
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_BO","Caption","Remaining Qty")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_BO","MinWidth","88")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_BO","HeaderFontBold",True)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_BO","AllowShowHide",False)
	
	'Gui.frmShip.GsGCStaging.AddColumn("gvStagExpand","PCT_STAGED","String",True,True)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PCT_STAGED","Caption","Percent Staged")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PCT_STAGED","MinWidth","88")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PCT_STAGED","HeaderFontBold",True)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PCT_STAGED","AllowShowHide",False)
	
	'QTY_ONHAND
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_ONHAND","Caption","OnHand Qty")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_ONHAND","MinWidth","88")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_ONHAND","HeaderFontBold",True)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","QTY_ONHAND","AllowShowHide",False)
	
	'CUSTOMER_PART
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","CUSTOMER_PART","Caption","Customer Part")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","CUSTOMER_PART","MinWidth","150")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","CUSTOMER_PART","HeaderFontBold",True)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","CUSTOMER_PART","AllowShowHide",False)
	
	'PHASE	
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PHASE","Visible",False)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PHASE","Caption","Phase")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PHASE","MinWidth","45")
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PHASE","HeaderFontBold",True)
	Gui.frmShip.GsGCStaging.SetColumnProperty("gvStagExpand","PHASE","AllowShowHide",False)
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.LoadStagingDetailsGV.End

Program.Sub.AddQTYColumns.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	'Must add the PROJECT column last to perserve serialization. Then fill from dictionary
	f.Data.DataTable.AddColumn("dtStaging","PROJECT","String")
	F.Data.Dictionary.CreateFromSQL("dPROJECT","con","Select ORDER_NO, PROJECT From V_ORDER_HEADER where PROJECT <> ''")
	F.Data.Dictionary.SetDefaultReturn("dPROJECT", "")
	F.Data.DataTable.FillFromDictionary("dtStaging","dPROJECT","ORDER_NO","PROJECT")
	F.Data.Dictionary.Close("dPROJECT")		
	F.Data.DataTable.AddExpressionColumn("dtStagingDetails", "PCT_STAGED", "String", "(Convert(IIF(QTY_ORDERED = 0, 0, ((QTY_SHIPPED/QTY_ORDERED)*100)), 'System.Int32')) + '%'")
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.AddQTYColumns.End

Program.Sub.GsGCStaging_RowCellClick.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sPackList.Declare

	F.Intrinsic.Control.BlockEvents
	
	F.Intrinsic.Control.SelectCase(V.Args.Column)
		Function.Intrinsic.Control.Case("PCK_NO")
			F.Intrinsic.Control.If(V.Global.bShipOEPermission,=,True,or,v.Global.bShipSHIPPermission,=,True)
			f.Intrinsic.Control.AndIf(V.Screen.frmShip!optShip.Value,=,"True")			
				Gui.frmShip.GsGCStaging.GetCellValueByColumnName("gvStaging","PCK_NO",V.Args.RowIndex,V.Local.sPackList)				
				gui.frmShip.tabShip.Enabled(False)
				F.Global.Callwrapper.New("Staging","Inventory.OpenStagingShipments")
				F.Global.Callwrapper.SetProperty("Staging","PackingList",V.Local.sPackList)
				F.Global.CallWrapper.Run("Staging")
				F.Intrinsic.Control.If(V.Screen.frmShip!chkdisablerefresh.Value,=,0)
					F.Intrinsic.Control.CallSub(LoadStaging)
				F.Intrinsic.Control.EndIf
				gui.frmShip.tabShip.Enabled(True)
			F.Intrinsic.Control.EndIf
	Function.Intrinsic.Control.EndSelect
	
	f.Intrinsic.Control.UnBlockEvents
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.GsGCStaging_RowCellClick.End

Program.Sub.GsGCLoad_RowCellClick.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	V.Local.sPart.Declare
	V.Local.sLoc.Declare
	V.Local.sDesc.Declare
	V.Local.sOrderNo.Declare
	V.Local.sOrderLine.Declare
	V.Local.sLoadNo.Declare
	V.Local.sQtyOnHand.Declare
	V.Local.sShipSchd.Declare
	V.Local.sParams.Declare
	V.Local.sSQL.Declare
	V.Local.sPackingList.Declare
	v.Local.bEdit.Declare
	V.Local.sSupDemValue.Declare
	V.Local.sGV.Declare
	V.Local.bOpenSupplyDemand.Declare("Boolean", False)	
	V.Local.sPackList.Declare
	V.Local.sTruckTypeID.Declare
	V.Local.sRet.Declare
	v.Local.sfilter.Declare
	v.Local.sSel.Declare
	v.Local.i.Declare(Long)
	v.Local.sDockID.Declare
	v.Local.sBin.Declare
	V.Local.sordersuffix.Declare
	v.Local.stemp.Declare
	V.Local.sOrder.Declare
	V.Local.sSOLine.Declare
	V.Local.sLine.Declare
	V.Local.sText.Declare
	V.Local.sTextTbl.Declare
	V.Local.sWaybill.Declare
	V.Local.sLocn.Declare
	V.Local.sDock.Declare
	v.Local.dateyyyymmddnnss.Declare(String)
	V.Local.sLOADINGSTATUS.Declare
	V.Local.bHold.Declare
	V.Local.sCarrierCD.Declare
	V.Local.iSrvcType.Declare
	V.Local.sPaymentOption.Declare
	V.Local.sVIA.Declare
	V.Local.sShortDesc.Declare
	V.Local.sLongDesc.Declare
	V.Local.sCSRV.Declare
	V.Local.iStagedCount.Declare(Long)
	V.Local.iNonStagedCount.Declare(Long)
	V.Local.sConfirmMsg.Declare
	V.Local.iConfirmBtn.Declare(Long)
	V.Local.sShipViaDesc.Declare
		
	F.Intrinsic.Control.SelectCase(V.Args.ControlName)
		F.Intrinsic.Control.Case("GSGCALLSHIP")
			V.Local.sGV.Set("gvAllShip")
		F.Intrinsic.Control.Case("GSGCDUE")
			V.Local.sGV.Set("gvDue")
		F.Intrinsic.Control.Case("GSGCLOAD")
			V.Local.sGV.Set("gvLoad")
	F.Intrinsic.Control.EndSelect
	
	F.Intrinsic.Control.BlockEvents
'	Function.Intrinsic.Debug.InvokeDebugger
'	Function.Intrinsic.Debug.Stop
	
	F.Intrinsic.Control.SelectCase(V.Args.Column)
		Function.Intrinsic.Control.Case("PACKING LIST")
		'7/14/25 BY BS
		'ADD LOGIC TO WRITE PO PCK LIST TO PACKING LIST COLUMN IN DT INSTEAD OF CARRIER LOAD NUMBER
		'IF 7551 IS TRUE AND ORDER_SUFFIX IS 'P' THEN RUN SUB TO PRINT OSV PACK LIST
			F.Intrinsic.Control.If(V.Global.bShipOEPermission,=,True,or,v.Global.bShipSHIPPermission,=,True)
			f.Intrinsic.Control.AndIf(V.Screen.frmShip!optShip.Value,=,"True")
			'6/1/26 BS - POR020: Block if row is on shipping hold
			F.Intrinsic.Control.If(V.Global.bIsPOR020,=,True)
				Gui.frmShip.GsGCLoad.GetCellValueByColumnName("gvLoad","SHP_HLD_FLAG",V.Args.RowIndex,V.Local.bHold)
				F.Intrinsic.Control.If(V.Local.bHold,=,True)
					F.Intrinsic.UI.Msgbox("This sales order is on shipping hold. The packing list cannot be opened until the hold is removed.","Warning")
					F.Intrinsic.Control.UnBlockEvents
					F.Intrinsic.Control.ExitSub
				F.Intrinsic.Control.EndIf
			F.Intrinsic.Control.EndIf
				Gui.frmShip.GsGCLoad.GetCellValueByColumnName("gvLoad","Packing List",V.Args.RowIndex,V.Local.sPackList)				
				gui.frmShip.tabShip.Enabled(False)
				F.Global.Callwrapper.New("Staging","Inventory.OpenStagingShipments")
				F.Global.Callwrapper.SetProperty("Staging","PackingList",V.Local.sPackList)
				F.Global.CallWrapper.Run("Staging")
				F.Intrinsic.Control.If(V.Screen.frmShip!chkdisablerefresh.Value,=,0)
					F.Intrinsic.Control.CallSub(cmdrefresh_click)
					'F.Intrinsic.Control.CallSub(LOADLOAD)
				F.Intrinsic.Control.EndIf
				gui.frmShip.tabShip.Enabled(True)
			F.Intrinsic.Control.EndIf
	
		F.Intrinsic.Control.Case("DISPLAY_PART")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"PART",V.Args.RowIndex,V.Local.sPart)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOCATION",V.Args.RowIndex,V.Local.sLoc)
			'Hierarchy - With View or Ship selected we will read the users menu permissions to open the proper Supply and Demand screen.
			'No Dollars
			F.Intrinsic.Control.If(V.Global.bSupDemNODollars)
				V.Local.sSupDemValue.Set("W")
				V.Local.bOpenSupplyDemand.Set(True)
			F.Intrinsic.Control.EndIf
			'View
			F.Intrinsic.Control.If(V.Global.bSupDemView)
				V.Local.sSupDemValue.Set("V")
				V.Local.bOpenSupplyDemand.Set(True)
			F.Intrinsic.Control.EndIf
			'Wth Edit
			F.Intrinsic.Control.If(V.Global.bSupDemEdit)
				V.Local.sSupDemValue.Set("M")
				V.Local.bOpenSupplyDemand.Set(True)
			F.Intrinsic.Control.EndIf
			'New
			F.Intrinsic.Control.If(V.Global.bSupDemNew)
				V.Local.sSupDemValue.Set("M")
				V.Local.bOpenSupplyDemand.Set(True)
			F.Intrinsic.Control.EndIf
			
			F.Intrinsic.Control.If(V.Local.bOpenSupplyDemand)
				F.Intrinsic.String.ConcatCallWrapperArgs(V.Local.sPart,V.Local.sLoc,V.Local.sSupDemValue,V.Local.sParams)
				gui.frmShip.tabShip.Enabled(False)
				F.Global.General.CallWrappersync(300011,v.Local.sParams)
				gui.frmShip.tabShip.Enabled(True)
			F.Intrinsic.Control.EndIf
			
		F.Intrinsic.Control.Case("ORDER_NO")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrderNo)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"RECORD_NO",V.Args.RowIndex,V.Local.sOrderLine)
			F.Intrinsic.String.RPad(V.Local.sOrderLine,"0",4,V.Local.sOrderLine)
			F.Intrinsic.Control.If(v.Global.bViewSO)
				F.Intrinsic.String.Concat(v.Local.sOrderNo,"!*!","V","!*!","*!*ZDR*!*",v.Local.sParams)
				gui.frmShip.tabShip.Enabled(False)
				F.Global.General.CallWrapperSync(200000,V.Local.sParams)
			f.Intrinsic.Control.EndIf			
			f.Intrinsic.Control.UnBlockEvents
			gui.frmShip.tabShip.Enabled(True)
			F.Intrinsic.Control.ExitSub
	
		F.Intrinsic.Control.Case("FLAG_USE_MQD")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"FLAG_USE_MQD",V.Args.RowIndex,v.Local.sShipSchd)
			F.Intrinsic.Control.If(V.Local.sShipSchd,=,"Ship Schd")
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrderNo)
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"RECORD_NO",v.Args.RowIndex,v.Local.sOrderLine)
				Gui.frmShipSch.txtOrder.Text(V.Local.sOrderNo)
				Gui.frmShipSch.txtOrdLn.Text(V.Local.sOrderLine)
				F.Intrinsic.Control.CallSub(LoadShipSched)
			F.Intrinsic.Control.EndIf
			f.Intrinsic.Control.UnBlockEvents
			F.Intrinsic.Control.ExitSub
	
		F.Intrinsic.Control.Case("QTY_ONHAND")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"PART",V.Args.RowIndex,V.Local.sPart)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOCATION",V.Args.RowIndex,V.Local.sLoc)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"DESCRIPTION",V.Args.RowIndex,V.Local.sDesc)
			F.Intrinsic.Control.CallSub(LoadItemMaster,"Part",V.Local.sPart,"Loc",V.Local.sLoc,"Desc",V.Local.sDesc)
			f.Intrinsic.Control.UnBlockEvents
			F.Intrinsic.Control.ExitSub

		F.Intrinsic.Control.Case("QTY_90")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"PART",V.Args.RowIndex,V.Local.sPart)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOCATION",V.Args.RowIndex,V.Local.sLoc)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"DESCRIPTION",V.Args.RowIndex,V.Local.sDesc)
			
			f.Intrinsic.Control.If(V.Screen.frmShip!ddlCalculateMRPOnHand.ItemData,=,4)
				F.Intrinsic.Control.CallSub(LoadItemMaster90_UDF,"Part",V.Local.sPart,"Loc",V.Local.sLoc,"Desc",V.Local.sDesc)
			F.Intrinsic.Control.ELSE
				F.Intrinsic.Control.CallSub(LoadItemMaster90,"Part",V.Local.sPart,"Loc",V.Local.sLoc,"Desc",V.Local.sDesc)
			F.Intrinsic.Control.EndIf
			f.Intrinsic.Control.UnBlockEvents
			F.Intrinsic.Control.ExitSub	
	
		F.Intrinsic.Control.Case("PICKLIST")
			F.Intrinsic.Control.If(V.Global.bShip)				
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrderNo)
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"FLAG_USE_MQD",V.Args.RowIndex,V.Local.sShipSchd)
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOAD NUMBER",V.Args.RowIndex,V.Local.sLoadNo)
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_LINE",V.Args.RowIndex,V.Local.sOrderLine)
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_SUFFIX",V.Args.RowIndex,V.Local.sordersuffix)
				'5/21/26 BS - Skip pick list printing for outside PO lines
				F.Intrinsic.String.Left(V.Local.sordersuffix.Trim,1,V.Local.stemp)
				F.Intrinsic.Control.If(V.Local.stemp,=,"P")
					F.Intrinsic.UI.Msgbox("Pick lists are not available for outside PO lines.","Information")
					F.Intrinsic.Control.ExitSub
				F.Intrinsic.Control.EndIf
				F.Intrinsic.Control.CallSub(PrintPickList,"OrderNo",V.Local.sOrderNo,"OrderLine",V.Local.sOrderLine,"ShipSchd",V.Local.sShipSchd,"LoadNo",V.Local.sLoadNo)
				
				Function.Intrinsic.Control.If(v.Args.bPrinted,=,True)
					Gui.frmShip.[V.Args.ControlName].SetCellValueByColumnName(V.Local.sGV,"PICKLIST",V.Args.RowIndex,"RePrint")
					'TODO...  set Printed Flag for each order in the Load
					'Filter to Load Records, then loop.
					F.Intrinsic.Control.CallSub(UpdatePrintFlag,"Order",V.Local.sOrderNo)
				Function.Intrinsic.Control.EndIf
			
			F.Intrinsic.Control.EndIf

		F.Intrinsic.Control.Case("STAGED")						
			F.Intrinsic.Control.If(V.Screen.frmShip!optShip.Value,=,True)
				F.Intrinsic.Control.AndIf(V.Args.CellValue,=,True)
					Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrderNo)
					F.Intrinsic.String.Build("SELECT TOP 1 PCK_NO FROM STAGING_ORDERS WHERE ORDER_NO = {0}",V.Local.sOrderNo,V.Local.sSQL)
					F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.sPackingList)
					F.Intrinsic.Control.If(V.Local.sPackingList, <>, "")
						gui.frmShip.tabShip.Enabled(False)
						F.Global.Callwrapper.New("Staged","Inventory.OpenStagingShipments")
						F.Global.Callwrapper.SetProperty("Staged","PackingList",V.Local.sPackingList)
						F.Global.CallWrapper.Run("Staged")
						gui.frmShip.tabShip.Enabled(True)
						f.Intrinsic.Control.CallSub(cmdrefresh_click)
					F.Intrinsic.Control.EndIf
			F.Intrinsic.Control.EndIf	
			
		f.Intrinsic.Control.Case("ASSIGNED_TO")			
			'means they have some selected build our browser.
			Function.Intrinsic.Control.If(v.DataTable.dtMobileUsers.Exists,=,False)
				'get all gS MObile users.Common Connection
				F.ODBC.Connection!conC.OpenCommonConnection
				F.Data.Datatable.CreateFromSQL("dtMobileUsers","conC","Select UserID,lTrim(Rtrim(Name)) As Name,Employee_ID From MOBILE_USER_INFO")
				'Add ClockIn and how many assigned orders they are assigned to columns. Fill them from dict above.
				F.Data.Datatable.AddColumn("dtMobileUsers","Clocked_In","String","") 
				F.Data.Datatable.AddColumn("dtMobileUsers","NumAssigned","Integer",0)
				'close common
				F.ODBC.Connection!conC.Close
			Function.Intrinsic.Control.EndIf	
			'get clocked in users.
			F.Data.Dictionary.CreateFromSQL("dicClockIn","con","Select Employee,Clocked_In From TIME_ATTENDANCE Where Clocked_IN = 'Y'")		
			'get number of assignments they currently have assigned to them
			F.Data.Dictionary.CreateFromSQL("dicAssigned","con","Select Assigned_To,Count(Order_Line) As Count_Amt From Load_Plan Group By Assigned_To")	
			F.Data.Dictionary.SetDefaultReturn("dicAssigned","0")
			Function.Data.Dictionary.SetDefaultReturn("dicClockIn","")
			F.Data.Datatable.FillFromDictionary("dtMobileUsers","dicClockIn","EMPLOYEE_ID","Clocked_In")
			F.Data.Datatable.FillFromDictionary("dtMobileUsers","dicAssigned","USERID","NumAssigned")	
			f.Data.DataTable.AddRow("dtMobileUsers","USERID","~ANY", "Name","Any Picker","EMPLOYEE_ID"," ","Clocked_In", " ")	
			f.Data.Dictionary.Close("dicClockIn")
			f.Data.Dictionary.Close("dicAssigned")
			'browser from datatable. 
			'title (0), dt (1), column titles (2), column widths (3), sret (4)
			F.Intrinsic.UI.BrowserFromDataTable("Select a GS Mobile User","dtMobileUsers","GS Mobile User*!*Name*!*Employee ID*!*Clocked In*!*Assigned Count","100*!*150*!*0*!*100*!*100",v.Local.sRet)	
			Function.Intrinsic.Control.If(v.Local.sRet.Trim,<>,"***CANCEL***")
				f.Intrinsic.String.Split(v.Local.sRet,"*!*",v.Local.sret) 
				'split the selection from above 
				F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)	
				'update the Mobile User chosen from browser (sRet) into each Assign Picker chcked lined in gv (SSEL) 				
				'set the mobile use column
				F.Data.Datatable.SetValue("dtLoad",V.Args.RowIndex,"ASSIGNED_TO",v.local.sRet(0).trim)
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrderNo)
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"Order_Line",V.Args.RowIndex,V.Local.sOrderLine)
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_SUFFIX",V.Args.RowIndex,V.Local.sordersuffix)
				F.Intrinsic.String.Build("UPDATE LOAD_PLAN SET ASSIGNED_TO = '{3}' WHERE ORDER_NO = '{0}' AND ORDER_LINE = '{1}' AND ORDER_SUFFIX = '{2}' and LOAD_NO <> 0;",V.Local.sOrderNo,V.Local.sOrderLine,V.Local.sOrderSuffix,v.local.sRet(0).trim,V.Local.sSQL)
				F.ODBC.Connection!con.Execute(V.Local.sSQL)
				gui.frmShip.lblRunMRP.Visible(True)
			f.Intrinsic.Control.EndIf
		
		f.Intrinsic.Control.Case("TRUCK TYPE ID")	
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOAD NUMBER",V.Args.RowIndex,V.Local.sLoadNo)
			f.Intrinsic.String.Build("[LOAD NUMBER] = {0} and [LOAD NUMBER] <> 0 and [LOAD NUMBER] <> 9999",V.Local.sLoadNo,v.Local.sfilter)
			F.Data.Datatable.Select("dtLoad",v.Local.sfilter,v.Local.sSel)	
			Function.Intrinsic.Control.If(v.Local.sSel.Trim,<>,"***NORETURN***")
				'create browser from TRUCK IDs
				F.Data.Datatable.CreateFromSQL("dtTruckType","con","SELECT TYPE_ID, DESCRIPTION, LENGTH, WIDTH,MAX_WEIGHT_LBS,PERCENT_CAPACITY from TRUCK_TYPE order by TYPE_ID")
	'			'browser from datatable. 
				'title (0), dt (1), column titles (2), column widths (3), sret (4)
				F.Intrinsic.UI.BrowserFromDataTable("Select a Truck Type ID","dtTruckType","Type_ID*!*DESCRIPTION*!*LENGTH*!*WIDTH*!*MAX_WEIGHT*!*PERCENT_CAPACITY","200*!*300*!*200*!*200*!*200*!*200",v.Local.sRet)
				Function.Intrinsic.Control.If(v.Local.sRet.Trim,<>,"***CANCEL***")
					f.Intrinsic.String.Split(v.Local.sRet,"*!*",v.Local.sret)
					V.Local.sTruckTypeID.Set(V.Local.sRet(0))
				f.Intrinsic.Control.Else
					Function.Intrinsic.Control.UnBlockEvents
					f.Intrinsic.Control.ExitSub
				f.Intrinsic.Control.EndIf			
	'			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOAD NUMBER",V.Args.RowIndex,V.Local.sLoadNo)
	'			f.Intrinsic.String.Build("[LOAD NUMBER] = {0} and [LOAD NUMBER] <> 0 and [LOAD NUMBER] <> 9999",V.Local.sLoadNo,v.Local.sfilter)
	'			F.Data.Datatable.Select("dtLoad",v.Local.sfilter,v.Local.sSel)	
	'			Function.Intrinsic.Control.If(v.Local.sSel.Trim,<>,"***NORETURN***")
					F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
					F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
						'update gridview with truckID for load number selected				
						F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"TRUCK TYPE ID",v.Local.sRet(0))	
						F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"TRUCK DESCRIPTION",v.Local.sRet(1))
						F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"Truck Max Weight(lbs)",v.Local.sRet(4))
						f.Intrinsic.Math.Mult(v.Local.sRet(2),v.Local.sRet(3),v.Local.sRet(5),v.Local.stemp)
						f.Intrinsic.Math.Div(v.Local.stemp,100,v.Local.stemp)
						F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"Truck SF Capacity",v.Local.stemp)
					F.Intrinsic.Control.Next(v.Local.i)	
					F.Intrinsic.String.Build("UPDATE LOAD_PLAN SET TRUCK_TYPE = '{1}' WHERE LOAD_NO = {0} ;",v.Local.sLoadNo,V.Local.sTruckTypeID,V.Local.sSQL)
				F.ODBC.Connection!con.Execute(V.Local.sSQL)
			F.Intrinsic.Control.Else
				F.Intrinsic.UI.Msgbox("Load must not be 0 or 9999.")
				Function.Intrinsic.Control.UnBlockEvents
				f.Intrinsic.Control.ExitSub
			F.Intrinsic.Control.EndIf
		f.Intrinsic.Control.Case("DOCK ID")		
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOAD NUMBER",V.Args.RowIndex,V.Local.sLoadNo)
			f.Intrinsic.String.Build("[LOAD NUMBER] = {0} and [LOAD NUMBER] <> 0 and [LOAD NUMBER] <> 9999",V.Local.sLoadNo,v.Local.sfilter)
			F.Data.Datatable.Select("dtLoad",v.Local.sfilter,v.Local.sSel)	
			Function.Intrinsic.Control.If(v.Local.sSel.Trim,<>,"***NORETURN***")
				'create browser from Dock IDs
				F.Data.Datatable.CreateFromSQL("dtDockNo","con","SELECT DOCK_NO, DOCK_TYPE, DOCK_DESC from DOCK_TYPE ORDER BY DOCK_NO")
	'			'browser from datatable. 
				'title (0), dt (1), column titles (2), column widths (3), sret (4)
				F.Intrinsic.UI.BrowserFromDataTable("Select a Dock Number","dtDockNo","DOCK_NO*!*DOCK_TYPE*!*DOCK_DESC","200*!*200*!*300",v.Local.sRet)
				Function.Intrinsic.Control.If(v.Local.sRet.Trim,<>,"***CANCEL***")
					f.Intrinsic.String.Split(v.Local.sRet,"*!*",v.Local.sret)
					V.Local.sDockID.Set(V.Local.sRet(0))
				f.Intrinsic.Control.Else
					Function.Intrinsic.Control.UnBlockEvents
					f.Intrinsic.Control.ExitSub
				f.Intrinsic.Control.EndIf			
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOAD NUMBER",V.Args.RowIndex,V.Local.sLoadNo)
				f.Intrinsic.String.Build("[LOAD NUMBER] = {0} and [LOAD NUMBER] <> 0 and [LOAD NUMBER] <> 9999",V.Local.sLoadNo,v.Local.sfilter)
				F.Data.Datatable.Select("dtLoad",v.Local.sfilter,v.Local.sSel)	
				Function.Intrinsic.Control.If(v.Local.sSel.Trim,<>,"***NORETURN***")
					F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
					F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
						'update gridview with truckID for load number selected
						F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"DOCK ID",v.Local.sRet(0))					
					F.Intrinsic.Control.Next(v.Local.i)
					F.Intrinsic.String.Build("UPDATE LOAD_PLAN SET DOCK_NO = '{1}' WHERE LOAD_NO = {0} ;",v.Local.sLoadNo,V.Local.sDockID,V.Local.sSQL)
					F.ODBC.Connection!con.Execute(V.Local.sSQL)
				F.Intrinsic.Control.Else
					F.Intrinsic.UI.Msgbox("Load must not be 0 or 9999.")
					Function.Intrinsic.Control.UnBlockEvents
					f.Intrinsic.Control.ExitSub
				F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.Else
			F.Intrinsic.UI.Msgbox("Load must not be 0 or 9999.")
			Function.Intrinsic.Control.UnBlockEvents
			f.Intrinsic.Control.ExitSub
		F.Intrinsic.Control.EndIf	
		F.Intrinsic.Control.CaseAny("CARRIER_CD","Carrier","CARRIER")
		'-- OE_CARRIER browser: select carrier and sync to orders/shipments
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOAD NUMBER",V.Args.RowIndex,V.Local.sLoadNo)
			f.Intrinsic.String.Build("[LOAD NUMBER] = {0} and [LOAD NUMBER] <> 0 and [LOAD NUMBER] <> 9999",V.Local.sLoadNo,v.Local.sfilter)
			F.Data.Datatable.Select("dtLoad",v.Local.sfilter,v.Local.sSel)
			Function.Intrinsic.Control.If(v.Local.sSel.Trim,<>,"***NORETURN***")
				'-- Query OE_CARRIER for browser
				F.Intrinsic.Control.If(V.DataTable.dtCarrier.Exists,=,True)
					F.Data.DataTable.Close("dtCarrier")
				F.Intrinsic.Control.EndIf
				F.Data.Datatable.CreateFromSQL("dtCarrier","con","SELECT RTRIM(CARRIER_CD) AS CARRIER_CD, SRVC_TYPE, RTRIM(SHORT_DESC) AS SHORT_DESC, RTRIM(LONG_DESC) AS LONG_DESC, RTRIM(PAYMENT_OPTION) AS PAYMENT_OPTION, RTRIM(VIA) AS VIA FROM V_OE_CARRIER ORDER BY CARRIER_CD, SRVC_TYPE")
				F.Intrinsic.UI.BrowserFromDataTable("Select a Carrier","dtCarrier","CARRIER_CD*!*SRVC_TYPE*!*SHORT_DESC*!*LONG_DESC*!*PAYMENT_OPTION*!*VIA","100*!*80*!*200*!*300*!*100*!*60",v.Local.sRet)
				Function.Intrinsic.Control.If(v.Local.sRet.Trim,<>,"***CANCEL***")
					f.Intrinsic.String.Split(v.Local.sRet,"*!*",v.Local.sret)
					V.Local.sCarrierCD.Set(V.Local.sRet(0))
					V.Local.iSrvcType.Set(V.Local.sRet(1))
					V.Local.sShortDesc.Set(V.Local.sRet(2))
					V.Local.sLongDesc.Set(V.Local.sRet(3))
					V.Local.sPaymentOption.Set(V.Local.sRet(4))
					V.Local.sVIA.Set(V.Local.sRet(5))
				f.Intrinsic.Control.Else
					F.Data.DataTable.Close("dtCarrier")
					Function.Intrinsic.Control.UnBlockEvents
					f.Intrinsic.Control.ExitSub
				f.Intrinsic.Control.EndIf
				F.Data.DataTable.Close("dtCarrier")
				'-- Count distinct packing lists and distinct orders for confirmation
				F.Intrinsic.String.Build("SELECT COUNT(DISTINCT H.PCK_NO) FROM LOAD_PLAN G, STAGING_QUANTITY H WHERE G.ORDER_NO = H.ORDER_NO AND G.ORDER_LINE = H.LINE AND G.LOAD_NO = {0} AND G.ORDER_SUFFIX <> 'P' AND H.PCK_NO <> ''",V.Local.sLoadNo,V.Local.sSQL)
				F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.iStagedCount)
				F.Intrinsic.Control.If(V.Ambient.ExecuteAndReturnEOF,=,True)
					V.Local.iStagedCount.Set(0)
				F.Intrinsic.Control.EndIf
				F.Intrinsic.String.Build("SELECT COUNT(DISTINCT G.ORDER_NO) FROM LOAD_PLAN G WHERE G.LOAD_NO = {0} AND G.ORDER_SUFFIX <> 'P'",V.Local.sLoadNo,V.Local.sSQL)
				F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.iNonStagedCount)
				F.Intrinsic.Control.If(V.Ambient.ExecuteAndReturnEOF,=,True)
					V.Local.iNonStagedCount.Set(0)
				F.Intrinsic.Control.EndIf
				'-- Confirmation dialog
				F.Intrinsic.String.Build("Change carrier to {0} / {1} for {2} packing list(s) and {3} sales order(s)?",V.Local.sCarrierCD,V.Local.sShortDesc,V.Local.iStagedCount,V.Local.iNonStagedCount,V.Local.sConfirmMsg)
				F.Intrinsic.UI.Msgbox(V.Local.sConfirmMsg,"Confirm Carrier Change",V.Enum.MsgBoxStyle!YesNo,V.Local.iConfirmBtn)
				F.Intrinsic.Control.If(V.Local.iConfirmBtn,<>,6)
					Function.Intrinsic.Control.UnBlockEvents
					f.Intrinsic.Control.ExitSub
				F.Intrinsic.Control.EndIf
				'-- Resolve SHIP_VIA description for grid display
				V.Local.sShipViaDesc.Set("")
				F.Intrinsic.String.Build("SELECT RTRIM(MESSAGE) FROM SHIP_VIA WHERE ID = '{0}'",V.Local.sVIA,V.Local.sSQL)
				F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.sShipViaDesc)
				F.Intrinsic.Control.If(V.Ambient.ExecuteAndReturnEOF,=,True)
					V.Local.sShipViaDesc.Set("")
				F.Intrinsic.Control.EndIf
				'-- Update all dtLoad rows on this load with selected carrier
				f.Intrinsic.String.Build("[LOAD NUMBER] = {0} and [LOAD NUMBER] <> 0 and [LOAD NUMBER] <> 9999",V.Local.sLoadNo,v.Local.sfilter)
				F.Data.Datatable.Select("dtLoad",v.Local.sfilter,v.Local.sSel)
				F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
				F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
					F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"CARRIER_CD",V.Local.sCarrierCD)
					F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"CARR_SHORT_DESC",V.Local.sShortDesc)
					F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"CARR_LONG_DESC",V.Local.sLongDesc)
					F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"SHIP_VIA_SHIP",V.Local.sShipViaDesc)
				F.Intrinsic.Control.Next(v.Local.i)
				'-- Update LOAD_PLAN.CARRIER in database
				F.Intrinsic.String.Build("UPDATE LOAD_PLAN SET CARRIER = '{0}' WHERE LOAD_NO = {1}",V.Local.sCarrierCD,V.Local.sLoadNo,V.Local.sSQL)
				F.ODBC.Connection!con.Execute(V.Local.sSQL)
				'-- Sync carrier to orders/shipments via SyncCarrierFromLoad
				F.Intrinsic.Control.CallSub(SyncCarrierFromLoad,"sLoadNo",V.Local.sLoadNo,"sCarrierCD",V.Local.sCarrierCD,"iSrvcType",V.Local.iSrvcType,"sPaymentOption",V.Local.sPaymentOption,"sVIA",V.Local.sVIA)
				gui.frmShip.lblRunMRP.Visible(True)
			F.Intrinsic.Control.Else
				F.Intrinsic.UI.Msgbox("Load must not be 0 or 9999.")
				Function.Intrinsic.Control.UnBlockEvents
				f.Intrinsic.Control.ExitSub
			F.Intrinsic.Control.EndIf
			
		f.Intrinsic.Control.Case("STAGING BIN")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOAD NUMBER",V.Args.RowIndex,V.Local.sLoadNo)
			f.Intrinsic.String.Build("[LOAD NUMBER] = {0} and [LOAD NUMBER] <> 0 and [LOAD NUMBER] <> 9999",V.Local.sLoadNo,v.Local.sfilter)
			F.Data.Datatable.Select("dtLoad",v.Local.sfilter,v.Local.sSel)	
			Function.Intrinsic.Control.If(v.Local.sSel.Trim,<>,"***NORETURN***")
				'create browser from Bin master
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOCATION",V.Args.RowIndex,V.Local.sLoc)
				F.Intrinsic.String.Build("SELECT BIN,BIN_DESCRIPTION FROM BIN_MASTER WHERE LOCATION = '{0}' ORDER BY BIN;",V.Local.sLoc,V.Local.sSQL)
				F.Data.Datatable.CreateFromSQL("dtBin","con",V.Local.sSQL)
	'			'browser from datatable. 
				'title (0), dt (1), column titles (2), column widths (3), sret (4)
				F.Intrinsic.UI.BrowserFromDataTable("Select a Bin to Stage into","dtBin","BIN*!*BIN_DESCRIPTION","200*!*300",v.Local.sRet)
				Function.Intrinsic.Control.If(v.Local.sRet.Trim,<>,"***CANCEL***")
					f.Intrinsic.String.Split(v.Local.sRet,"*!*",v.Local.sret)
					V.Local.sBin.Set(V.Local.sRet(0))
				f.Intrinsic.Control.Else
					Function.Intrinsic.Control.UnBlockEvents
					f.Intrinsic.Control.ExitSub
				f.Intrinsic.Control.EndIf			
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOAD NUMBER",V.Args.RowIndex,V.Local.sLoadNo)
				f.Intrinsic.String.Build("[LOAD NUMBER] = {0} and [LOAD NUMBER] <> 0",V.Local.sLoadNo,v.Local.sfilter)
				F.Data.Datatable.Select("dtLoad",v.Local.sfilter,v.Local.sSel)
				Function.Intrinsic.Control.If(v.Local.sSel.Trim,<>,"***NORETURN***")
					F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
					F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
						'update gridview with Staging_Bin for load number selected
						F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"STAGING BIN",v.Local.sRet(0))					
					F.Intrinsic.Control.Next(v.Local.i)	
					F.Intrinsic.String.Build("UPDATE LOAD_PLAN SET STAGING_BIN = '{1}' WHERE LOAD_NO = {0};",v.Local.sLoadNo,V.Local.sBin,V.Local.sSQL)
					F.ODBC.Connection!con.Execute(V.Local.sSQL)
				f.Intrinsic.Control.Else
					Function.Intrinsic.Control.UnBlockEvents
					f.Intrinsic.Control.ExitSub
				F.Intrinsic.Control.EndIf
			F.Intrinsic.Control.Else
				F.Intrinsic.UI.Msgbox("Load must not be 0 or 9999.")
				Function.Intrinsic.Control.UnBlockEvents
				f.Intrinsic.Control.ExitSub
			F.Intrinsic.Control.EndIf
			
		F.Intrinsic.Control.Case("LOADING_STATUS")
		v.Local.dateyyyymmddnnss.Set(v.Ambient.Time)
		f.Intrinsic.String.Concat(v.Ambient.Date.PSQLFriendly," ",v.Ambient.Time.PSQLFriendly,v.Local.dateyyyymmddnnss)
		f.Intrinsic.String.Format(v.Local.dateyyyymmddnnss,"YYYY-MM-DD HH:NN:SS.000",v.Local.dateyyyymmddnnss)
		
		Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrder)
		Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"Order_Line",V.Args.RowIndex,V.Local.sLine)
		Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_SUFFIX",V.Args.RowIndex,V.Local.sOrderSuffix)
		Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOAD NUMBER",V.Args.RowIndex,V.Local.sLoadNo)
		Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"DOCK ID",V.Args.RowIndex,V.Local.sDock)
		Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOADING_STATUS",V.Args.RowIndex,V.Local.sLOADINGSTATUS)
		F.Intrinsic.String.Build("SELECT * FROM LOAD_PLAN WHERE ORDER_NO = '{0}' AND ORDER_LINE = '{1}' AND ORDER_SUFFIX = '{2}' and LOAD_NO NOT IN (0,9999);",V.Local.sOrder,V.Local.sLine,V.Local.sOrderSuffix,V.Local.sSQL)
		F.ODBC.Connection!con.OpenRecordsetRO("rstloading",V.Local.sSQL)
		F.Intrinsic.Control.If(V.ODBC.con!rstloading.EOF,=,True)
			F.ODBC.con!rstloading.Close
			Function.Intrinsic.Control.UnBlockEvents
			F.Data.Datatable.SetValue("dtLoad",V.Args.RowIndex,"LOADING_STATUS",0)
			F.Intrinsic.UI.Msgbox("Load must not be 0 or 9999.")				
			f.Intrinsic.Control.ExitSub						
		F.Intrinsic.Control.EndIf
		F.ODBC.con!rstloading.Close
		'validate if Dock/Truck is not blank
		f.Intrinsic.Control.If(v.Local.sDock.Trim,=,"")
		'f.Intrinsic.Control.AndIf(v.Args.value,=,True)
			'F.ODBC.con!rstloading.Close	
			Function.Intrinsic.Control.UnBlockEvents
			F.Data.Datatable.SetValue("dtLoad",V.Args.RowIndex,"LOADING_STATUS",0)
			f.Intrinsic.String.Build("Can not start loading Load {0} with Dock Number not set.",v.Local.sLoadNo,v.Local.sSQL)
			F.Intrinsic.UI.Msgbox(v.Local.sSQL)
			f.Intrinsic.Control.ExitSub	
		f.Intrinsic.Control.EndIf
		'validate if dock is active for another load
		F.Intrinsic.String.Build("SELECT LOAD, DOCK FROM GCG_5235_RFID_LOAD WHERE ACTIVE =1 AND LOAD <> {0} and DOCK = '{1}';",V.Local.sLoadNo,V.Local.sDock.Trim,V.Local.sSQL)				
		F.ODBC.Connection!con.OpenRecordsetRO("rsttest",V.Local.sSQL)
		F.Intrinsic.Control.If(V.ODBC.con!rsttest.EOF,<>,True)	
			Function.Intrinsic.Control.UnBlockEvents
			F.Data.Datatable.SetValue("dtLoad",V.Args.RowIndex,"LOADING_STATUS",0)
			f.Intrinsic.String.Build("Load {0} is active for same Dock {1}.",V.ODBC.Con!rsttest.FieldValTrim!LOAD,V.ODBC.Con!rsttest.FieldValTrim!DOCK,v.Local.sSQL)
			F.Intrinsic.UI.Msgbox(v.Local.sSQL)
			F.ODBC.con!rsttest.Close
			f.Intrinsic.Control.ExitSub					
		F.Intrinsic.Control.EndIf
		F.ODBC.con!rsttest.Close
		'check if there is a record in GCG_5235_RFID_LOAD for active load#
		F.Intrinsic.String.Build("SELECT LOAD FROM GCG_5235_RFID_LOAD WHERE LOAD = {0};",V.Local.sLoadNo,V.Local.sDock,V.Local.sSQL)
		F.ODBC.Connection!con.OpenRecordsetRO("rstexist",V.Local.sSQL)
		F.Intrinsic.Control.If(V.ODBC.con!rstexist.EOF,=,True)					
			F.Intrinsic.String.Build("INSERT INTO GCG_5235_RFID_LOAD (LOAD,DOCK,ACTIVE,MOBILEUSER) VALUES({4},'{5}',{0},'{6}')",1,V.Local.sOrder,V.Local.sLine,V.Local.sOrderSuffix,V.Local.sLoadNo,V.Local.sDock.Trim,V.Caller.User,V.Local.sSQL)				
			F.ODBC.Connection!con.Execute(V.Local.sSQL)	
			f.Intrinsic.String.Build("[LOAD NUMBER] = {0} AND [LOAD NUMBER] <> 0 AND [LOAD NUMBER] <> 9999",V.Local.sLoadNo,v.Local.sfilter)
			F.Data.Datatable.Select("dtLoad",v.Local.sfilter,v.Local.sSel)					
			Function.Intrinsic.Control.If(v.Local.sSel.Trim,<>,"***NORETURN***")
				F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
				F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
					'update gridview with LOADING STATUS TRUE/FALSE for load number selected
					F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"LOADING_STATUS",1)						
				F.Intrinsic.Control.Next(v.Local.i)	
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.Else
		Function.Intrinsic.Debug.Stop
			F.Intrinsic.Control.If(V.Local.sLOADINGSTATUS,=,True)			
				f.Intrinsic.String.Build("[LOAD NUMBER] = {0} AND [LOAD NUMBER] <> 0 AND [LOAD NUMBER] <> 9999 and [LOADING_STATUS] = 1",V.Local.sLoadNo,v.Local.sfilter)
				F.Data.Datatable.Select("dtLoad",v.Local.sfilter,v.Local.sSel)					
				Function.Intrinsic.Control.If(v.Local.sSel.Trim,<>,"***NORETURN***")
					F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
					F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
						'update gridview with LOADING STATUS TRUE/FALSE for load number selected
						F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"LOADING_STATUS",0)						
					F.Intrinsic.Control.Next(v.Local.i)	
						F.Intrinsic.String.Build("UPDATE GCG_5235_RFID_LOAD SET ACTIVE = 0, MOBILEUSER='{6}',ENDDATE = '{7}' WHERE LOAD = {4} AND DOCK = '{5}';","",V.Local.sOrder,V.Local.sLine,V.Local.sOrderSuffix,V.Local.sLoadNo,V.Local.sDock.Trim,V.Caller.User,v.Local.dateyyyymmddnnss,V.Local.sSQL)
					F.ODBC.Connection!con.Execute(V.Local.sSQL)
				F.Intrinsic.Control.Else
					Function.Intrinsic.Control.UnBlockEvents
					f.Intrinsic.Control.ExitSub
					F.ODBC.con!rstexist.Close
				F.Intrinsic.Control.EndIf
			F.Intrinsic.Control.Else			
				f.Intrinsic.String.Build("[LOAD NUMBER] = {0} AND [LOAD NUMBER] <> 0 AND [LOAD NUMBER] <> 9999 and [LOADING_STATUS] = 0",V.Local.sLoadNo,v.Local.sfilter)
				F.Data.Datatable.Select("dtLoad",v.Local.sfilter,v.Local.sSel)					
				Function.Intrinsic.Control.If(v.Local.sSel.Trim,<>,"***NORETURN***")
					F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
					F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
						'update gridview with LOADING STATUS TRUE/FALSE for load number selected
						F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"LOADING_STATUS",1)						
					F.Intrinsic.Control.Next(v.Local.i)	
						F.Intrinsic.String.Build("UPDATE GCG_5235_RFID_LOAD SET ACTIVE = 1, MOBILEUSER='{6}',STARTDATE = '{7}', ENDDATE = ('1900-01-01') WHERE LOAD = {4} AND DOCK = '{5}';","",V.Local.sOrder,V.Local.sLine,V.Local.sOrderSuffix,V.Local.sLoadNo,V.Local.sDock.Trim,V.Caller.User,v.Local.dateyyyymmddnnss,V.Local.sSQL)
					F.ODBC.Connection!con.Execute(V.Local.sSQL)
				F.Intrinsic.Control.Else
					Function.Intrinsic.Control.UnBlockEvents
					f.Intrinsic.Control.ExitSub
					F.ODBC.con!rstexist.Close
				F.Intrinsic.Control.EndIf
			F.Intrinsic.Control.EndIf
			'F.ODBC.con!rsttest.Close
			
			
		F.Intrinsic.Control.EndIf
	'f.Intrinsic.Control.EndIf
		
		'F.ODBC.con!rstloading.Close	
		F.ODBC.con!rstexist.Close
		'F.ODBC.con!rsttest.Close		
			
		F.Intrinsic.Control.Case("BOL_SHIP_FROM")
			'-- BOL Ship From: browse LOCATION_ADDRESS and update BOL_HEADER ship-from fields
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"WAY_BILL",V.Args.RowIndex,V.Local.sWaybill)
			'-- Validate: must have a staged BOL/waybill number
			F.Intrinsic.Control.If(V.Local.sWaybill.Trim,=,"")
				F.Intrinsic.UI.Msgbox("No BOL exists for this line. Stage the order first.")
				Function.Intrinsic.Control.UnBlockEvents
				f.Intrinsic.Control.ExitSub
			F.Intrinsic.Control.EndIf
			'-- Query LOCATION_ADDRESS for browser
			F.Intrinsic.Control.If(V.DataTable.dtLocAddr.Exists,=,True)
				F.Data.DataTable.Close("dtLocAddr")
			F.Intrinsic.Control.EndIf
			F.Data.Datatable.CreateFromSQL("dtLocAddr","con","SELECT RTRIM(LOCN) AS LOCN, RTRIM(NAME) AS NAME, RTRIM(ADRS1) AS ADRS1, RTRIM(CITY) AS CITY, RTRIM(STATE) AS STATE, RTRIM(ZIP) AS ZIP FROM V_LOCATION_ADDRESS ORDER BY LOCN")
			'-- Browser popup
			F.Intrinsic.UI.BrowserFromDataTable("Select Ship From Location","dtLocAddr","LOCN*!*NAME*!*ADRS1*!*CITY*!*STATE*!*ZIP","60*!*200*!*200*!*150*!*60*!*100",v.Local.sRet)
			Function.Intrinsic.Control.If(v.Local.sRet.Trim,<>,"***CANCEL***")
				f.Intrinsic.String.Split(v.Local.sRet,"*!*",v.Local.sret)
				V.Local.sLocn.Set(V.Local.sRet(0))
				'-- Query full address from LOCATION_ADDRESS for the selected LOCN
				F.Intrinsic.Control.If(V.DataTable.dtLocFull.Exists,=,True)
					F.Data.DataTable.Close("dtLocFull")
				F.Intrinsic.Control.EndIf
				F.Intrinsic.String.Build("SELECT RTRIM(NAME) AS NAME, RTRIM(ADRS1) AS ADRS1, RTRIM(ADRS2) AS ADRS2, RTRIM(ADRS3) AS ADRS3, RTRIM(ADRS4) AS ADRS4, RTRIM(ADRS5) AS ADRS5, RTRIM(CITY) AS CITY, RTRIM(STATE) AS STATE, RTRIM(ZIP) AS ZIP, RTRIM(COUNTRY) AS COUNTRY, RTRIM(TELEPHONE) AS TELEPHONE, RTRIM(FAX) AS FAX FROM V_LOCATION_ADDRESS WHERE LOCN = '{0}'",V.Local.sLocn.PSQLFriendly,V.Local.sSQL)
				F.Data.Datatable.CreateFromSQL("dtLocFull","con",V.Local.sSQL)
				'-- Build UPDATE for BOL_HEADER with address from selected location
				F.Intrinsic.String.Build("UPDATE BOL_HEADER SET FROM_NAME = '{0}', FROM_ADRS1 = '{1}', FROM_ADRS2 = '{2}', FROM_ADRS3 = '{3}', FROM_ADRS4 = '{4}', FROM_ADRS5 = '{5}', FROM_CITY = '{6}', FROM_STATE = '{7}', FROM_ZIP = '{8}', FROM_COUNTRY = '{9}', FROM_TELEPHONE = '{10}', FROM_FAX = '{11}' WHERE WAYBILL_NO = '{12}'",V.DataTable.dtLocFull(0).NAME!FieldValTrim,V.DataTable.dtLocFull(0).ADRS1!FieldValTrim,V.DataTable.dtLocFull(0).ADRS2!FieldValTrim,V.DataTable.dtLocFull(0).ADRS3!FieldValTrim,V.DataTable.dtLocFull(0).ADRS4!FieldValTrim,V.DataTable.dtLocFull(0).ADRS5!FieldValTrim,V.DataTable.dtLocFull(0).CITY!FieldValTrim,V.DataTable.dtLocFull(0).STATE!FieldValTrim,V.DataTable.dtLocFull(0).ZIP!FieldValTrim,V.DataTable.dtLocFull(0).COUNTRY!FieldValTrim,V.DataTable.dtLocFull(0).TELEPHONE!FieldValTrim,V.DataTable.dtLocFull(0).FAX!FieldValTrim,V.Local.sWaybill,V.Local.sSQL)
				F.ODBC.Connection!con.Execute(V.Local.sSQL)
				'-- Update all grid rows sharing this WAY_BILL
				F.Intrinsic.String.Build("[WAY_BILL] = '{0}'",V.Local.sWaybill,V.Local.sFilter)
				F.Data.Datatable.Select("dtLoad",V.Local.sFilter,V.Local.sSel)
				F.Intrinsic.Control.If(V.Local.sSel.Trim,<>,"***NORETURN***")
					F.Intrinsic.String.Split(V.Local.sSel,"*!*",V.Local.sSel)
					F.Intrinsic.Control.For(V.Local.i,0,V.Local.sSel.UBound)
						F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"BOL_SHIP_FROM",V.DataTable.dtLocFull(0).NAME!FieldValTrim)
					F.Intrinsic.Control.Next(V.Local.i)
				F.Intrinsic.Control.EndIf
				F.Data.DataTable.Close("dtLocFull")
			f.Intrinsic.Control.Else
				Function.Intrinsic.Control.UnBlockEvents
				f.Intrinsic.Control.ExitSub
			f.Intrinsic.Control.EndIf
			F.Data.DataTable.Close("dtLocAddr")
			
		'7/14/26 BS - Freight Class child grid
		F.Intrinsic.Control.Case("FRT_CLASS")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"Packing List",V.Args.RowIndex,V.Local.sPackList)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrderNo)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"RECORD_NO",V.Args.RowIndex,V.Local.sOrderLine)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"WAY_BILL",V.Args.RowIndex,V.Local.sWaybill)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"NMFC_NO",V.Args.RowIndex,V.Global.sFrtClassNMFC)
			F.Intrinsic.Control.If(V.Local.sPackList.Trim,<>,"")
				F.Intrinsic.Control.CallSub(LoadFrtClassDetail,"PckNo",V.Local.sPackList,"OrderNo",V.Local.sOrderNo,"OrderLine",V.Local.sOrderLine,"Waybill",V.Local.sWaybill,"RowIdx",V.Args.RowIndex)
			F.Intrinsic.Control.EndIf
			F.Intrinsic.Control.UnBlockEvents
			F.Intrinsic.Control.ExitSub

		Function.Intrinsic.Control.EndSelect
	f.Intrinsic.Control.UnBlockEvents
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.GsGCLoad_RowCellClick.End

Program.Sub.LoadShipped.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare

	V.Local.sFilter.Declare
	
	F.Intrinsic.Control.If(V.DataTable.dtShipped.Exists)
		F.Data.DataTable.Close("dtShipped")
		Gui.frmShip.GsGCShipped.ClearGrouping("gvShipped")
	F.Intrinsic.Control.EndIf

	F.Data.DataTable.CreateFromSQL("dtShipped0","con","SELECT '' as 'SODocCntrl', V_SHIPMENT_LINES.ORDER_NO,V_SHIPMENT_LINES.ORDER_SUFFIX,V_SHIPMENT_LINES.CUSTOMER,V_CUSTOMER_MASTER.NAME_CUSTOMER,V_SHIPMENT_HEADER.CUSTOMER_PO,COALESCE(PART,'') AS PART,'' As DISPLAY_PART,LOCATION,ORDER_DESC,V_SHIPMENT_LINES.PCK_NO,DATE_SHIP,QTY_SHIPPED,LN_SHP_STAT,V_SHIPMENT_LINES.CUSTOMER_PART,LTrim(RTrim(V_SHIPMENT_LINES.LN_USER_1)) As LN_USER_1,LTrim(RTrim(V_SHIPMENT_LINES.LN_USER_2)) As LN_USER_2,LTrim(RTrim(V_SHIPMENT_LINES.LN_USER_3)) As LN_USER_3,LTrim(RTrim(V_SHIPMENT_LINES.LN_USER_4)) As LN_USER_4, LTrim(RTrim(V_SHIPMENT_LINES.LN_USER_5)) As LN_USER_5,V_SHIPMENT_LINES.ORDER_REC,V_SHIPMENT_HEADER.SALESPERSON,V_SHIPMENT_HEADER.SHIP_VIA,V_SHIPMENT_HEADER.SHIP_ID,V_SHIPMENT_HEADER.TRACKING_NO, V_SHIPMENT_HEADER.PROJECT ,  V_SHIPMENT_LINES.PHASE FROM V_SHIPMENT_LINES JOIN V_SHIPMENT_HEADER ON V_SHIPMENT_LINES.ORDER_NO = V_SHIPMENT_HEADER.ORDER_NO AND V_SHIPMENT_LINES.ORDER_SUFFIX = V_SHIPMENT_HEADER.ORDER_SUFFIX LEFT JOIN V_CUSTOMER_MASTER ON V_SHIPMENT_LINES.CUSTOMER = V_CUSTOMER_MASTER.CUSTOMER WHERE QTY_SHIPPED <> 0 AND LN_SHP_STAT <> 0 ORDER BY DATE_SHIP, V_SHIPMENT_LINES.ORDER_NO;",True)
	
	F.Data.DataTable.AddDisplayPartColumn("dtShipped0",0,"PART","DISPLAY_PART")
	
	'Doc control for SO (uses shared dDCC from LoadSharedDictionaries)
	F.Data.DataTable.SetValue("dtShipped0",-1,"SODocCntrl","DCS-OFF")
	F.Data.DataTable.FillFromDictionary("dtShipped0","dDCC","ORDER_NO","SODocCntrl")
	
	'Create DataView and filter out locations
	F.Intrinsic.Control.If(V.Global.bShippingOverride,=,True,or,v.Global.bUseShippingLocations,=,False)
		V.Local.sFilter.Set("")
	F.Intrinsic.Control.Else
		F.Intrinsic.String.Build("LOCATION = '{0}'",V.Global.sShippingLocation,V.Local.sFilter)
	F.Intrinsic.Control.EndIf
	F.Data.DataView.Create("dtShipped0","dvShipped",22,V.Local.sFilter,"")
	
	'Convert DV to DT
	F.Data.DataView.ToDataTable("dtShipped0","dvShipped","dtShipped",True)
	F.Data.DataTable.Close("dtShipped0")
	
	F.Intrinsic.Control.CallSub(LoadShippedGV)
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.LoadShipped.End

Program.Sub.LoadShippedGV.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.iCnt.Declare
	V.Local.sColumns.Declare
	V.Local.sSelect.Declare

	Gui.frmShip.GsGCShipped.AddGridViewFromDataTable("gvShipped","dtShipped")
	Gui.frmShip.GsGCShipped.SuspendLayout()
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","MultiSelect",True)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","OptionBehaviorEditable",True)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","AllowSort",True)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","AllowFilter",True)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","OptionsDetailShowDetailTabs",False)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","OptionsViewShowGroupPanel",True)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","OptionsViewColumnAutoWidth",False)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","showconditionalformattingitem",true)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","OptionsViewShowAutoFilterRow",True)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","showgrouppanel",true)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","showtotalsummarymenu",true)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","showaddnewsummaryitem",true)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","showgroupsortsummaryitems",true)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","showgroupsummarymenu",true)
	Gui.frmShip.GsGCShipped.SetGridViewProperty("gvShipped","Showsummaryitemmode",true)
	
	
	'Loop through columns names by using the V.DataTable.dtName.FieldNames
	F.Intrinsic.String.Split(V.DataTable.dtShipped.FieldNames,"*!*",V.Local.sColumns)
	F.Intrinsic.Control.For(V.Local.iCnt,0,V.Local.sColumns.UBound,1)
		Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped",V.Local.sColumns(V.Local.iCnt),"HeaderFontBold",True)
	F.Intrinsic.Control.Next(V.Local.iCnt)

	'LN_SHP_STAT
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LN_SHP_STAT","Visible",False)
	
	'PART
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","PART","Visible",False)

	'ORDER_NO
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_NO","Caption","Order No")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_NO","MinWidth","70")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_NO","AllowEdit",False)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_NO","ReadOnly",True)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_NO","HeaderHAlignment","Center")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_NO","CellHAlignment","Center")
	
	'ORDER_SUFFIX
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_SUFFIX","Caption","Suffix")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_SUFFIX","MinWidth","45")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_SUFFIX","AllowEdit",False)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_SUFFIX","ReadOnly",True)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_SUFFIX","HeaderHAlignment","Center")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_SUFFIX","CellHAlignment","Center")
	
	'CUSTOMER
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","CUSTOMER","Caption","Customer")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","CUSTOMER","MinWidth","70")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","CUSTOMER","AllowEdit",False)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","CUSTOMER","ReadOnly",True)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","CUSTOMER","HeaderHAlignment","Center")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","CUSTOMER","CellHAlignment","Center")
	
	'NAME_CUSTOMER
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","NAME_CUSTOMER","Caption","Customer Name")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","NAME_CUSTOMER","MinWidth","150")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","NAME_CUSTOMER","AllowEdit",False)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","NAME_CUSTOMER","ReadOnly",True)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","NAME_CUSTOMER","HeaderHAlignment","Center")
	
	'CUSTOMER_PO
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","CUSTOMER_PO","Caption","Customer PO")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","CUSTOMER_PO","MinWidth","115")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","CUSTOMER_PO","AllowEdit",False)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","CUSTOMER_PO","ReadOnly",True)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","CUSTOMER_PO","HeaderHAlignment","Left")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","CUSTOMER_PO","CellHAlignment","Left")
	
	
	'DISPLAY_PART
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","DISPLAY_PART","Caption","Part Number")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","DISPLAY_PART","MinWidth","130")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","DISPLAY_PART","AllowEdit",False)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","DISPLAY_PART","ReadOnly",True)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","DISPLAY_PART","HeaderHAlignment","Center")
	F.Intrinsic.Control.If(V.Global.bLongPart)
		Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","DISPLAY_PART","MinWidth","250")
	F.Intrinsic.Control.EndIf
	
	'LOCATION
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LOCATION","Caption","Loc")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LOCATION","MinWidth","45")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LOCATION","AllowEdit",False)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LOCATION","ReadOnly",True)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","LOCATION","HeaderHAlignment","Center")
	
	'ORDER_DESC
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_DESC","Caption","Description")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_DESC","MinWidth","230")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_DESC","AllowEdit",False)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_DESC","ReadOnly",True)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","ORDER_DESC","HeaderHAlignment","Center")
	
	'PCK_NO
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","PCK_NO","Caption","Packing No")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","PCK_NO","MinWidth","70")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","PCK_NO","AllowEdit",False)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","PCK_NO","ReadOnly",True)
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","PCK_NO","HeaderHAlignment","Center")
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","PCK_NO","CellHAlignment","Center")
	
	'DATE_SHIP
	Gui.frmShip.GsGCShipped.SetColumnProperty("gvShipped","DATE_SHIP","Caption","Date Shipped")
