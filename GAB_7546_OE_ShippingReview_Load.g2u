	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CODE_SOURCE","HeaderHAlignment","Center")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CODE_SOURCE","CellHAlignment","Center")
	
