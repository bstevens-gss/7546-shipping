f.Intrinsic.Math.Add(v.Global.sLoadNo,1,v.Global.iLoadNo)
F.Global.General.SaveOption("402675","0000",1,"",v.Global.iLoadNo,,0,V.Ambient.Date)
'filter for selected rows in load#0

