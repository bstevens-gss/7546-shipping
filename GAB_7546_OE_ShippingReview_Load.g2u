			F.Intrinsic.Control.If(V.DataTable.dtAllShip(v.Local.iCnt).QTY_ONHAND!fieldValFloat,>=,V.DataTable.dtAllShip(v.Local.iCnt).QTY_BO!FieldValFloat)
				Gui.frmShip.GsGCAllShip.SetRowAppearance("gvAllShip",v.Local.iCnt,"BackColor",V.Enum.ThemeColors!ColorGreen.Highlight)
				F.Data.DataTable.SetValue("dtAllShip",V.Local.iCnt,"STATUS","Ready To Ship")
