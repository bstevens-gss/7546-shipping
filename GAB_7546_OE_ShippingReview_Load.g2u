Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")	
		'create browser from existing loads
		'F.Data.Datatable.CreateFromSQL("dtactiveloads","con","SELECT DISTINCT L.LOAD_NO AS 'Load Number',L.CARRIER_LOAD_NUM AS 'Carrier Load Number' from STAGING_QUANTITY H LEFT OUTER JOIN LOAD_PLAN L ON H.ORDER_NO = L.ORDER_NO AND H.LINE = L.ORDER_LINE where LOAD_NO <> 0")
		F.Data.DataView.Create("dtLoad", "dvtemp", 22, "[Load Number]<>0", "")
		F.Data.DataView.ToDataTableDistinct("dtLoad", "dvtemp", "dtactiveloads", "Load Number*!*Carrier Load Number", True)	
		f.Data.DataView.Close("dtLoad", "dvtemp")
		'browser from datatable. 
		'title (0), dt (1), column titles (2), column widths (3), sret (4)
		F.Intrinsic.UI.BrowserFromDataTable("Select a Load","dtactiveloads","Load Number*!*Carrier Load Number","200*!*200",v.Local.sRet)
		Function.Intrinsic.Control.If(v.Local.sRet.Trim,<>,"***CANCEL***")
			f.Intrinsic.String.Split(v.Local.sRet,"*!*",v.Local.sret) 
			f.Data.Datatable.Close("dtactiveloads")
		f.Intrinsic.Control.Else
			Function.Intrinsic.Control.UnBlockEvents
			f.Data.Datatable.Close("dtactiveloads")
			f.Intrinsic.Control.ExitSub
