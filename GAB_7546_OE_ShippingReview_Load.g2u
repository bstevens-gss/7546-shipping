Gui.frmSplitLine.GsGCSplit.MainView("gvSplit")

F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",V.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
F.Intrinsic.Control.EndTry
Program.Sub.ResetSplitGridColumns.End

'7546 Hultec 03/23/2026: UnLoad event for Split SO Line form - saves grid serialization and hides the modal form.
Program.Sub.frmSplitLine_UnLoad.Start
'7546 Hultec 03/23/2026: Save grid layout to registry before closing
V.Local.sSer.Declare(String)
Gui.frmSplitLine.GsGCSplit.Serialize("gvSplit",V.Local.sSer)
F.Global.Registry.AddValue(V.Caller.User,V.Caller.CompanyCode,"GVSPLIT",7546,1000,False,"Serialize",False,0,-999.0,1/1/1980,12:00:00 AM,V.Local.sSer)
Gui.frmSplitLine..Visible(False)
Program.Sub.frmSplitLine_UnLoad.End

'7546 Hultec 03/23/2026: Edit Sales Order - opens the selected order in the classic Order Entry screen (ORD200).
'      Requires IPM 132 (Order Entry > Edit > Sales Orders). ORD200 enforces edit-level security internally.
'      Uses ASSIGNPICKER checkbox to determine which order to edit (first selected row).
'      Checks OrderLocked before launching. No auto-refresh; user refreshes manually.
Program.Sub.EditSalesOrder_Click.Start
F.Intrinsic.Control.Try
V.Local.sError.Declare
V.Local.sSel.Declare(String)
V.Local.iTab.Declare(Long)
V.Local.sOrderNo.Declare(String)
V.Local.bHasAccess.Declare(Boolean,False)

'7546 Hultec 03/23/2026: Permission check - Order Entry > Edit > Sales Orders (IPM 132, level 1)
F.Global.Security.CheckUserAccessIPM(132,1,V.Local.bHasAccess)
F.Intrinsic.Control.If(V.Local.bHasAccess,=,False)
	F.Intrinsic.UI.Msgbox("You do not have permission to access Order Entry.")
	F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.EndIf

V.Local.iTab.Set(V.Screen.frmShip!tabShip.Tab)

F.Intrinsic.Control.If(V.Local.iTab,<>,0,"AND",V.Local.iTab,<>,1)
	F.Intrinsic.UI.Msgbox("Edit Sales Order is only available from the Open Orders or Due Today tabs.")
	F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.EndIf

F.Intrinsic.Control.If(V.Local.iTab,=,0)
	F.Data.DataTable.AcceptChanges("dtAllShip")
	F.Data.Datatable.Select("dtAllShip","ASSIGNPICKER = 1",V.Local.sSel)
F.Intrinsic.Control.Else
	F.Data.DataTable.AcceptChanges("dtDueShip")
	F.Data.Datatable.Select("dtDueShip","ASSIGNPICKER = 1",V.Local.sSel)
F.Intrinsic.Control.EndIf

F.Intrinsic.Control.If(V.Local.sSel,=,"***NORETURN***")
	F.Intrinsic.UI.Msgbox("No lines selected. Check the line you want to edit first.")
	F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.EndIf

'7546 Hultec 03/23/2026: Extract ORDER_NO from the first selected row
F.Intrinsic.String.Split(V.Local.sSel,"*!*",V.Local.sSel)
F.Intrinsic.Control.If(V.Local.iTab,=,0)
	V.Local.sOrderNo.Set(V.DataTable.dtAllShip(V.Local.sSel(0)).ORDER_NO!FieldVal)
F.Intrinsic.Control.Else
	V.Local.sOrderNo.Set(V.DataTable.dtDueShip(V.Local.sSel(0)).ORDER_NO!FieldVal)
F.Intrinsic.Control.EndIf

'7546 Hultec 03/23/2026: Check if order is locked by another user
Function.Intrinsic.Control.CallSub(OrderLocked,"sOrderNo",V.Local.sOrderNo)
F.Intrinsic.Control.If(V.Args.bIsLocked)
	F.Intrinsic.String.Build("Order {0} is locked by User: {1}. Cannot edit.",V.Local.sOrderNo,V.Args.sLockingUser,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.EndIf

'7546 Hultec 03/23/2026: Launch classic Order Entry screen via Sales.EditSalesOrderInClassicScreen
Gui.frmShip.tabShip.Enabled(False)
F.Global.Callwrapper.New("EditSO","Sales.EditSalesOrderInClassicScreen")
F.Global.Callwrapper.SetProperty("EditSO","Company",V.Caller.CompanyCode)
F.Global.Callwrapper.SetProperty("EditSO","SalesOrder",V.Local.sOrderNo)
F.Global.CallWrapper.Run("EditSO")
Gui.frmShip.tabShip.Enabled(True)

F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",V.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	Gui.frmShip.tabShip.Enabled(True)
F.Intrinsic.Control.EndTry
Program.Sub.EditSalesOrder_Click.End

'7546 UDF 04/06/2026: RowCellClick handler for Split SO Line grid — opens Document Control for the SO.
Program.Sub.GsGCSplit_RowCellClick.Start
F.Intrinsic.Control.Try
V.Local.sError.Declare
V.Local.sOrderNo.Declare
V.Local.iRefID.Declare(Long)
V.Local.iLinkID.Declare(Long)
V.Local.sLinkID.Declare
V.Local.iPID.Declare(Long)

F.Intrinsic.Control.SelectCase(V.Args.Column)
	F.Intrinsic.Control.CaseAny("SODocCntrl","SODOCCNTRL")
		V.Local.sOrderNo.Set(V.DataTable.dtSplitLines(V.Args.RowIndex).ORDER_NO!FieldValTrim)
		F.Global.DocumentControl.GetLinkID(V.Local.sOrderNo.Trim,45,V.Local.iRefID)
		F.Intrinsic.Control.If(V.Local.iRefID,=,-1)
			F.ODBC.Connection!con.ExecuteAndReturn("SELECT MAX(LINK_ID) AS 'LinkID' FROM LINK_DATA",V.Local.sLinkID)
			F.Intrinsic.Math.ConvertToLong(V.Local.sLinkID,V.Local.iLinkID)
			F.Intrinsic.Math.Add(V.Local.iLinkID,1,V.Local.iLinkID)
			F.Intrinsic.String.LPad(V.Local.iLinkID,"0",9,V.Local.sLinkID)
			V.Local.iRefID.Set(V.Local.iLinkID)
			F.Global.DocumentControl.CreateReference(V.Local.sOrderNo,"00045",V.Local.iRefID)
		F.Intrinsic.Control.EndIf
		F.Global.DocumentControl.Invoke(V.Local.sOrderNo,45,"(Sales Order Master)",V.Local.iPID)
F.Intrinsic.Control.EndSelect

F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",V.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
F.Intrinsic.Control.EndTry
Program.Sub.GsGCSplit_RowCellClick.End

'-- Sync carrier selection from Load tab to orders/shipments.
'   Staged (have packing list): insert S50 wireless transactions for WIREPOLL to process.
'   All orders: UPDATE ORDER_HEADER directly.
Program.Sub.SyncCarrierFromLoad.Start
F.Intrinsic.Control.SetErrorHandler("SyncCarrier_Err")
F.Intrinsic.Control.ClearErrors
V.Local.sError.Declare(String,"")
V.Local.sLoadNo.Declare(String)
V.Local.sCarrierCD.Declare(String)
V.Local.iSrvcType.Declare(String)
V.Local.sPaymentOption.Declare(String)
V.Local.sVIA.Declare(String)
V.Local.sSQL.Declare(String)
V.Local.sFilter.Declare(String)
V.Local.sSel.Declare(String)
V.Local.i.Declare(Long)
V.Local.iMax.Declare(Long)
V.Local.sTransIDNew.Declare(String)
V.Local.sUserID.Declare(String)
V.Local.sPL.Declare(String)
V.Local.sShipViaDesc.Declare(String)
V.Local.sCarrierAcct.Declare(String)
V.Local.sOrderNo.Declare(String)
V.Local.sCustNo.Declare(String)
V.Local.sTemp.Declare(String)

V.Local.sLoadNo.Set(V.Args.sLoadNo)
V.Local.sCarrierCD.Set(V.Args.sCarrierCD)
V.Local.iSrvcType.Set(V.Args.iSrvcType)
V.Local.sPaymentOption.Set(V.Args.sPaymentOption)
V.Local.sVIA.Set(V.Args.sVIA)
V.Local.sUserID.Set(V.Caller.User)

'-- STAGED: query DB directly for ALL distinct packing lists on this load
F.Intrinsic.Control.If(V.DataTable.dtStagedPL.Exists,=,True)
	F.Data.DataTable.Close("dtStagedPL")
F.Intrinsic.Control.EndIf
F.Intrinsic.String.Build("SELECT DISTINCT RTRIM(H.PCK_NO) AS PCK_NO FROM LOAD_PLAN G, STAGING_QUANTITY H WHERE G.ORDER_NO = H.ORDER_NO AND G.ORDER_LINE = H.LINE AND G.LOAD_NO = {0} AND G.ORDER_SUFFIX <> 'P' AND H.PCK_NO <> ''",V.Local.sLoadNo,V.Local.sSQL)
F.Data.DataTable.CreateFromSQL("dtStagedPL","con",V.Local.sSQL,True)

'-- Insert S50 wireless transaction for each distinct packing list
F.Intrinsic.Control.If(V.DataTable.dtStagedPL.RowCount,>,0)
	F.Intrinsic.Math.Sub(V.DataTable.dtStagedPL.RowCount,1,V.Local.iMax)
	F.Intrinsic.Control.For(V.Local.i,0,V.Local.iMax,1)
		V.Local.sPL.Set(V.DataTable.dtStagedPL(V.Local.i).PCK_NO!FieldValTrim)
		F.Intrinsic.Control.If(V.Local.sPL,<>,"")
			'-- Get next TRANS_ID (same pattern as Click_Load_Ship S40)
			F.ODBC.Connection!con.ExecuteAndReturn("SELECT TOP 1 RIGHT(CONCAT('000000000',CAST(TRANS_ID AS INT)+1),9) AS TRANS_ID FROM WIRELESS_HDR ORDER BY TRANS_ID DESC",V.Local.sTransIDNew)
			F.Intrinsic.String.LPad(V.Local.sTransIDNew,"0",9,V.Local.sTransIDNew)
			'-- INSERT WIRELESS_HDR with ATTEMPTED_FLAG='Y' (locks row until LINE is written)
			F.Intrinsic.String.Build("INSERT INTO WIRELESS_HDR (TRANS_ID,TRANS_TYPE,ATTEMPTED_DATE,ATTEMPTED_TIME,USER_ID,BATCH,ATTEMPTED_FLAG) VALUES ('{0}','S50','00000000','00000000','{1}',0,'Y')",V.Local.sTransIDNew,V.Local.sUserID,V.Local.sSQL)
			F.ODBC.Connection!con.Execute(V.Local.sSQL)
			'-- INSERT WIRELESS_LINE: FIELD_1=PCK_NO, FIELD_2=CARRIER_CD, FIELD_3=SRVC_TYPE
			F.Intrinsic.String.Build("INSERT INTO WIRELESS_LINE (TRANS_ID,SEQ,TRANS_TYPE,FIELD_1,FIELD_2,FIELD_3,ERROR_ID) VALUES ('{0}','0000','S50','{1}','{2}','{3}',0)",V.Local.sTransIDNew,V.Local.sPL,V.Local.sCarrierCD,V.Local.iSrvcType,V.Local.sSQL)
			F.ODBC.Connection!con.Execute(V.Local.sSQL)
			'-- Release for WIREPOLL by clearing ATTEMPTED_FLAG
			F.Intrinsic.String.Build("UPDATE WIRELESS_HDR SET ATTEMPTED_FLAG='' WHERE TRANS_ID='{0}'",V.Local.sTransIDNew,V.Local.sSQL)
			F.ODBC.Connection!con.Execute(V.Local.sSQL)
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.Next(V.Local.i)
F.Intrinsic.Control.EndIf
F.Data.DataTable.Close("dtStagedPL")

'-- ALL ORDERS: update ORDER_HEADER for every order on this load
F.Intrinsic.Control.If(V.DataTable.dtLoadOrders.Exists,=,True)
	F.Data.DataTable.Close("dtLoadOrders")
F.Intrinsic.Control.EndIf
F.Intrinsic.String.Build("SELECT DISTINCT RTRIM(G.ORDER_NO) AS ORDER_NO FROM LOAD_PLAN G WHERE G.LOAD_NO = {0} AND G.ORDER_SUFFIX <> 'P'",V.Local.sLoadNo,V.Local.sSQL)
F.Data.DataTable.CreateFromSQL("dtLoadOrders","con",V.Local.sSQL,True)

F.Intrinsic.Control.If(V.DataTable.dtLoadOrders.RowCount,>,0)
	'-- Resolve SHIP_VIA description from OE_CARRIER.VIA -> SHIP_VIA.MESSAGE
	V.Local.sShipViaDesc.Set("")
	F.Intrinsic.String.Build("SELECT RTRIM(MESSAGE) FROM SHIP_VIA WHERE ID = '{0}'",V.Local.sVIA,V.Local.sSQL)
	F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.sShipViaDesc)
	F.Intrinsic.Control.If(V.Ambient.ExecuteAndReturnEOF,=,True)
		V.Local.sShipViaDesc.Set("")
	F.Intrinsic.Control.EndIf
	F.Intrinsic.Math.Sub(V.DataTable.dtLoadOrders.RowCount,1,V.Local.iMax)
	F.Intrinsic.Control.For(V.Local.i,0,V.Local.iMax,1)
		V.Local.sOrderNo.Set(V.DataTable.dtLoadOrders(V.Local.i).ORDER_NO!FieldValTrim)
		F.Intrinsic.Control.If(V.Local.sOrderNo,<>,"")
			'-- If collect (CC), look up customer carrier account from AR_CUST_CARRIER
			F.Intrinsic.Control.If(V.Local.sPaymentOption,=,"CC")
				F.Intrinsic.String.Build("SELECT RTRIM(CUSTOMER) FROM V_ORDER_HEADER WHERE ORDER_NO = '{0}'",V.Local.sOrderNo,V.Local.sSQL)
				F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.sCustNo)
				V.Local.sCarrierAcct.Set("")
				F.Intrinsic.Control.If(V.Ambient.ExecuteAndReturnEOF,=,False)
					F.Intrinsic.String.Build("SELECT RTRIM(ACCT_NO) FROM AR_CUST_CARRIER WHERE CUST_NO = '{0}' AND CARRIER_CD = '{1}' AND SRVC_TYPE = {2}",V.Local.sCustNo,V.Local.sCarrierCD,V.Local.iSrvcType,V.Local.sSQL)
					F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.sCarrierAcct)
					F.Intrinsic.Control.If(V.Ambient.ExecuteAndReturnEOF,=,True)
						V.Local.sCarrierAcct.Set("")
					F.Intrinsic.Control.EndIf
				F.Intrinsic.Control.EndIf
				F.Intrinsic.String.Build("UPDATE ORDER_HEADER SET CARRIER_CD = '{0}', SRVC_TYPE = {1}, SHIP_VIA = '{2}', CARRIER_ACCT = '{3}' WHERE ORDER_NO = '{4}'",V.Local.sCarrierCD,V.Local.iSrvcType,V.Local.sShipViaDesc,V.Local.sCarrierAcct,V.Local.sOrderNo,V.Local.sSQL)
				F.ODBC.Connection!con.Execute(V.Local.sSQL)
			F.Intrinsic.Control.Else
				F.Intrinsic.String.Build("UPDATE ORDER_HEADER SET CARRIER_CD = '{0}', SRVC_TYPE = {1}, SHIP_VIA = '{2}' WHERE ORDER_NO = '{3}'",V.Local.sCarrierCD,V.Local.iSrvcType,V.Local.sShipViaDesc,V.Local.sOrderNo,V.Local.sSQL)
				F.ODBC.Connection!con.Execute(V.Local.sSQL)
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.Next(V.Local.i)
F.Intrinsic.Control.EndIf
F.Data.DataTable.Close("dtLoadOrders")

F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.Label("SyncCarrier_Err")
F.Intrinsic.Control.If(V.Ambient.ErrorNumber,<>,0)
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",V.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
F.Intrinsic.Control.EndIf
Program.Sub.SyncCarrierFromLoad.End

Program.Sub.Comments.Start
${$0$}$$}$$}$12:00:00 AM$}$False
