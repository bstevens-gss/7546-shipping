	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.CallSub(frmShip_UnLoad)	
Function.Intrinsic.Control.EndTry	

Program.Sub.Click_Print_PL_Certs.End

Program.Sub.Click_Print_BOL.Start
Function.Intrinsic.Control.Try
v.Local.sFilterString.Declare
V.Local.sActiveFilter.Declare
v.Local.sError.Declare(String)
v.Local.sSel.Declare(String)
v.Local.sRet.Declare(String)
v.Local.i.Declare(Long)
v.Local.dPickDate.Declare(Date)
v.Local.sSQL.Declare(String)
v.Local.sQuery.Declare(String)
v.Local.iCnt.Declare
v.Local.sParam.Declare

'filter for selected rows
Function.Intrinsic.Control.BlockEvents
Function.Data.DataTable.AcceptChanges("dtLoad")
'verify that we have a checked value in SELECT and load is not 0. 
'filter distinct BOLs
v.Local.sFilterString.Set("[SELECT] = 1 and [WAY_BILL] <> ''")
f.Data.DataView.Create("dtLoad","dvloadbol",22,v.Local.sFilterString,"")
f.Data.DataView.ToDataTableDistinct("dtload","dvloadbol","dtloadbol","WAY_BILL",)
F.Data.Datatable.Select("dtLoadbol","[WAY_BILL] <> ''",v.Local.sSel)

Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")	
		F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
		F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
			'Print BOL
			f.Global.General.CallWrapperSync(910060,v.DataTable.dtLoadbol(v.Local.sSel(v.Local.i)).WAY_BILL!FieldValTRIM)
		F.Intrinsic.Control.Next(v.Local.i)	
f.Intrinsic.Control.Else
	F.Intrinsic.UI.Msgbox("Please select rows from load with packing lists.  Click OK to Exit.","Warning")
Function.Intrinsic.Control.EndIf
f.Data.Datatable.Close("dtloadbol")
f.Data.DataView.Close("dtLoad","dvloadbol")
Function.Intrinsic.Control.UnBlockEvents
f.Intrinsic.Control.ExitSub
Function.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.CallSub(frmShip_UnLoad)	
Function.Intrinsic.Control.EndTry	
Program.Sub.Click_Print_BOL.End

Program.Sub.GsGCShipped_RowCellClick.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sPart.Declare
	V.Local.sLoc.Declare
	V.Local.sDesc.Declare
	V.Local.sOrderNo.Declare
	V.Local.sOrderLine.Declare
	V.Local.sQtyOnHand.Declare
	V.Local.sShipSchd.Declare
	V.Local.sParams.Declare
	V.Local.sSQL.Declare
	V.Local.sPackingList.Declare
	v.Local.bEdit.Declare
	V.Local.sSupDemValue.Declare
	V.Local.sGV.Declare
	V.Local.bOpenSupplyDemand.Declare("Boolean", False)
	V.Local.iRet.Declare
	v.Local.iPID.Declare
	V.Local.bRel.Declare
	v.Local.lRet.Declare
	v.Local.iRefID.Declare
	v.Local.iLinkID.Declare
	v.Local.sLinkID.Declare
	

	V.Local.sGV.Set("gvShipped")
	
	f.Intrinsic.Control.BlockEvents
	
	F.Intrinsic.Control.SelectCase(V.Args.Column)		
		f.Intrinsic.Control.caseany("SODocCntrl","SODOCCNTRL")
			V.Local.sOrderNo.Set(V.DataTable.dtShipped(V.Args.RowIndex).ORDER_NO!FieldValTRIM)
			f.Global.DocumentControl.GetLinkID(v.Local.sOrderNo.Trim,45,v.Local.iRefID)
			f.Intrinsic.Control.If(v.Local.irefid,=,-1)
				F.ODBC.Connection!con.ExecuteAndReturn("SELECT MAX(LINK_ID) AS 'LinkID' FROM LINK_DATA",v.Local.sLinkID)
				f.Intrinsic.Math.ConvertToLong(v.Local.sLinkID,v.Local.iLinkID)
				f.Intrinsic.Math.Add(v.Local.iLinkID,1,v.Local.iLinkID)
				f.Intrinsic.string.LPad(v.Local.iLinkID,"0",9,v.Local.sLinkID)
				V.Local.iRefID.Set(v.Local.iLinkID)
				F.Global.DocumentControl.CreateReference(V.Local.sPart,"00045",V.Local.iRefID)
			f.Intrinsic.Control.EndIf
			F.Global.DocumentControl.Invoke(V.Local.sOrderNo,45,"(Sales Order Master)",V.Local.iPID)
	F.Intrinsic.Control.EndSelect
	f.Intrinsic.Control.UnBlockEvents

	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.GsGCShipped_RowCellClick.End

Program.Sub.LoadLoad_7551_outsidePO.Start
F.Intrinsic.Control.Try
Gui.frmShip.lblStatus.Caption("Loading Load tab Outside PO....")
V.Local.sError.Declare
'NEED TO QUERY LOAD_PLAN TABLE FOR ORDER_SUFFIX = 'P' AND SHIPPED = 0
	f.Data.DataTable.CreateFromSQL("dtLoadPO","con","select G.LOAD_NO as 'Load Number',G.ORDER_NO,LEFT(G.ORDER_LINE,3) AS RECORD_NO,G.ORDER_LINE,G.ORDER_SUFFIX,'P' AS CURRENT_ORDER_SUFFIX,P.PART,P.LOCATION,P.QTY_ORDER AS QTY_BO,P.DESCRIPTION,P.PRODUCT_LINE,G.LOAD_SEQ AS 'Drop Seq', rtrim(G.CARRIER) AS 'Carrier Number', rtrim(P.USER_1) AS 'Carrier Load Number', rtrim(G.CARRIER_TRAILER) AS 'Carrier Trailer',G.TRUCK_TYPE AS 'Truck Type ID',G.STAGING_BIN AS 'Staging Bin', G.DOCK_NO AS 'Dock ID', G.PICK_BY_DATE AS 'Pick By Date', G.SHIP_DATE AS 'Ship Date', G.NOTES AS 'Load Notes', G.PCKLST_DISP_FLAG AS 'Ready to Pick', G.PICKED,H.VENDOR AS CUSTOMER,B.NAME_VENDOR AS NAME_CUSTOMER,H.PURCHASE_ORDER AS CUSTOMER_PO,B.ADDRESS_1 AS ADDRESS_1_SHIP,B.ADDRESS_2 AS ADDRESS_2_SHIP,B.ADDRESS_3 AS ADDRESS_3_SHIP,B.ADDRESS_4 AS ADDRESS_4_SHIP,B.ADDRESS_5 AS ADDRESS_5_SHIP,B.CITY AS CITY_SHIP,B.STATE AS STATE_SHIP,B.ZIP AS ZIP_SHIP,K.PRINT_DATE AS 'DATE_ORDER',CASE WHEN P.SHIP_DATE_L = '1900-01-01' THEN CONVERT(NULL, SQL_DATE) ELSE P.SHIP_DATE_L  END  AS 'DATE_ITEM_PROM',RTRIM(P.USER_1)+RTRIM(P.PURCHASE_ORDER)+RTRIM(P.RECORD_NO) AS OPOL,CASE WHEN isnumeric(rtrim(P.USER_3)) = 1 THEN rtrim(P.USER_3) ELSE 0.0000 END AS 'Staged Qty',CASE WHEN RTRIM(G.DOCK_NO) = '' THEN (RTRIM(CAST(G.LOAD_NO AS VARCHAR(4)))+'') ELSE (RTRIM(CAST(G.LOAD_NO AS VARCHAR(4)))+RTRIM(G.DOCK_NO)) END AS LD,COALESCE(CASE WHEN ISNUMERIC(RTRIM(P.USER_3)) = 1 THEN CONVERT(RTRIM(P.USER_3),SQL_DOUBLE) * COALESCE(M.LBS,0) ELSE 0 END,0) AS WEIGHT from LOAD_PLAN G LEFT JOIN V_PO_LINES P ON G.ORDER_NO=P.PURCHASE_ORDER AND G.ORDER_LINE=P.RECORD_NO LEFT JOIN V_PO_HEADER H ON P.PURCHASE_ORDER=H.PURCHASE_ORDER LEFT JOIN GCG_7551_PO_PACK K ON P.PURCHASE_ORDER=K.PURCHASE_ORDER AND P.RECORD_NO=K.PO_LINE LEFT JOIN INVENTORY_MST2 M ON K.PART=M.PART AND P.LOCATION=M.LOCATION LEFT JOIN V_PO_VENDOR_BUY B ON H.VENDOR=B.VENDOR AND H.PURCHASE_ORDER=B.PURCHASE_ORDER WHERE ORDER_SUFFIX like 'P%' AND SHIPPED = 0",True)
	f.Data.Datatable.Merge("dtLoadPO","dtLoad0",False,2)
	f.Data.Datatable.Close("dtLoadPO")
F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.End 
F.Intrinsic.Control.EndTry
Program.Sub.LoadLoad_7551_outsidePO.End

