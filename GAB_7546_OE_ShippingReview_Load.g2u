	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PROJECT","CellHAlignment","Center")
	
	'PHASE	
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PHASE","Visible",False)
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PHASE","Caption","Phase")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PHASE","MinWidth","45")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PHASE","AllowEdit",False)
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PHASE","ReadOnly",True)
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PHASE","HeaderHAlignment","Center")
	Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"PHASE","CellHAlignment","Center")
	
	F.Intrinsic.Control.If(v.Args.gsgc,=,"GsGCLoad")
		'CONTACT
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT","Visible",False)
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT","Caption","Contact Name")
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT","MinWidth","70")
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT","AllowEdit",False)
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT","ReadOnly",True)
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT","HeaderHAlignment","Center")
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT","CellHAlignment","Center")
		
		'CONTACT_PHONE
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_PHONE","Visible",False)
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_PHONE","Caption","Contact Phone")
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_PHONE","MinWidth","50")
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_PHONE","AllowEdit",False)
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_PHONE","ReadOnly",True)
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_PHONE","HeaderHAlignment","Center")
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_PHONE","CellHAlignment","Center")
		
		'CONTACT_EMAIL
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_EMAIL","Visible",False)
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_EMAIL","Caption","Contact Email")
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_EMAIL","MinWidth","90")
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_EMAIL","AllowEdit",False)
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_EMAIL","ReadOnly",True)
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_EMAIL","HeaderHAlignment","Center")
		Gui.frmShip.[V.Args.GSGC].SetColumnProperty(V.Args.GV,"CONTACT_EMAIL","CellHAlignment","Center")
	F.Intrinsic.Control.EndIf
	
	F.Intrinsic.Control.If(V.Args.GSGC,=,"GsGCAllShip")
		F.Intrinsic.Control.CallSub(ResetGridColors,"MenuName","CTXOPEN")
	F.Intrinsic.Control.ElseIf(V.Args.GSGC,=,"GsGCDue")
		F.Intrinsic.Control.CallSub(ResetGridColors,"MenuName","CTXDUE")
	F.Intrinsic.Control.ElseIf(V.Args.GSGC,=,"GsGCLoad")
		F.Intrinsic.Control.CallSub(ResetGridColors,"MenuName","CTXLOAD")
	F.Intrinsic.Control.EndIf
		
	Gui.frmShip.[V.Args.GSGC].AddSummaryItem(V.Args.GV,"Weight","","Sum","Total Est. Unpackaged Weight = (",")","n0")
	Gui.frmShip.[V.Args.GSGC].AddSummaryItem(V.Args.GV,"Est Packaged Weight","","Sum","Total Est. Packaged Weight = (",")","n0")
	Gui.frmShip.[V.Args.GSGC].AddSummaryItem(V.Args.GV,"Est Area","","Sum","Total Est. Area (Ft) = (",")","n0")
	F.Intrinsic.Control.If(V.Args.GV,=,"gvLoad")
		Gui.frmShip.[V.Args.GSGC].AddSummaryItem(V.Args.GV,"Staged PL Weight","","Sum","Total Staged PL Weight = (",")","n0")
		Gui.frmShip.[V.Args.GSGC].AddSummaryItem(V.Args.GV,"Staged PL Cartons","","Sum","Total Staged PL Cartons = (",")","n0")
		Gui.frmShip.[V.Args.GSGC].AddSummaryItem(V.Args.GV,"Staged PL Pallets","","Sum","Total Staged PL Pallets = (",")","n0")
	F.Intrinsic.Control.EndIf
	
	Gui.frmShip.[V.Args.GSGC].ResumeLayout()
	Gui.frmShip.[V.Args.GSGC].MainView(V.Args.GV)
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.LoadOpenOrdersGV.End

Program.Sub.GsGCAllShip_RowCellClick.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sPart.Declare
	V.Local.sLoc.Declare
	V.Local.sDesc.Declare
	V.Local.sOrderNo.Declare
	V.Local.sOrderLine.Declare
	V.Local.sLoadNo.Declare
	V.Local.sQtyOnHand.Declare
	V.Local.sShipSchd.Declare
	V.Local.sParams.Declare
	V.Local.sSQL.Declare
	V.Local.sPackingList.Declare
	v.Local.bEdit.Declare
	V.Local.sSupDemValue.Declare
	V.Local.sGV.Declare
	V.Local.bOpenSupplyDemand.Declare("Boolean", False)
	
	F.Intrinsic.Control.SelectCase(V.Args.ControlName)
		F.Intrinsic.Control.Case("GSGCALLSHIP")
			V.Local.sGV.Set("gvAllShip")
		F.Intrinsic.Control.Case("GSGCDUE")
			V.Local.sGV.Set("gvDue")
	F.Intrinsic.Control.EndSelect
	
	f.Intrinsic.Control.BlockEvents
	
	F.Intrinsic.Control.SelectCase(V.Args.Column)
		F.Intrinsic.Control.Case("DISPLAY_PART")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"PART",V.Args.RowIndex,V.Local.sPart)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOCATION",V.Args.RowIndex,V.Local.sLoc)
			'Hierarchy - With View or Ship selected we will read the users menu permissions to open the proper Supply and Demand screen.
			'No Dollars
			F.Intrinsic.Control.If(V.Global.bSupDemNODollars)
				V.Local.sSupDemValue.Set("W")
				V.Local.bOpenSupplyDemand.Set(True)
			F.Intrinsic.Control.EndIf
			'View
			F.Intrinsic.Control.If(V.Global.bSupDemView)
				V.Local.sSupDemValue.Set("V")
				V.Local.bOpenSupplyDemand.Set(True)
			F.Intrinsic.Control.EndIf
			'Wth Edit
			F.Intrinsic.Control.If(V.Global.bSupDemEdit)
				V.Local.sSupDemValue.Set("M")
				V.Local.bOpenSupplyDemand.Set(True)
			F.Intrinsic.Control.EndIf
			'New
			F.Intrinsic.Control.If(V.Global.bSupDemNew)
				V.Local.sSupDemValue.Set("M")
				V.Local.bOpenSupplyDemand.Set(True)
			F.Intrinsic.Control.EndIf
			
			F.Intrinsic.Control.If(V.Local.bOpenSupplyDemand)
				F.Intrinsic.String.ConcatCallWrapperArgs(V.Local.sPart,V.Local.sLoc,V.Local.sSupDemValue,V.Local.sParams)
				gui.frmShip.tabShip.Enabled(False)
				F.Global.General.CallWrappersync(300011,v.Local.sParams)
				gui.frmShip.tabShip.Enabled(True)
			F.Intrinsic.Control.EndIf
			
		F.Intrinsic.Control.Case("ORDER_NO")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrderNo)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"RECORD_NO",V.Args.RowIndex,V.Local.sOrderLine)
			F.Intrinsic.String.RPad(V.Local.sOrderLine,"0",4,V.Local.sOrderLine)
			F.Intrinsic.Control.If(V.Screen.frmShip!optShip.Value,=,True)
				f.Intrinsic.Control.If(v.Global.bShipOEPermission,=,True,or,v.Global.bShipSHIPPermission,=,True)
					Gui.frmShip.[V.Args.ControlName].Enabled(False)
					F.Global.Callwrapper.New("Ship","Sales.NewShipments")
					F.Global.Callwrapper.SetProperty("Ship","OrderNumber",V.Local.sOrderNo)
					F.Global.Callwrapper.SetProperty("Ship","OrderLine",V.Local.sOrderLine)
					F.Global.CallWrapper.Run("Ship")
					Gui.frmShip.[V.Args.ControlName].Enabled(True)
				f.Intrinsic.Control.Elseif(v.Global.bViewSO)
					F.Intrinsic.String.Concat(v.Local.sOrderNo,"!*!","V","!*!","*!*ZDR*!*",v.Local.sParams)
					gui.frmShip.tabShip.Enabled(False)
					F.Global.General.CallWrapperSync(200000,V.Local.sParams)
				f.Intrinsic.Control.EndIf
			F.Intrinsic.Control.Else
				f.Intrinsic.Control.If(v.Global.bViewSO)
					F.Intrinsic.String.Concat(v.Local.sOrderNo,"!*!","V","!*!","*!*ZDR*!*",v.Local.sParams)
					gui.frmShip.tabShip.Enabled(False)
					F.Global.General.CallWrapperSync(200000,V.Local.sParams)
				f.Intrinsic.Control.EndIf			
			F.Intrinsic.Control.EndIf
			f.Intrinsic.Control.UnBlockEvents
			gui.frmShip.tabShip.Enabled(True)
			F.Intrinsic.Control.ExitSub
	
		F.Intrinsic.Control.Case("FLAG_USE_MQD")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"FLAG_USE_MQD",V.Args.RowIndex,v.Local.sShipSchd)
			F.Intrinsic.Control.If(V.Local.sShipSchd,=,"Ship Schd")
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrderNo)
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"RECORD_NO",v.Args.RowIndex,v.Local.sOrderLine)
				Gui.frmShipSch.txtOrder.Text(V.Local.sOrderNo)
				Gui.frmShipSch.txtOrdLn.Text(V.Local.sOrderLine)
				F.Intrinsic.Control.CallSub(LoadShipSched)
			F.Intrinsic.Control.EndIf
			f.Intrinsic.Control.UnBlockEvents
			F.Intrinsic.Control.ExitSub
	
		F.Intrinsic.Control.Case("QTY_ONHAND")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"PART",V.Args.RowIndex,V.Local.sPart)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOCATION",V.Args.RowIndex,V.Local.sLoc)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"DESCRIPTION",V.Args.RowIndex,V.Local.sDesc)
			F.Intrinsic.Control.CallSub(LoadItemMaster,"Part",V.Local.sPart,"Loc",V.Local.sLoc,"Desc",V.Local.sDesc)
			f.Intrinsic.Control.UnBlockEvents
			F.Intrinsic.Control.ExitSub
			
		F.Intrinsic.Control.Case("QTY_90")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"PART",V.Args.RowIndex,V.Local.sPart)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"LOCATION",V.Args.RowIndex,V.Local.sLoc)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"DESCRIPTION",V.Args.RowIndex,V.Local.sDesc)
			
			f.Intrinsic.Control.If(V.Screen.frmShip!ddlCalculateMRPOnHand.ItemData,=,4)
				F.Intrinsic.Control.CallSub(LoadItemMaster90_UDF,"Part",V.Local.sPart,"Loc",V.Local.sLoc,"Desc",V.Local.sDesc)
			F.Intrinsic.Control.ELSE
				F.Intrinsic.Control.CallSub(LoadItemMaster90,"Part",V.Local.sPart,"Loc",V.Local.sLoc,"Desc",V.Local.sDesc)
			F.Intrinsic.Control.EndIf		
			
			f.Intrinsic.Control.UnBlockEvents
			F.Intrinsic.Control.ExitSub		
	
		F.Intrinsic.Control.Case("PICKLIST")
			F.Intrinsic.Control.If(V.Global.bShip)				
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrderNo)
				Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"FLAG_USE_MQD",V.Args.RowIndex,V.Local.sShipSchd)
				F.Intrinsic.Control.CallSub(PrintPickList,"OrderNo",V.Local.sOrderNo,"ShipSchd",V.Local.sShipSchd,"LoadNo","0")
				Function.Intrinsic.Control.If(v.Args.bPrinted,=,True)
					Gui.frmShip.[V.Args.ControlName].SetCellValueByColumnName(V.Local.sGV,"PICKLIST",V.Args.RowIndex,"RePrint")
					F.Intrinsic.Control.CallSub(UpdatePrintFlag,"Order",V.Local.sOrderNo,"Load","0")
				Function.Intrinsic.Control.EndIf
			F.Intrinsic.Control.EndIf

		F.Intrinsic.Control.Case("STAGED")						
			F.Intrinsic.Control.If(V.Screen.frmShip!optShip.Value,=,True)
				F.Intrinsic.Control.AndIf(V.Args.CellValue,=,True)
					Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrderNo)
					F.Intrinsic.String.Build("SELECT TOP 1 PCK_NO FROM STAGING_ORDERS WHERE ORDER_NO = {0}",V.Local.sOrderNo,V.Local.sSQL)
					F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.sPackingList)
					F.Intrinsic.Control.If(V.Local.sPackingList, <>, "")
						gui.frmShip.tabShip.Enabled(False)
						F.Global.Callwrapper.New("Staged","Inventory.OpenStagingShipments")
						F.Global.Callwrapper.SetProperty("Staged","PackingList",V.Local.sPackingList)
						F.Global.CallWrapper.Run("Staged")
						gui.frmShip.tabShip.Enabled(True)
						f.Intrinsic.Control.CallSub(cmdrefresh_click)
					F.Intrinsic.Control.EndIf
			F.Intrinsic.Control.EndIf			
	F.Intrinsic.Control.EndSelect
	f.Intrinsic.Control.UnBlockEvents

	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.GsGCAllShip_RowCellClick.End

Program.Sub.frmShipSch_UnLoad.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	Gui.frmShipSch..Visible(False)
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.frmShipSch_UnLoad.End

Program.Sub.LoadShipSched.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sSQL.Declare
	V.Local.iCnt.Declare
	V.Local.sColumns.Declare

	F.Intrinsic.Control.If(V.DataTable.dtShipSched.Exists)
		F.Data.DataTable.Close("dtShipSched")
	F.Intrinsic.Control.EndIf

	F.Intrinsic.String.Build("SELECT ORDER_NO,ORDER_LINE,IF(DATE_DUE = '1900-01-01', CONVERT(NULL, SQL_DATE), DATE_DUE) AS DATE_DUE,QTY_SCHED,QTY_OPEN,FLAG_CLOSED,INFO FROM V_OE_SHIP_SCHED WHERE ORDER_NO='{0}' AND ORDER_LINE='{1}0'",V.Screen.frmShipSch!txtOrder.Text,V.Screen.frmShipSch!txtOrdLn.Text,V.Local.sSQL)
	F.Data.DataTable.CreateFromSQL("dtShipSched","con",v.Local.sSQL)

	Gui.frmShipSch.GSGCShipSch.AddGridViewFromDataTable("gvShipSched","dtShipSched")
	Gui.frmShipSch.GSGCShipSch.SuspendLayout()
	Gui.frmShipSch.GSGCShipSch.SetGridViewProperty("gvShipSched","MultiSelect",True)
	Gui.frmShipSch.GSGCShipSch.SetGridViewProperty("gvShipSched","OptionBehaviorEditable",False)
	Gui.frmShipSch.GSGCShipSch.SetGridViewProperty("gvShipSched","ReadOnly",True)
	Gui.frmShipSch.GSGCShipSch.SetGridViewProperty("gvShipSched","AllowSort",True)
	Gui.frmShipSch.GSGCShipSch.SetGridViewProperty("gvShipSched","AllowFilter",True)
	Gui.frmShipSch.GSGCShipSch.SetGridViewProperty("gvShipSched","OptionsDetailShowDetailTabs",False)
	Gui.frmShipSch.GSGCShipSch.SetGridViewProperty("gvShipSched","OptionsViewShowGroupPanel",True)
	Gui.frmShipSch.GSGCShipSch.SetGridViewProperty("gvShipSched","AllowColumnMoving",False)
	
	'Loop through columns names by using the V.DataTable.dtName.FieldNames
	F.Intrinsic.String.Split(V.DataTable.dtShipSched.FieldNames,"*!*",V.Local.sColumns)
	F.Intrinsic.Control.For(V.Local.iCnt,0,V.Local.sColumns.UBound,1)
		Gui.frmShipSch.GSGCShipSch.SetColumnProperty("gvShipSched",V.Local.sColumns(V.Local.iCnt),"HeaderFontBold",True)
	F.Intrinsic.Control.Next(V.Local.iCnt)
	
	'ORDER_NO
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","ORDER_NO","Visible",False)
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","ORDER_NO","Caption","Order #")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","ORDER_NO","MinWidth","50")
	
	'ORDER_LINE
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","ORDER_LINE","Visible",False)
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","ORDER_LINE","Caption","Line")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","ORDER_LINE","MinWidth","15")
	
	'DATE_DUE
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","DATE_DUE","Caption","Date Due")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","DATE_DUE","MinWidth","60")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","DATE_DUE","HeaderHAlignment","Center")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","DATE_DUE","CellHAlignment","Center")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","DATE_DUE","DisplayCustomDatetime","d")
	
	'QTY_SCHED
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","QTY_SCHED","Caption","Qty Scheduled")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","QTY_SCHED","MinWidth","70")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","QTY_SCHED","HeaderHAlignment","Center")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","QTY_SCHED","CellHAlignment","Center")
	
	'QTY_OPEN
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","QTY_OPEN","Caption","Qty Open")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","QTY_OPEN","MinWidth","70")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","QTY_OPEN","HeaderHAlignment","Center")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","QTY_OPEN","CellHAlignment","Center")
	
	'FLAG_CLOSED
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","FLAG_CLOSED","Caption","Closed")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","FLAG_CLOSED","MinWidth","30")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","FLAG_CLOSED","HeaderHAlignment","Center")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","FLAG_CLOSED","CellHAlignment","Center")
	
	'INFO
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","INFO","Caption","Info")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","INFO","MinWidth","120")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","INFO","HeaderHAlignment","Center")
	Gui.frmShipSch.GSGCShipSch.setColumnProperty("gvShipSched","INFO","CellHAlignment","Center")

	Gui.frmShipSch.GSGCShipSch.ResumeLayout()
	Gui.frmShipSch.GSGCShipSch.MainView("gvShipSched")
	
	Gui.frmShipSch..Show
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.LoadShipSched.End

Program.Sub.LoadFrtClassDetail.Start
'-- 7/14/26 BS - Opens child grid showing pallet detail for the clicked order/line
'-- Allows editing of Freight Class which saves to BOL_PART_INFO and BOL_ITEM
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	V.Local.sSQL.Declare
	V.Local.iCnt.Declare(Long)
	V.Local.iLastRow.Declare(Long)
	V.Local.sColumns.Declare

	'-- Store context in globals for the CellValueChanged handler
	V.Global.sFrtClassPckNo.Set(V.Args.PckNo)
	V.Global.sFrtClassOrderNo.Set(V.Args.OrderNo)
	V.Global.sFrtClassOrderLine.Set(V.Args.OrderLine)
	V.Global.sFrtClassWaybill.Set(V.Args.Waybill)
	V.Global.iFrtClassRowIdx.Set(V.Args.RowIdx)

	'-- Close existing DataTable if open
	F.Intrinsic.Control.If(V.DataTable.dtFrtClass.Exists,=,True)
		F.Data.DataTable.Close("dtFrtClass")
	F.Intrinsic.Control.EndIf

	'-- Query all order lines sharing the same pallet(s) as the clicked order/line
	F.Intrinsic.String.Build("SELECT DISTINCT BPD.ORDER_NO, BPD.ORDER_LINE, RTRIM(BPD.PART) AS PART, RTRIM(BPD.LOCN) AS LOCN, RTRIM(BPD.LOT) AS LOT, RTRIM(BPD.BIN) AS BIN, RTRIM(BPD.HEAT) AS HEAT, RTRIM(BPD.SERIAL) AS SERIAL, BPD.CRTN_NO, BPD.QTY, BPD.LBS_PER_PC, RTRIM(BPD.PLLT_CD) AS PLLT_CD, BPN.PLLT_NO, BPN.PKGD_WEIGHT, RTRIM(BPN.TRCKNG_NO) AS TRCKNG_NO, RTRIM(BPN.USR_DFND_NO) AS USR_DFND_NO, RTRIM(BPI.FRT_CLASS) AS FRT_CLASS FROM BOL_PACK_DTL BPD JOIN BOL_PALLET_NUM BPN ON BPD.PCK_NO = BPN.PCK_NO AND BPD.PLLT_NO = BPN.PLLT_NO LEFT JOIN BOL_PART_INFO BPI ON BPI.PCK_NO = BPD.PCK_NO AND BPI.ORDER_NO = BPD.ORDER_NO AND BPI.LINE = BPD.ORDER_LINE WHERE BPD.PCK_NO = '{0}' AND BPD.PLLT_NO IN (SELECT PLLT_NO FROM BOL_PACK_DTL WHERE PCK_NO = '{0}' AND ORDER_NO = '{1}' AND ORDER_LINE = '{2}0')",V.Args.PckNo,V.Args.OrderNo,V.Args.OrderLine,V.Local.sSQL)
	F.Data.DataTable.CreateFromSQL("dtFrtClass","con",V.Local.sSQL,True)

	'-- Add Print Label column and fill with "Print" text
	F.Data.DataTable.AddColumn("dtFrtClass","PRINT_LABEL","String")
	F.Intrinsic.Math.Sub(V.DataTable.dtFrtClass.RowCount,1,V.Local.iLastRow)
	F.Intrinsic.Control.For(V.Local.iCnt,0,V.Local.iLastRow,1)
		F.Data.DataTable.SetValue("dtFrtClass",V.Local.iCnt,"PRINT_LABEL","Print")
	F.Intrinsic.Control.Next(V.Local.iCnt)

	'-- Bind to grid
	Gui.frmFrtClass.GSGCFrtClass.AddGridViewFromDataTable("gvFrtClass","dtFrtClass")
	Gui.frmFrtClass.GSGCFrtClass.SuspendLayout()
	Gui.frmFrtClass.GSGCFrtClass.SetGridViewProperty("gvFrtClass","MultiSelect",False)
	Gui.frmFrtClass.GSGCFrtClass.SetGridViewProperty("gvFrtClass","OptionBehaviorEditable",True)
	Gui.frmFrtClass.GSGCFrtClass.SetGridViewProperty("gvFrtClass","ReadOnly",False)
	Gui.frmFrtClass.GSGCFrtClass.SetGridViewProperty("gvFrtClass","AllowSort",True)
	Gui.frmFrtClass.GSGCFrtClass.SetGridViewProperty("gvFrtClass","AllowFilter",True)
	Gui.frmFrtClass.GSGCFrtClass.SetGridViewProperty("gvFrtClass","OptionsViewShowGroupPanel",False)
	Gui.frmFrtClass.GSGCFrtClass.SetGridViewProperty("gvFrtClass","AllowColumnMoving",False)

	'-- Bold headers
	F.Intrinsic.String.Split(V.DataTable.dtFrtClass.FieldNames,"*!*",V.Local.sColumns)
	F.Intrinsic.Control.For(V.Local.iCnt,0,V.Local.sColumns.UBound,1)
		Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass",V.Local.sColumns(V.Local.iCnt),"HeaderFontBold",True)
	F.Intrinsic.Control.Next(V.Local.iCnt)

	'-- ORDER_NO
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","ORDER_NO","Caption","Order")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","ORDER_NO","MinWidth","70")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","ORDER_NO","AllowEdit",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","ORDER_NO","ReadOnly",True)

	'-- ORDER_LINE
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","ORDER_LINE","Caption","Line")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","ORDER_LINE","MinWidth","50")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","ORDER_LINE","AllowEdit",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","ORDER_LINE","ReadOnly",True)

	'-- PART
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PART","Caption","Part")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PART","MinWidth","100")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PART","AllowEdit",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PART","ReadOnly",True)

	'-- LOCN
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","LOCN","Caption","Location")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","LOCN","MinWidth","60")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","LOCN","AllowEdit",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","LOCN","ReadOnly",True)

	'-- Hidden S20 context fields
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","LOT","Visible",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","BIN","Visible",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","HEAT","Visible",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","SERIAL","Visible",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","CRTN_NO","Visible",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","QTY","Visible",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","LBS_PER_PC","Visible",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PLLT_CD","Visible",False)

	'-- PLLT_NO
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PLLT_NO","Caption","Pallet No")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PLLT_NO","MinWidth","80")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PLLT_NO","AllowEdit",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PLLT_NO","ReadOnly",True)

	'-- PKGD_WEIGHT
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PKGD_WEIGHT","Caption","Pkgd Weight")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PKGD_WEIGHT","MinWidth","90")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PKGD_WEIGHT","AllowEdit",True)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PKGD_WEIGHT","ReadOnly",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PKGD_WEIGHT","CellBackColor","LightYellow")

	'-- TRCKNG_NO
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","TRCKNG_NO","Caption","Tracking No")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","TRCKNG_NO","MinWidth","150")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","TRCKNG_NO","AllowEdit",True)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","TRCKNG_NO","ReadOnly",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","TRCKNG_NO","CellBackColor","LightYellow")

	'-- USR_DFND_NO
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","USR_DFND_NO","Caption","User Defined No")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","USR_DFND_NO","MinWidth","150")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","USR_DFND_NO","AllowEdit",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","USR_DFND_NO","ReadOnly",True)

	'-- FRT_CLASS (editable)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","FRT_CLASS","Caption","Freight Class")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","FRT_CLASS","MinWidth","80")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","FRT_CLASS","AllowEdit",True)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","FRT_CLASS","ReadOnly",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","FRT_CLASS","CellBackColor","LightYellow")

	'-- Print Label column (click to print)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PRINT_LABEL","Caption","Print Label")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PRINT_LABEL","MinWidth","70")
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PRINT_LABEL","AllowEdit",False)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PRINT_LABEL","ReadOnly",True)
	Gui.frmFrtClass.GSGCFrtClass.SetColumnProperty("gvFrtClass","PRINT_LABEL","CellBackColor","LightGray")

	Gui.frmFrtClass.GSGCFrtClass.ResumeLayout()
	Gui.frmFrtClass.GSGCFrtClass.MainView("gvFrtClass")

	Gui.frmFrtClass.btnCalcClass.Enabled(True)
	V.Global.sFrtClassWtPallets.Set("")
	Gui.frmFrtClass..Show

	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End
	F.Intrinsic.Control.EndTry
Program.Sub.LoadFrtClassDetail.End

Program.Sub.GSGCFrtClass_CellValueChanged.Start
'-- 7/14/26 BS - Save freight class to BOL_PART_INFO and BOL_ITEM when edited in child grid
'-- Updates ALL order lines on the same pallet in BOL_PART_INFO, child grid, and parent Load grid
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	V.Local.sSQL.Declare
	V.Local.sNewClass.Declare
	V.Local.sRowOrderNo.Declare
	V.Local.sRowOrderLine.Declare
	V.Local.iRow.Declare(Long)
	V.Local.iLastRow.Declare(Long)
	V.Local.sFilter.Declare
	V.Local.sSel.Declare
	V.Local.i.Declare(Long)
	V.Local.sTransIDNew.Declare
	V.Local.sPallet.Declare
	V.Local.sWtCheck.Declare
	V.Local.sNowStamp.Declare
	V.Local.sDateChg.Declare
	V.Local.sTimeChg.Declare
	V.Local.sOrderNo.Declare
	V.Local.sOrderLine.Declare
	V.Local.sPart.Declare
	V.Local.sLocn.Declare
	V.Local.sLot.Declare
	V.Local.sBin.Declare
	V.Local.sHeat.Declare
	V.Local.sSerial.Declare
	V.Local.sCrtnNo.Declare
	V.Local.sQty.Declare
	V.Local.sLbsPerPc.Declare
	V.Local.sPlltCd.Declare
	V.Local.sTrckngNo.Declare
	V.Local.iLabelAnswer.Declare(Long)
	V.Local.sLabelRet.Declare
	V.Local.sLabelParts.Declare
	V.Local.sLabelPrinter.Declare
	V.Local.sCurrentWt.Declare
	V.Local.fCurrentWt.Declare(Float)
	V.Local.fNewWt.Declare(Float)
	V.Local.fDelta.Declare(Float)
	V.Local.fStagedWt.Declare(Float)
	V.Local.fNewStagedWt.Declare(Float)

	F.Intrinsic.Control.If(V.Args.Column,=,"FRT_CLASS")
		V.Local.sNewClass.Set(V.Args.Value.Trim)

		'-- Loop through all rows in dtFrtClass and update BOL_PART_INFO for each order/line
		F.Intrinsic.Math.Sub(V.DataTable.dtFrtClass.RowCount,1,V.Local.iLastRow)
		F.Intrinsic.Control.For(V.Local.iRow,0,V.Local.iLastRow,1)
			V.Local.sRowOrderNo.Set(V.DataTable.dtFrtClass(V.Local.iRow).ORDER_NO!FieldValTrim)
			V.Local.sRowOrderLine.Set(V.DataTable.dtFrtClass(V.Local.iRow).ORDER_LINE!FieldValTrim)

			'-- Update BOL_PART_INFO for this order/line with audit trail
			F.Intrinsic.String.Build("UPDATE BOL_PART_INFO SET FRT_CLASS = '{0}', CHG_PGM = '7546', CHG_BY = '{4}', CHG_DATE = CURDATE(), CHG_TIME = CURTIME() WHERE PCK_NO = '{1}' AND ORDER_NO = '{2}' AND LINE = '{3}'",V.Local.sNewClass,V.Global.sFrtClassPckNo,V.Local.sRowOrderNo,V.Local.sRowOrderLine,V.Caller.User,V.Local.sSQL)
			F.ODBC.Connection!con.Execute(V.Local.sSQL)

			'-- Update FRT_CLASS in child grid DataTable
			F.Data.Datatable.SetValue("dtFrtClass",V.Local.iRow,"FRT_CLASS",V.Local.sNewClass)
		F.Intrinsic.Control.Next(V.Local.iRow)

		'-- Update BOL_ITEM for all SEQ rows on this waybill
		F.Intrinsic.Control.If(V.Global.sFrtClassWaybill.Trim,<>,"")
			F.Intrinsic.String.Build("UPDATE BOL_ITEM SET FRT_CLASS = '{0}' WHERE WAYBILL_NO = '{1}'",V.Local.sNewClass,V.Global.sFrtClassWaybill.Trim,V.Local.sSQL)
			F.ODBC.Connection!con.Execute(V.Local.sSQL)
		F.Intrinsic.Control.EndIf

		'-- Update parent Load grid for all rows with same packing list
		F.Intrinsic.String.Build("[Packing List] = '{0}'",V.Global.sFrtClassPckNo,V.Local.sFilter)
		F.Data.Datatable.Select("dtLoad",V.Local.sFilter,V.Local.sSel)
		F.Intrinsic.Control.If(V.Local.sSel.Trim,<>,"***NORETURN***")
			F.Intrinsic.String.Split(V.Local.sSel,"*!*",V.Local.sSel)
			F.Intrinsic.Control.For(V.Local.i,0,V.Local.sSel.UBound)
				F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"FRT_CLASS",V.Local.sNewClass)
			F.Intrinsic.Control.Next(V.Local.i)
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf

	F.Intrinsic.Control.If(V.Args.Column,=,"TRCKNG_NO")
		'-- Update BOL_PALLET_NUM with new dimensions
		V.Local.sRowOrderNo.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).PLLT_NO!FieldValTrim)
		F.Intrinsic.String.Build("UPDATE BOL_PALLET_NUM SET TRCKNG_NO = '{0}', CHG_PGM = '7546', CHG_BY = '{3}', CHG_DATE = CURDATE(), CHG_TIME = CURTIME() WHERE PCK_NO = '{1}' AND PLLT_NO = '{2}'",V.Args.Value.Trim,V.Global.sFrtClassPckNo,V.Local.sRowOrderNo,V.Caller.User,V.Local.sSQL)
		F.ODBC.Connection!con.Execute(V.Local.sSQL)

		'-- Propagate to all rows in child grid with same pallet number
		F.Intrinsic.Math.Sub(V.DataTable.dtFrtClass.RowCount,1,V.Local.iLastRow)
		F.Intrinsic.Control.For(V.Local.iRow,0,V.Local.iLastRow,1)
			V.Local.sRowOrderLine.Set(V.DataTable.dtFrtClass(V.Local.iRow).PLLT_NO!FieldValTrim)
			F.Intrinsic.Control.If(V.Local.sRowOrderLine,=,V.Local.sRowOrderNo)
				F.Data.Datatable.SetValue("dtFrtClass",V.Local.iRow,"TRCKNG_NO",V.Args.Value.Trim)
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.Next(V.Local.iRow)
	F.Intrinsic.Control.EndIf

	F.Intrinsic.Control.If(V.Args.Column,=,"PKGD_WEIGHT")
		'-- 7/15/26 BS - Update pallet weight via S20 WirePoll (once per pallet)
		V.Local.sPallet.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).PLLT_NO!FieldValTrim)

		'-- Skip S20 if weight did not actually change
		F.Intrinsic.String.Build("SELECT PKGD_WEIGHT FROM BOL_PALLET_NUM WHERE PCK_NO='{0}' AND PLLT_NO='{1}'",V.Global.sFrtClassPckNo,V.Local.sPallet,V.Local.sSQL)
		F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.sCurrentWt)
		V.Local.fCurrentWt.Set(V.Local.sCurrentWt)
		V.Local.fNewWt.Set(V.Args.Value.Trim)
		F.Intrinsic.Control.If(V.Local.fCurrentWt,=,V.Local.fNewWt)
			F.Intrinsic.Control.ExitSub
		F.Intrinsic.Control.EndIf

		V.Local.sOrderNo.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).ORDER_NO!FieldValTrim)
		V.Local.sOrderLine.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).ORDER_LINE!FieldValTrim)
		V.Local.sPart.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).PART!FieldValTrim)
		V.Local.sLocn.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).LOCN!FieldValTrim)
		V.Local.sLot.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).LOT!FieldValTrim)
		V.Local.sBin.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).BIN!FieldValTrim)
		V.Local.sHeat.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).HEAT!FieldValTrim)
		V.Local.sSerial.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).SERIAL!FieldValTrim)
		V.Local.sCrtnNo.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).CRTN_NO!FieldValTrim)
		V.Local.sQty.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).QTY!FieldValTrim)
		V.Local.sLbsPerPc.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).LBS_PER_PC!FieldValTrim)
		V.Local.sPlltCd.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).PLLT_CD!FieldValTrim)
		V.Local.sTrckngNo.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).TRCKNG_NO!FieldValTrim)

		'-- Check if S20 already submitted for this pallet in this session
		F.Intrinsic.String.InStr(V.Global.sFrtClassWtPallets,V.Local.sPallet,V.Local.sWtCheck)
		F.Intrinsic.Control.If(V.Local.sWtCheck,=,"0")
			'-- Derive audit timestamp
			V.Local.sNowStamp.Set(V.Ambient.Now.FormatYYYYMMDDHHNNSS)
			F.Intrinsic.String.Mid(V.Local.sNowStamp,1,8,V.Local.sDateChg)
			F.Intrinsic.String.Mid(V.Local.sNowStamp,9,6,V.Local.sTimeChg)
			F.Intrinsic.String.Concat(V.Local.sTimeChg,"00",V.Local.sTimeChg)

			'-- Get next TRANS_ID
			F.ODBC.Connection!con.ExecuteAndReturn("SELECT TOP 1 RIGHT(CONCAT('000000000',CAST(TRANS_ID AS INT)+1),9) AS TRANS_ID FROM WIRELESS_HDR ORDER BY TRANS_ID DESC",V.Local.sTransIDNew)
			F.Intrinsic.String.LPad(V.Local.sTransIDNew,"0",9,V.Local.sTransIDNew)

			'-- INSERT WIRELESS_HDR
			F.Intrinsic.String.Build("INSERT INTO WIRELESS_HDR (TRANS_ID,TRANS_TYPE,ATTEMPTED_DATE,ATTEMPTED_TIME,USER_ID,BATCH,ATTEMPTED_FLAG) VALUES ('{0}','S20','00000000','00000000','{1}',0,'Y')",V.Local.sTransIDNew,V.Caller.User,V.Local.sSQL)
			F.ODBC.Connection!con.Execute(V.Local.sSQL)

			'-- INSERT WIRELESS_LINE: all S20 context fields per mobile form
			F.Intrinsic.StringBuilder.Create("sbSQL")
			F.Intrinsic.StringBuilder.Append("sbSQL","INSERT INTO WIRELESS_LINE (TRANS_ID,SEQ,TRANS_TYPE,FIELD_1,FIELD_2,FIELD_3,FIELD_4,FIELD_5,FIELD_6,FIELD_7,FIELD_8,FIELD_9,FIELD_10,FIELD_11,FIELD_13,FIELD_14,FIELD_15,FIELD_18,FIELD_19,FIELD_21,FIELD_23,FIELD_24,ERROR_ID,DATE_LAST_CHG,TIME_LAST_CHG,LAST_CHG_BY) VALUES ('")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sTransIDNew)
			F.Intrinsic.StringBuilder.Append("sbSQL","','0000','S20','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Global.sFrtClassPckNo)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sOrderNo)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sOrderLine)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sPart)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sLocn)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sLot)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sBin)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sHeat)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sSerial)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sCrtnNo)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sPallet)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sPlltCd)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sQty)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sLbsPerPc)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Args.Value.Trim)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sTrckngNo)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sPallet)
			F.Intrinsic.StringBuilder.Append("sbSQL","','N','',0,'")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sDateChg)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sTimeChg)
			F.Intrinsic.StringBuilder.Append("sbSQL","','")
			F.Intrinsic.StringBuilder.Append("sbSQL",V.Caller.User)
			F.Intrinsic.StringBuilder.Append("sbSQL","')")
			F.Intrinsic.StringBuilder.ToString("sbSQL",V.Local.sSQL)
			F.Intrinsic.StringBuilder.Dispose("sbSQL")
			F.ODBC.Connection!con.Execute(V.Local.sSQL)

			'-- Reset all pallets LABEL_FLAG to N for this packing list
			F.Intrinsic.String.Build("UPDATE BOL_PALLET_NUM SET LABEL_FLAG='N' WHERE PCK_NO='{0}'",V.Global.sFrtClassPckNo,V.Local.sSQL)
			F.ODBC.Connection!con.Execute(V.Local.sSQL)

			'-- Prompt to print label after weight update
			F.Intrinsic.UI.Msgbox("Print a new pallet label?","Print Label?",V.Enum.MsgBoxStyle!YesNo,V.Local.iLabelAnswer)
			F.Intrinsic.Control.If(V.Local.iLabelAnswer,=,6)
				F.ODBC.Connection!conC.OpenCommonConnection
				F.Data.DataTable.CreateFromSQL("dtPrinters","conC","SELECT RTRIM(SENTINELALIAS) AS SENTINELALIAS, RTRIM(PRINTERNAME) AS PRINTERNAME FROM SERVER_PRINTERS WHERE SENTINELENABLED = 1 AND SENTINELALIAS IS NOT NULL AND RTRIM(SENTINELALIAS) <> '' ORDER BY SENTINELALIAS")
				F.ODBC.Connection!conC.Close
				F.Intrinsic.Control.If(V.DataTable.dtPrinters.RowCount,>,0)
					F.Intrinsic.UI.BrowserFromDataTable("Select Label Printer","dtPrinters","Sentinel Alias*!*Printer Name","200*!*300",V.Local.sLabelRet)
					F.Intrinsic.Control.If(V.Local.sLabelRet.Trim,<>,"***CANCEL***")
						F.Intrinsic.String.Split(V.Local.sLabelRet,"*!*",V.Local.sLabelParts)
						V.Local.sLabelPrinter.Set(V.Local.sLabelParts(0).Trim)
						F.Intrinsic.String.Build("UPDATE WIRELESS_HDR SET LABEL_PRINTER='{0}' WHERE TRANS_ID='{1}'",V.Local.sLabelPrinter,V.Local.sTransIDNew,V.Local.sSQL)
						F.ODBC.Connection!con.Execute(V.Local.sSQL)
						F.Intrinsic.String.Build("UPDATE WIRELESS_LINE SET FIELD_24='Y', FIELD_25='' WHERE TRANS_ID='{0}'",V.Local.sTransIDNew,V.Local.sSQL)
						F.ODBC.Connection!con.Execute(V.Local.sSQL)
						'-- Set LABEL_FLAG=Y for this pallet
						F.Intrinsic.String.Build("UPDATE BOL_PALLET_NUM SET LABEL_FLAG='Y' WHERE PCK_NO='{0}' AND PLLT_NO='{1}'",V.Global.sFrtClassPckNo,V.Local.sPallet,V.Local.sSQL)
						F.ODBC.Connection!con.Execute(V.Local.sSQL)
					F.Intrinsic.Control.EndIf
				F.Intrinsic.Control.EndIf
				F.Data.DataTable.Close("dtPrinters")
			F.Intrinsic.Control.EndIf

			'-- Release for WirePoll
			F.Intrinsic.String.Build("UPDATE WIRELESS_HDR SET ATTEMPTED_FLAG='' WHERE TRANS_ID='{0}'",V.Local.sTransIDNew,V.Local.sSQL)
			F.ODBC.Connection!con.Execute(V.Local.sSQL)

			'-- Mark pallet as submitted
			F.Intrinsic.String.Build("{0}|{1}",V.Global.sFrtClassWtPallets,V.Local.sPallet,V.Global.sFrtClassWtPallets)
		F.Intrinsic.Control.EndIf

		'-- Propagate to all rows with same pallet number
		F.Intrinsic.Math.Sub(V.DataTable.dtFrtClass.RowCount,1,V.Local.iLastRow)
		F.Intrinsic.Control.For(V.Local.iRow,0,V.Local.iLastRow,1)
			V.Local.sRowOrderLine.Set(V.DataTable.dtFrtClass(V.Local.iRow).PLLT_NO!FieldValTrim)
			F.Intrinsic.Control.If(V.Local.sRowOrderLine,=,V.Local.sPallet)
				F.Data.Datatable.SetValue("dtFrtClass",V.Local.iRow,"PKGD_WEIGHT",V.Args.Value.Trim)
			F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.Next(V.Local.iRow)

		'-- Update Staged PL Weight in parent Load grid by delta
		F.Intrinsic.Math.Sub(V.Local.fNewWt,V.Local.fCurrentWt,V.Local.fDelta)
		F.Intrinsic.String.Build("[Packing List] = '{0}' AND [Staged PL Mixed] = ''",V.Global.sFrtClassPckNo,V.Local.sFilter)
		F.Data.Datatable.Select("dtLoad",V.Local.sFilter,V.Local.sSel)
		F.Intrinsic.Control.If(V.Local.sSel.Trim,<>,"***NORETURN***")
			F.Intrinsic.String.Split(V.Local.sSel,"*!*",V.Local.sSel)
			V.Local.fStagedWt.Set(V.DataTable.dtLoad(V.Local.sSel(0)).Staged PL Weight!FieldVal)
			F.Intrinsic.Math.Add(V.Local.fStagedWt,V.Local.fDelta,V.Local.fNewStagedWt)
			F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(0),"Staged PL Weight",V.Local.fNewStagedWt)
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf

	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End
	F.Intrinsic.Control.EndTry
Program.Sub.GSGCFrtClass_CellValueChanged.End

Program.Sub.frmFrtClass_UnLoad.Start
'-- 7/14/26 BS - Hide freight class child form on close
	F.Intrinsic.Control.Try
	V.Local.sError.Declare

	Gui.frmFrtClass..Visible(False)

	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End
	F.Intrinsic.Control.EndTry
Program.Sub.frmFrtClass_UnLoad.End


Program.Sub.GSGCFrtClass_RowCellClick.Start
'-- 7/16/26 BS; UDF - Print Label button column: submit S20 with print flag
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	V.Local.sSQL.Declare
	V.Local.sTransIDNew.Declare
	V.Local.sPallet.Declare
	V.Local.sOrderNo.Declare
	V.Local.sOrderLine.Declare
	V.Local.sPart.Declare
	V.Local.sLocn.Declare
	V.Local.sLot.Declare
	V.Local.sBin.Declare
	V.Local.sHeat.Declare
	V.Local.sSerial.Declare
	V.Local.sCrtnNo.Declare
	V.Local.sQty.Declare
	V.Local.sLbsPerPc.Declare
	V.Local.sPlltCd.Declare
	V.Local.sTrckngNo.Declare
	V.Local.sWeight.Declare
	V.Local.sNowStamp.Declare
	V.Local.sDateChg.Declare
	V.Local.sTimeChg.Declare
	V.Local.sLabelQty.Declare
	V.Local.sRet.Declare
	V.Local.sParts.Declare
	V.Local.sPRID.Declare
	V.Local.sHdrMax.Declare
	V.Local.sLineMax.Declare
	V.Local.iHdrMax.Declare(Long)
	V.Local.iLineMax.Declare(Long)

	F.Intrinsic.Control.If(V.Args.Column,<>,"PRINT_LABEL")
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf

	'-- Browse for label printer (exit if cancelled)
	F.ODBC.Connection!conC.OpenCommonConnection
	F.Data.DataTable.CreateFromSQL("dtPrinters","conC","SELECT RTRIM(SENTINELALIAS) AS SENTINELALIAS, RTRIM(PRINTERNAME) AS PRINTERNAME FROM SERVER_PRINTERS WHERE SENTINELENABLED = 1 AND SENTINELALIAS IS NOT NULL AND RTRIM(SENTINELALIAS) <> '' ORDER BY SENTINELALIAS")
	F.ODBC.Connection!conC.Close

	F.Intrinsic.Control.If(V.DataTable.dtPrinters.RowCount,=,0)
		F.Intrinsic.UI.Msgbox("No Sentinel label printers are configured.","No Printers")
		F.Data.DataTable.Close("dtPrinters")
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf

	F.Intrinsic.UI.BrowserFromDataTable("Select Label Printer","dtPrinters","Sentinel Alias*!*Printer Name","200*!*300",V.Local.sRet)
	F.Data.DataTable.Close("dtPrinters")

	F.Intrinsic.Control.If(V.Local.sRet.Trim,=,"***CANCEL***")
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf

	F.Intrinsic.String.Split(V.Local.sRet,"*!*",V.Local.sParts)
	V.Local.sPRID.Set(V.Local.sParts(0).Trim)

	'-- Gather row context
	V.Local.sPallet.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).PLLT_NO!FieldValTrim)
	V.Local.sOrderNo.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).ORDER_NO!FieldValTrim)
	V.Local.sOrderLine.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).ORDER_LINE!FieldValTrim)
	V.Local.sPart.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).PART!FieldValTrim)
	V.Local.sLocn.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).LOCN!FieldValTrim)
	V.Local.sLot.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).LOT!FieldValTrim)
	V.Local.sBin.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).BIN!FieldValTrim)
	V.Local.sHeat.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).HEAT!FieldValTrim)
	V.Local.sSerial.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).SERIAL!FieldValTrim)
	V.Local.sCrtnNo.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).CRTN_NO!FieldValTrim)
	V.Local.sQty.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).QTY!FieldValTrim)
	V.Local.sLbsPerPc.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).LBS_PER_PC!FieldValTrim)
	V.Local.sPlltCd.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).PLLT_CD!FieldValTrim)
	V.Local.sTrckngNo.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).TRCKNG_NO!FieldValTrim)
	V.Local.sWeight.Set(V.DataTable.dtFrtClass(V.Args.RowIndex).PKGD_WEIGHT!FieldValTrim)

	'-- Derive audit timestamp
	V.Local.sNowStamp.Set(V.Ambient.Now.FormatYYYYMMDDHHNNSS)
	F.Intrinsic.String.Mid(V.Local.sNowStamp,1,8,V.Local.sDateChg)
	F.Intrinsic.String.Mid(V.Local.sNowStamp,9,6,V.Local.sTimeChg)
	F.Intrinsic.String.Concat(V.Local.sTimeChg,"00",V.Local.sTimeChg)

	'-- Get next TRANS_ID (check both HDR and LINE for max to avoid duplicates)
	F.ODBC.Connection!con.ExecuteAndReturn("SELECT TOP 1 CAST(TRANS_ID AS INT) FROM WIRELESS_HDR ORDER BY TRANS_ID DESC",V.Local.sHdrMax)
	F.ODBC.Connection!con.ExecuteAndReturn("SELECT TOP 1 CAST(TRANS_ID AS INT) FROM WIRELESS_LINE ORDER BY TRANS_ID DESC",V.Local.sLineMax)
	V.Local.iHdrMax.Set(V.Local.sHdrMax)
	V.Local.iLineMax.Set(V.Local.sLineMax)
	F.Intrinsic.Control.If(V.Local.iLineMax,>,V.Local.iHdrMax)
		F.Intrinsic.Math.Add(V.Local.iLineMax,1,V.Local.iHdrMax)
	F.Intrinsic.Control.Else
		F.Intrinsic.Math.Add(V.Local.iHdrMax,1,V.Local.iHdrMax)
	F.Intrinsic.Control.EndIf
	F.Intrinsic.String.Build("{0}",V.Local.iHdrMax,V.Local.sTransIDNew)
	F.Intrinsic.String.LPad(V.Local.sTransIDNew,"0",9,V.Local.sTransIDNew)

	'-- INSERT WIRELESS_HDR with LABEL_PRINTER (Sentinel alias name)
	F.Intrinsic.String.Build("INSERT INTO WIRELESS_HDR (TRANS_ID,TRANS_TYPE,ATTEMPTED_DATE,ATTEMPTED_TIME,USER_ID,BATCH,ATTEMPTED_FLAG,LABEL_PRINTER) VALUES ('{0}','S20','00000000','00000000','{1}',0,'Y','{2}')",V.Local.sTransIDNew,V.Caller.User,V.Local.sPRID,V.Local.sSQL)
	F.ODBC.Connection!con.Execute(V.Local.sSQL)

	'-- INSERT WIRELESS_LINE with print flag Y and label quantity
	F.Intrinsic.StringBuilder.Create("sbSQL")
	F.Intrinsic.StringBuilder.Append("sbSQL","INSERT INTO WIRELESS_LINE (TRANS_ID,SEQ,TRANS_TYPE,FIELD_1,FIELD_2,FIELD_3,FIELD_4,FIELD_5,FIELD_6,FIELD_7,FIELD_8,FIELD_9,FIELD_10,FIELD_11,FIELD_13,FIELD_14,FIELD_15,FIELD_18,FIELD_19,FIELD_21,FIELD_23,FIELD_24,FIELD_25,ERROR_ID,DATE_LAST_CHG,TIME_LAST_CHG,LAST_CHG_BY) VALUES ('")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sTransIDNew)
	F.Intrinsic.StringBuilder.Append("sbSQL","','0000','S20','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Global.sFrtClassPckNo)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sOrderNo)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sOrderLine)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sPart)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sLocn)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sLot)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sBin)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sHeat)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sSerial)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sCrtnNo)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sPallet)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sPlltCd)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sQty)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sLbsPerPc)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sWeight)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sTrckngNo)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sPallet)
	F.Intrinsic.StringBuilder.Append("sbSQL","','N','Y','',0,'")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sDateChg)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Local.sTimeChg)
	F.Intrinsic.StringBuilder.Append("sbSQL","','")
	F.Intrinsic.StringBuilder.Append("sbSQL",V.Caller.User)
	F.Intrinsic.StringBuilder.Append("sbSQL","')")
	F.Intrinsic.StringBuilder.ToString("sbSQL",V.Local.sSQL)
	F.Intrinsic.StringBuilder.Dispose("sbSQL")
	F.ODBC.Connection!con.Execute(V.Local.sSQL)

	'-- Reset all pallets LABEL_FLAG to N, then set Y for this pallet
	F.Intrinsic.String.Build("UPDATE BOL_PALLET_NUM SET LABEL_FLAG='N' WHERE PCK_NO='{0}'",V.Global.sFrtClassPckNo,V.Local.sSQL)
	F.ODBC.Connection!con.Execute(V.Local.sSQL)
	F.Intrinsic.String.Build("UPDATE BOL_PALLET_NUM SET LABEL_FLAG='Y' WHERE PCK_NO='{0}' AND PLLT_NO='{1}'",V.Global.sFrtClassPckNo,V.Local.sPallet,V.Local.sSQL)
	F.ODBC.Connection!con.Execute(V.Local.sSQL)

	'-- Release for WirePoll
	F.Intrinsic.String.Build("UPDATE WIRELESS_HDR SET ATTEMPTED_FLAG='' WHERE TRANS_ID='{0}'",V.Local.sTransIDNew,V.Local.sSQL)
	F.ODBC.Connection!con.Execute(V.Local.sSQL)

	F.Intrinsic.UI.Msgbox("Label print submitted.","Print Label")

	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End
	F.Intrinsic.Control.EndTry
Program.Sub.GSGCFrtClass_RowCellClick.End

Program.Sub.btnCalcClass_Click.Start
'-- 7/14/26 BS - Delegate to CalcFrtClass subroutine
	F.Intrinsic.Control.Try
	V.Local.sError.Declare

	F.Intrinsic.Control.CallSub(CalcFrtClass)

	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End
	F.Intrinsic.Control.EndTry
Program.Sub.btnCalcClass_Click.End

Program.Sub.CalcFrtClass.Start
'-- 7/14/26 BS - Calculate freight class from density (NMFC 57410)
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	V.Local.iRow.Declare(Long)
	V.Local.iLastRow.Declare(Long)
	V.Local.sVal.Declare
	V.Local.sCalcClass.Declare
	V.Local.sSQL.Declare
	V.Local.sRows.Declare

	'-- NMFC 57410 guard
	F.Intrinsic.Control.If(V.Global.sFrtClassNMFC.Trim,<>,"57410")
		F.Intrinsic.UI.Msgbox("Calculate Class is only available for NMFC 57410.","Information")
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf

	'-- Clear warned-pallets tracker
	V.Global.sFrtClassWarned.Set("")

	'-- Loop through rows - delegate per-row calculation
	F.Intrinsic.Math.Sub(V.DataTable.dtFrtClass.RowCount,1,V.Local.iLastRow)
	F.Intrinsic.Control.For(V.Local.iRow,0,V.Local.iLastRow,1)
		V.Global.iFrtClassRowIdx.Set(V.Local.iRow)
		F.Intrinsic.Control.CallSub(CalcOneRow)
	F.Intrinsic.Control.Next(V.Local.iRow)

	'-- Get calculated class from first row for BOL_ITEM and parent grid
	V.Local.sCalcClass.Set(V.DataTable.dtFrtClass(0).FRT_CLASS!FieldValTrim)
	F.Intrinsic.Control.If(V.Local.sCalcClass.Trim,=,"")
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf

	'-- Update BOL_ITEM
	F.Intrinsic.Control.If(V.Global.sFrtClassWaybill.Trim,<>,"")
		F.Intrinsic.String.Build("UPDATE BOL_ITEM SET FRT_CLASS = '{0}' WHERE WAYBILL_NO = '{1}'",V.Local.sCalcClass,V.Global.sFrtClassWaybill.Trim,V.Local.sSQL)
		F.ODBC.Connection!con.Execute(V.Local.sSQL)
	F.Intrinsic.Control.EndIf

	'-- Update parent Load grid
	F.Intrinsic.String.Build("[Packing List] = '{0}'",V.Global.sFrtClassPckNo,V.Local.sVal)
	F.Data.Datatable.Select("dtLoad",V.Local.sVal,V.Local.sRows)
	F.Intrinsic.Control.If(V.Local.sRows.Trim,<>,"***NORETURN***")
		F.Intrinsic.String.Split(V.Local.sRows,"*!*",V.Local.sVal)
		F.Intrinsic.Math.Sub(V.Local.sVal.UBound,0,V.Local.iLastRow)
		F.Intrinsic.Control.For(V.Local.iRow,0,V.Local.iLastRow,1)
			F.Data.Datatable.SetValue("dtLoad",V.Local.sVal(V.Local.iRow),"FRT_CLASS",V.Local.sCalcClass)
		F.Intrinsic.Control.Next(V.Local.iRow)
	F.Intrinsic.Control.EndIf

	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End
	F.Intrinsic.Control.EndTry
Program.Sub.CalcFrtClass.End

Program.Sub.CalcOneRow.Start
'-- 7/14/26 BS - Calculate freight class for one row (no Decimal vars - GAB bug workaround)
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	V.Local.sVal.Declare
	V.Local.sWeight.Declare
	V.Local.sVolume.Declare
	V.Local.sDensity.Declare
	V.Local.sParts.Declare
	V.Local.sClass.Declare
	V.Local.sSQL.Declare
	V.Local.sOrderNo.Declare
	V.Local.sOrderLine.Declare
	V.Local.sPallet.Declare
	V.Local.bWarned.Declare

	'-- Read pallet number for once-per-pallet warning logic
	V.Local.sPallet.Set(V.DataTable.dtFrtClass(V.Global.iFrtClassRowIdx).PLLT_NO!FieldValTrim)
	F.Intrinsic.String.InStr(V.Global.sFrtClassWarned,V.Local.sPallet,V.Local.bWarned)

	'-- Read order/line for warning messages
	V.Local.sOrderNo.Set(V.DataTable.dtFrtClass(V.Global.iFrtClassRowIdx).ORDER_NO!FieldValTrim)
	V.Local.sOrderLine.Set(V.DataTable.dtFrtClass(V.Global.iFrtClassRowIdx).ORDER_LINE!FieldValTrim)

	'-- Read weight
	V.Local.sWeight.Set(V.DataTable.dtFrtClass(V.Global.iFrtClassRowIdx).PKGD_WEIGHT!FieldValTrim)
	F.Intrinsic.Control.If(V.Local.sWeight,=,"")
		F.Intrinsic.Control.If(V.Local.bWarned,=,"0")
			F.Intrinsic.String.Build("Pallet {0} (Order {1}/{2}): Packaged Weight is empty. Cannot calculate class.",V.Local.sPallet,V.Local.sOrderNo,V.Local.sOrderLine,V.Local.sVal)
			F.Intrinsic.UI.Msgbox(V.Local.sVal,"Validation")
			F.Intrinsic.String.Build("{0}|{1}",V.Global.sFrtClassWarned,V.Local.sPallet,V.Global.sFrtClassWarned)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.If(V.Local.sWeight,<=,"0")
		F.Intrinsic.Control.If(V.Local.bWarned,=,"0")
			F.Intrinsic.String.Build("Pallet {0} (Order {1}/{2}): Packaged Weight must be > 0. Current value: {3}",V.Local.sPallet,V.Local.sOrderNo,V.Local.sOrderLine,V.Local.sWeight,V.Local.sVal)
			F.Intrinsic.UI.Msgbox(V.Local.sVal,"Validation")
			F.Intrinsic.String.Build("{0}|{1}",V.Global.sFrtClassWarned,V.Local.sPallet,V.Global.sFrtClassWarned)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf

	'-- Read dimensions and validate format (LxWxH)
	V.Local.sVal.Set(V.DataTable.dtFrtClass(V.Global.iFrtClassRowIdx).TRCKNG_NO!FieldValTrim)
	F.Intrinsic.Control.If(V.Local.sVal,=,"")
		F.Intrinsic.Control.If(V.Local.bWarned,=,"0")
			F.Intrinsic.String.Build("Pallet {0} (Order {1}/{2}): Tracking No is empty. Must be in format 'LxWxH' (e.g. '40x40x48').",V.Local.sPallet,V.Local.sOrderNo,V.Local.sOrderLine,V.Local.sError)
			F.Intrinsic.UI.Msgbox(V.Local.sError,"Validation")
			F.Intrinsic.String.Build("{0}|{1}",V.Global.sFrtClassWarned,V.Local.sPallet,V.Global.sFrtClassWarned)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf
	F.Intrinsic.String.UCase(V.Local.sVal,V.Local.sVal)
	F.Intrinsic.String.Split(V.Local.sVal,"X",V.Local.sParts)
	F.Intrinsic.Control.If(V.Local.sParts.UBound,<>,2)
		F.Intrinsic.Control.If(V.Local.bWarned,=,"0")
			F.Intrinsic.String.Build("Pallet {0} (Order {1}/{2}): Tracking No '{3}' is not in required format 'LxWxH' (3 numeric values separated by x).",V.Local.sPallet,V.Local.sOrderNo,V.Local.sOrderLine,V.Local.sVal,V.Local.sError)
			F.Intrinsic.UI.Msgbox(V.Local.sError,"Validation")
			F.Intrinsic.String.Build("{0}|{1}",V.Global.sFrtClassWarned,V.Local.sPallet,V.Global.sFrtClassWarned)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf
	F.Intrinsic.Math.IsNumeric(V.Local.sParts(0),V.Local.sError)
	F.Intrinsic.Control.If(V.Local.sError,=,"False")
		F.Intrinsic.Control.If(V.Local.bWarned,=,"0")
			F.Intrinsic.String.Build("Pallet {0} (Order {1}/{2}): Tracking No '{3}' contains non-numeric value. All dimensions must be numeric.",V.Local.sPallet,V.Local.sOrderNo,V.Local.sOrderLine,V.Local.sVal,V.Local.sError)
			F.Intrinsic.UI.Msgbox(V.Local.sError,"Validation")
			F.Intrinsic.String.Build("{0}|{1}",V.Global.sFrtClassWarned,V.Local.sPallet,V.Global.sFrtClassWarned)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf
	F.Intrinsic.Math.IsNumeric(V.Local.sParts(1),V.Local.sError)
	F.Intrinsic.Control.If(V.Local.sError,=,"False")
		F.Intrinsic.Control.If(V.Local.bWarned,=,"0")
			F.Intrinsic.String.Build("Pallet {0} (Order {1}/{2}): Tracking No '{3}' contains non-numeric value. All dimensions must be numeric.",V.Local.sPallet,V.Local.sOrderNo,V.Local.sOrderLine,V.Local.sVal,V.Local.sError)
			F.Intrinsic.UI.Msgbox(V.Local.sError,"Validation")
			F.Intrinsic.String.Build("{0}|{1}",V.Global.sFrtClassWarned,V.Local.sPallet,V.Global.sFrtClassWarned)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf
	F.Intrinsic.Math.IsNumeric(V.Local.sParts(2),V.Local.sError)
	F.Intrinsic.Control.If(V.Local.sError,=,"False")
		F.Intrinsic.Control.If(V.Local.bWarned,=,"0")
			F.Intrinsic.String.Build("Pallet {0} (Order {1}/{2}): Tracking No '{3}' contains non-numeric value. All dimensions must be numeric.",V.Local.sPallet,V.Local.sOrderNo,V.Local.sOrderLine,V.Local.sVal,V.Local.sError)
			F.Intrinsic.UI.Msgbox(V.Local.sError,"Validation")
			F.Intrinsic.String.Build("{0}|{1}",V.Global.sFrtClassWarned,V.Local.sPallet,V.Global.sFrtClassWarned)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf

	'-- Volume in cubic inches: L * W * H
	F.Intrinsic.Math.Mult(V.Local.sParts(0),V.Local.sParts(1),V.Local.sVolume)
	F.Intrinsic.Math.Mult(V.Local.sVolume,V.Local.sParts(2),V.Local.sVolume)

	'-- Convert to cubic feet: volume / 1728
	F.Intrinsic.Math.Div(V.Local.sVolume,1728,V.Local.sVolume)
	F.Intrinsic.Control.If(V.Local.sVolume,<=,"0")
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf

	'-- Density: weight / cubic feet
	F.Intrinsic.Math.Div(V.Local.sWeight,V.Local.sVolume,V.Local.sDensity)

	'-- Density to Class lookup (must check highest first)
	F.Intrinsic.Control.If(V.Local.sDensity,>=,"15")
		V.Local.sClass.Set("70")
	F.Intrinsic.Control.ElseIf(V.Local.sDensity,>=,"12")
		V.Local.sClass.Set("85")
	F.Intrinsic.Control.ElseIf(V.Local.sDensity,>=,"10")
		V.Local.sClass.Set("92.5")
	F.Intrinsic.Control.ElseIf(V.Local.sDensity,>=,"8")
		V.Local.sClass.Set("100")
	F.Intrinsic.Control.ElseIf(V.Local.sDensity,>=,"6")
		V.Local.sClass.Set("125")
	F.Intrinsic.Control.ElseIf(V.Local.sDensity,>=,"4")
		V.Local.sClass.Set("175")
	F.Intrinsic.Control.Else
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf

	'-- Save to DataTable
	F.Data.Datatable.SetValue("dtFrtClass",V.Global.iFrtClassRowIdx,"FRT_CLASS",V.Local.sClass)

	'-- Update BOL_PART_INFO with audit trail
	F.Intrinsic.String.Build("UPDATE BOL_PART_INFO SET FRT_CLASS = '{0}', CHG_PGM = '7546', CHG_BY = '{4}', CHG_DATE = CURDATE(), CHG_TIME = CURTIME() WHERE PCK_NO = '{1}' AND ORDER_NO = '{2}' AND LINE = '{3}'",V.Local.sClass,V.Global.sFrtClassPckNo,V.Local.sOrderNo,V.Local.sOrderLine,V.Caller.User,V.Local.sSQL)
	F.ODBC.Connection!con.Execute(V.Local.sSQL)

	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("CalcOneRow error: {0} - {1}",V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.EndTry
Program.Sub.CalcOneRow.End

Program.Sub.PrintPickList.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	V.Local.bLocked.Declare
	V.Local.sName.Declare
	V.Local.sValue.Declare
	V.Local.iRet.Declare(Long)	
	
	'OrderLocked sub checks the lock table to see if the SO is locked by anyone else. Pass in Order Number and the sub returns 
	'a is locked boolean value and the user who has it locked if it's locked. 
	Function.Intrinsic.Control.CallSub(OrderLocked,"sOrderNo",v.Args.OrderNO)
	F.Intrinsic.Control.If(v.Args.bIsLocked)		
		F.Intrinsic.String.Build("Order {0} locked by User: {1}. Continue?",v.Args.OrderNo,v.Args.sLockingUser,v.Local.sName)
		F.Intrinsic.UI.Msgbox(v.Local.sName,"Order Locked...",3,v.Local.iRet)
		Function.Intrinsic.Control.If(v.Local.iRet,<>,6)						
			f.Intrinsic.Variable.AddRV("bPrinted",False)
			f.Intrinsic.Control.ExitSub
		Function.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf
	
	F.Intrinsic.Control.If(V.Screen.frmShip!ddlPicklistRpt.ItemData,=,0)
		F.Intrinsic.String.ConcatCallWrapperArgs(V.Args.OrderNo,V.Args.OrderNo,"N","*!*ZDR*!*","*!*ZDR*!*","Y",V.Local.sValue)
			gui.frmShip..Enabled(False)
			F.Global.General.CallWrapperSync(910201,V.Local.sValue)
			Gui.frmShip..Enabled(True)
			Gui.frmShip..SetFocus(True)
	F.Intrinsic.Control.ElseIf(V.Screen.frmShip!ddlPicklistRpt.ItemData,=,1)
		F.Intrinsic.String.ConcatCallWrapperArgs(V.Args.OrderNo,V.Args.OrderNo,"N","*!*ZDR*!*","*!*ZDR*!*","Y",V.Local.sValue)
		gui.frmShip.tabShip.Enabled(False)
		F.Global.General.CallWrapperSync(910202,V.Local.sValue)
		gui.frmShip.tabShip.Enabled(True)		
	F.Intrinsic.Control.Else
		'5/21/26 BS - Pass OrderLine parameter to Report 95 (matches Open Orders per-line printing)
		F.Intrinsic.String.Split("OrderNo*!*OrderLine*!*LoadNo","*!*",V.Local.sName)
		F.Intrinsic.String.Build("{0}*!*{1}*!*{2}",V.Args.OrderNo,V.Args.OrderLine,V.Args.LoadNo,V.Local.sValue)
		F.Intrinsic.String.Split(V.Local.sValue,"*!*",V.Local.sValue)
		gui.frmShip.tabShip.Enabled(False)
		F.Global.BI.PrintReport(95,0,V.Local.sName,V.Local.sValue,False)
		gui.frmShip.tabShip.Enabled(True)
	F.Intrinsic.Control.EndIf
    f.Intrinsic.Variable.AddRV("bPrinted",True)

	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.PrintPickList.End

Program.Sub.UpdatePrintFlag.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sSQL.Declare
	V.Local.sFilter.Declare
	
	'Update Lines
	F.Intrinsic.String.Build("Select * from ORDER_LINES where ORDER_NO ='{0}'",v.Args.OrderNo,v.Local.sSQL)
	F.ODBC.Connection!con.OpenLocalRecordsetRW("rstFlag",v.Local.sSQL)
	F.Intrinsic.Control.DoUntil(v.ODBC.con!rstFlag.EOF)

		F.Intrinsic.Control.If(v.ODBC.con!rstFlag.FieldVal!RECORD_TYPE,=,"L")
			F.ODBC.con!rstFlag.Set!Pick_List_Printed("Y")
			F.ODBC.con!rstFlag.Update
		F.Intrinsic.Control.EndIf
		F.ODBC.con!rstFlag.MoveNext
	F.Intrinsic.Control.Loop
	F.ODBC.con!rstFlag.Close

	'Update Header
	F.Intrinsic.String.Build("Select * from ORDER_HEADER where ORDER_NO ='{0}'",v.Args.OrderNo,v.Local.sSQL)
	F.ODBC.Connection!con.OpenLocalRecordsetRW("rstFlag",v.Local.sSQL)
	F.Intrinsic.Control.If(v.ODBC.con!rstFlag.FieldVal!RECORD_NO,=,"A")
		F.ODBC.con!rstFlag.Set!FLAG_PICKLIST("Y")
		F.ODBC.con!rstFlag.Update
	F.Intrinsic.Control.EndIf
	F.ODBC.con!rstFlag.Close
	
	'dtAllShip
	F.Intrinsic.String.Build("ORDER_NO = '{0}'",V.Args.OrderNo,V.Local.sFilter)
	F.Data.DataView.Create("dtAllShip","dvPickList",22,V.Local.sFilter,"")
	F.Data.DataView.SetValue("dtAllShip","dvPickList",-1,"PICKLIST","RePrint")
	F.Data.DataView.Close("dtAllShip","dvPickList")
	
	'dtDueShip
	F.Intrinsic.String.Build("ORDER_NO = '{0}'",V.Args.OrderNo,V.Local.sFilter)
	F.Data.DataView.Create("dtDueShip","dvPickList",22,V.Local.sFilter,"")
	F.Data.DataView.SetValue("dtDueShip","dvPickList",-1,"PICKLIST","RePrint")
	F.Data.DataView.Close("dtDueShip","dvPickList")
	
	'TODO
	'dtLoad
	F.Intrinsic.String.Build("[LOAD NUMBER] = '{0}'",V.Args.LoadNo,V.Local.sFilter)
	F.Data.DataView.Create("dtLoad","dvPickList",22,V.Local.sFilter,"")
	F.Data.DataView.SetValue("dtLoad","dvPickList",-1,"PICKLIST","RePrint")
	F.Data.DataView.Close("dtLoad","dvPickList")
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.UpdatePrintFlag.End

Program.Sub.GsGCAllShip_CellValueChanged.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sSQL.Declare
	V.Local.sOrder.Declare
	V.Local.sSOLine.Declare
	V.Local.sLine.Declare
	V.Local.sText.Declare
	V.Local.sTextTbl.Declare
	V.Local.sGV.Declare
	
	F.Intrinsic.Control.SelectCase(V.Args.ControlName)
		F.Intrinsic.Control.Case("GSGCALLSHIP")
			V.Local.sGV.Set("gvAllShip")
			
		F.Intrinsic.Control.Case("GSGCDUE")
			V.Local.sGV.Set("gvDue")
	F.Intrinsic.Control.EndSelect
	
	F.Intrinsic.Control.SelectCase(V.Args.Column)
		F.Intrinsic.Control.Case("NOTES")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrder)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"RECORD_NO",V.Args.RowIndex,V.Local.sLine)
			F.Intrinsic.String.Replace(V.Args.Value,"'","''",V.Local.sTextTbl)
			F.Intrinsic.String.Build("SELECT * FROM GAB_4167_SO_NOTES WHERE SO = '{0}' AND SOLINE = '{1}';",V.Local.sOrder,V.Local.sLine,V.Local.sSQL)
			F.ODBC.Connection!con.OpenRecordsetRW("rstNotes",V.Local.sSQL)
			F.Intrinsic.Control.If(V.ODBC.con!rstNotes.EOF,=,True)
				F.Intrinsic.String.Build("INSERT INTO GAB_4167_SO_NOTES(SO,SOLINE,NOTES) VALUES('{0}','{1}','{2}');",V.Local.sOrder,V.Local.sLine,V.Local.sTextTbl,V.Local.sSQL)
				F.ODBC.Connection!con.Execute(V.Local.sSQL)
			F.Intrinsic.Control.Else
				F.Intrinsic.String.Build("UPDATE GAB_4167_SO_NOTES SET NOTES = '{0}' WHERE SO = '{1}' AND SOLINE = '{2}';",V.Local.sTextTbl,V.Local.sOrder,V.Local.sLine,V.Local.sSQL)
				F.ODBC.Connection!con.Execute(V.Local.sSQL)
			F.Intrinsic.Control.EndIf
			F.ODBC.con!rstNotes.Close
			F.Intrinsic.Control.CallSub(CheckNote,"OrderNo",V.Local.sOrder,"OrderLine",V.Local.sLine,"FieldName","NOTES","Text",V.Local.sTextTbl)
	
		F.Intrinsic.Control.CaseAny("USER_1","USER_2","USER_3","USER_4","USER_5")
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"ORDER_NO",V.Args.RowIndex,V.Local.sOrder)
			Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"RECORD_NO",V.Args.RowIndex,V.Local.sLine)
			F.Intrinsic.String.RPad(V.Local.sLine,"0",4,V.Local.sSOLine)
			F.Intrinsic.String.Left(V.Args.Value,30,V.Local.sText)
			F.Intrinsic.String.Replace(V.Local.sText,"'","''",V.Local.sTextTbl)
			F.Intrinsic.String.Build("UPDATE ORDER_LINES SET {0} = '{1}' WHERE ORDER_NO = '{2}' AND RECORD_NO = '{3}';",V.Args.Column,V.Local.sTextTbl,V.Local.sOrder,V.Local.sSOLine,V.Local.sSQL)
			F.ODBC.Connection!con.Execute(V.Local.sSQL)
			F.Intrinsic.Control.CallSub(CheckNote,"OrderNo",V.Local.sOrder,"OrderLine",V.Local.sLine,"FieldName",V.Args.Column,"Text",V.Local.sText)
	F.Intrinsic.Control.EndSelect
	
	F.Intrinsic.Control.Catch
		F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
		F.Intrinsic.UI.Msgbox(V.Local.sError)
		F.Intrinsic.Control.End 
	F.Intrinsic.Control.EndTry
Program.Sub.GsGCAllShip_CellValueChanged.End

Program.Sub.GsGCLoad_CellValueChanged.Start
	F.Intrinsic.Control.Try
	V.Local.sError.Declare
	
	V.Local.sSQL.Declare
	V.Local.sOrder.Declare
	V.Local.sSOLine.Declare
	v.Local.sOrderSuffix.Declare
	V.Local.sLine.Declare
	V.Local.sText.Declare
	V.Local.sTextTbl.Declare
	V.Local.sGV.Declare
	v.Local.sLoadNo.Declare
