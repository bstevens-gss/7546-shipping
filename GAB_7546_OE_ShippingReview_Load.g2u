	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	gui.frmShip.tabShip.Enabled(True)
	F.Intrinsic.Control.End
F.Intrinsic.Control.EndTry
Program.Sub.SplitSOLine_Click.End

Program.Sub.SplitSOLine_Save.Start
'7546 Hultec 03/23/2026: Save handler for Split SO Line. Validates qty/date, checks order lock,
'      ship schedule (V_OE_SHIP_SCHED), and staged shipment (STAGING_QUANTITY) before processing.
'      Creates new SO lines via ORDADCMD, sets user field (dynamic from OE_USER_FLDS_LN "SPLIT FROM LINE" label)/dates on new lines,
'      and updates original line qty/weight via Sales.UpdateOrderLinesByFile CallWrapper.
F.Intrinsic.Control.Try
V.Local.sError.Declare
V.Local.i.Declare(Long)
V.Local.iRow.Declare(Long)
V.Local.fQtySplit.Declare(Float)
V.Local.fQtyBo.Declare(Float)
V.Local.sOrderNo.Declare(String)
V.Local.sOrderLine.Declare(String)
V.Local.sRecNo.Declare(String)
V.Local.sNewLine.Declare(String)
V.Local.sNewRecNo.Declare(String)
V.Local.sSQL.Declare(String)
V.Local.sReturn.Declare(String)
V.Local.sCust.Declare(String)
V.Local.sPart.Declare(String)
V.Local.sLoc.Declare(String)
V.Local.sProdLine.Declare(String)
V.Local.sDesc.Declare(String)
V.Local.fWeight.Declare(Float)
V.Local.fPrice.Declare(Float)
V.Local.fCost.Declare(Float)
V.Local.sUOM.Declare(String)
V.Local.sText.Declare(String)
V.Local.sTemp.Declare(String)
V.Local.sTemp1.Declare(String)
V.Local.sFilePath.Declare(String)
V.Local.sParam.Declare(String)
V.Local.sUser.Declare(String)
V.Local.fLineQty.Declare(Float)
V.Local.fExtPrice.Declare(Float)
V.Local.bExists.Declare(Boolean)
V.Local.iRet.Declare(Long)
V.Local.sMsg.Declare(String)
V.Local.dNewDue.Declare(Date)
V.Local.sDateOrder.Declare(String)
V.Local.bSkip.Declare(Boolean)
V.Local.fOrigWeight.Declare(Float)
V.Local.fUnitWeight.Declare(Float)
V.Local.fNewWeight.Declare(Float)
V.Local.sSer.Declare(String)
'7546 UDF 03/25/2026: Variables for dynamic user field lookup from OE_USER_FLDS_LN
V.Local.sUFColumn.Declare(String)
V.Local.iUFKeyID.Declare(Long)
V.Local.sUFReturn.Declare(String)

F.Data.DataTable.AcceptChanges("dtSplitLines")

'7546 UDF 03/25/2026: Dynamic user field lookup — query V_OE_USER_FLDS_LN for label "SPLIT FROM LINE"
'      to determine which ORDER_LINES column to write the original line number to. If not configured, skip.
V.Local.sUFColumn.Set("")
F.ODBC.Connection!con.ExecuteAndReturn("SELECT RTRIM(KEY_ID) FROM V_OE_USER_FLDS_LN WHERE RTRIM(LABEL) = 'SPLIT FROM LINE'",V.Local.sUFReturn)
F.Intrinsic.Control.If(V.Local.sUFReturn,>,"")
	F.Intrinsic.Math.Add(V.Local.sUFReturn,0,V.Local.iUFKeyID)
	F.Intrinsic.String.Build("USER_{0}",V.Local.iUFKeyID,V.Local.sUFColumn)
F.Intrinsic.Control.EndIf

F.Intrinsic.Control.For(V.Local.i,0,V.DataTable.dtSplitLines.RowCount--)
	V.Local.fQtySplit.Set(V.DataTable.dtSplitLines(V.Local.i).QTY_SPLIT!FieldValFloat)
	V.Local.fQtyBo.Set(V.DataTable.dtSplitLines(V.Local.i).QTY_BO!FieldValFloat)
	F.Intrinsic.Control.If(V.Local.fQtySplit,<=,0)
		F.Intrinsic.Math.Add(V.Local.i,1,V.Local.iRow)
		F.Intrinsic.String.Build("Row {0}: Qty to Split must be greater than 0.",V.Local.iRow,V.Local.sMsg)
		F.Intrinsic.UI.Msgbox(V.Local.sMsg)
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.If(V.Local.fQtySplit,>=,V.Local.fQtyBo)
		F.Intrinsic.Math.Add(V.Local.i,1,V.Local.iRow)
		F.Intrinsic.String.Build("Row {0}: Qty to Split ({1}) must be less than Open Qty ({2}).",V.Local.iRow,V.Local.fQtySplit,V.Local.fQtyBo,V.Local.sMsg)
		F.Intrinsic.UI.Msgbox(V.Local.sMsg)
		F.Intrinsic.Control.ExitSub
	F.Intrinsic.Control.EndIf
F.Intrinsic.Control.Next(V.Local.i)

F.Intrinsic.String.Build("You are about to split {0} line(s). Continue?",V.DataTable.dtSplitLines.RowCount,V.Local.sMsg)
F.Intrinsic.UI.Msgbox(V.Local.sMsg,"Confirm Split",4,V.Local.iRet)
F.Intrinsic.Control.If(V.Local.iRet,<>,6)
	F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.EndIf

Gui.frmSplitLine.cmdSplitSave.Enabled(False)
Gui.frmSplitLine.cmdSplitCancel.Enabled(False)

F.Intrinsic.Control.For(V.Local.i,0,V.DataTable.dtSplitLines.RowCount--)
	V.Local.bSkip.Set(False)
	V.Local.sOrderNo.Set(V.DataTable.dtSplitLines(V.Local.i).ORDER_NO!FieldVal)
	V.Local.sOrderLine.Set(V.DataTable.dtSplitLines(V.Local.i).ORDER_LINE!FieldVal)
	V.Local.sRecNo.Set(V.DataTable.dtSplitLines(V.Local.i).RECORD_NO!FieldVal)
	V.Local.fQtySplit.Set(V.DataTable.dtSplitLines(V.Local.i).QTY_SPLIT!FieldValFloat)
	V.Local.dNewDue.Set(V.DataTable.dtSplitLines(V.Local.i).NEW_DUE_DATE!FieldVal)
	V.Local.sCust.Set(V.DataTable.dtSplitLines(V.Local.i).CUSTOMER!FieldVal)
	V.Local.sPart.Set(V.DataTable.dtSplitLines(V.Local.i).PART!FieldVal)
	V.Local.sLoc.Set(V.DataTable.dtSplitLines(V.Local.i).LOCATION!FieldVal)
	V.Local.sProdLine.Set(V.DataTable.dtSplitLines(V.Local.i).PRODUCT_LINE!FieldVal)
	V.Local.sDesc.Set(V.DataTable.dtSplitLines(V.Local.i).DESCRIPTION!FieldVal)
	V.Local.fWeight.Set(V.DataTable.dtSplitLines(V.Local.i).WEIGHT!FieldValFloat)

	F.Intrinsic.Math.Add(V.Local.i,1,V.Local.iRow)
	F.Intrinsic.String.Build("Processing line {0} of {1}...",V.Local.iRow,V.DataTable.dtSplitLines.RowCount,V.Local.sMsg)
	Gui.frmSplitLine.lblSplitStatus.Caption(V.Local.sMsg)

	Function.Intrinsic.Control.CallSub(OrderLocked,"sOrderNo",V.Local.sOrderNo)
	F.Intrinsic.Control.If(v.Args.bIsLocked)
		F.Intrinsic.String.Build("Order {0} is locked by User: {1}. Skipping this line.",V.Local.sOrderNo,v.Args.sLockingUser,V.Local.sMsg)
		F.Intrinsic.UI.Msgbox(V.Local.sMsg)
		V.Local.bSkip.Set(True)
	F.Intrinsic.Control.EndIf

	'7546 Hultec 03/23/2026: Do not allow splitting when a ship schedule exists for this order line.
	'      Any record in V_OE_SHIP_SCHED (open or closed) blocks the split.
	F.Intrinsic.Control.If(V.Local.bSkip.Not)
		F.Intrinsic.String.Build("SELECT COUNT(*) FROM V_OE_SHIP_SCHED WHERE ORDER_NO = '{0}' AND ORDER_LINE = '{1}'",V.Local.sOrderNo,V.Local.sOrderLine,V.Local.sSQL)
		F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.sReturn)
		F.Intrinsic.Control.If(V.Local.sReturn,<>,"0")
			F.Intrinsic.String.Build("Order {0} Line {1} has an active ship schedule. Cannot split this line.",V.Local.sOrderNo,V.Local.sRecNo,V.Local.sMsg)
			F.Intrinsic.UI.Msgbox(V.Local.sMsg)
			V.Local.bSkip.Set(True)
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf

	'7546 Hultec 03/23/2026: Do not allow splitting when the order line is part of a staged shipment.
	'      Any record in STAGING_QUANTITY for this order/line blocks the split.
	F.Intrinsic.Control.If(V.Local.bSkip.Not)
		F.Intrinsic.String.Build("SELECT COUNT(*) FROM STAGING_QUANTITY WHERE ORDER_NO = '{0}' AND LINE = '{1}'",V.Local.sOrderNo,V.Local.sOrderLine,V.Local.sSQL)
		F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.sReturn)
		F.Intrinsic.Control.If(V.Local.sReturn,<>,"0")
			F.Intrinsic.String.Build("Order {0} Line {1} has an active staged shipment. Cannot split this line.",V.Local.sOrderNo,V.Local.sRecNo,V.Local.sMsg)
			F.Intrinsic.UI.Msgbox(V.Local.sMsg)
			V.Local.bSkip.Set(True)
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf

	F.Intrinsic.Control.If(V.Local.bSkip.Not)
		F.Intrinsic.String.Build("SELECT TOP 1 record_no FROM v_order_lines WHERE order_no = '{0}' AND record_no < '700' ORDER BY record_no DESC",V.Local.sOrderNo,V.Local.sSQL)
		F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.sReturn)
		F.Intrinsic.Control.If(V.Local.sReturn,>,"")
			F.Intrinsic.Math.Add(V.Local.sReturn.Left3,1,V.Local.sNewLine)
			F.Intrinsic.String.LPad(V.Local.sNewLine,"0",3,V.Local.sNewLine)
		F.Intrinsic.Control.Else
			V.Local.sNewLine.Set("010")
		F.Intrinsic.Control.EndIf
		F.Intrinsic.String.Build("{0}0",V.Local.sNewLine,V.Local.sNewRecNo)

		F.Intrinsic.String.Build("SELECT PRICE, COST, DATE_ORDER, QTY_ORDERED, WEIGHT FROM ORDER_LINES WHERE ORDER_NO = '{0}' AND RECORD_NO = '{1}'",V.Local.sOrderNo,V.Local.sOrderLine,V.Local.sSQL)
		F.ODBC.Connection!con.OpenRecordsetRO("rstSplitOL",V.Local.sSQL)
		F.Intrinsic.Control.If(V.ODBC.con!rstSplitOL.EOF,=,False)
			V.Local.fPrice.Set(V.ODBC.con!rstSplitOL.FieldValFloat!PRICE)
			V.Local.fCost.Set(V.ODBC.con!rstSplitOL.FieldValFloat!COST)
			V.Local.sDateOrder.Set(V.ODBC.con!rstSplitOL.FieldVal!DATE_ORDER)
			V.Local.fLineQty.Set(V.ODBC.con!rstSplitOL.FieldValFloat!QTY_ORDERED)
			V.Local.fOrigWeight.Set(V.ODBC.con!rstSplitOL.FieldValFloat!WEIGHT)
		F.Intrinsic.Control.Else
			V.Local.fPrice.Set(0)
			V.Local.fCost.Set(0)
			V.Local.sDateOrder.Set("")
			V.Local.fLineQty.Set(0)
			V.Local.fOrigWeight.Set(0)
		F.Intrinsic.Control.EndIf
		F.ODBC.con!rstSplitOL.Close
		F.Intrinsic.Control.If(V.Local.fLineQty,>,0)
			F.Intrinsic.Math.Div(V.Local.fOrigWeight,V.Local.fLineQty,V.Local.fUnitWeight)
		F.Intrinsic.Control.Else
			V.Local.fUnitWeight.Set(0)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.Math.Sub(V.Local.fLineQty,V.Local.fQtySplit,V.Local.fLineQty)
		F.Intrinsic.Math.Mult(V.Local.fUnitWeight,V.Local.fLineQty,V.Local.fNewWeight)

		F.Intrinsic.String.Build("SELECT UM_INVENTORY FROM V_INVENTORY_MSTR WHERE PART = '{0}' AND LOCATION = '{1}'",V.Local.sPart,V.Local.sLoc,V.Local.sSQL)
		F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.sUOM)
		F.Intrinsic.Control.If(V.Local.sUOM,=,"")
			V.Local.sUOM.Set("EA")
		F.Intrinsic.Control.EndIf

		V.Local.sText.Set("")
		F.Intrinsic.String.Concat(V.Local.sText,"O",V.Local.sText)
		F.Intrinsic.String.RPad(V.Local.sCust.RTrim," ",7,V.Local.sTemp)
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sTemp,V.Local.sText)
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sOrderNo,V.Local.sText)
		F.Intrinsic.String.RPad(V.Local.sPart," ",20,V.Local.sTemp)
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sTemp,V.Local.sText)
		V.Local.sTemp.Set("")
		F.Intrinsic.String.RPad(V.Local.sTemp," ",18,V.Local.sTemp)
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sTemp,V.Local.sText)
		F.Intrinsic.String.RPad(V.Local.sLoc," ",2,V.Local.sTemp)
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sTemp,V.Local.sText)
		F.Intrinsic.String.RPad(V.Local.sProdLine," ",5,V.Local.sTemp)
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sTemp,V.Local.sText)
		F.Intrinsic.String.RPad(V.Local.sDesc," ",30,V.Local.sTemp)
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sTemp,V.Local.sText)
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sNewLine,V.Local.sText)
		F.Intrinsic.String.Concat(V.Local.sText,"S",V.Local.sText)

		F.Intrinsic.String.IsInString(V.Local.fQtySplit.String,".",False,V.Local.bExists)
		F.Intrinsic.Control.If(V.Local.bExists)
			F.Intrinsic.String.Split(V.Local.fQtySplit.String,".",V.Local.sTemp)
			F.Intrinsic.String.LPad(V.Local.sTemp(0),"0",9,V.Local.sTemp1)
			F.Intrinsic.String.RPad(V.Local.sTemp(1),"0",4,V.Local.sTemp)
			F.Intrinsic.String.Left(V.Local.sTemp,4,V.Local.sTemp)
			F.Intrinsic.String.Concat(V.Local.sTemp1,V.Local.sTemp,V.Local.sTemp)
		F.Intrinsic.Control.Else
			F.Intrinsic.String.LPad(V.Local.fQtySplit.String,"0",9,V.Local.sTemp)
			F.Intrinsic.String.Concat(V.Local.sTemp,"0000",V.Local.sTemp)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sTemp,V.Local.sText)

		F.Intrinsic.String.IsInString(V.Local.fWeight.String,".",False,V.Local.bExists)
		F.Intrinsic.Control.If(V.Local.bExists)
			F.Intrinsic.String.Split(V.Local.fWeight.String,".",V.Local.sTemp)
			F.Intrinsic.String.LPad(V.Local.sTemp(0),"0",7,V.Local.sTemp1)
			F.Intrinsic.String.Left(V.Local.sTemp(1),3,V.Local.sTemp)
			F.Intrinsic.String.RPad(V.Local.sTemp,"0",3,V.Local.sTemp)
			F.Intrinsic.String.Concat(V.Local.sTemp1,V.Local.sTemp,V.Local.sTemp)
		F.Intrinsic.Control.Else
			F.Intrinsic.String.LPad(V.Local.fWeight.String,"0",7,V.Local.sTemp)
			F.Intrinsic.String.Concat(V.Local.sTemp,"000",V.Local.sTemp)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.String.RPad(V.Local.sTemp,"0",10,V.Local.sTemp)
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sTemp,V.Local.sText)

		F.Intrinsic.String.IsInString(V.Local.fPrice.String,".",False,V.Local.bExists)
		F.Intrinsic.Control.If(V.Local.bExists)
			F.Intrinsic.String.Split(V.Local.fPrice.String,".",V.Local.sTemp)
			F.Intrinsic.String.LPad(V.Local.sTemp(0),"0",10,V.Local.sTemp1)
			F.Intrinsic.String.RPad(V.Local.sTemp(1),"0",6,V.Local.sTemp)
			F.Intrinsic.String.Left(V.Local.sTemp,6,V.Local.sTemp)
			F.Intrinsic.String.Concat(V.Local.sTemp1,V.Local.sTemp,V.Local.sTemp)
		F.Intrinsic.Control.Else
			F.Intrinsic.String.LPad(V.Local.fPrice.String,"0",10,V.Local.sTemp)
			F.Intrinsic.String.Concat(V.Local.sTemp,"000000",V.Local.sTemp)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sTemp,V.Local.sText)

		V.Local.sTemp.Set("")
		F.Intrinsic.String.RPad(V.Local.sTemp," ",150,V.Local.sTemp)
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sTemp,V.Local.sText)
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sUOM.RTrim,V.Local.sText)
		V.Local.sTemp.Set("")
		F.Intrinsic.String.RPad(V.Local.sTemp," ",98,V.Local.sTemp)
		F.Intrinsic.String.Concat(V.Local.sText,V.Local.sTemp,V.Local.sText)

		F.Intrinsic.String.Build("{0}\SPLIT_{1}_{2}",V.Caller.FilesDir,V.Local.sOrderNo,V.Local.i,V.Local.sFilePath)
		F.Intrinsic.File.Exists(V.Local.sFilePath,V.Local.bExists)
		F.Intrinsic.Control.If(V.Local.bExists)
			F.Intrinsic.File.DeleteFile(V.Local.sFilePath)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.File.String2File(V.Local.sFilePath,V.Local.sText)

		F.Intrinsic.String.RPad(V.Caller.User," ",8,V.Local.sUser)
		F.Intrinsic.String.Concat(V.Caller.CompanyCode,V.Local.sUser,V.Local.sFilePath,V.Local.sParam)
		F.Intrinsic.Task.Launchgsssync("ORDADCMD","-c",V.Local.sParam)
		F.Intrinsic.File.Exists(V.Local.sFilePath,V.Local.bExists)
		F.Intrinsic.Control.If(V.Local.bExists)
			F.Intrinsic.File.DeleteFile(V.Local.sFilePath)
		F.Intrinsic.Control.EndIf

		'7546 UDF 03/25/2026: Write original line RECORD_NO to the dynamically-resolved user field on the new split line (skip if no "SPLIT FROM LINE" label configured)
		F.Intrinsic.Control.If(V.Local.sUFColumn,<>,"")
			F.Intrinsic.String.Build("UPDATE ORDER_LINES SET {0} = '{1}' WHERE ORDER_NO = '{2}' AND RECORD_NO = '{3}'",V.Local.sUFColumn,V.Local.sRecNo,V.Local.sOrderNo,V.Local.sNewRecNo,V.Local.sSQL)
			F.ODBC.Connection!con.Execute(V.Local.sSQL)
		F.Intrinsic.Control.EndIf

		'7546 Hultec 03/23/2026: Commented out direct SQL for DATE_ITEM_PROM; now sent via Sales.UpdateOrderLinesByFile at CSV position 16.
		'F.Intrinsic.String.Build("UPDATE ORDER_LINES SET DATE_ITEM_PROM = '{0}', MUST_DLVR_BY_DATE = '{0}' WHERE ORDER_NO = '{1}' AND RECORD_NO = '{2}'",V.Local.dNewDue.FormatYYYYMMDD,V.Local.sOrderNo,V.Local.sNewRecNo,V.Local.sSQL)
		'F.ODBC.Connection!con.Execute(V.Local.sSQL)
		F.Intrinsic.Control.If(V.Local.sDateOrder,<>,"")
			F.Intrinsic.String.Build("UPDATE ORDER_LINES SET DATE_ORDER = '{0}' WHERE ORDER_NO = '{1}' AND RECORD_NO = '{2}'",V.Local.sDateOrder,V.Local.sOrderNo,V.Local.sNewRecNo,V.Local.sSQL)
			F.ODBC.Connection!con.Execute(V.Local.sSQL)
		F.Intrinsic.Control.EndIf

		F.Intrinsic.String.Left(V.Local.sOrderLine,3,V.Local.sTemp)
		'7546 Hultec 03/23/2026: Format price as 16-char with 6 decimal precision per CallWrapper spec.
		F.Intrinsic.String.Format(V.Local.fPrice,"0.000000",V.Local.sMsg)
		F.Intrinsic.String.Build("L,{0},{1},,,{2},{3},,,,,,,,,,,,,,,,,{4},,,",V.Local.sOrderNo,V.Local.sTemp,V.Local.fLineQty,V.Local.sMsg,V.Local.fNewWeight,V.Local.sTemp1)
		'7546 Hultec 03/23/2026: Append second CSV line for new split line - set DATE_ITEM_PROM at position 16.
		F.Intrinsic.String.Build("L,{0},{1},,,,,,,,,,,,,{2},,,,,,,,,,,",V.Local.sOrderNo,V.Local.sNewLine,V.Local.dNewDue.FormatYYYYMMDD,V.Local.sTemp)
		F.Intrinsic.String.Concat(V.Local.sTemp1,V.Ambient.Newline,V.Local.sTemp,V.Local.sTemp1)
		F.Intrinsic.String.Build("SPLIT_UPD_{0}_{1}.txt",V.Local.sOrderNo,V.Local.i,V.Local.sTemp)
		F.Intrinsic.String.Build("{0}\{1}",V.Caller.FilesDir,V.Local.sTemp,V.Local.sFilePath)
		F.Intrinsic.File.Exists(V.Local.sFilePath,V.Local.bExists)
		F.Intrinsic.Control.If(V.Local.bExists)
			F.Intrinsic.File.DeleteFile(V.Local.sFilePath)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.File.String2File(V.Local.sFilePath,V.Local.sTemp1)
		F.Global.Callwrapper.New("SplitUpd","Sales.UpdateOrderLinesByFile")
		F.Global.Callwrapper.SetProperty("SplitUpd","Company",V.Caller.CompanyCode)
		F.Global.Callwrapper.SetProperty("SplitUpd","CallingProgram","GAB_7546_OE_ShippingReview_Load")
		F.Global.Callwrapper.SetProperty("SplitUpd","Screenless",1)
		F.Global.Callwrapper.SetProperty("SplitUpd","InputFileName",V.Local.sTemp)
		F.Global.CallWrapper.Run("SplitUpd")
		F.Global.CallWrapper.GetProperty("SplitUpd","Status",V.Local.sReturn)
		F.Intrinsic.Control.If(V.Local.sReturn,<>,"Success")
			F.Intrinsic.String.Build("Warning: Line update returned status '{0}' for Order {1} Line {2}.",V.Local.sReturn,V.Local.sOrderNo,V.Local.sOrderLine,V.Local.sMsg)
			F.Intrinsic.UI.Msgbox(V.Local.sMsg)
		F.Intrinsic.Control.EndIf
		F.Intrinsic.File.Exists(V.Local.sFilePath,V.Local.bExists)
		F.Intrinsic.Control.If(V.Local.bExists)
			F.Intrinsic.File.DeleteFile(V.Local.sFilePath)
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.EndIf
F.Intrinsic.Control.Next(V.Local.i)

V.Global.bSplitSaved.Set(True)
Gui.frmSplitLine.lblSplitStatus.Caption("Split complete.")
'7546 Hultec 03/23/2026: Save grid layout before closing
Gui.frmSplitLine.GsGCSplit.Serialize("gvSplit",V.Local.sSer)
F.Global.Registry.AddValue(V.Caller.User,V.Caller.CompanyCode,"GVSPLIT",7546,1000,False,"Serialize",False,0,-999.0,1/1/1980,12:00:00 AM,V.Local.sSer)
Gui.frmSplitLine..Visible(False)

F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	Gui.frmSplitLine.cmdSplitSave.Enabled(True)
	Gui.frmSplitLine.cmdSplitCancel.Enabled(True)
	Gui.frmSplitLine.lblSplitStatus.Caption("An error occurred. Review and try again or Cancel.")
F.Intrinsic.Control.EndTry
Program.Sub.SplitSOLine_Save.End

'7546 Hultec 03/23/2026: Cancel handler for Split SO Line. Saves grid layout and form size, cleans up dtSplitLines, and hides the form.
Program.Sub.SplitSOLine_Cancel.Start
F.Intrinsic.Control.Try
V.Local.sError.Declare
V.Local.sSer.Declare(String)
V.Global.bSplitSaved.Set(False)
'7546 Hultec 03/23/2026: Save grid layout before closing - must happen before DataTable is closed
Gui.frmSplitLine.GsGCSplit.Serialize("gvSplit",V.Local.sSer)
F.Global.Registry.AddValue(V.Caller.User,V.Caller.CompanyCode,"GVSPLIT",7546,1000,False,"Serialize",False,0,-999.0,1/1/1980,12:00:00 AM,V.Local.sSer)
F.Intrinsic.Control.If(V.DataTable.dtSplitLines.Exists)
	F.Data.DataTable.Close("dtSplitLines")
F.Intrinsic.Control.EndIf
Gui.frmSplitLine..Visible(False)
F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.End
F.Intrinsic.Control.EndTry
Program.Sub.SplitSOLine_Cancel.End

'7546 UDF 03/25/2026: Reset grid serialization for Split SO Line grid. Clears saved layout and rebuilds the grid view from scratch (same pattern as main grid ResetGridColumns + cmdRefresh_Click).
Program.Sub.ResetSplitGridColumns.Start
F.Intrinsic.Control.Try
V.Local.sError.Declare

'7546 UDF 03/25/2026: Clear saved layout from registry
F.Global.Registry.AddValue(V.Caller.User,V.Caller.CompanyCode,"GVSPLIT",7546,1000,False,"Serialize",False,0,-999.0,1/1/1980,12:00:00 AM,"")

'7546 UDF 03/25/2026: Rebuild grid view from DataTable to get a clean default layout (individual SetColumnProperty calls cannot override a deserialized layout)
Gui.frmSplitLine.GsGCSplit.AddGridViewFromDataTable("gvSplit","dtSplitLines")
Gui.frmSplitLine.GsGCSplit.SuspendLayout()
Gui.frmSplitLine.GsGCSplit.SetGridViewProperty("gvSplit","OptionBehaviorEditable",True)
