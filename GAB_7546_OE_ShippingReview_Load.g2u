Program.Sub.PrintPOPackForLoad.Start
'5/20/26 BS - PO Pack List direct print to selected printer without preview
'Prints GCG_7551_PO_PACK.rpt for PO lines on the selected load.
'Reads V.Global.bSuppressPOPackLotBin to pass SUPPRESS_LOTBIN param to Crystal.
F.Intrinsic.Control.Try
V.Local.sError.Declare
V.Local.iRptID.Declare(Long,0)
V.Local.sRptLoc.Declare(String,"")
V.Local.iBiRunID.Declare(Long,0)
V.Local.iLogID.Declare(Long,0)
V.Local.sParam.Declare(String,"")
V.Local.sValue.Declare(String,"")
V.Local.sSuppressFlag.Declare(String,"N")
v.Local.sFilterString.Declare
v.Local.sSel.Declare(String)
v.Local.i.Declare(Long)

F.Intrinsic.Control.If(V.Global.bSuppressPOPackLotBin)
	V.Local.sSuppressFlag.Set("Y")
F.Intrinsic.Control.EndIf

Function.Intrinsic.Control.BlockEvents
Function.Data.DataTable.AcceptChanges("dtLoad")
v.Local.sFilterString.Set("[SELECT] = 1 and [Carrier Load Number] <> '' and [ORDER_SUFFIX] = 'P'")
f.Data.DataView.Create("dtLoad","dvloadPOPL",22,v.Local.sFilterString,"")
f.Data.DataView.ToDataTableDistinct("dtload","dvloadPOPL","dtloadPOPL","Carrier Load Number",)
F.Data.Datatable.Select("dtLoadPOPL","[Carrier Load Number] <> ''",v.Local.sSel)
Function.Intrinsic.Control.If(v.Local.sSel,<>,"***NORETURN***")
	F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
	F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
		F.Intrinsic.Control.If(v.DataTable.dtLoadPOPL(v.Local.sSel(v.Local.i)).Carrier Load Number!FieldValtrim,<>,"")
			F.Global.BI.GetRunID(V.Local.iBiRunID)
			F.Global.BI.GetIDFromName("GCG_7551_PO_PACK.rpt",V.Local.iRptID)
			F.Intrinsic.Control.If(V.Local.iRptID,=,-1)
				F.Intrinsic.String.Build("{0}\Custom\GCG_7551_PO_PACK.rpt",V.Caller.BusintDir,V.Local.sRptLoc)
				F.Global.BI.InitializeReport("PO Pack List Report",V.Local.sRptLoc,V.Local.iRptId)
			F.Intrinsic.Control.EndIf
			
			F.Global.BI.StartLogging(V.Local.iBiRunID,V.Local.iRptID,-1,"GCG_7551_PO_PACK",V.Local.iLogID)
			F.Global.BI.StopLogging(V.Local.iLogID)
			
			V.Local.sParam.Set("PO_PACK_NUM*!*SUPPRESS_LOTBIN")
			F.Intrinsic.String.Build("{0}*!*{1}",v.DataTable.dtLoadPOPL(v.Local.sSel(v.Local.i)).Carrier Load Number!FieldValtrim,V.Local.sSuppressFlag,V.Local.sValue)
			
			F.Intrinsic.String.Split(V.Local.sParam,"*!*",V.Local.sParam)
			F.Intrinsic.String.Split(V.Local.sValue,"*!*",V.Local.sValue)
			
			F.Global.BI.PrintReport(v.Local.iRptID,3,V.Local.sParam,V.Local.sValue,V.Global.sPOPackPrinter,True)
		F.Intrinsic.Control.EndIf
	F.Intrinsic.Control.Next(v.Local.i)
F.Intrinsic.Control.EndIf

f.Data.Datatable.Close("dtloadPOPL")
f.Data.DataView.Close("dtLoad","dvloadPOPL")
Function.Intrinsic.Control.UnBlockEvents
F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.End
F.Intrinsic.Control.EndTry
Program.Sub.PrintPOPackForLoad.End

Program.Sub.Click_Print_POPackList.Start
'5/20/26 BS - Standalone PO Pack List print with printer dialog and lot/bin suppression
'Context menu handler for standalone "Print PO Pack Report" -- delegates to PrintPOPackForLoad with lot/bin visible.
F.Intrinsic.Control.Try
V.Local.sError.Declare

F.Intrinsic.Control.SelectCase(v.Args.ItemName.UCase)
	F.Intrinsic.Control.Case("PACKREPORT")
		F.Intrinsic.Printer.SelectPrinterDialog
		F.Intrinsic.Control.If(v.Ambient.PRINTERDIALOGSELECTION,<>,"***CANCEL***")
			V.Global.sPOPackPrinter.Set(v.Ambient.PRINTERDIALOGSELECTION)
			V.Global.bSuppressPOPackLotBin.Set(True)
			F.Intrinsic.Control.CallSub(PrintPOPackForLoad)
			V.Global.bSuppressPOPackLotBin.Set(False)
			V.Global.sPOPackPrinter.Set("")
		F.Intrinsic.Control.EndIf
F.Intrinsic.Control.EndSelect

F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.End
F.Intrinsic.Control.EndTry
Program.Sub.Click_Print_POPackList.End

Program.Sub.CheckAllocationType.Start
F.Intrinsic.Control.Try
F.ODBC.Connection!con.ExecuteAndReturn("Select Case F_LONG When 1 Then 'LOT' When 2 Then 'HEAT' When 3 Then 'SERIAL_NUMBER' Else 'NONE' End As ALLOC_TYPE From Op_Header Where ID = 401187 And SEQUENCE = 0000;",V.Global.sAllocType)
F.Intrinsic.Control.Catch
	F.Intrinsic.String.Build("Project: {0}{1}{1}Subroutine: {2}{1}Error Occurred {3} with description {4}{1}{1}GAB Version: {5}",v.Caller.ScriptFile,V.Ambient.Newline,V.Ambient.CurrentSubroutine,V.Ambient.ErrorNumber,V.Ambient.ErrorDescription,V.Ambient.GABVersion,V.Local.sError)
	F.Intrinsic.UI.Msgbox(V.Local.sError)
	F.Intrinsic.Control.End 
F.Intrinsic.Control.EndTry

Program.Sub.CheckAllocationType.End

'7546 Hultec 03/23/2026: Context menu handler for "Split SO Line". Collects checked rows from the
'      active grid (Open Orders or Past Due), builds dtSplitLines DataTable (global scope), configures
'      the split grid with editable QTY_SPLIT and NEW_DUE_DATE columns, and shows the modal form.
Program.Sub.SplitSOLine_Click.Start
F.Intrinsic.Control.Try
V.Local.sError.Declare
V.Local.sSel.Declare(String)
V.Local.i.Declare(Long)
V.Local.iTab.Declare(Long)
V.Local.sCust.Declare(String)
V.Local.sNameCust.Declare(String)
V.Local.sOrdNo.Declare(String)
V.Local.sRecNo.Declare(String)
V.Local.sOrdLn.Declare(String)
V.Local.sDispPart.Declare(String)
V.Local.sDesc.Declare(String)
V.Local.sShipId.Declare(String)
V.Local.sCityShip.Declare(String)
V.Local.sStateShip.Declare(String)
V.Local.sNameShip.Declare(String)
V.Local.fQtyBo.Declare(Float)
V.Local.sPart.Declare(String)
V.Local.sLoc.Declare(String)
V.Local.sProdLine.Declare(String)
V.Local.sOrdSuffix.Declare(String)
V.Local.fWeight.Declare(Float)
V.Local.bHasAccess.Declare(Boolean,False)
V.Local.sSer.Declare(String)

'7546 Hultec 03/23/2026: Permission check - Order Entry > Edit > Sales Orders (IPM 132, level 1)
F.Global.Security.CheckUserAccessIPM(132,1,V.Local.bHasAccess)
F.Intrinsic.Control.If(V.Local.bHasAccess,=,False)
	F.Intrinsic.UI.Msgbox("You do not have permission to access Order Entry.")
	F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.EndIf

V.Local.iTab.Set(v.Screen.frmShip!tabShip.Tab)

F.Intrinsic.Control.If(V.Local.iTab,<>,0,"AND",V.Local.iTab,<>,1)
	F.Intrinsic.UI.Msgbox("Split SO Line is only available from the Open Orders or Due Today tabs.")
	F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.EndIf

F.Intrinsic.Control.If(V.Local.iTab,=,0)
	F.Data.DataTable.AcceptChanges("dtAllShip")
	F.Data.Datatable.Select("dtAllShip","ASSIGNPICKER = 1",V.Local.sSel)
F.Intrinsic.Control.Else
	F.Data.DataTable.AcceptChanges("dtDueShip")
	F.Data.Datatable.Select("dtDueShip","ASSIGNPICKER = 1",V.Local.sSel)
F.Intrinsic.Control.EndIf

F.Intrinsic.Control.If(V.Local.sSel,=,"***NORETURN***")
	F.Intrinsic.UI.Msgbox("No lines selected. Check the lines you want to split first.")
	F.Intrinsic.Control.ExitSub
F.Intrinsic.Control.EndIf

F.Intrinsic.String.Split(V.Local.sSel,"*!*",V.Local.sSel)

F.Intrinsic.Control.If(V.DataTable.dtSplitLines.Exists)
	F.Data.DataTable.Close("dtSplitLines")
F.Intrinsic.Control.EndIf

F.Data.DataTable.Create("dtSplitLines",True)
F.Data.DataTable.AddColumn("dtSplitLines","CUSTOMER","String","")
F.Data.DataTable.AddColumn("dtSplitLines","NAME_CUSTOMER","String","")
F.Data.DataTable.AddColumn("dtSplitLines","ORDER_NO","String","")
F.Data.DataTable.AddColumn("dtSplitLines","RECORD_NO","String","")
F.Data.DataTable.AddColumn("dtSplitLines","ORDER_LINE","String","")
F.Data.DataTable.AddColumn("dtSplitLines","DISPLAY_PART","String","")
F.Data.DataTable.AddColumn("dtSplitLines","DESCRIPTION","String","")
F.Data.DataTable.AddColumn("dtSplitLines","SHIP_ID","String","")
F.Data.DataTable.AddColumn("dtSplitLines","CITY_SHIP","String","")
F.Data.DataTable.AddColumn("dtSplitLines","STATE_SHIP","String","")
F.Data.DataTable.AddColumn("dtSplitLines","NAME_CUSTOMER_SHIP","String","")
F.Data.DataTable.AddColumn("dtSplitLines","QTY_BO","Float",0)
F.Data.DataTable.AddColumn("dtSplitLines","QTY_SPLIT","Float",0)
F.Data.DataTable.AddColumn("dtSplitLines","NEW_DUE_DATE","Date")
F.Data.DataTable.AddColumn("dtSplitLines","PART","String","")
F.Data.DataTable.AddColumn("dtSplitLines","LOCATION","String","")
F.Data.DataTable.AddColumn("dtSplitLines","PRODUCT_LINE","String","")
F.Data.DataTable.AddColumn("dtSplitLines","ORDER_SUFFIX","String","")
F.Data.DataTable.AddColumn("dtSplitLines","WEIGHT","Float",0)
'7546 UDF 04/06/2026: SO Document Control column
F.Data.DataTable.AddColumn("dtSplitLines","SODocCntrl","String","DCS-OFF")

F.Intrinsic.Control.For(V.Local.i,0,V.Local.sSel.UBound)
	F.Intrinsic.Control.If(V.Local.iTab,=,0)
		V.Local.sCust.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).CUSTOMER!FieldVal)
		V.Local.sNameCust.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).NAME_CUSTOMER!FieldVal)
		V.Local.sOrdNo.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).ORDER_NO!FieldVal)
		V.Local.sRecNo.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).RECORD_NO!FieldVal)
		V.Local.sOrdLn.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).ORDER_LINE!FieldVal)
		V.Local.sDispPart.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).DISPLAY_PART!FieldVal)
		V.Local.sDesc.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).DESCRIPTION!FieldVal)
		V.Local.sShipId.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).SHIP_ID!FieldVal)
		V.Local.sCityShip.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).CITY_SHIP!FieldVal)
		V.Local.sStateShip.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).STATE_SHIP!FieldVal)
		V.Local.sNameShip.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).NAME_CUSTOMER_SHIP!FieldVal)
		V.Local.fQtyBo.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).QTY_BO!FieldValFloat)
		V.Local.sPart.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).PART!FieldVal)
		V.Local.sLoc.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).LOCATION!FieldVal)
		V.Local.sProdLine.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).PRODUCT_LINE!FieldVal)
		V.Local.sOrdSuffix.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).ORDER_SUFFIX!FieldVal)
		V.Local.fWeight.Set(V.DataTable.dtAllShip(V.Local.sSel(V.Local.i)).WEIGHT!FieldValFloat)
	F.Intrinsic.Control.Else
		V.Local.sCust.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).CUSTOMER!FieldVal)
		V.Local.sNameCust.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).NAME_CUSTOMER!FieldVal)
		V.Local.sOrdNo.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).ORDER_NO!FieldVal)
		V.Local.sRecNo.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).RECORD_NO!FieldVal)
		V.Local.sOrdLn.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).ORDER_LINE!FieldVal)
		V.Local.sDispPart.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).DISPLAY_PART!FieldVal)
		V.Local.sDesc.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).DESCRIPTION!FieldVal)
		V.Local.sShipId.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).SHIP_ID!FieldVal)
		V.Local.sCityShip.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).CITY_SHIP!FieldVal)
		V.Local.sStateShip.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).STATE_SHIP!FieldVal)
		V.Local.sNameShip.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).NAME_CUSTOMER_SHIP!FieldVal)
		V.Local.fQtyBo.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).QTY_BO!FieldValFloat)
		V.Local.sPart.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).PART!FieldVal)
		V.Local.sLoc.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).LOCATION!FieldVal)
		V.Local.sProdLine.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).PRODUCT_LINE!FieldVal)
		V.Local.sOrdSuffix.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).ORDER_SUFFIX!FieldVal)
		V.Local.fWeight.Set(V.DataTable.dtDueShip(V.Local.sSel(V.Local.i)).WEIGHT!FieldValFloat)
	F.Intrinsic.Control.EndIf
	F.Data.DataTable.AddRow("dtSplitLines","CUSTOMER",V.Local.sCust,"NAME_CUSTOMER",V.Local.sNameCust,"ORDER_NO",V.Local.sOrdNo,"RECORD_NO",V.Local.sRecNo,"ORDER_LINE",V.Local.sOrdLn,"DISPLAY_PART",V.Local.sDispPart,"DESCRIPTION",V.Local.sDesc,"SHIP_ID",V.Local.sShipId,"CITY_SHIP",V.Local.sCityShip,"STATE_SHIP",V.Local.sStateShip,"NAME_CUSTOMER_SHIP",V.Local.sNameShip,"QTY_BO",V.Local.fQtyBo,"QTY_SPLIT",0,"NEW_DUE_DATE",V.Ambient.Date,"PART",V.Local.sPart,"LOCATION",V.Local.sLoc,"PRODUCT_LINE",V.Local.sProdLine,"ORDER_SUFFIX",V.Local.sOrdSuffix,"WEIGHT",V.Local.fWeight)
F.Intrinsic.Control.Next(V.Local.i)

'7546 UDF 04/06/2026: Fill SO Document Control status from shared dDCC dictionary
F.Data.DataTable.FillFromDictionary("dtSplitLines","dDCC","ORDER_NO","SODocCntrl")

