			F.Intrinsic.Control.Else
				'f.Intrinsic.String.Build("[LOAD NUMBER] = {0} AND [LOAD NUMBER] <> 0",V.Local.sLoadNo,v.Local.sfilter)
				'f.Intrinsic.String.Build("[LOAD NUMBER] = {0} AND [LOAD NUMBER] <> 0 and [Packing List]<> ''",V.Local.sLoadNo,v.Local.sfilter)
				f.Intrinsic.String.Build("[LOAD NUMBER] = {0} AND [LOAD NUMBER] <> 0 ",V.Local.sLoadNo,v.Local.sfilter)
				F.Data.Datatable.Select("dtLoad",v.Local.sfilter,v.Local.sSel)	
				Function.Intrinsic.Control.If(v.Local.sSel.Trim,<>,"***NORETURN***")
					F.Intrinsic.String.Split(v.Local.sSel,"*!*",v.Local.sSEL)
					F.Intrinsic.Control.For(v.Local.i,0,v.Local.sSel.UBound)
						Gui.frmShip.[V.Args.ControlName].GetCellValueByColumnName(V.Local.sGV,"PACKING LIST",V.Local.sSel(v.Local.i),v.Local.sPackinglist)
						'update gridview with ship date for load number selected
						F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"SHIP DATE",V.Args.Value)
						'update staged packing list ship date						
						f.Intrinsic.Control.If(v.Local.sPackinglist,<>,"")						
							F.Data.Datatable.SetValue("dtLoad",V.Local.sSel(V.Local.i),"PL SHIP DATE",V.Args.Value)							
							'set dates in staged PL tables		
							F.Intrinsic.String.Build("UPDATE STAGING_HEADER SET SHP_DATE = '{0}' WHERE PCK_NO = '{1}';",V.Args.Value.FormatYYYY-MM-DD,V.Local.sPackinglist,V.Local.sSQL)
							F.ODBC.Connection!con.Execute(V.Local.sSQL)
							F.Intrinsic.String.Build("UPDATE SHIPMENT_HEADER SET DATE_SHIPPED = '{0}',CNV_SHIP_DATE = '{1}' WHERE RECORD_TYPE IN ('A','L') AND PCK_NO = '{2}';",V.Args.Value.FormatMMDDYY,V.Args.Value.FormatYYYYMMDD,V.Local.sPackinglist,V.Local.sSQL)
							F.ODBC.Connection!con.Execute(V.Local.sSQL)							
							f.Intrinsic.String.Build("SELECT DISTINCT WAY_BILL FROM V_SHIPMENT_HEADER WHERE PCK_NO = '{0}';",v.Local.sPackinglist,v.Local.sSQL)
							F.ODBC.Connection!con.ExecuteAndReturn(V.Local.sSQL,V.Local.sWaybill)
							F.Intrinsic.String.Build("UPDATE BOL_HEADER SET DATE1 = '{0}', ETA_DATE = '{0}' WHERE WAYBILL_NO = '{1}';",V.Args.Value.FormatYYYYMMDD,V.Local.sWaybill.RTrim,V.Local.sSQL)
							F.ODBC.Connection!con.Execute(V.Local.sSQL)
						f.Intrinsic.Control.EndIf
					F.Intrinsic.Control.Next(v.Local.i)	
					F.Intrinsic.String.Build("UPDATE LOAD_PLAN SET SHIP_DATE = '{0}' WHERE LOAD_NO = {4};",V.Args.Value.FormatYYYY-MM-DD,V.Local.sOrder,V.Local.sLine,V.Local.sOrderSuffix,v.Local.sLoadNo,V.Local.sSQL)
					F.ODBC.Connection!con.Execute(V.Local.sSQL)
					gui.frmShip.lblRunMRP.Visible(True)
				F.Intrinsic.Control.Else
					Function.Intrinsic.Control.UnBlockEvents
					F.Data.Datatable.SetValue("dtLoad",V.Args.RowIndex,"SHIP DATE","1900-01-01")
					F.Intrinsic.UI.Msgbox("Load does not have any staged packing lists.  Load ship date can be updated once the load is staged.")
					F.ODBC.con!rstshipdate.Close
					f.Intrinsic.Control.ExitSub
				F.Intrinsic.Control.EndIf
			F.ODBC.con!rstshipdate.Close
			F.Intrinsic.Control.EndIf
			
'		F.Intrinsic.Control.CaseAny("Loading_Status","LOADING_STATUS")
'			v.Local.dateyyyymmddnnss.Set(v.Ambient.Time)
'			f.Intrinsic.String.Concat(v.Ambient.Date.PSQLFriendly," ",v.Ambient.Time.PSQLFriendly,v.Local.dateyyyymmddnnss)
