Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","QTY_SPLIT","MinWidth","80")
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","QTY_SPLIT","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","QTY_SPLIT","CellHAlignment","Right")
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","QTY_SPLIT","DisplayCustomNumeric","n4")

Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","NEW_DUE_DATE","Caption","New Due Date")
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","NEW_DUE_DATE","DisplayFormatType","DateTime")
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","NEW_DUE_DATE","DisplayCustomDatetime","d")
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","NEW_DUE_DATE","AllowEdit",True)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","NEW_DUE_DATE","ReadOnly",False)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","NEW_DUE_DATE","VisibleIndex","12")
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","NEW_DUE_DATE","MinWidth","90")
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","NEW_DUE_DATE","CellBackColor",V.Enum.ThemeColors!ColorYellow.Highlight)

Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","ORDER_LINE","Visible",False)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","PART","Visible",False)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","LOCATION","Visible",False)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","PRODUCT_LINE","Visible",False)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","ORDER_SUFFIX","Visible",False)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","WEIGHT","Visible",False)

'7546 UDF 04/06/2026: SO Document Control icon column (mirrors Shipped tab pattern)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","SODocCntrl","CellHAlignment","Center")
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","SODocCntrl","HeaderFontBold",True)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","SODocCntrl","Icon","DCS-OFF")
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","SODocCntrl","AllowEdit",False)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","SODocCntrl","ReadOnly",True)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","SODocCntrl","Caption","SO Doc")
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","SODocCntrl","MinWidth","35")
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","SODocCntrl","Width","35")
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","SODocCntrl","Visible",True)
Gui.frmSplitLine.GsGCSplit.SetColumnProperty("gvSplit","SODocCntrl","Fixed","Left")
Gui.frmSplitLine.GsGCSplit.AddStyleFormatCondition("gvSplit","SODocCntrl","TAGSPLITDCC","Equal","DCS-ON")
Gui.frmSplitLine.GsGCSplit.SetStyleFormatConditionProperty("gvSplit","SODocCntrl","TAGSPLITDCC","BackColor","GreenYellow")

Gui.frmSplitLine.GsGCSplit.ResumeLayout()
