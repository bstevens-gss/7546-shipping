			F.Intrinsic.String.Build("Update Load_Plan Set Load_No = '{0}', ORDER_SUFFIX = '{5}' Where ORDER_NO = '{1}' And ORDER_SUFFIX = '{2}' AND ORDER_LINE = '{3}' and CUSTOMER = '{4}'",v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).Load Number!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_NO!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_SUFFIX!FieldValTRIM,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).ORDER_LINE!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).CUSTOMER!FieldVal,v.DataTable.dtLoad(v.Local.sSel(v.Local.i)).CURRENT_ORDER_SUFFIX!FieldVal,v.Local.sSQL)
